{% paginate collections by 15 %}
<section class="w-full bg-[#ffffff] pt-16 md:pt-24 pb-24 md:pb-32 px-5 md:px-10">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <header class="text-center">
      <h1 class="font-heading text-4xl md:text-6xl lg:text-[6rem] leading-none tracking-[-0.02em] text-[#0a0a0a] uppercase mb-6">
        {{ section.settings.title | default: 'Collections' }}
      </h1>
      <p class="mt-4 text-base md:text-xl lg:text-2xl text-[#666] font-body max-w-4xl mx-auto tracking-normal">
        {{ section.settings.description | default: 'Discover our curated selections.' }}
      </p>
    </header>

    <!-- List -->
    <ul class="max-w-4xl mx-auto border-t border-[#e5e5e5] mt-10 md:mt-16">
      {%- for collection in collections -%}
        <li class="border-b border-[#e5e5e5]">
          <a href="{{ collection.url }}" class="group py-6 md:py-8 flex items-center justify-between">
            <h3 class="font-heading text-2xl md:text-4xl lg:text-[4rem] text-[#0a0a0a] uppercase tracking-[-0.02em] group-hover:ml-4 transition-all duration-500 ease-out">{{ collection.title }}</h3>
            <div class="flex items-center gap-6">
              <span class="font-body text-xs md:text-sm text-[#888] tracking-widest uppercase opacity-0 md:group-hover:opacity-100 transition-opacity duration-500">{{ collection.all_products_count }} items</span>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0a0a0a" stroke-width="1.5" class="opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-500 ease-out"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </div>
          </a>
        </li>
      {%- endfor -%}
    </ul>

    <!-- Pagination -->
    {%- if paginate.pages > 1 -%}
      <div class="mt-20 flex justify-center">
        <nav class="flex items-center gap-2" aria-label="Pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="w-10 h-10 flex items-center justify-center rounded-full border border-[#e0e0e0] hover:border-[#0a0a0a] transition-colors" aria-label="Previous page">
              &larr;
            </a>
          {%- endif -%}

          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="w-10 h-10 flex items-center justify-center rounded-full border border-transparent font-body text-sm hover:bg-[#f4f4f4] transition-colors">{{ part.title }}</a>
            {%- else -%}
              {%- if part.title == paginate.current_page -%}
                <span class="w-10 h-10 flex items-center justify-center rounded-full bg-[#0a0a0a] text-white font-body text-sm">{{ part.title }}</span>
              {%- else -%}
                <span class="w-10 h-10 flex items-center justify-center font-body text-sm text-[#999]">{{ part.title }}</span>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="w-10 h-10 flex items-center justify-center rounded-full border border-[#e0e0e0] hover:border-[#0a0a0a] transition-colors" aria-label="Next page">
              &rarr;
            </a>
          {%- endif -%}
        </nav>
      </div>
    {%- endif -%}
  </div>
</section>
{% endpaginate %}

{% schema %}
{
  "name": "Collections List",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Discover our curated selections."
    }
  ]
}
{% endschema %}
