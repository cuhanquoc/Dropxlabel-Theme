{% paginate collections by 15 %}
<section class="bg-white text-[#0a0a0a] pt-32 pb-24 md:pt-40 md:pb-32 px-5 md:px-10">
  <div class="max-w-[1440px] mx-auto">
    <!-- Header -->
    <header class="mb-16 md:mb-24 text-center max-w-3xl mx-auto">
      <h1 class="font-heading text-[clamp(2.5rem,8vw,5.5rem)] font-light leading-[1.1] tracking-tight mb-4">
        {{ section.settings.title | default: 'Collections' }}
      </h1>
      <p class="font-body text-base md:text-lg text-[#666] tracking-wide">
        {{ section.settings.subtitle | default: 'Discover our curated selections.' }}
      </p>
    </header>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-12 md:gap-y-16">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" class="group block relative">
          <!-- Image Wrapper -->
          <div class="relative w-full aspect-[4/5] overflow-hidden bg-[#f4f4f4] rounded-md mb-6">
            {%- if collection.image -%}
              <img src="{{ collection.image | image_url: width: 800 }}" 
                   alt="{{ collection.title | escape }}"
                   class="w-full h-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-105"
                   loading="lazy">
            {%- elsif collection.products.first and collection.products.first.featured_image -%}
              <img src="{{ collection.products.first.featured_image | image_url: width: 800 }}" 
                   alt="{{ collection.title | escape }}"
                   class="w-full h-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-105"
                   loading="lazy">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full text-gray-300' }}
            {%- endif -%}
            
            <!-- Overlay on hover -->
            <div class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
          </div>
          
          <!-- Text -->
          <div class="flex items-center justify-between gap-4">
            <div>
              <h3 class="font-body font-bold text-xl md:text-2xl tracking-wide uppercase transition-colors group-hover:text-[#444]">{{ collection.title }}</h3>
              <p class="font-body text-[0.8rem] uppercase tracking-[0.1em] text-[#888] mt-2 block">{{ collection.all_products_count }} products</p>
            </div>
            <!-- Arrow -->
            <div class="w-10 h-10 rounded-full border border-[#e0e0e0] flex items-center justify-center shrink-0 group-hover:bg-[#0a0a0a] group-hover:border-[#0a0a0a] group-hover:text-white transition-all duration-300">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>

    <!-- Pagination -->
    {%- if paginate.pages > 1 -%}
      <div class="mt-20 flex justify-center">
        <nav class="flex items-center gap-2" aria-label="Pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="w-10 h-10 flex items-center justify-center rounded-full border border-[#e0e0e0] hover:border-[#0a0a0a] transition-colors" aria-label="Previous page">
              &larr;
            </a>
          {%- endif -%}

          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="w-10 h-10 flex items-center justify-center rounded-full border border-transparent font-body text-sm hover:bg-[#f4f4f4] transition-colors">{{ part.title }}</a>
            {%- else -%}
              {%- if part.title == paginate.current_page -%}
                <span class="w-10 h-10 flex items-center justify-center rounded-full bg-[#0a0a0a] text-white font-body text-sm">{{ part.title }}</span>
              {%- else -%}
                <span class="w-10 h-10 flex items-center justify-center font-body text-sm text-[#999]">{{ part.title }}</span>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="w-10 h-10 flex items-center justify-center rounded-full border border-[#e0e0e0] hover:border-[#0a0a0a] transition-colors" aria-label="Next page">
              &rarr;
            </a>
          {%- endif -%}
        </nav>
      </div>
    {%- endif -%}
  </div>
</section>
{% endpaginate %}

{% schema %}
{
  "name": "Collections List",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Discover our curated selections."
    }
  ]
}
{% endschema %}
