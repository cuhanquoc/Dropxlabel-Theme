<help-center-section class="block bg-white">
  <div class="max-w-[720px] mx-auto px-5 md:px-8 py-12 md:py-20">

    <!-- ── Heading ── -->
    <h2 class="font-heading font-bold text-[clamp(1.8rem,5vw,2.8rem)] leading-[1.1] text-[#0a0a0a] mb-4">
      {{ section.settings.heading | default: 'Customer Help Center' }}
    </h2>
    <p class="font-body text-[0.88rem] md:text-[0.92rem] leading-[1.7] text-[#555] mb-10 max-w-[600px]">
      {{ section.settings.description | default: "Welcome to our Customer Help Center! We're here to assist you with any questions or concerns you may have. Whether you need help with orders, shipping, returns, or product details, you'll find all the answers right here." }}
    </p>

    <!-- ── FAQ Items ── -->
    <div class="hc-faq-list">
      {%- for i in (1..8) -%}
        {%- assign q_key = 'q' | append: i -%}
        {%- assign a_key = 'a' | append: i -%}
        {%- assign question = section.settings[q_key] -%}
        {%- assign answer = section.settings[a_key] -%}
        {%- if question != blank -%}
          <div class="hc-faq-item border-t border-[#e5e5e5]">
            <button class="hc-faq-btn w-full flex items-center justify-between py-5 md:py-6 gap-4 text-left group"
                    aria-expanded="false">
              <span class="hc-faq-question font-heading font-bold text-[1.05rem] md:text-[1.15rem] leading-[1.3] text-[#0a0a0a] transition-colors duration-400">
                {{ question }}
              </span>
              <span class="hc-faq-icon shrink-0 w-9 h-9 md:w-10 md:h-10 rounded-full bg-[#0a0a0a] flex items-center justify-center transition-all duration-400">
                <!-- Plus icon -->
                <svg class="hc-icon-plus w-4 h-4 text-white transition-transform duration-300" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M8 3v10M3 8h10"/>
                </svg>
                <!-- Close icon (hidden by default) -->
                <svg class="hc-icon-close w-4 h-4 text-white hidden transition-transform duration-300" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 4l8 8M12 4l-8 8"/>
                </svg>
              </span>
            </button>
            <div class="hc-faq-answer overflow-hidden"
                 style="max-height: 0; opacity: 0; transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease, padding 0.4s ease;">
              <div class="hc-faq-answer-inner rounded-xl bg-[#0a0a0a] px-5 py-5 md:px-6 md:py-6 mb-4">
                <p class="font-body text-[0.85rem] leading-[1.7] text-white/80">
                  {{ answer }}
                </p>
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</help-center-section>

<script>
  if (!customElements.get('help-center-section')) {
    class HelpCenterSection extends HTMLElement {
      constructor() {
        super();
        this._buttons = [];
      }

      connectedCallback() {
        this._buttons = [...this.querySelectorAll('.hc-faq-btn')];
        this._buttons.forEach(btn => {
          btn._handler = () => this.toggle(btn);
          btn.addEventListener('click', btn._handler);
        });
      }

      disconnectedCallback() {
        this._buttons.forEach(btn => {
          btn.removeEventListener('click', btn._handler);
        });
        this._buttons = [];
      }

      toggle(btn) {
        const item = btn.closest('.hc-faq-item');
        const answer = item.querySelector('.hc-faq-answer');
        const question = btn.querySelector('.hc-faq-question');
        const iconPlus = btn.querySelector('.hc-icon-plus');
        const iconClose = btn.querySelector('.hc-icon-close');
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        if (isOpen) {
          /* ── Close ── */
          answer.style.maxHeight = '0';
          answer.style.opacity = '0';
          btn.setAttribute('aria-expanded', 'false');
          item.classList.remove('hc-faq-open');
          iconPlus.classList.remove('hidden');
          iconClose.classList.add('hidden');
        } else {
          /* ── Close all others first ── */
          this._buttons.forEach(otherBtn => {
            if (otherBtn !== btn && otherBtn.getAttribute('aria-expanded') === 'true') {
              const otherItem = otherBtn.closest('.hc-faq-item');
              const otherAnswer = otherItem.querySelector('.hc-faq-answer');
              const otherIconPlus = otherBtn.querySelector('.hc-icon-plus');
              const otherIconClose = otherBtn.querySelector('.hc-icon-close');
              otherAnswer.style.maxHeight = '0';
              otherAnswer.style.opacity = '0';
              otherBtn.setAttribute('aria-expanded', 'false');
              otherItem.classList.remove('hc-faq-open');
              otherIconPlus.classList.remove('hidden');
              otherIconClose.classList.add('hidden');
            }
          });

          /* ── Open ── */
          answer.style.maxHeight = answer.scrollHeight + 'px';
          answer.style.opacity = '1';
          btn.setAttribute('aria-expanded', 'true');
          item.classList.add('hc-faq-open');
          iconPlus.classList.add('hidden');
          iconClose.classList.remove('hidden');
        }
      }
    }

    customElements.define('help-center-section', HelpCenterSection);
  }
</script>

{% schema %}
{
  "name": "Customer Help Center",
  "tag": "section",
  "class": "help-center-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer Help Center"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Welcome to our Customer Help Center! We're here to assist you with any questions or concerns you may have. Whether you need help with orders, shipping, returns, or product details, you'll find all the answers right here."
    },
    {
      "type": "header",
      "content": "Question 1"
    },
    {
      "type": "text",
      "id": "q1",
      "label": "Question 1",
      "default": "What is your return and exchange policy?"
    },
    {
      "type": "textarea",
      "id": "a1",
      "label": "Answer 1",
      "default": "We offer a hassle-free return and exchange policy within 30 days of delivery. Items must be unused, in original packaging, and with tags intact. For exchanges, simply initiate a request through our return portal or contact support."
    },
    {
      "type": "header",
      "content": "Question 2"
    },
