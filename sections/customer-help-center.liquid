<help-center-section class="block">
  <!-- ── Section with white bg and generous padding ── -->
  <div style="background-color: {{ section.settings.bg_color | default: '#ffffff' }}; padding-top: 3rem; padding-bottom: 1rem;" class="md:py-20">
    <div class="hc-shell max-w-[720px] mx-auto px-5 md:px-8">

      <div class="hc-intro">
        <!-- ── Heading ── -->
        <h2 style="font-size: clamp(2rem, 6vw, 3.2rem); font-weight: 800; line-height: 1.1; color: #0a0a0a; margin-bottom: 1rem; font-family: var(--font-heading, 'Playfair Display', serif);">
          {{ section.settings.heading | default: 'Customer Help Center' }}
        </h2>
        <p style="font-size: 0.92rem; line-height: 1.75; color: #666; margin-bottom: 2rem; max-width: 600px; font-family: var(--font-body, 'Inter', sans-serif);">
          {{ section.settings.description | default: "Welcome to our Customer Help Center! We're here to assist you with any questions or concerns you may have. Whether you need help with orders, shipping, returns, or product details, you'll find all the answers right here." }}
        </p>
      </div>

      <!-- ── FAQ Items ── -->
      <div class="hc-faq-list" style="overflow: visible;">

        {%- if section.blocks.size > 0 -%}
          {%- comment -%} Block-based rendering — merchant adds FAQ items via Theme Editor {%- endcomment -%}
          {%- for block in section.blocks -%}
            {%- if block.type == "category_header" -%}
              <div class="hc-category-header" {{ block.shopify_attributes }} style="padding: 2rem 0 0.5rem; border-bottom: 2px solid #0a0a0a; margin-bottom: 0.5rem;">
                <h3 style="font-family: var(--font-heading, 'Playfair Display', serif); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #0a0a0a;">
                  {{ block.settings.title }}
                </h3>
              </div>

            {%- elsif block.type == "faq_item" -%}
              {%- if block.settings.question != blank -%}
                <div class="hc-faq-item" {{ block.shopify_attributes }} style="border-top: 1px solid #e5e5e5; transition: background-color 0.4s ease;">
                  <button class="hc-faq-btn" aria-expanded="false"
                          style="width: 100%; display: grid; grid-template-columns: minmax(0, 1fr) 32px; align-items: center; padding: 1.25rem 0.5rem; gap: 1rem; text-align: left; background: none; border: none; cursor: pointer;">
                    <span class="hc-faq-question" style="font-family: var(--font-heading, 'Playfair Display', serif); font-weight: 700; font-size: 1.1rem; line-height: 1.3; color: #0a0a0a; transition: color 0.3s ease;">
                      {{ block.settings.question }}
                    </span>
                    <span class="hc-faq-icon" style="flex-shrink: 0; width: 32px; height: 32px; border-radius: 50%; background-color: #0a0a0a; display: flex; align-items: center; justify-content: center; transition: background-color 0.3s ease;">
                      <svg class="hc-icon-plus" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="white" stroke-width="2" style="transition: transform 0.3s ease;">
                        <line x1="8" y1="3" x2="8" y2="13"/>
                        <line x1="3" y1="8" x2="13" y2="8"/>
                      </svg>
                      <svg class="hc-icon-close" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="white" stroke-width="2" style="display: none; transition: transform 0.3s ease;">
                        <line x1="4" y1="4" x2="12" y2="12"/>
                        <line x1="12" y1="4" x2="4" y2="12"/>
                      </svg>
                    </span>
                  </button>
                  <div class="hc-faq-answer" style="max-height: 0; overflow: hidden; opacity: 0; transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;">
                    <div class="hc-faq-answer-inner" style="padding: 0 0.5rem 0.65rem 0.5rem;">
                      <p style="font-family: var(--font-body, 'Inter', sans-serif); font-size: 0.88rem; line-height: 1.75; color: rgba(255,255,255,0.75); transition: color 0.3s ease;">
                        {{ block.settings.answer }}
                      </p>
                    </div>
                  </div>
                </div>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}

        {%- else -%}
          {%- comment -%} Legacy fallback — settings q1..q8 / a1..a8 {%- endcomment -%}
          {%- for i in (1..8) -%}
            {%- assign q_key = 'q' | append: i -%}
            {%- assign a_key = 'a' | append: i -%}
            {%- assign question = section.settings[q_key] -%}
            {%- assign answer = section.settings[a_key] -%}
            {%- if question != blank -%}
              <div class="hc-faq-item" style="border-top: 1px solid #e5e5e5; transition: background-color 0.4s ease;">

                <button class="hc-faq-btn" aria-expanded="false"
                        style="width: 100%; display: grid; grid-template-columns: minmax(0, 1fr) 32px; align-items: center; padding: 1.25rem 0.5rem; gap: 1rem; text-align: left; background: none; border: none; cursor: pointer;">
                  <span class="hc-faq-question" style="font-family: var(--font-heading, 'Playfair Display', serif); font-weight: 700; font-size: 1.1rem; line-height: 1.3; color: #0a0a0a; transition: color 0.3s ease;">
                    {{ question }}
                  </span>
                  <span class="hc-faq-icon" style="flex-shrink: 0; width: 32px; height: 32px; border-radius: 50%; background-color: #0a0a0a; display: flex; align-items: center; justify-content: center; transition: background-color 0.3s ease;">
                    <!-- Plus icon -->
                    <svg class="hc-icon-plus" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="white" stroke-width="2" style="transition: transform 0.3s ease;">
                      <line x1="8" y1="3" x2="8" y2="13"/>
                      <line x1="3" y1="8" x2="13" y2="8"/>
                    </svg>
                    <!-- Close icon -->
                    <svg class="hc-icon-close" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="white" stroke-width="2" style="display: none; transition: transform 0.3s ease;">
                      <line x1="4" y1="4" x2="12" y2="12"/>
                      <line x1="12" y1="4" x2="4" y2="12"/>
                    </svg>
                  </span>
                </button>

                <div class="hc-faq-answer" style="max-height: 0; overflow: hidden; opacity: 0; transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;">
                  <div class="hc-faq-answer-inner" style="padding: 0 0.5rem 0.65rem 0.5rem;">
                    <p style="font-family: var(--font-body, 'Inter', sans-serif); font-size: 0.88rem; line-height: 1.75; color: rgba(255,255,255,0.75); transition: color 0.3s ease;">
                      {{ answer }}
                    </p>
                  </div>
                </div>

              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}

      </div>

    </div>
  </div>
</help-center-section>

<style>
  .hc-shell {
    --hc-side-pad: 1.25rem;
  }

  .hc-faq-list {
    margin-inline: calc(var(--hc-side-pad) * -1);
  }

  .hc-faq-item {
    position: relative;
    overflow: visible;
    background-color: transparent;
    transition: background-color 0.35s ease;
  }

  .hc-faq-btn {
    padding: 0.95rem var(--hc-side-pad) !important;
    gap: 0.85rem !important;
  }

  .hc-faq-answer-inner {
    padding: 0 var(--hc-side-pad) 0.35rem !important;
  }

  .hc-faq-item.is-open {
    background-color: #0a0a0a;
  }

  .hc-faq-item.is-open .hc-faq-question {
    color: #ffffff !important;
  }

  .hc-faq-item.is-open .hc-faq-icon {
    background-color: #333333 !important;
  }

  .hc-faq-item.is-open .hc-icon-plus {
    display: none !important;
  }

  .hc-faq-item.is-open .hc-icon-close {
    display: block !important;
  }

  @media (min-width: 1024px) {
    .hc-shell {
      --hc-side-pad: 2rem;
      max-width: 1240px !important;
      display: grid;
      grid-template-columns: minmax(280px, 0.85fr) minmax(0, 1.15fr);
      gap: 4rem;
      align-items: start;
    }

    .hc-intro {
      position: sticky;
      top: 7rem;
      padding-top: 0.25rem;
    }

    .hc-intro h2 {
      font-size: clamp(3rem, 4vw, 4.5rem) !important;
      max-width: 9ch;
      margin-bottom: 1.5rem !important;
    }

    .hc-intro p {
      font-size: 1rem !important;
      margin-bottom: 0 !important;
    }

    .hc-faq-list {
      margin-inline: 0;
    }

    .hc-faq-btn {
      padding: 1.45rem 0.75rem !important;
    }

    .hc-faq-question {
      font-size: 1.3rem !important;
      line-height: 1.35 !important;
    }

    .hc-faq-answer > div {
      padding: 0 0.75rem 1.5rem 0.75rem !important;
    }

    .hc-faq-answer p {
      font-size: 0.98rem !important;
    }
  }
</style>

<script>
  if (!customElements.get('help-center-section')) {
    class HelpCenterSection extends HTMLElement {
      constructor() {
        super();
        this._buttons = [];
      }

      connectedCallback() {
        this._buttons = [...this.querySelectorAll('.hc-faq-btn')];
        this._buttons.forEach(btn => {
          btn._handler = () => this.toggle(btn);
          btn.addEventListener('click', btn._handler);
        });
      }

      disconnectedCallback() {
        this._buttons.forEach(btn => {
          btn.removeEventListener('click', btn._handler);
        });
        this._buttons = [];
      }

      closeItem(btn, { animate = true } = {}) {
        const item = btn.closest('.hc-faq-item');
        const answer = item.querySelector('.hc-faq-answer');
        const transition = 'max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease';

        item.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');

        if (!animate) {
          answer.style.transition = 'none';
          answer.style.maxHeight = '0';
          answer.style.opacity = '0';
          answer.offsetHeight;
          answer.style.transition = transition;
          return;
        }

        if (answer.style.maxHeight === 'none' || !answer.style.maxHeight) {
          answer.style.maxHeight = answer.scrollHeight + 'px';
          answer.offsetHeight;
        }

        answer.style.maxHeight = '0';
        answer.style.opacity = '0';
      }

      openItem(btn) {
        const item = btn.closest('.hc-faq-item');
        const answer = item.querySelector('.hc-faq-answer');
        const targetHeight = answer.scrollHeight;

        item.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');

        answer.style.maxHeight = '0';
        answer.style.opacity = '0';
        answer.offsetHeight;
        answer.style.maxHeight = targetHeight + 'px';
        answer.style.opacity = '1';

        const onTransitionEnd = event => {
          if (event.propertyName !== 'max-height') return;
          if (btn.getAttribute('aria-expanded') !== 'true') return;
          answer.style.maxHeight = 'none';
          answer.removeEventListener('transitionend', onTransitionEnd);
        };

        answer.addEventListener('transitionend', onTransitionEnd);
      }

      toggle(btn) {
        const icon = btn.querySelector('.hc-faq-icon');
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        icon.style.transition = 'background-color 0.3s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1)';
        icon.style.transform = 'rotate(360deg)';
        setTimeout(() => { icon.style.transform = ''; }, 450);

        if (isOpen) {
          this.closeItem(btn);
        } else {
          const activeBtn = this._buttons.find(otherBtn => otherBtn !== btn && otherBtn.getAttribute('aria-expanded') === 'true');
          if (activeBtn) {
            this.closeItem(activeBtn, { animate: false });
            requestAnimationFrame(() => {
              this.openItem(btn);
            });
            return;
          }

          this.openItem(btn);
        }
      }
    }

    customElements.define('help-center-section', HelpCenterSection);
  }
</script>

