{%- liquid
  assign help_section_id = 'hc-' | append: section.id
-%}

<help-center-section class="block">
  <div
    class="relative overflow-hidden py-16 md:py-24"
    style="background-color: {{ section.settings.bg_color | default: '#f8f6f1' }}; color: #0c0c0b;"
  >
    <div class="absolute inset-x-0 top-0 h-24" style="background: linear-gradient(180deg, rgba(255,255,255,0.68), transparent);"></div>

    <div class="relative mx-auto max-w-3xl px-5 md:px-8">
      <div class="mb-10 md:mb-12">
        <p
          class="mb-4 inline-flex rounded-full border px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.28em] backdrop-blur-sm"
          style="border-color: rgba(12,12,11,0.08); background-color: rgba(255,255,255,0.7); color: #6f6558; -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px);"
        >
          Help center
        </p>
        <h2 class="font-heading text-[clamp(2.3rem,6vw,4rem)] leading-[0.95] tracking-[-0.05em]" style="color: #0c0c0b;">
          {{ section.settings.heading | default: 'Need a hand?' }}
        </h2>
        <p class="mt-4 max-w-2xl font-body text-[0.98rem] leading-7 md:text-[1.02rem]" style="color: #645c50;">
          {{ section.settings.description | default: "Find clear answers about shipping, returns, payments, and order support. If you still need help, reach out and we'll point you to the right next step." }}
        </p>
      </div>

      <div
        class="overflow-hidden rounded-2xl border backdrop-blur-sm"
        style="border-color: rgba(12,12,11,0.08); background-color: rgba(255,255,255,0.8); box-shadow: 0 22px 60px -42px rgba(12,12,11,0.28); -webkit-backdrop-filter: blur(10px); backdrop-filter: blur(10px);"
      >
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'category_header' -%}
              <div class="border-b px-5 py-4 md:px-7 md:py-5" style="border-color: rgba(12,12,11,0.06); background-color: #f8f4ee;" {{ block.shopify_attributes }}>
                <p class="font-body text-[10px] font-semibold uppercase tracking-[0.28em]" style="color: #6f6558;">
                  {{ block.settings.title | default: 'General' }}
                </p>
              </div>
            {%- elsif block.type == 'faq_item' and block.settings.question != blank -%}
              {%- assign faq_uid = help_section_id | append: '-' | append: forloop.index0 -%}
              <div class="hc-faq-item border-b last:border-b-0" style="border-color: rgba(12,12,11,0.06);" data-open="false" {{ block.shopify_attributes }}>
                <button
                  type="button"
                  id="{{ faq_uid }}-button"
                  aria-expanded="false"
                  aria-controls="{{ faq_uid }}-panel"
                  class="flex w-full items-center gap-4 px-5 py-5 text-left transition-colors duration-300 md:px-7 md:py-6"
                  style="background-color: transparent;"
                  data-open="false"
                  data-faq-trigger
                >
                  <span class="min-w-0 flex-1">
                    <span class="mb-1 block text-[10px] font-semibold uppercase tracking-[0.24em]" style="color: rgba(111,101,88,0.78);">Question</span>
                    <span class="block font-heading text-[1.03rem] leading-[1.45] tracking-[-0.03em] md:text-[1.08rem]" style="color: #0c0c0b;">
                      {{ block.settings.question }}
                    </span>
                  </span>

                  <span
                    class="hc-faq-icon flex h-10 w-10 shrink-0 items-center justify-center rounded-full border transition duration-300 ease-out"
                    style="border-color: rgba(12,12,11,0.08); background-color: #f4efe7; color: #0c0c0b;"
                    aria-hidden="true"
                  >
                    <svg class="hc-icon hc-icon--plus block h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                      <line x1="8" y1="3" x2="8" y2="13"></line>
                      <line x1="3" y1="8" x2="13" y2="8"></line>
                    </svg>
                    <svg class="hc-icon hc-icon--close hidden h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                      <line x1="4" y1="4" x2="12" y2="12"></line>
                      <line x1="12" y1="4" x2="4" y2="12"></line>
                    </svg>
                  </span>
                </button>

                <div
                  id="{{ faq_uid }}-panel"
                  role="region"
                  aria-labelledby="{{ faq_uid }}-button"
                  aria-hidden="true"
                  class="overflow-hidden"
                  style="max-height: 0; opacity: 0; transition: max-height 500ms cubic-bezier(0.22,1,0.36,1), opacity 300ms ease;"
                  data-open="false"
                >
                  <div class="px-5 pb-5 md:px-7 md:pb-6">
                    <p class="max-w-2xl font-body text-[0.94rem] leading-7" style="color: #5f564b;">
                      {{ block.settings.answer | default: 'We keep the answer brief here so the page stays easy to scan.' }}
                    </p>
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..8) -%}
            {%- assign q_key = 'q' | append: i -%}
            {%- assign a_key = 'a' | append: i -%}
            {%- assign question = section.settings[q_key] -%}
            {%- assign answer = section.settings[a_key] -%}
            {%- if question != blank -%}
              {%- assign faq_uid = help_section_id | append: '-legacy-' | append: i -%}
              <div class="hc-faq-item border-b last:border-b-0" style="border-color: rgba(12,12,11,0.06);" data-open="false">
                <button
                  type="button"
                  id="{{ faq_uid }}-button"
                  aria-expanded="false"
                  aria-controls="{{ faq_uid }}-panel"
                  class="flex w-full items-center gap-4 px-5 py-5 text-left transition-colors duration-300 md:px-7 md:py-6"
                  style="background-color: transparent;"
                  data-open="false"
                  data-faq-trigger
                >
                  <span class="min-w-0 flex-1">
                    <span class="mb-1 block text-[10px] font-semibold uppercase tracking-[0.24em]" style="color: rgba(111,101,88,0.78);">Question</span>
                    <span class="block font-heading text-[1.03rem] leading-[1.45] tracking-[-0.03em] md:text-[1.08rem]" style="color: #0c0c0b;">
                      {{ question }}
                    </span>
                  </span>

                  <span
                    class="hc-faq-icon flex h-10 w-10 shrink-0 items-center justify-center rounded-full border transition duration-300 ease-out"
                    style="border-color: rgba(12,12,11,0.08); background-color: #f4efe7; color: #0c0c0b;"
                    aria-hidden="true"
                  >
                    <svg class="hc-icon hc-icon--plus block h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                      <line x1="8" y1="3" x2="8" y2="13"></line>
                      <line x1="3" y1="8" x2="13" y2="8"></line>
                    </svg>
                    <svg class="hc-icon hc-icon--close hidden h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                      <line x1="4" y1="4" x2="12" y2="12"></line>
                      <line x1="12" y1="4" x2="4" y2="12"></line>
                    </svg>
                  </span>
                </button>

                <div
                  id="{{ faq_uid }}-panel"
                  role="region"
                  aria-labelledby="{{ faq_uid }}-button"
                  aria-hidden="true"
                  class="overflow-hidden"
                  style="max-height: 0; opacity: 0; transition: max-height 500ms cubic-bezier(0.22,1,0.36,1), opacity 300ms ease;"
                  data-open="false"
                >
                  <div class="px-5 pb-5 md:px-7 md:pb-6">
                    <p class="max-w-2xl font-body text-[0.94rem] leading-7" style="color: #5f564b;">
                      {{ answer | default: 'We keep the answer brief here so the page stays easy to scan.' }}
                    </p>
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</help-center-section>

<script>
  if (!customElements.get('help-center-section')) {
    class HelpCenterSection extends HTMLElement {
      connectedCallback() {
        this._reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        this._triggers = [...this.querySelectorAll('[data-faq-trigger]')];
        this._handlers = new Map();
        this._resizeHandler = () => this.updateOpenPanels();

        this._triggers.forEach((trigger) => {
          const handler = () => this.toggle(trigger);
          this._handlers.set(trigger, handler);
          trigger.addEventListener('click', handler);
        });

        window.addEventListener('resize', this._resizeHandler, { passive: true });
      }

      disconnectedCallback() {
        this._triggers?.forEach((trigger) => {
          const handler = this._handlers?.get(trigger);
          if (handler) trigger.removeEventListener('click', handler);
        });

        window.removeEventListener('resize', this._resizeHandler);
        this._triggers = [];
        this._handlers = new Map();
        this._resizeHandler = null;
      }

      toggle(trigger) {
        const item = trigger.closest('.hc-faq-item');
        if (!item) return;

        const isOpen = item.dataset.open === 'true';
        this.closeAll();

        if (!isOpen) {
          this.openItem(trigger);
        }
      }

      openItem(trigger) {
        const item = trigger.closest('.hc-faq-item');
        const panel = this.getPanel(trigger);
        const icon = item?.querySelector('.hc-faq-icon');
        const plus = item?.querySelector('.hc-icon--plus');
        const close = item?.querySelector('.hc-icon--close');

        if (!item || !panel) return;

        item.dataset.open = 'true';
        trigger.dataset.open = 'true';
        trigger.setAttribute('aria-expanded', 'true');
        panel.dataset.open = 'true';
        panel.setAttribute('aria-hidden', 'false');

        item.style.backgroundColor = '#f7f3ec';
        trigger.style.backgroundColor = '#f7f3ec';
        if (icon) {
          icon.style.backgroundColor = '#0c0c0b';
          icon.style.color = '#f8f6f1';
        }
        if (plus) plus.style.display = 'none';
        if (close) close.style.display = 'block';

        panel.style.maxHeight = `${panel.scrollHeight}px`;
        panel.style.opacity = '1';

        if (this._reduceMotion) {
          panel.style.transition = 'none';
        }
      }

      closeAll() {
        this._triggers.forEach((trigger) => {
          const item = trigger.closest('.hc-faq-item');
          const panel = this.getPanel(trigger);
          const icon = item?.querySelector('.hc-faq-icon');
          const plus = item?.querySelector('.hc-icon--plus');
          const close = item?.querySelector('.hc-icon--close');

          if (item) {
            item.dataset.open = 'false';
            item.style.backgroundColor = 'transparent';
          }

          trigger.dataset.open = 'false';
          trigger.setAttribute('aria-expanded', 'false');
          trigger.style.backgroundColor = 'transparent';

          if (icon) {
            icon.style.backgroundColor = '#f4efe7';
            icon.style.color = '#0c0c0b';
          }
          if (plus) plus.style.display = 'block';
          if (close) close.style.display = 'none';

          if (panel) {
            panel.dataset.open = 'false';
            panel.setAttribute('aria-hidden', 'true');
            panel.style.maxHeight = '0px';
            panel.style.opacity = '0';
            if (this._reduceMotion) {
              panel.style.transition = 'none';
            }
          }
        });
      }

      updateOpenPanels() {
        this._triggers.forEach((trigger) => {
          const item = trigger.closest('.hc-faq-item');
          const panel = this.getPanel(trigger);
          if (!item || !panel || item.dataset.open !== 'true') return;
          panel.style.maxHeight = `${panel.scrollHeight}px`;
        });
      }

      getPanel(trigger) {
        const panelId = trigger.getAttribute('aria-controls');
        if (!panelId) return null;

        return this.querySelector(`#${CSS.escape(panelId)}`);
      }
    }

    customElements.define('help-center-section', HelpCenterSection);
  }
</script>

