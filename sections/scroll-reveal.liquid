{% comment %}
  ═══════════════════════════════════════════════════════════════
  SCROLL REVEAL — Pinned Scrubbing Reveal (Quiet Luxury)
  Cuộn chuột để điều khiển timeline: Light → Dark transition
  GSAP ScrollTrigger | pin: true | scrub: 1
  ═══════════════════════════════════════════════════════════════
{% endcomment %}

<style>
  /* ═══ Section Container ═══ */
  .sr-section {
    position: relative;
    width: 100%;
    height: 100dvh;
    overflow: hidden;
    background-color: #f5f0eb;
  }

  /* ═══ Light Layer (bottom) ═══ */
  .sr-light {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .sr-text-light {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 7vw, 6.5rem);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: #0a0a0a;
    text-align: center;
    max-width: 900px;
    will-change: transform, opacity;
  }

  .sr-sub-light {
    font-family: var(--font-body);
    font-size: clamp(0.8rem, 1.2vw, 1rem);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(10, 10, 10, 0.5);
    margin-top: 1.5rem;
    will-change: transform, opacity;
  }

  /* ═══ Dark Overlay (top — clip-path hidden initially) ═══ */
  .sr-dark-overlay {
    position: absolute;
    inset: 0;
    background-color: #0a0a0a;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    clip-path: polygon(0% 100%, 100% 100%, 100% 100%, 0% 100%);
    will-change: clip-path;
  }

  .sr-text-dark {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 7vw, 6.5rem);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: #ffffff;
    text-align: center;
    max-width: 900px;
    will-change: transform, opacity;
  }

  .sr-sub-dark {
    font-family: var(--font-body);
    font-size: clamp(0.8rem, 1.2vw, 1rem);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin-top: 1.5rem;
    will-change: transform, opacity;
  }

  /* ═══ Decorative accent line ═══ */
  .sr-accent-line {
    width: 48px;
    height: 1px;
    margin-bottom: 2rem;
    will-change: transform, opacity;
  }

  .sr-accent-line--light {
    background-color: rgba(10, 10, 10, 0.2);
  }

  .sr-accent-line--dark {
    background-color: rgba(255, 255, 255, 0.2);
  }

  /* ── Desktop (≥ 768px) ── */
  @media (min-width: 768px) {
    .sr-light,
    .sr-dark-overlay {
      padding: 3rem;
    }
    .sr-accent-line {
      width: 60px;
      margin-bottom: 2.5rem;
    }
  }

  /* ── Mobile (< 768px) ── */
  @media (max-width: 767px) {
    .sr-text-light,
    .sr-text-dark {
      font-size: clamp(1.8rem, 8vw, 3rem);
      max-width: 100%;
    }
    .sr-sub-light,
    .sr-sub-dark {
      font-size: 0.72rem;
      letter-spacing: 0.15em;
      margin-top: 1rem;
    }
    .sr-light,
    .sr-dark-overlay {
      padding: 1.5rem;
    }
    .sr-accent-line {
      width: 32px;
      margin-bottom: 1.5rem;
    }
  }
</style>

<section class="sr-section" id="scroll-reveal">

  <!-- ══ LIGHT LAYER ══ -->
  <div class="sr-light">
    <div class="sr-accent-line sr-accent-line--light sr-line-light"></div>
    <h2 class="sr-text-light">
      {{ section.settings.light_heading | default: 'The Art of Timeless Design' }}
    </h2>
    <p class="sr-sub-light">
      {{ section.settings.light_subtext | default: 'Where tradition meets innovation' }}
    </p>
  </div>

  <!-- ══ DARK OVERLAY ══ -->
  <div class="sr-dark-overlay">
    <div class="sr-accent-line sr-accent-line--dark sr-line-dark"></div>
    <h2 class="sr-text-dark">
      {{ section.settings.dark_heading | default: 'Crafted for Those Who Dare' }}
    </h2>
    <p class="sr-sub-dark">
      {{ section.settings.dark_subtext | default: 'Redefining luxury, one detail at a time' }}
    </p>
  </div>

</section>

{% schema %}
{
  "name": "Scroll Reveal",
  "tag": "section",
  "class": "scroll-reveal-section",
  "settings": [
    {
      "type": "header",
      "content": "Light Mode (Before Scroll)"
    },
    {
      "type": "textarea",
      "id": "light_heading",
      "label": "Light Heading",
      "default": "The Art of Timeless Design"
    },
    {
      "type": "text",
      "id": "light_subtext",
      "label": "Light Sub-text",
      "default": "Where tradition meets innovation"
    },
    {
      "type": "header",
      "content": "Dark Mode (After Scroll)"
    },
    {
      "type": "textarea",
      "id": "dark_heading",
      "label": "Dark Heading",
      "default": "Crafted for Those Who Dare"
    },
    {
      "type": "text",
      "id": "dark_subtext",
      "label": "Dark Sub-text",
      "default": "Redefining luxury, one detail at a time"
    }
  ],
  "presets": [
    {
      "name": "Scroll Reveal"
    }
  ]
}
{% endschema %}
