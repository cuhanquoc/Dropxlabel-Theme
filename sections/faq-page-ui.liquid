{{ 'faq-page-ui.css' | asset_url | stylesheet_tag }}

<faq-page-ui
  class="faq-page"
  style="
    --faq-page-bg: {{ section.settings.page_bg_color }};
    --faq-card-bg: {{ section.settings.card_bg_color }};
    --faq-card-text: {{ section.settings.text_color }};
    --faq-card-muted: {{ section.settings.muted_text_color }};
    --faq-card-border: {{ section.settings.border_color }};
    --faq-icon-bg: {{ section.settings.icon_bg_color }};
    --faq-icon-color: {{ section.settings.icon_color }};
    --faq-card-radius: {{ section.settings.card_radius }}px;
    --faq-item-radius: {{ section.settings.item_radius }}px;
    --faq-hero-height: {{ section.settings.hero_height_mobile }}px;
    --faq-shadow: 0 {{ section.settings.shadow_y }}px {{ section.settings.shadow_blur }}px rgba(0, 0, 0, {{ section.settings.shadow_opacity | divided_by: 100.0 }});
  "
>
  <div class="faq-page__frame">
    <div class="faq-page__hero">
      {%- assign overlay_top_alpha = section.settings.overlay_top_opacity | divided_by: 100.0 -%}
      {%- assign overlay_middle_alpha = section.settings.overlay_middle_opacity | divided_by: 100.0 -%}
      {%- assign overlay_bottom_alpha = section.settings.overlay_bottom_opacity | divided_by: 100.0 -%}
      {%- if section.settings.hero_image != blank -%}
        <div class="faq-page__hero-media">
          {{
            section.settings.hero_image
            | image_url: width: 1200
            | image_tag:
              alt: section.settings.hero_image_alt,
              loading: 'eager',
              fetchpriority: 'high'
          }}
        </div>
      {%- else -%}
        <div class="faq-page__hero-placeholder" aria-hidden="true"></div>
      {%- endif -%}

      <div
        class="faq-page__hero-overlay"
        style="background: linear-gradient(to bottom, {{ section.settings.overlay_color | color_modify: 'alpha', overlay_top_alpha }}, {{ section.settings.overlay_color | color_modify: 'alpha', overlay_middle_alpha }}, {{ section.settings.overlay_color | color_modify: 'alpha', overlay_bottom_alpha }});"
        aria-hidden="true"
      ></div>

      <div class="faq-page__hero-content">
        {%- if section.settings.hero_title != blank -%}
          <h1 class="faq-page__hero-title">{{ section.settings.hero_title | escape }}</h1>
        {%- endif -%}
      </div>
    </div>

    <div class="faq-page__body">
      {%- if section.settings.heading != blank -%}
        <h2 class="faq-page__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="faq-page__description">{{ section.settings.description | newline_to_br }}</div>
      {%- endif -%}

      <div class="faq-page__items" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq_item' and block.settings.question != blank -%}
            {%- assign panel_id = 'faq-page-panel-' | append: block.id -%}
            {%- assign trigger_id = 'faq-page-trigger-' | append: block.id -%}
            <div
              class="faq-page__item{% if block.settings.default_open %} is-open{% endif %}"
              style="--faq-item-index: {{ forloop.index0 }};"
              role="listitem"
              {{ block.shopify_attributes }}
            >
              <button
                id="{{ trigger_id }}"
                class="faq-page__item-toggle"
                type="button"
                aria-expanded="{% if block.settings.default_open %}true{% else %}false{% endif %}"
                aria-controls="{{ panel_id }}"
              >
                <span class="faq-page__question">{{ block.settings.question | escape }}</span>
                <span class="faq-page__icon" aria-hidden="true">
                  <svg class="faq-page__icon-svg faq-page__icon-svg--plus" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M7 1V13M1 7H13" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                  </svg>
                  <svg class="faq-page__icon-svg faq-page__icon-svg--close" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3.5 3.5L10.5 10.5M10.5 3.5L3.5 10.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                  </svg>
                </span>
              </button>

              <div
                id="{{ panel_id }}"
                class="faq-page__panel{% if block.settings.default_open %} is-open{% endif %}"
                role="region"
                aria-labelledby="{{ trigger_id }}"
                {% unless block.settings.default_open %}hidden{% endunless %}
              >
                <div class="faq-page__answer-wrap">
                  <div class="faq-page__answer rte">
                    {{ block.settings.answer }}
                  </div>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</faq-page-ui>

<script src="{{ 'faq-page-ui.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "FAQ Page UI",
  "tag": "section",
  "class": "faq-page-ui-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "Hero image alt text",
      "default": "Yellow knitted fabric texture"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title",
      "default": "Customer Queries"
    },
    {
      "type": "range",
      "id": "hero_height_mobile",
      "label": "Hero height on mobile",
      "min": 180,
      "max": 360,
      "step": 10,
      "default": 260
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_top_opacity",
      "label": "Overlay top opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40
    },
    {
      "type": "range",
      "id": "overlay_middle_opacity",
      "label": "Overlay middle opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20
    },
    {
      "type": "range",
      "id": "overlay_bottom_opacity",
      "label": "Overlay bottom opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Got Questions? We've Got Answers!"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We know that choosing the right products and understanding how they work can sometimes be overwhelming. That's why we've put together a comprehensive FAQ section to help answer all your queries quickly and efficiently."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "page_bg_color",
      "label": "Page background",
      "default": "#E8E8E8"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background",
      "default": "#F3F3F3"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Primary text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Secondary text color",
      "default": "#4F4F4F"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Accordion border color",
      "default": "#E5E5E5"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Icon background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Shape & shadow"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 28
    },
    {
      "type": "range",
      "id": "item_radius",
      "label": "Accordion item radius",
      "min": 0,
      "max": 24,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "shadow_y",
      "label": "Shadow Y offset",
      "min": 0,
      "max": 48,
      "step": 1,
      "default": 28
    },
    {
      "type": "range",
      "id": "shadow_blur",
      "label": "Shadow blur",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 70
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "label": "Shadow opacity",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 18
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How can I track my order?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Once your order is shipped, you'll receive a tracking number via email to monitor your delivery status.</p>"
        },
        {
          "type": "checkbox",
          "id": "default_open",
          "label": "Open by default",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Page UI",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "How can I track my order?",
            "answer": "<p>Once your order is shipped, you'll receive a tracking number via email to monitor your delivery status.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer a 30-day return policy on all unused items in their original packaging. Simply contact our support team to initiate a return.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How long does it take to process a refund?",
            "answer": "<p>Refunds are typically processed within 5-7 business days after we receive your returned item. You'll receive a confirmation email once the refund has been issued.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What payment methods do you accept?",
            "answer": "<p>We accept all major credit cards (Visa, MasterCard, American Express), PayPal, Apple Pay, and Google Pay for your convenience.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How can I contact customer support?",
            "answer": "<p>You can reach our customer support team via email, live chat on the website, or by calling your support hotline.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
