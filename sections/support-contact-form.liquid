{%- liquid
  assign section_bg = section.settings.background_color | default: 'transparent'
  assign card_bg = section.settings.card_background_color | default: 'var(--color-background, #ffffff)'
  assign hero_overlay_opacity = section.settings.hero_overlay_opacity | divided_by: 100.0
  assign form_id = 'SupportContactForm-' | append: section.id
  assign success_message = 'Thanks for contacting Celisira. We will reply as soon as possible.'
  assign first_name_label = 'First name'
  assign last_name_label = 'Last name'
  assign email_label = 'Email'
  assign phone_label = 'Phone number'
  assign comment_label = 'Comment'
  assign success_heading = section.settings.success_heading | default: 'Thank you for contacting Celisira'
  assign success_description = section.settings.success_description | default: 'We received your message and will get back to you as soon as possible.'
-%}

<section
  id="SupportContact-{{ section.id }}"
  class="support-contact-section"
  style="
    --sc-padding-top: {{ section.settings.padding_top }}px;
    --sc-padding-bottom: {{ section.settings.padding_bottom }}px;
    --sc-section-bg: {{ section_bg }};
    --sc-card-bg: {{ card_bg }};
    --sc-overlay-opacity: {{ hero_overlay_opacity }};
  "
>
  <div class="sc-shell">
    <header class="sc-hero" role="banner">
      {%- if section.settings.hero_image != blank -%}
        {{
          section.settings.hero_image
          | image_url: width: 1600
          | image_tag:
            class: 'sc-hero__image',
            loading: 'eager',
            fetchpriority: 'high',
            widths: '480, 720, 960, 1200, 1600',
            sizes: '(max-width: 767px) 100vw, (max-width: 1023px) 560px, 44vw',
            alt: section.settings.hero_title
        }}
      {%- endif -%}

      <div class="sc-hero__overlay" aria-hidden="true"></div>
      <div class="sc-hero__content">
        {%- if section.settings.hero_title != blank -%}
          <h1 class="sc-hero__title">{{ section.settings.hero_title }}</h1>
        {%- endif -%}
        {%- if section.settings.hero_description != blank -%}
          <p class="sc-hero__description">{{ section.settings.hero_description }}</p>
        {%- endif -%}
      </div>
    </header>

    <div class="sc-form-wrap">
      <article class="sc-card" aria-labelledby="sc-form-title-{{ section.id }}">
        {%- if section.settings.form_heading != blank -%}
          <h2 id="sc-form-title-{{ section.id }}" class="sc-card__title">{{ section.settings.form_heading }}</h2>
        {%- endif -%}
        {%- if section.settings.form_description != blank -%}
          <p class="sc-card__description">{{ section.settings.form_description }}</p>
        {%- endif -%}

        {%- form 'contact', id: form_id, class: 'sc-form' -%}
          {%- if form.posted_successfully? -%}
            <div class="sc-success" role="status" tabindex="-1">
              <div class="sc-success__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6 9 17l-5-5"></path>
                </svg>
              </div>
              <h3 class="sc-success__title">{{ success_heading }}</h3>
              <p class="sc-success__description">{{ success_description }}</p>
              <p class="sc-success__note">{{ success_message }}</p>
            </div>
          {%- else -%}
            {%- if form.errors -%}
              <div class="sc-form__feedback sc-form__feedback--error" role="alert">
                {{ form.errors | default_errors }}
              </div>
            {%- endif -%}

            <div class="sc-form__grid">
              <div class="sc-field">
                <label class="sc-label sr-only" for="sc-name-{{ section.id }}">
                  {{ first_name_label }}
                </label>
                <input
                  id="sc-name-{{ section.id }}"
                  class="sc-input"
                  type="text"
                  name="contact[name]"
                  autocomplete="given-name"
                  value="{% if form.name %}{{ form.name | escape }}{% elsif customer %}{{ customer.first_name | escape }}{% endif %}"
                  placeholder="{{ first_name_label }}"
                >
              </div>

              <div class="sc-field">
                <label class="sc-label sr-only" for="sc-last-name-{{ section.id }}">
                  {{ last_name_label }}
                </label>
                <input
                  id="sc-last-name-{{ section.id }}"
                  class="sc-input"
                  type="text"
                  name="contact[last_name]"
                  autocomplete="family-name"
                  value="{{ form.last_name | escape }}"
                  placeholder="{{ last_name_label }}"
                >
              </div>

              <div class="sc-field">
                <label class="sc-label sr-only" for="sc-email-{{ section.id }}">
                  {{ email_label }}
                </label>
                <input
                  id="sc-email-{{ section.id }}"
                  class="sc-input"
                  type="email"
                  name="contact[email]"
                  autocomplete="email"
                  autocorrect="off"
                  autocapitalize="off"
                  required
                  value="{% if form.email %}{{ form.email | escape }}{% elsif customer %}{{ customer.email | escape }}{% endif %}"
                  placeholder="{{ email_label }}"
                >
              </div>

              <div class="sc-field">
                <label class="sc-label sr-only" for="sc-phone-{{ section.id }}">
                  {{ phone_label }}
                </label>
                <input
                  id="sc-phone-{{ section.id }}"
                  class="sc-input"
                  type="tel"
                  name="contact[phone]"
                  autocomplete="tel"
                  value="{% if form.phone %}{{ form.phone | escape }}{% elsif customer %}{{ customer.phone | escape }}{% endif %}"
                  placeholder="{{ phone_label }}"
                >
              </div>

              <div class="sc-field sc-field--full">
                <label class="sc-label sr-only" for="sc-message-{{ section.id }}">
                  {{ comment_label }}
                </label>
                <textarea
                  id="sc-message-{{ section.id }}"
                  class="sc-input sc-textarea"
                  name="contact[body]"
                  rows="6"
                  placeholder="{{ comment_label }}"
                >{{- form.body | escape -}}</textarea>
              </div>
            </div>

            <button class="sc-submit" type="submit">
              {{ section.settings.submit_label | default: 'Send' }}
            </button>
          {%- endif -%}
        {%- endform -%}
      </article>
    </div>

    <div class="sc-info">
      {%- if section.settings.info_heading != blank -%}
        <h2 class="sc-info__heading">{{ section.settings.info_heading }}</h2>
      {%- endif -%}
      {%- if section.settings.info_description != blank -%}
        <p class="sc-info__description">{{ section.settings.info_description }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="sc-info__list" role="list">
          {%- for block in section.blocks -%}
            <li class="sc-info__item" {{ block.shopify_attributes }}>
              {%- if block.settings.label != blank -%}
                <p class="sc-info__label">{{ block.settings.label }}</p>
              {%- endif -%}

              {%- assign block_content = block.settings.content | strip -%}
              {%- case block.type -%}
                {%- when 'phone' -%}
                  {%- assign phone_href = block_content | remove: ' ' | remove: '(' | remove: ')' | remove: '-' -%}
                  <a class="sc-info__value" href="tel:{{ phone_href }}">{{ block_content }}</a>
                {%- when 'email' -%}
                  <a class="sc-info__value" href="mailto:{{ block_content | escape }}">{{ block_content }}</a>
                {%- else -%}
                  <p class="sc-info__value">{{ block_content }}</p>
              {%- endcase -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <ul class="sc-info__list" role="list">
          <li class="sc-info__item">
            <p class="sc-info__label">{{ section.settings.fallback_card_1_label }}</p>
            <p class="sc-info__value">{{ section.settings.fallback_card_1_content }}</p>
          </li>
          <li class="sc-info__item">
            <p class="sc-info__label">{{ section.settings.fallback_card_2_label }}</p>
            <a class="sc-info__value" href="tel:{{ section.settings.fallback_card_2_content | remove: ' ' | remove: '(' | remove: ')' | remove: '-' }}">
              {{ section.settings.fallback_card_2_content }}
            </a>
          </li>
          <li class="sc-info__item">
            <p class="sc-info__label">{{ section.settings.fallback_card_3_label }}</p>
            <a class="sc-info__value" href="mailto:{{ section.settings.fallback_card_3_content | escape }}">
              {{ section.settings.fallback_card_3_content }}
            </a>
          </li>
        </ul>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #SupportContact-{{ section.id }} {
    padding-top: var(--sc-padding-top);
    padding-bottom: var(--sc-padding-bottom);
    background: var(--sc-section-bg);
    color: var(--color-base-text, var(--color-text, currentColor));
  }

  #SupportContact-{{ section.id }} .sc-shell {
    max-width: 430px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  #SupportContact-{{ section.id }} .sc-hero {
    position: relative;
    min-height: 340px;
    overflow: hidden;
    background: var(--sc-card-bg);
  }

  #SupportContact-{{ section.id }} .sc-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #SupportContact-{{ section.id }} .sc-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--sc-overlay-opacity));
  }

  #SupportContact-{{ section.id }} .sc-hero__content {
    position: relative;
    z-index: 1;
    min-height: 340px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 24px;
    color: var(--color-background, #ffffff);
  }

  #SupportContact-{{ section.id }} .sc-hero__title {
    margin: 0 0 12px;
    font-size: clamp(1.9rem, 6vw, 2.125rem);
    line-height: 1.15;
    color: inherit;
  }

  #SupportContact-{{ section.id }} .sc-hero__description {
    margin: 0;
    max-width: 32ch;
    line-height: 1.6;
    color: inherit;
    opacity: 0.92;
  }

  #SupportContact-{{ section.id }} .sc-form-wrap {
    padding: 16px 16px 0;
  }

  #SupportContact-{{ section.id }} .sc-card {
    background: var(--sc-card-bg);
    border-radius: 20px;
    padding: 28px 20px 24px;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.08);
  }

  #SupportContact-{{ section.id }} .sc-card__title,
  #SupportContact-{{ section.id }} .sc-info__heading {
    margin: 0 0 8px;
    line-height: 1.25;
    color: inherit;
  }

  #SupportContact-{{ section.id }} .sc-card__title {
    font-size: clamp(1.35rem, 4.8vw, 1.5rem);
  }

  #SupportContact-{{ section.id }} .sc-card__description,
  #SupportContact-{{ section.id }} .sc-info__description {
    margin: 0 0 24px;
    line-height: 1.6;
    color: inherit;
    opacity: 0.72;
  }

  #SupportContact-{{ section.id }} .sc-form {
    display: grid;
    gap: 12px;
  }

  #SupportContact-{{ section.id }} .sc-form__feedback {
    margin: 0 0 4px;
    border-radius: 14px;
    padding: 10px 14px;
    line-height: 1.5;
  }

  #SupportContact-{{ section.id }} .sc-form__feedback--success {
    background: rgba(16, 185, 129, 0.15);
  }

  #SupportContact-{{ section.id }} .sc-form__feedback--error {
    background: rgba(239, 68, 68, 0.13);
  }

  #SupportContact-{{ section.id }} .sc-success {
    display: grid;
    gap: 14px;
    justify-items: start;
    padding: 8px 0 4px;
  }

  #SupportContact-{{ section.id }} .sc-success__icon {
    width: 52px;
    height: 52px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(16, 185, 129, 0.12);
    color: rgb(5, 150, 105);
  }

  #SupportContact-{{ section.id }} .sc-success__icon svg {
    width: 24px;
    height: 24px;
  }

  #SupportContact-{{ section.id }} .sc-success__title {
    margin: 0;
    font-size: clamp(1.25rem, 4.8vw, 1.45rem);
    line-height: 1.25;
    color: inherit;
  }

  #SupportContact-{{ section.id }} .sc-success__description,
  #SupportContact-{{ section.id }} .sc-success__note {
    margin: 0;
    line-height: 1.6;
    color: inherit;
  }

  #SupportContact-{{ section.id }} .sc-success__description {
    opacity: 0.8;
  }

  #SupportContact-{{ section.id }} .sc-success__note {
    opacity: 0.7;
  }

  #SupportContact-{{ section.id }} .sc-form__grid {
    display: grid;
    gap: 12px;
  }

  #SupportContact-{{ section.id }} .sc-field--full {
    width: 100%;
  }

  #SupportContact-{{ section.id }} .sc-input {
    width: 100%;
    min-height: 48px;
    border: 1px solid transparent;
    border-radius: 999px;
    background: var(--color-input-background, rgba(0, 0, 0, 0.04));
    padding: 12px 18px;
    color: inherit;
    line-height: 1.5;
  }

  #SupportContact-{{ section.id }} .sc-input::placeholder {
    color: inherit;
    opacity: 0.55;
  }

  #SupportContact-{{ section.id }} .sc-input:focus-visible {
    border-color: rgba(0, 0, 0, 0.32);
    box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.16);
    outline: none;
  }

  #SupportContact-{{ section.id }} .sc-textarea {
    border-radius: 22px;
    min-height: 148px;
    resize: vertical;
    padding-block: 14px;
  }

  #SupportContact-{{ section.id }} .sc-submit {
    width: 100%;
    min-height: 52px;
    border: 0;
    border-radius: 999px;
    padding: 12px 20px;
    line-height: 1.2;
    cursor: pointer;
    background: var(--color-base-text, var(--color-text, #111111));
    color: var(--color-background, #ffffff);
    transition: opacity 0.2s ease;
  }

  #SupportContact-{{ section.id }} .sc-submit:hover {
    opacity: 0.88;
  }

  #SupportContact-{{ section.id }} .sc-info {
    padding: 36px 16px 48px;
  }

  #SupportContact-{{ section.id }} .sc-info__heading {
    margin-bottom: 14px;
    font-size: clamp(1.55rem, 7.2vw, 1.95rem);
    line-height: 1.2;
  }

  #SupportContact-{{ section.id }} .sc-info__description {
    margin-bottom: 24px;
  }

  #SupportContact-{{ section.id }} .sc-info__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 14px;
  }

  #SupportContact-{{ section.id }} .sc-info__item {
    background: var(--sc-card-bg);
    border-radius: 16px;
    padding: 18px 16px;
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.06);
    display: grid;
    gap: 8px;
  }

  #SupportContact-{{ section.id }} .sc-info__label {
    margin: 0;
    line-height: 1.4;
    font-weight: 600;
    color: inherit;
  }

  #SupportContact-{{ section.id }} .sc-info__value {
    margin: 0;
    line-height: 1.6;
    color: inherit;
    text-decoration: none;
    opacity: 0.82;
    word-break: break-word;
  }

  #SupportContact-{{ section.id }} .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    #SupportContact-{{ section.id }} .sc-shell {
      max-width: 560px;
    }
  }

  @media (min-width: 1024px) {
    #SupportContact-{{ section.id }} .sc-shell {
      max-width: min(1240px, calc(100vw - 64px));
      display: grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(420px, 0.85fr);
      grid-template-areas:
        "hero form"
        "info form";
      gap: 28px;
      align-items: start;
    }

    #SupportContact-{{ section.id }} .sc-hero {
      grid-area: hero;
      min-height: 620px;
    }

    #SupportContact-{{ section.id }} .sc-hero__content {
      padding: 44px;
      align-items: flex-start;
      text-align: left;
    }

    #SupportContact-{{ section.id }} .sc-hero__title {
      font-size: clamp(2.8rem, 4vw, 4.4rem);
      max-width: 10ch;
      margin-bottom: 16px;
    }

    #SupportContact-{{ section.id }} .sc-hero__description {
      font-size: 1rem;
      max-width: 40ch;
    }

    #SupportContact-{{ section.id }} .sc-form-wrap {
      grid-area: form;
      padding: 0;
      position: sticky;
      top: 7rem;
    }

    #SupportContact-{{ section.id }} .sc-card {
      padding: 40px 32px 32px;
      border-radius: 28px;
    }

    #SupportContact-{{ section.id }} .sc-card__title {
      font-size: clamp(1.75rem, 2.5vw, 2.35rem);
    }

    #SupportContact-{{ section.id }} .sc-form__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    #SupportContact-{{ section.id }} .sc-field--full {
      grid-column: 1 / -1;
    }

    #SupportContact-{{ section.id }} .sc-info {
      grid-area: info;
      padding: 8px 0 0;
    }

    #SupportContact-{{ section.id }} .sc-info__heading {
      font-size: clamp(2rem, 3vw, 2.8rem);
      max-width: 14ch;
    }

    #SupportContact-{{ section.id }} .sc-info__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }
  }
</style>

