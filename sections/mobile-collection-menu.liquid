{%- liquid
  assign tab_blocks = section.blocks | where: 'type', 'category_tab'
  assign menu_title = section.settings.menu_title | default: 'Catalog'
  assign group_heading = section.settings.group_heading | default: 'Collections'
-%}

<style>
  #mobile-collection-menu {
    --mcm-bg: var(--color-background, var(--color-base-background-1, #fffdf9));
    --mcm-surface: color-mix(in srgb, var(--mcm-bg) 92%, var(--color-foreground, var(--color-base-text, #111)) 8%);
    --mcm-text: var(--color-foreground, var(--color-base-text, #111111));
    --mcm-muted: color-mix(in srgb, var(--mcm-text) 38%, transparent);
    --mcm-line: color-mix(in srgb, var(--mcm-text) 12%, transparent);
    --mcm-accent: color-mix(in srgb, var(--mcm-text) 86%, #7c6046 14%);
    --mcm-sale: color-mix(in srgb, #b0134f 86%, var(--mcm-text) 14%);
    --mcm-tab-size: {{ section.settings.tab_font_size }}px;
    --mcm-group-size: {{ section.settings.group_font_size }}px;
    --mcm-link-size: {{ section.settings.link_font_size }}px;
    position: fixed;
    inset: 0;
    z-index: 9998;
    background: var(--mcm-bg);
    color: var(--mcm-text);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.28s ease, visibility 0.28s ease;
    overscroll-behavior: contain;
  }

  #mobile-collection-menu.mcm-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  #mobile-collection-menu .mcm-shell {
    display: flex;
    flex-direction: column;
    height: 100%;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--mcm-bg) 96%, var(--mcm-text) 4%) 0%, var(--mcm-bg) 14rem);
  }

  #mobile-collection-menu .mcm-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 1.1rem 0.35rem;
    flex-shrink: 0;
  }

  #mobile-collection-menu .mcm-kicker {
    margin: 0;
    font-size: 0.7rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--mcm-muted);
  }

  #mobile-collection-menu .mcm-close {
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--mcm-line);
    border-radius: 999px;
    background: color-mix(in srgb, var(--mcm-bg) 90%, var(--mcm-text) 10%);
    color: var(--mcm-text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: transform 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
  }

  #mobile-collection-menu .mcm-close:active {
    transform: scale(0.96);
  }

  #mobile-collection-menu .mcm-tabs-wrap {
    position: sticky;
    top: 0;
    z-index: 2;
    padding: 0 1.1rem;
    background: linear-gradient(180deg, var(--mcm-bg) 0%, color-mix(in srgb, var(--mcm-bg) 90%, transparent) 100%);
    border-bottom: 1px solid var(--mcm-line);
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  #mobile-collection-menu .mcm-tabs-wrap::-webkit-scrollbar {
    display: none;
  }

  #mobile-collection-menu .mcm-tabs {
    display: flex;
    gap: 1.35rem;
    min-width: max-content;
  }

  #mobile-collection-menu .mcm-tab {
    position: relative;
    padding: 0.95rem 0 0.9rem;
    border: 0;
    background: transparent;
    color: var(--mcm-muted);
    font: inherit;
    font-size: var(--mcm-tab-size);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    white-space: nowrap;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.18s ease;
  }

  #mobile-collection-menu .mcm-tab::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 2px;
    transform: scaleX(0);
    transform-origin: center;
    background: var(--mcm-text);
    transition: transform 0.22s ease;
  }

  #mobile-collection-menu .mcm-tab--active {
    color: var(--mcm-text);
  }

  #mobile-collection-menu .mcm-tab--active::after {
    transform: scaleX(1);
  }

  #mobile-collection-menu .mcm-scroll {
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  #mobile-collection-menu .mcm-panel {
    display: none;
  }

  #mobile-collection-menu .mcm-panel--active {
    display: block;
    animation: mcmPanelIn 0.24s ease;
  }

  #mobile-collection-menu .mcm-banner-link,
  #mobile-collection-menu .mcm-banner-static {
    display: block;
    color: inherit;
    text-decoration: none;
    overflow: hidden;
    border-bottom: 1px solid var(--mcm-line);
  }

  #mobile-collection-menu .mcm-banner-image {
    width: 100%;
    height: auto;
    max-height: 16.25rem;
    object-fit: cover;
    display: block;
    background: var(--mcm-surface);
  }

  #mobile-collection-menu .mcm-banner-placeholder {
    height: 11rem;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--mcm-bg) 80%, var(--mcm-text) 20%) 0%, color-mix(in srgb, var(--mcm-bg) 96%, #c3a991 4%) 100%);
  }

  #mobile-collection-menu .mcm-groups {
    padding: 0 1.1rem 2rem;
  }

  #mobile-collection-menu .mcm-group {
    display: flex;
    align-items: flex-start;
    gap: 0.95rem;
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--mcm-line);
  }

  #mobile-collection-menu .mcm-group:last-child {
    border-bottom: 0;
  }

  #mobile-collection-menu .mcm-group-num {
    flex: 0 0 2.6rem;
    padding-top: 0.12rem;
    font-size: 0.64rem;
    letter-spacing: 0.08em;
    color: color-mix(in srgb, var(--mcm-text) 28%, transparent);
  }

  #mobile-collection-menu .mcm-group-body {
    min-width: 0;
    flex: 1;
  }

  #mobile-collection-menu .mcm-group-title {
    margin: 0 0 0.72rem;
    font-size: var(--mcm-group-size);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mcm-accent);
  }

  #mobile-collection-menu .mcm-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  #mobile-collection-menu .mcm-links li + li {
    margin-top: 0.1rem;
  }

  #mobile-collection-menu .mcm-link {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding: 0.38rem 0;
    color: color-mix(in srgb, var(--mcm-text) 80%, transparent);
    text-decoration: none;
    font-size: var(--mcm-link-size);
    line-height: 1.28;
    letter-spacing: 0.04em;
    transition: color 0.18s ease;
  }

  #mobile-collection-menu .mcm-link--sale {
    color: var(--mcm-sale);
  }

  #mobile-collection-menu .mcm-link-badge {
    display: inline-flex;
    align-items: center;
    min-height: 1.15rem;
    padding: 0.1rem 0.36rem;
    border: 1px solid currentColor;
    border-radius: 999px;
    font-size: 0.5rem;
    line-height: 1;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  #mobile-collection-menu .mcm-empty {
    padding: 2.6rem 1.1rem;
    color: var(--mcm-muted);
    font-size: 0.86rem;
    line-height: 1.6;
  }

  @keyframes mcmPanelIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #mobile-collection-menu,
    #mobile-collection-menu .mcm-tab,
    #mobile-collection-menu .mcm-close,
    #mobile-collection-menu .mcm-panel--active,
    #mobile-collection-menu .mcm-tab::after {
      transition: none;
      animation: none;
    }
  }

  @media (min-width: 768px) {
    #mobile-collection-menu {
      display: none !important;
    }
  }
</style>

<div id="mobile-collection-menu" aria-hidden="true" role="dialog" aria-modal="true" aria-label="{{ menu_title }}">
  <div class="mcm-shell">
    <div class="mcm-topbar">
      <p class="mcm-kicker">{{ menu_title }}</p>
      <button class="mcm-close" type="button" data-mcm-close aria-label="Close menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    {%- if tab_blocks.size > 0 -%}
      <div class="mcm-tabs-wrap">
        <div class="mcm-tabs" role="tablist">
          {%- for block in tab_blocks -%}
            <button
              class="mcm-tab{% if forloop.first %} mcm-tab--active{% endif %}"
              type="button"
              role="tab"
              data-mcm-tab="{{ forloop.index0 }}"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-controls="mcm-panel-{{ block.id }}"
              id="mcm-tab-{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.label | default: 'Category' }}
            </button>
          {%- endfor -%}
        </div>
      </div>

      <div class="mcm-scroll" data-mcm-scroll>
        {%- for tab_block in tab_blocks -%}
          <section
            class="mcm-panel{% if forloop.first %} mcm-panel--active{% endif %}"
            id="mcm-panel-{{ tab_block.id }}"
            role="tabpanel"
            aria-labelledby="mcm-tab-{{ tab_block.id }}"
            data-mcm-panel="{{ forloop.index0 }}"
          >
            {%- if tab_block.settings.banner_image != blank -%}
              {%- if tab_block.settings.banner_link != blank -%}
                <a class="mcm-banner-link" href="{{ tab_block.settings.banner_link }}">
                  {{ tab_block.settings.banner_image | image_url: width: 1200 | image_tag: class: 'mcm-banner-image', widths: '480, 720, 960, 1200', sizes: '100vw', loading: 'lazy', alt: tab_block.settings.banner_alt | default: tab_block.settings.label }}
                </a>
              {%- else -%}
                <div class="mcm-banner-static">
                  {{ tab_block.settings.banner_image | image_url: width: 1200 | image_tag: class: 'mcm-banner-image', widths: '480, 720, 960, 1200', sizes: '100vw', loading: 'lazy', alt: tab_block.settings.banner_alt | default: tab_block.settings.label }}
                </div>
              {%- endif -%}
            {%- endif -%}

            <div class="mcm-groups">
              {%- liquid
                assign inside_tab = false
                assign has_group_blocks = false
                for block in section.blocks
                  if block.id == tab_block.id
                    assign inside_tab = true
                    continue
                  endif
                  if inside_tab
                    if block.type == 'category_tab'
                      break
                    endif
                    if block.type == 'collection_group'
                      assign has_group_blocks = true
                      break
                    endif
                  endif
                endfor
              -%}

              {%- if has_group_blocks -%}
                {%- assign inside_tab = false -%}
                {%- for block in section.blocks -%}
                  {%- if block.id == tab_block.id -%}
                    {%- assign inside_tab = true -%}
                    {%- continue -%}
                  {%- endif -%}
                  {%- if inside_tab -%}
                    {%- if block.type == 'category_tab' -%}
                      {%- break -%}
                    {%- endif -%}
                    {%- if block.type == 'collection_group' -%}
                      <div class="mcm-group" {{ block.shopify_attributes }}>
                        <div class="mcm-group-num">|{{ block.settings.number | default: '01' }}|</div>
                        <div class="mcm-group-body">
                          <h3 class="mcm-group-title">{{ block.settings.title | default: group_heading }}</h3>
                          {%- if block.settings.collections.size > 0 -%}
                            <ul class="mcm-links">
                              {%- for collection in block.settings.collections -%}
                                <li>
                                  <a class="mcm-link{% if collection.all_products_count == 0 %} mcm-link--sale{% endif %}" href="{{ collection.url }}">
                                    <span>{{ collection.title }}</span>
                                    {%- if collection.all_products_count > 0 and section.settings.show_collection_count -%}
                                      <span class="mcm-link-badge">{{ collection.all_products_count }}</span>
                                    {%- endif -%}
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- elsif block.settings.fallback_menu != blank -%}
                            <ul class="mcm-links">
                              {%- for link in linklists[block.settings.fallback_menu].links -%}
                                <li>
                                  <a class="mcm-link" href="{{ link.url }}">
                                    <span>{{ link.title }}</span>
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- else -%}
                            <div class="mcm-empty">Choose Shopify collections for this group.</div>
                          {%- endif -%}
                        </div>
                      </div>
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- elsif tab_block.settings.collections.size > 0 -%}
                <div class="mcm-group" {{ tab_block.shopify_attributes }}>
                  <div class="mcm-group-num">|{{ tab_block.settings.group_number | default: '01' }}|</div>
                  <div class="mcm-group-body">
                    <h3 class="mcm-group-title">{{ tab_block.settings.group_title | default: group_heading }}</h3>
                    <ul class="mcm-links">
                      {%- for collection in tab_block.settings.collections -%}
                        <li>
                          <a class="mcm-link{% if collection.all_products_count == 0 %} mcm-link--sale{% endif %}" href="{{ collection.url }}">
                            <span>{{ collection.title }}</span>
                            {%- if collection.all_products_count > 0 and section.settings.show_collection_count -%}
                              <span class="mcm-link-badge">{{ collection.all_products_count }}</span>
                            {%- endif -%}
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>
                </div>
              {%- elsif tab_block.settings.fallback_menu != blank -%}
                <div class="mcm-group" {{ tab_block.shopify_attributes }}>
                  <div class="mcm-group-num">|{{ tab_block.settings.group_number | default: '01' }}|</div>
                  <div class="mcm-group-body">
                    <h3 class="mcm-group-title">{{ tab_block.settings.group_title | default: group_heading }}</h3>
                    <ul class="mcm-links">
                      {%- for link in linklists[tab_block.settings.fallback_menu].links -%}
                        <li>
                          <a class="mcm-link" href="{{ link.url }}">
                            <span>{{ link.title }}</span>
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>
                </div>
              {%- else -%}
                <div class="mcm-empty" {{ tab_block.shopify_attributes }}>
                  Add one or more <strong>Collection group</strong> blocks under this category tab, then choose Shopify collections inside each group.
                </div>
              {%- endif -%}
            </div>
          </section>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="mcm-scroll" data-mcm-scroll>
        <div class="mcm-empty">
          Add a <strong>Category tab</strong> block in Theme Editor, then open that block to rename the parent collection tab and select its child collections from Shopify.
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    'use strict';
    var KEY = '__mcm_init';
    if (window[KEY]) return;
    window[KEY] = true;

    var overlay = document.getElementById('mobile-collection-menu');
    if (!overlay) return;

    var tabs = Array.prototype.slice.call(overlay.querySelectorAll('[data-mcm-tab]'));
    var panels = Array.prototype.slice.call(overlay.querySelectorAll('[data-mcm-panel]'));
    var scrollArea = overlay.querySelector('[data-mcm-scroll]');

    function switchTab(idx) {
      tabs.forEach(function (tab) {
        var active = tab.getAttribute('data-mcm-tab') === String(idx);
        tab.classList.toggle('mcm-tab--active', active);
        tab.setAttribute('aria-selected', active ? 'true' : 'false');
      });

      panels.forEach(function (panel) {
        panel.classList.toggle('mcm-panel--active', panel.getAttribute('data-mcm-panel') === String(idx));
      });

      if (scrollArea) scrollArea.scrollTop = 0;
    }

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        switchTab(tab.getAttribute('data-mcm-tab'));
      });
    });

    window.MobileCollectionMenu = {
      open: function () {
        overlay.classList.add('mcm-open');
        overlay.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      },
      close: function () {
        overlay.classList.remove('mcm-open');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      },
      toggle: function () {
        if (overlay.classList.contains('mcm-open')) {
          this.close();
        } else {
          this.open();
        }
      }
    };

    overlay.querySelectorAll('[data-mcm-close]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        window.MobileCollectionMenu.close();
      });
    });

    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape' && overlay.classList.contains('mcm-open')) {
        window.MobileCollectionMenu.close();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Mobile Collection Menu",
  "tag": "section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "menu_title",
      "label": "Menu title",
      "default": "Catalog"
    },
    {
      "type": "text",
      "id": "group_heading",
      "label": "Default group heading",
      "default": "Collections"
    },
    {
      "type": "range",
      "id": "tab_font_size",
      "label": "Tab font size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "group_font_size",
      "label": "Group title font size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "range",
      "id": "link_font_size",
      "label": "Collection link font size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "checkbox",
      "id": "show_collection_count",
      "label": "Show collection product count",
      "default": false
    }
  ],
  "max_blocks": 50,
  "blocks": [
    {
      "type": "category_tab",
      "name": "Category tab",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Tab label",
          "default": "Women"
        },
        {
          "type": "image_picker",
          "id": "banner_image",
          "label": "Banner image"
        },
        {
          "type": "url",
          "id": "banner_link",
          "label": "Banner link"
        },
        {
          "type": "text",
          "id": "banner_alt",
          "label": "Banner alt text"
        },
        {
          "type": "text",
          "id": "group_number",
          "label": "Group number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "group_title",
          "label": "Group title",
          "default": "Collections"
        },
        {
          "type": "collection_list",
          "id": "collections",
          "label": "Child collections"
        },
        {
          "type": "link_list",
          "id": "fallback_menu",
          "label": "Fallback menu",
          "info": "Used only if you do not select child collections."
        }
      ]
    },
    {
      "type": "collection_group",
      "name": "Collection group",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Group number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Group title",
          "default": "New"
        },
        {
          "type": "collection_list",
          "id": "collections",
          "label": "Shopify collections"
        },
        {
          "type": "link_list",
          "id": "fallback_menu",
          "label": "Fallback menu",
          "info": "Used only if you do not select Shopify collections."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mobile Collection Menu",
      "blocks": [
        { "type": "category_tab", "settings": { "label": "Women", "group_number": "01", "group_title": "Collections" } },
        { "type": "category_tab", "settings": { "label": "Men", "group_number": "01", "group_title": "Collections" } },
        { "type": "category_tab", "settings": { "label": "Kids", "group_number": "01", "group_title": "Collections" } },
        { "type": "category_tab", "settings": { "label": "Perfume", "group_number": "01", "group_title": "Collections" } }
      ]
    }
  ]
}
{% endschema %}
