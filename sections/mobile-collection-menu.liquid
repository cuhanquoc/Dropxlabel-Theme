{%- liquid
  assign tab_blocks = section.blocks | where: 'type', 'category_tab'
  assign menu_title = section.settings.menu_title | default: 'Catalog'
-%}

<style>
  #mobile-collection-menu {
    --mcm-bg: var(--color-background, #f6f1ea);
    --mcm-surface: color-mix(in srgb, var(--mcm-bg) 88%, #ffffff 12%);
    --mcm-text: var(--color-foreground, #171412);
    --mcm-muted: color-mix(in srgb, var(--mcm-text) 44%, transparent);
    --mcm-line: color-mix(in srgb, var(--mcm-text) 12%, transparent);
    --mcm-accent: color-mix(in srgb, var(--mcm-text) 76%, #6b4f35 24%);
    --mcm-sale: color-mix(in srgb, #8c1f45 82%, var(--mcm-text) 18%);
    --mcm-tab-size: {{ section.settings.tab_font_size }}px;
    --mcm-group-size: {{ section.settings.group_font_size }}px;
    --mcm-link-size: {{ section.settings.link_font_size }}px;
    position: fixed;
    inset: 0;
    z-index: 220;
    background: linear-gradient(180deg, rgba(250, 247, 242, 0.985) 0%, rgba(245, 239, 231, 0.985) 100%);
    color: var(--mcm-text);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.28s ease, visibility 0.28s ease;
    overscroll-behavior: contain;
  }

  #mobile-collection-menu.mcm-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  body.mcm-open {
    overflow: hidden;
  }

  #mobile-collection-menu .mcm-shell {
    display: flex;
    flex-direction: column;
    height: 100%;
    background:
      radial-gradient(circle at top, rgba(255, 255, 255, 0.65), transparent 42%),
      linear-gradient(180deg, color-mix(in srgb, var(--mcm-bg) 98%, #ffffff 2%) 0%, var(--mcm-bg) 14rem);
  }

  #mobile-collection-menu .mcm-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.1rem 0.45rem;
    flex-shrink: 0;
  }

  #mobile-collection-menu .mcm-kicker {
    margin: 0;
    font-size: 0.7rem;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--mcm-muted);
  }

  #mobile-collection-menu .mcm-close {
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid var(--mcm-line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.62);
    color: var(--mcm-text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: transform 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
    box-shadow: 0 8px 18px rgba(23, 20, 18, 0.06);
  }

  #mobile-collection-menu .mcm-close:active {
    transform: scale(0.96);
  }

  #mobile-collection-menu .mcm-tabs-wrap {
    position: sticky;
    top: 0;
    z-index: 2;
    padding: 0.2rem 1.1rem 0.6rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.74) 0%, rgba(255, 255, 255, 0.22) 100%);
    border-bottom: 1px solid var(--mcm-line);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  #mobile-collection-menu .mcm-tabs-wrap::-webkit-scrollbar {
    display: none;
  }

  #mobile-collection-menu .mcm-tabs {
    display: flex;
    gap: 0.55rem;
    min-width: max-content;
    padding-bottom: 0.25rem;
  }

  #mobile-collection-menu .mcm-tab {
    position: relative;
    padding: 0.85rem 1rem;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--mcm-muted);
    font: inherit;
    font-size: var(--mcm-tab-size);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.18s ease, background-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
  }

  #mobile-collection-menu .mcm-tab::after {
    content: "";
    position: absolute;
    left: 18%;
    right: 18%;
    bottom: -0.35rem;
    height: 2px;
    transform: scaleX(0);
    transform-origin: center;
    background: var(--mcm-text);
    transition: transform 0.22s ease;
  }

  #mobile-collection-menu .mcm-tab--active {
    color: var(--mcm-bg);
    background: var(--mcm-text);
    box-shadow: 0 10px 24px rgba(23, 20, 18, 0.12);
    transform: translateY(-1px);
  }

  #mobile-collection-menu .mcm-tab--active::after {
    transform: scaleX(1);
  }

  #mobile-collection-menu .mcm-scroll {
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  #mobile-collection-menu .mcm-panel {
    display: none;
  }

  #mobile-collection-menu .mcm-panel--active {
    display: block;
    animation: mcmPanelIn 0.26s ease;
  }

  #mobile-collection-menu .mcm-banner-link,
  #mobile-collection-menu .mcm-banner-static {
    display: block;
    color: inherit;
    text-decoration: none;
    overflow: hidden;
    border-bottom: 1px solid var(--mcm-line);
    margin: 0.2rem 1rem 0;
    border-radius: 24px;
    background: var(--mcm-surface);
    box-shadow: 0 10px 26px rgba(23, 20, 18, 0.05);
  }

  #mobile-collection-menu .mcm-banner-image {
    width: 100%;
    height: auto;
    max-height: 15.5rem;
    object-fit: cover;
    display: block;
    background: var(--mcm-surface);
  }

  #mobile-collection-menu .mcm-banner-placeholder {
    height: 12rem;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--mcm-bg) 82%, var(--mcm-text) 18%) 0%, color-mix(in srgb, var(--mcm-bg) 96%, #c3a991 4%) 100%);
  }

  #mobile-collection-menu .mcm-groups {
    padding: 0.9rem 1rem 2rem;
  }

  #mobile-collection-menu .mcm-group {
    display: grid;
    grid-template-columns: 2.8rem minmax(0, 1fr);
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem;
    margin-bottom: 0.85rem;
    border: 1px solid var(--mcm-line);
    border-radius: 24px;
    background: color-mix(in srgb, var(--mcm-bg) 86%, #ffffff 14%);
    box-shadow: 0 12px 28px rgba(23, 20, 18, 0.04);
  }

  #mobile-collection-menu .mcm-group:last-child {
    margin-bottom: 0;
  }

  #mobile-collection-menu .mcm-group-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.8rem;
    height: 2.8rem;
    padding-top: 0;
    font-size: 0.64rem;
    letter-spacing: 0.14em;
    color: color-mix(in srgb, var(--mcm-text) 32%, transparent);
    border: 1px solid var(--mcm-line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.6);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35);
  }

  #mobile-collection-menu .mcm-group-body {
    min-width: 0;
    flex: 1;
  }

  #mobile-collection-menu .mcm-group-title {
    margin: 0 0 0.72rem;
    font-size: var(--mcm-group-size);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--mcm-accent);
  }

  #mobile-collection-menu .mcm-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  #mobile-collection-menu .mcm-links li + li {
    margin-top: 0.18rem;
  }

  #mobile-collection-menu .mcm-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    width: 100%;
    padding: 0.55rem 0;
    color: color-mix(in srgb, var(--mcm-text) 82%, transparent);
    text-decoration: none;
    font-size: var(--mcm-link-size);
    line-height: 1.35;
    letter-spacing: 0.02em;
    transition: color 0.18s ease, transform 0.18s ease;
  }

  #mobile-collection-menu .mcm-link--sale {
    color: var(--mcm-sale);
  }

  #mobile-collection-menu .mcm-link-badge {
    display: inline-flex;
    align-items: center;
    min-height: 1.15rem;
    padding: 0.12rem 0.44rem;
    border: 1px solid currentColor;
    border-radius: 999px;
    font-size: 0.5rem;
    line-height: 1;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  #mobile-collection-menu .mcm-empty {
    padding: 2.2rem 1rem;
    color: var(--mcm-muted);
    font-size: 0.86rem;
    line-height: 1.6;
    border: 1px dashed var(--mcm-line);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.5);
  }

  @keyframes mcmPanelIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #mobile-collection-menu,
    #mobile-collection-menu .mcm-tab,
    #mobile-collection-menu .mcm-close,
    #mobile-collection-menu .mcm-panel--active,
    #mobile-collection-menu .mcm-tab::after {
      transition: none;
      animation: none;
    }
  }

  @media (min-width: 768px) {
    #mobile-collection-menu {
      display: none !important;
    }
  }
</style>

<div id="mobile-collection-menu" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="mobile-collection-menu-title">
  <div class="mcm-shell">
    <div class="mcm-topbar">
      <h2 class="mcm-kicker" id="mobile-collection-menu-title">{{ menu_title }}</h2>
      <button class="mcm-close" type="button" data-mcm-close aria-label="Close categories">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    {%- if tab_blocks.size > 0 -%}
      <div class="mcm-tabs-wrap">
        <div class="mcm-tabs" role="tablist">
          {%- for block in tab_blocks -%}
            <button
              class="mcm-tab{% if forloop.first %} mcm-tab--active{% endif %}"
              type="button"
              role="tab"
              data-mcm-tab="{{ forloop.index0 }}"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-controls="mcm-panel-{{ block.id }}"
              id="mcm-tab-{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.label | default: 'Category' }}
            </button>
          {%- endfor -%}
        </div>
      </div>

      <div class="mcm-scroll" data-mcm-scroll>
        {%- for tab_block in tab_blocks -%}
          {%- assign tab_index = forloop.index0 -%}
          <section
            class="mcm-panel{% if forloop.first %} mcm-panel--active{% endif %}"
            id="mcm-panel-{{ tab_block.id }}"
            role="tabpanel"
            aria-labelledby="mcm-tab-{{ tab_block.id }}"
            data-mcm-panel="{{ forloop.index0 }}"
          >
            {%- if tab_block.settings.banner_image != blank -%}
              {%- if tab_block.settings.banner_link != blank -%}
                <a class="mcm-banner-link" href="{{ tab_block.settings.banner_link }}">
                  {{ tab_block.settings.banner_image | image_url: width: 1200 | image_tag: class: 'mcm-banner-image', widths: '480, 720, 960, 1200', sizes: '100vw', loading: 'lazy', alt: tab_block.settings.banner_alt | default: tab_block.settings.label }}
                </a>
              {%- else -%}
                <div class="mcm-banner-static">
                  {{ tab_block.settings.banner_image | image_url: width: 1200 | image_tag: class: 'mcm-banner-image', widths: '480, 720, 960, 1200', sizes: '100vw', loading: 'lazy', alt: tab_block.settings.banner_alt | default: tab_block.settings.label }}
                </div>
              {%- endif -%}
            {%- endif -%}

            <div class="mcm-groups">
              {%- assign current_tab_index = -1 -%}
              {%- assign has_group_blocks = false -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'category_tab' -%}
                  {%- assign current_tab_index = current_tab_index | plus: 1 -%}
                {%- endif -%}
                {%- if current_tab_index == tab_index and block.type == 'collection_group' -%}
                  {%- assign has_group_blocks = true -%}
                  {%- render 'mobile-collection-menu-group', block: block, show_collection_count: section.settings.show_collection_count -%}
                {%- endif -%}
              {%- endfor -%}

              {%- unless has_group_blocks -%}
                <div class="mcm-empty" {{ tab_block.shopify_attributes }}>
                  Add one or more <strong>Collection group</strong> blocks under this category tab. Then open each group and pick Shopify collections in the right sidebar.
                </div>
              {%- endunless -%}
            </div>
          </section>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="mcm-scroll" data-mcm-scroll>
        <div class="mcm-empty">
          Add a <strong>Category tab</strong> block in Theme Editor, then open that block to rename the parent collection tab and select its child collections from Shopify.
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    'use strict';
    var KEY = '__mcm_init';
    if (window[KEY]) return;
    window[KEY] = true;

    var overlay = document.getElementById('mobile-collection-menu');
    if (!overlay) return;

    var tabs = Array.prototype.slice.call(overlay.querySelectorAll('[data-mcm-tab]'));
    var panels = Array.prototype.slice.call(overlay.querySelectorAll('[data-mcm-panel]'));
    var scrollArea = overlay.querySelector('[data-mcm-scroll]');
    var closeButton = overlay.querySelector('[data-mcm-close]');
    var lastTrigger = null;
    var focusableSelectors = [
      'a[href]',
      'button:not([disabled])',
      'input:not([disabled])',
      'select:not([disabled])',
      'textarea:not([disabled])',
      '[tabindex]:not([tabindex="-1"])'
    ].join(', ');

    function switchTab(idx) {
      tabs.forEach(function (tab) {
        var active = tab.getAttribute('data-mcm-tab') === String(idx);
        tab.classList.toggle('mcm-tab--active', active);
        tab.setAttribute('aria-selected', active ? 'true' : 'false');
      });

      panels.forEach(function (panel) {
        panel.classList.toggle('mcm-panel--active', panel.getAttribute('data-mcm-panel') === String(idx));
      });

      if (scrollArea) scrollArea.scrollTop = 0;
    }

    function updateTriggerState(open) {
      window.dispatchEvent(new CustomEvent('mobile-collection-menu:change', {
        detail: { open: open }
      }));
    }

    function focusFirstElement() {
      var focusables = Array.prototype.slice.call(overlay.querySelectorAll(focusableSelectors));
      if (focusables.length > 0) {
        focusables[0].focus();
      } else if (closeButton) {
        closeButton.focus();
      }
    }

    function trapFocus(event) {
      if (!overlay.classList.contains('mcm-open') || event.key !== 'Tab') return;

      var focusables = Array.prototype.slice.call(overlay.querySelectorAll(focusableSelectors));
      if (focusables.length === 0) {
        event.preventDefault();
        if (closeButton) closeButton.focus();
        return;
      }

      var first = focusables[0];
      var last = focusables[focusables.length - 1];
      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    }

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        switchTab(tab.getAttribute('data-mcm-tab'));
      });
    });

    window.MobileCollectionMenu = {
      open: function () {
        if (overlay.classList.contains('mcm-open')) return;
        lastTrigger = document.activeElement;
        overlay.classList.add('mcm-open');
        overlay.setAttribute('aria-hidden', 'false');
        overlay.removeAttribute('inert');
        document.body.classList.add('mcm-open');
        document.body.style.overflow = 'hidden';
        updateTriggerState(true);
        window.requestAnimationFrame(focusFirstElement);
      },
      close: function () {
        if (!overlay.classList.contains('mcm-open')) return;
        overlay.classList.remove('mcm-open');
        overlay.setAttribute('aria-hidden', 'true');
        overlay.setAttribute('inert', '');
        document.body.classList.remove('mcm-open');
        document.body.style.overflow = '';
        updateTriggerState(false);
        if (lastTrigger && typeof lastTrigger.focus === 'function') {
          window.requestAnimationFrame(function () {
            lastTrigger.focus();
          });
        }
      },
      toggle: function () {
        if (overlay.classList.contains('mcm-open')) {
          this.close();
        } else {
          this.open();
        }
      }
    };

    overlay.querySelectorAll('[data-mcm-close]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        window.MobileCollectionMenu.close();
      });
    });

    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape' && overlay.classList.contains('mcm-open')) {
        window.MobileCollectionMenu.close();
      }
      trapFocus(event);
    });
  })();
</script>

{% schema %}
{
  "name": "Mobile Collection Menu",
  "tag": "section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "menu_title",
      "label": "Menu title",
      "default": "Catalog"
    },
    {
      "type": "range",
      "id": "tab_font_size",
      "label": "Tab font size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "group_font_size",
      "label": "Group title font size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "range",
      "id": "link_font_size",
      "label": "Collection link font size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "checkbox",
      "id": "show_collection_count",
      "label": "Show collection product count",
      "default": false
    }
  ],
  "max_blocks": 50,
  "blocks": [
    {
      "type": "category_tab",
      "name": "Category tab",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Tab label",
          "default": "Women"
        },
        {
          "type": "image_picker",
          "id": "banner_image",
