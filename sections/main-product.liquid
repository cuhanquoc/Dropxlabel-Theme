<section class="product-section w-full bg-white text-[#0a0a0a] pb-12" data-section-id="{{ section.id }}" data-product-handle="{{ product.handle }}">
  <style>
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    
    .shopify-payment-button__button {
      border-radius: 0px !important;
      height: 3.25rem !important;
      font-family: inherit !important;
      font-weight: 500 !important;
      font-size: 15px !important;
      letter-spacing: 0 !important;
      text-transform: none !important;
      background-color: transparent !important;
      color: black !important;
      border: 1px solid black !important;
      outline: none !important;
      box-shadow: none !important;
    }
  </style>

  <div class="max-w-[1440px] mx-auto xl:px-10 xl:flex xl:gap-12 xl:items-start pt-0 xl:pt-12 pb-12">
    
    <!-- GALLERY: 1 Main Image on top, Scrollable Thumbnails below (Green Sweater Style) -->
    <div class="product-gallery w-full xl:w-1/2 xl:sticky xl:top-[120px]">
      <!-- Main Image -->
      <div class="w-full relative bg-[#f4f4f4] aspect-[4/5] xl:rounded-none overflow-hidden flex items-center justify-center">
        {% if product.featured_image %}
          <img id="ProductMainImage" src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }}" class="w-full h-full object-cover transition-opacity duration-300">
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'w-full h-full text-gray-300 object-cover' }}
        {% endif %}
      </div>
      
      <!-- Thumbnail Slider -->
      {% if product.media.size > 1 %}
        <div class="overflow-x-auto snap-x flex gap-[2px] mt-[2px] hide-scrollbar relative w-full" id="ProductThumbnails">
          {% for media in product.media %}
            <button type="button" 
                    class="shrink-0 w-[calc(33.3333%-1.33px)] aspect-[4/5] bg-[#f4f4f4] snap-start relative group outline-none"
                    onclick="document.getElementById('ProductMainImage').src='{{ media.preview_image | image_url: width: 1200 }}'">
              <img src="{{ media.preview_image | image_url: width: 400 }}" alt="{{ media.alt | escape }}" class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:opacity-100 transition-opacity">
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- PRODUCT INFO: User's Classic Layout -->
    <div class="product-info w-full px-5 py-8 xl:px-0 xl:w-1/2 xl:max-w-[480px]">
      
      <!-- Title & Price (Matched to User's Screenshot) -->
      <h1 class="text-[17px] md:text-[22px] font-body font-medium mb-1 leading-snug">{{ product.title }}</h1>
      <div class="text-[20px] md:text-[24px] font-body font-bold mb-3 mt-1">
        <span id="ProductPrice">{{ product.selected_or_first_available_variant.price | money }} {{ cart.currency.iso_code }}</span>
        {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
          <s class="text-[#888] text-lg ml-2 font-normal" id="ProductComparePrice">{{ product.selected_or_first_available_variant.compare_at_price | money }}</s>
        {% endif %}
      </div>
      <p class="text-[15px] font-body text-[#0a0a0a] mb-6">Taxes included. <a href="#" class="text-[#c1a067] underline hover:text-[#a08453] transition-colors">Shipping</a> calculated at checkout.</p>

      <hr class="border-t border-[#eaeaea] mb-6">

      <!-- Product Form -->
      {%- form 'product', product, id: 'ProductForm', class: 'block' -%}
        <input type="hidden" name="id" id="VariantSelector" value="{{ product.selected_or_first_available_variant.id }}">

        <!-- Variants -->
        {%- unless product.has_only_default_variant -%}
          <div class="space-y-6 mb-7 pt-2">
            {%- for option in product.options_with_values -%}
              <div>
                {%- liquid
                   assign is_color = false
                   assign downcased_option = option.name | downcase
                   if downcased_option == 'color' or downcased_option == 'colour' or downcased_option == 'màu sắc' or downcased_option == 'màu'
                     assign is_color = true
                   endif
                -%}
                
                <div class="flex justify-between items-end mb-3">
                  <label class="text-[14px] font-bold font-body uppercase tracking-tight">{{ option.name }} : <span class="font-bold ml-1 text-[#0a0a0a]" id="OptionValue-{{ forloop.index0 }}">{{ option.selected_value }}</span></label>
                  {%- if option.name == 'Size' or option.name == 'Kích thước' -%}
                    <button type="button" class="text-[13px] font-bold font-body uppercase tracking-tight hover:text-gray-600 transition-colors">
                       SIZE CHART
                    </button>
                  {%- endif -%}
                </div>
                
                {% if is_color %}
                  <!-- Swatches for Color (Like the square image swatch in screenshot) -->
                  <div class="flex flex-wrap gap-[10px]">
                    {%- for value in option.values -%}
                      <label class="relative cursor-pointer group">
                        <input type="radio" class="sr-only peer" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %} data-option-index="{{ forloop.parentloop.index0 }}" onchange="updateVariant(this)">
                        
                        {%- assign variant_image = blank -%}
                        {%- for variant in product.variants -%}
                          {%- if variant.options[forloop.parentloop.index0] == value and variant.image -%}
                            {%- assign variant_image = variant.image -%}
                            {%- break -%}
                          {%- endif -%}
                        {%- endfor -%}
                          
                        <!-- Square swatch with gap -->
                        <div class="w-[60px] h-[60px] overflow-hidden border-[1px] border-transparent peer-checked:border-gray-800 transition-all p-[3px] opacity-70 hover:opacity-100 peer-checked:opacity-100">
                          <div class="w-full h-full overflow-hidden bg-gray-100">
                            {% if variant_image != blank %}
                              <img src="{{ variant_image | image_url: width: 100 }}" class="w-full h-full object-cover" alt="{{ value }}">
                            {% else %}
                              <div class="w-full h-full flex items-center justify-center text-[10px]" style="background-color: {{ value | split: ' ' | last | downcase | remove: '"' | remove: "'" }};">{{ value }}</div>
                            {% endif %}
                          </div>
                        </div>
                      </label>
                    {%- endfor -%}
                  </div>
                {% else %}
                  <!-- Connected Grid for Sizes (Like user's table border logic) -->
                  <div class="flex flex-wrap border-l border-t border-[#e2e2e2]">
                    {%- for value in option.values -%}
                      <label class="relative cursor-pointer group flex-grow-0">
                        <input type="radio" class="sr-only peer" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %} data-option-index="{{ forloop.parentloop.index0 }}" onchange="updateVariant(this)">
                        
                        <!-- Grid cell -->
                        <div class="h-[44px] min-w-[50px] px-3 flex items-center justify-center border-r border-b border-[#e2e2e2] text-[14px] font-body text-[#0a0a0a] bg-white peer-checked:font-bold transition-all hover:bg-gray-50">
                          {{ value }}
                        </div>
                        <div class="absolute inset-0 border-0 peer-checked:border-2 peer-checked:border-black opacity-0 peer-checked:opacity-100 pointer-events-none transition-opacity"></div>
                      </label>
                    {%- endfor -%}
                  </div>
                {% endif %}
              </div>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <!-- Quantity -->
        <div class="mb-8 pt-2">
          <label class="text-[14px] font-bold font-body uppercase tracking-tight mb-3 block">Quantity</label>
          <div class="flex items-center w-[120px] h-[44px] border border-gray-300">
            <button type="button" class="w-10 h-full flex items-center justify-center text-xl text-gray-500 hover:text-black hover:bg-gray-50 outline-none transition-colors" onclick="document.getElementById('QuantityInput').stepDown()">−</button>
            <input type="number" id="QuantityInput" name="quantity" class="w-full h-full text-center text-[15px] font-body bg-transparent outline-none appearance-none font-medium" value="1" min="1" aria-label="Quantity">
            <button type="button" class="w-10 h-full flex items-center justify-center text-xl text-gray-500 hover:text-black hover:bg-gray-50 outline-none transition-colors" onclick="document.getElementById('QuantityInput').stepUp()">+</button>
          </div>
        </div>

        <!-- Submit Buttons (NATURAL FLOW) -->
        <div class="flex flex-col gap-3 mb-8 w-full">
          <button type="submit" class="w-full h-[50px] bg-white text-black border border-black flex items-center justify-center text-[15px] font-body font-medium hover:bg-black hover:text-white transition-colors duration-300 uppercase tracking-widest">
            Add to cart
          </button>
          
          {%- if section.settings.show_dynamic_checkout -%}
            {{ form | payment_button }}
          {%- else -%}
            <button type="button" class="w-full h-[50px] bg-black text-white flex items-center justify-center text-[15px] font-body font-medium hover:opacity-80 transition-opacity duration-300 uppercase tracking-widest">
              Buy it now
            </button>
          {%- endif -%}
        </div>

      {%- endform -%}

      <!-- Socials / Description Area below form if needed -->
    </div>
  </div>

  <script>
    var productVariants = {{ product.variants | json }};
    function updateVariant(radio) {
      if(!radio.checked) return;
      
      var index = radio.getAttribute('data-option-index');
      var displayElement = document.getElementById('OptionValue-' + index);
      if(displayElement) displayElement.textContent = radio.value;

      var checkedOptions = Array.from(document.querySelectorAll('#ProductForm input[type="radio"]:checked')).map(r => r.value);
      var currentVariant = productVariants.find(v => {
        return checkedOptions.every((val, i) => v.options[i] === val);
      });

      if(currentVariant) {
        document.getElementById('VariantSelector').value = currentVariant.id;
        var priceFormatter = new Intl.NumberFormat('en-US', { style: 'currency', currency: '{{ cart.currency.iso_code }}' });
        document.getElementById('ProductPrice').textContent = priceFormatter.format(currentVariant.price / 100);
        var newUrl = new URL(window.location.href);
        newUrl.searchParams.set('variant', currentVariant.id);
        window.history.replaceState({}, '', newUrl);
        
        // Option to switch to variant image if it exists
        if(currentVariant.featured_media) {
            var mediaUrl = currentVariant.featured_media.preview_image.src;
            // Hacky quick extraction since src is full URL form, but Liquid passes object. 
            // In a real scenario we'd use Shopify JS API properly.
        }
      }
    }
  </script>
</section>

{% schema %}
{
  "name": "Product Main",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Product Main Feature"
    }
  ]
}
{% endschema %}
