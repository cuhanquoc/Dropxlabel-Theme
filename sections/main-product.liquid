<style>
  /* ─────────────────────────────────────────
     MAIN PRODUCT — Quiet Luxury Edition
  ───────────────────────────────────────── */

  /* Image stack item */
  .product-image-item {
    width: 100%;
    display: block;
    border-radius: 8px;
    overflow: hidden;
    background-color: #f5f4f1;
  }

  .product-image-item img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-image-item:hover img {
    transform: scale(1.025);
  }

  /* Breadcrumb */
  .product-breadcrumb {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    color: var(--color-muted);
    text-transform: uppercase;
    text-decoration: none;
  }

  .product-breadcrumb:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  /* Vendor tag */
  .product-vendor {
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  /* Product title */
  .product-title {
    font-family: var(--font-heading);
    font-size: clamp(1.7rem, 2.8vw, 2.5rem);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  /* Price */
  .product-price {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: 0.04em;
  }

  .product-price-compare {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--color-muted);
    text-decoration: line-through;
    margin-left: 0.6rem;
  }

  /* Option label */
  .option-label {
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text);
    font-weight: 500;
  }

  /* Size buttons */
  .size-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 48px;
    height: 48px;
    padding: 0 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: var(--color-text);
    background: transparent;
    cursor: pointer;
    transition: border-color 250ms ease, background-color 250ms ease, color 250ms ease;
  }

  .size-btn:hover,
  .size-btn.active {
    border-color: var(--color-text);
    background-color: var(--color-text);
    color: var(--color-bg);
  }

  .size-btn.unavailable {
    opacity: 0.35;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  /* Color swatch */
  .color-swatch {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 250ms ease, transform 250ms ease;
    position: relative;
  }

  .color-swatch:hover,
  .color-swatch.active {
    border-color: var(--color-text);
    transform: scale(1.1);
  }

  .color-swatch::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid transparent;
    transition: border-color 250ms ease;
  }

  .color-swatch.active::after {
    border-color: var(--color-text);
  }

  /* Quantity selector */
  .qty-btn {
    width: 40px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text);
    cursor: pointer;
    font-size: 1.1rem;
    transition: background-color 200ms ease;
    user-select: none;
  }

  .qty-btn:hover {
    background-color: var(--color-border);
  }

  .qty-input {
    width: 52px;
    height: 48px;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    border-left: none;
    border-right: none;
    text-align: center;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text);
    background: transparent;
    outline: none;
  }

  /* Add to Cart button */
  .btn-add-to-cart {
    width: 100%;
    height: 60px;
    background-color: var(--color-text);
    color: var(--color-bg);
    border: 2px solid var(--color-text);
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 0.68rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 350ms ease, color 350ms ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .btn-add-to-cart:hover {
    background-color: transparent;
    color: var(--color-text);
  }

  .btn-add-to-cart:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* Accordion details (Description/Materials) */
  .product-accordion {
    border-top: 1px solid var(--color-border);
  }

  .product-accordion-item {
    border-bottom: 1px solid var(--color-border);
  }

  .product-accordion-trigger {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.1rem 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .product-accordion-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 400ms cubic-bezier(0.16, 1, 0.3, 1),
                padding 300ms ease;
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.8;
    color: var(--color-muted);
  }

  .product-accordion-body.open {
    max-height: 400px;
    padding-bottom: 1.25rem;
  }

  /* Accordion icon rotate */
  .accordion-icon {
    transition: transform 300ms ease;
    flex-shrink: 0;
  }

  .product-accordion-trigger[aria-expanded="true"] .accordion-icon {
    transform: rotate(45deg);
  }

  /* Wishlist button */
  .btn-wishlist {
    width: 60px;
    height: 60px;
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    cursor: pointer;
    color: var(--color-text);
    transition: background-color 250ms ease, border-color 250ms ease, color 250ms ease;
    flex-shrink: 0;
  }

  .btn-wishlist:hover {
    background-color: var(--color-text);
    border-color: var(--color-text);
    color: var(--color-bg);
  }
</style>

{%- comment -%}
  ─────────────────────────────────────────
  MAIN PRODUCT SECTION
  Used in: templates/product.json
  ─────────────────────────────────────────
{%- endcomment -%}

<div
  id="main-product"
  class="max-w-screen-xl mx-auto px-6 md:px-10 py-12"
  data-product-id="{{ product.id }}"
>

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="mb-8 flex items-center gap-2">
    <a href="{{ routes.root_url }}" class="product-breadcrumb">Home</a>
    <span style="color: var(--color-border); font-size: 0.65rem;">›</span>
    <a href="{{ product.collections.first.url | default: routes.collections_url }}" class="product-breadcrumb">
      {{ product.collections.first.title | default: 'Catalog' }}
    </a>
    <span style="color: var(--color-border); font-size: 0.65rem;">›</span>
    <span style="font-family: var(--font-body); font-size: 0.65rem; letter-spacing: 0.14em; color: var(--color-text); text-transform: uppercase;">
      {{ product.title }}
    </span>
  </nav>

  <!-- ══════════════════════════════════════════
       Main 2-Column Grid: 60% Images / 40% Info
  ══════════════════════════════════════════ -->
  <div class="grid md:grid-cols-5 gap-10 md:gap-16">

    <!-- ── LEFT: Image Stack (60% = 3/5 cols) ── -->
    <div class="md:col-span-3">
      <div class="flex flex-col gap-5">

        {% for image in product.images %}
          <div class="product-image-item">
            <img
              src="{{ image | image_url: width: 1200 }}"
              alt="{{ image.alt | default: product.title | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="{{ image.width }}"
              height="{{ image.height }}"
            />
          </div>
        {% else %}
          <!-- Fallback if no images -->
          <div class="product-image-item" style="aspect-ratio: 3/4; background-color: var(--color-border);"></div>
        {% endfor %}

      </div>
    </div>
    <!-- / Left Column -->

    <!-- ── RIGHT: Product Info (40% = 2/5 cols) — STICKY ── -->
    <div class="md:col-span-2">
      <div class="sticky top-10">

        {%- form 'product', product, id: 'product-form', novalidate: 'novalidate' -%}
          <!-- Hidden variant input -->
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" id="selected-variant-id" />

          <!-- Vendor -->
          {% if product.vendor != blank %}
            <p class="product-vendor mb-3">{{ product.vendor }}</p>
          {% endif %}

          <!-- Title -->
          <h1 class="product-title mb-5">{{ product.title }}</h1>

          <!-- Price -->
          <div class="flex items-baseline gap-1 mb-8">
            <span class="product-price" id="product-price">
              {{ product.selected_or_first_available_variant.price | money }}
            </span>
            {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
              <span class="product-price-compare">
                {{ product.selected_or_first_available_variant.compare_at_price | money }}
              </span>
            {% endif %}
          </div>

          <!-- Thin divider -->
          <div style="height: 1px; background-color: var(--color-border); margin-bottom: 2rem;"></div>

          <!-- ── Variant Options ── -->
          {% unless product.has_only_default_variant %}
            {% for option in product.options_with_values %}

              {%- assign option_name_lower = option.name | downcase -%}
              <div class="mb-7">

                <!-- Option Label + selected value -->
                <div class="flex items-center justify-between mb-3">
                  <p class="option-label">{{ option.name }}</p>
                  <p style="font-family: var(--font-body); font-size: 0.75rem; color: var(--color-muted);" id="selected-{{ option.name | handleize }}">
                    {{ option.selected_value }}
                  </p>
                </div>

                {% if option_name_lower == 'color' or option_name_lower == 'colour' or option_name_lower == 'màu' %}
                  <!-- Color Swatches -->
                  <div class="flex flex-wrap gap-3" role="radiogroup" aria-label="{{ option.name }}">
                    {% for value in option.values %}
                      {%- assign swatch_color = value | downcase | replace: ' ', '-' -%}
                      <button
                        type="button"
                        class="color-swatch {% if value == option.selected_value %}active{% endif %}"
                        style="background-color: {{ value | downcase }};"
                        title="{{ value }}"
                        aria-label="{{ value }}"
                        data-option-position="{{ option.position }}"
                        data-option-value="{{ value }}"
                        onclick="selectOption(this, '{{ option.name | escape }}', '{{ value | escape }}')"
                      ></button>
                    {% endfor %}
                  </div>

                {% else %}
                  <!-- Size / Generic Option Buttons -->
                  <div class="flex flex-wrap gap-2" role="radiogroup" aria-label="{{ option.name }}">
                    {% for value in option.values %}
                      <button
                        type="button"
                        class="size-btn {% if value == option.selected_value %}active{% endif %}"
                        data-option-position="{{ option.position }}"
                        data-option-value="{{ value }}"
                        aria-label="{{ option.name }}: {{ value }}"
                        onclick="selectOption(this, '{{ option.name | escape }}', '{{ value | escape }}')"
                      >
                        {{ value }}
                      </button>
                    {% endfor %}
                  </div>
                {% endif %}

              </div>
            {% endfor %}
          {% endunless %}

          <!-- ── Quantity + Add to Cart ── -->
          <div class="mb-5">
            <!-- Quantity Selector -->
            <div class="flex items-center mb-4">
              <p class="option-label mr-5" style="white-space:nowrap;">Quantity</p>
              <div class="flex" style="border: 1px solid var(--color-border); border-radius: 8px; overflow: hidden;">
                <button
                  type="button"
                  class="qty-btn"
                  aria-label="Decrease quantity"
                  onclick="adjustQty(-1)"
                >−</button>
                <input
                  id="qty-input"
                  type="number"
                  name="quantity"
                  value="1"
                  min="1"
                  class="qty-input"
                  aria-label="Product quantity"
                />
                <button
                  type="button"
                  class="qty-btn"
                  aria-label="Increase quantity"
                  onclick="adjustQty(1)"
                >+</button>
              </div>
            </div>

            <!-- Add to Cart + Wishlist row -->
            <div class="flex gap-3">
              <button
                type="submit"
                name="add"
                id="add-to-cart-btn"
                class="btn-add-to-cart"
                {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
                  <path d="M3 6h18"/>
                  <path d="M16 10a4 4 0 0 1-8 0"/>
                </svg>
                {% if product.selected_or_first_available_variant.available %}
                  Add to Cart
                {% else %}
                  Sold Out
                {% endif %}
              </button>

              <!-- Wishlist -->
              <button
                type="button"
                class="btn-wishlist"
                aria-label="Add to wishlist"
                onclick="this.querySelector('svg').style.fill='currentColor'; this.classList.toggle('wishlisted');"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- ── Product Accordion (Description + Material) ── -->
          <div class="product-accordion mt-8">

            <!-- Description -->
            <div class="product-accordion-item">
              <button
                type="button"
                class="product-accordion-trigger"
                aria-expanded="true"
                onclick="toggleAccordion(this)"
              >
                <span>Description</span>
                <svg class="accordion-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 5v14M5 12h14"/>
                </svg>
              </button>
              <div class="product-accordion-body open">
                {% if product.description != blank %}
                  {{ product.description }}
                {% else %}
                  <p>{{ product.title }} — curated with intention, crafted for permanence.</p>
                {% endif %}
              </div>
            </div>

            <!-- Materials -->
            <div class="product-accordion-item">
              <button
                type="button"
                class="product-accordion-trigger"
                aria-expanded="false"
                onclick="toggleAccordion(this)"
              >
                <span>Materials & Care</span>
                <svg class="accordion-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 5v14M5 12h14"/>
                </svg>
              </button>
              <div class="product-accordion-body">
                {% assign material_meta = product.metafields.custom.materials %}
                {% if material_meta != blank %}
                  <p>{{ material_meta }}</p>
                {% else %}
                  <p>
                    Composition varies by style — refer to garment label for fibre content.
                    Gentle hand wash or dry clean recommended to preserve the integrity of the fabric.
                  </p>
                {% endif %}
              </div>
            </div>

          </div>
          <!-- / Product Accordion -->

        {%- endform -%}

      </div>
    </div>
    <!-- / Right Column -->

  </div>
</div>


<script>
  /* ─────────────────────────────────────────────────
     MAIN PRODUCT — Variant Selection & UI Logic
  ───────────────────────────────────────────────── */

  const productData = {{ product.variants | json }};

  /* ── Quantity adjust ── */
  function adjustQty(delta) {
    const input = document.getElementById('qty-input');
    const next  = Math.max(1, parseInt(input.value || 1) + delta);
    input.value = next;
  }

  /* ── Option select ── */
  function selectOption(el, optionName, value) {
    /* Highlight active button/swatch */
    const group = el.closest('[role="radiogroup"]');
    group.querySelectorAll('.size-btn, .color-swatch').forEach(b => b.classList.remove('active'));
    el.classList.add('active');

    /* Update displayed selected value label */
    const label = document.getElementById('selected-' + optionName.toLowerCase().replace(/\s+/g, '-'));
    if (label) label.textContent = value;

    /* Find matching variant */
    updateSelectedVariant();
  }

  function updateSelectedVariant() {
    /* Collect current selections from all active buttons */
    const selected = {};
    document.querySelectorAll('[data-option-position]').forEach(el => {
      if (el.classList.contains('active')) {
        selected[parseInt(el.dataset.optionPosition)] = el.dataset.optionValue;
      }
    });

    /* Match to a variant */
    const match = productData.find(v =>
      Object.entries(selected).every(([pos, val]) => v['option' + pos] === val)
    );

    if (match) {
      document.getElementById('selected-variant-id').value = match.id;
      /* Update price */
      const priceEl = document.getElementById('product-price');
      if (priceEl) {
        priceEl.textContent = (match.price / 100).toLocaleString('vi-VN') + '₫';
      }
      /* Update add to cart state */
      const btn = document.getElementById('add-to-cart-btn');
      if (btn) {
        btn.disabled = !match.available;
        btn.querySelector('span') || (btn.lastChild.textContent = match.available ? ' Add to Cart' : ' Sold Out');
      }
    }
  }

  /* ── Product accordion ── */
  function toggleAccordion(trigger) {
    const body     = trigger.nextElementSibling;
    const isOpen   = trigger.getAttribute('aria-expanded') === 'true';
    trigger.setAttribute('aria-expanded', !isOpen);
    body.classList.toggle('open', !isOpen);
  }
</script>
