{% endif %}

{% render 'product-reviews', product: product %}

<script>
  /* ─────────────────────────────────────────────────
     MAIN PRODUCT — Variant Selection & UI Logic
  ───────────────────────────────────────────────── */

  const productData = [
  {% for v in product.variants %}
    {
      id: {{ v.id }},
      title: {{ v.title | json }},
      option1: {{ v.option1 | json }},
      option2: {{ v.option2 | json }},
      option3: {{ v.option3 | json }},
      price: {{ v.price }},
      compare_at_price: {{ v.compare_at_price | default: 'null' }},
      available: {{ v.available }},
      inventory_management: {{ v.inventory_management | json }},
      inventory_quantity: {{ v.inventory_quantity | default: 0 }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
  ];

  /* ── Quantity adjust ── */
  function adjustQty(delta) {
    const input = document.getElementById('qty-input');
    const next  = Math.max(1, parseInt(input.value || 1) + delta);
    input.value = next;
  }

  /* ── Option select ── */
  function selectOption(el, optionName, value) {
    const group = el.closest('[role="radiogroup"]');
    group.querySelectorAll('.size-btn, .color-swatch').forEach(b => {
      b.classList.remove('active');
      b.classList.remove('size-pop');
    });
    el.classList.add('active');

    if (el.classList.contains('size-btn')) {
      el.classList.add('size-pop');
      el.addEventListener('animationend', function handler() {
        el.classList.remove('size-pop');
        el.removeEventListener('animationend', handler);
      });
    }

    const label = document.getElementById('selected-' + optionName.toLowerCase().replace(/\s+/g, '-'));
    if (label) label.textContent = value.toUpperCase();

    updateSelectedVariant();
  }

  function updateSelectedVariant() {
    /* Collect current selections */
    const selected = {};
    document.querySelectorAll('[data-option-position]').forEach(el => {
      if (el.classList.contains('active')) {
        selected[parseInt(el.dataset.optionPosition)] = el.dataset.optionValue;
      }
    });

    /* Match to a variant */
    const match = productData.find(v =>
      Object.entries(selected).every(([pos, val]) => v['option' + pos] === val)
    );

    if (match) {
      document.getElementById('selected-variant-id').value = match.id;
      
      /* Update price */
      const priceEl = document.getElementById('product-price');
      if (priceEl) priceEl.innerHTML = (match.price / 100).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + ' {{ shop.currency }}';
      
      /* Update compare at price if exists */
      const compareEl = document.querySelector('.product-price-compare');
      if (compareEl && match.compare_at_price) {
        compareEl.innerHTML = (match.compare_at_price / 100).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + ' {{ shop.currency }}';
        compareEl.style.display = 'inline';
      } else if (compareEl) {
        compareEl.style.display = 'none';
      }
      
      /* Update add to cart state */
      const btn = document.getElementById('add-to-cart-btn');
      if (btn) {
        btn.disabled = !match.available;
        btn.innerHTML = match.available ? 'Add to Cart' : 'Sold Out';
      }

      /* Update stock text natively */
      const stockEl = document.getElementById('variant-stock-display');
      const stockIcon = document.getElementById('variant-stock-icon');
      if (stockEl && stockIcon) {
        if (match.inventory_management && match.inventory_quantity > 0) {
          stockEl.textContent = match.inventory_quantity + ' in stock';
          stockIcon.setAttribute('fill', '#00a82d');
          stockIcon.style.color = '#00a82d';
          stockEl.style.color = '#111';
        } else if (match.available) {
          stockEl.textContent = 'In stock';
          stockIcon.setAttribute('fill', '#00a82d');
          stockIcon.style.color = '#00a82d';
          stockEl.style.color = '#111';
        } else {
          stockEl.textContent = 'Out of stock';
          stockIcon.setAttribute('fill', '#888');
          stockIcon.style.color = '#888';
          stockEl.style.color = '#888';
        }
      }
    }
  }

  /* ── Product accordion ── */
  function toggleAccordion(trigger) {
    const allTriggers = document.querySelectorAll('.product-accordion-trigger');
    const allBodies = document.querySelectorAll('.product-accordion-body');
    const body     = trigger.nextElementSibling;
    const isOpen   = trigger.getAttribute('aria-expanded') === 'true';

    // Close all blocks first
    allTriggers.forEach(t => t.setAttribute('aria-expanded', 'false'));
    allBodies.forEach(b => b.classList.remove('open'));

    // Open clicked block if it wasn't open already
    if (!isOpen) {
      trigger.setAttribute('aria-expanded', 'true');
      body.classList.add('open');
    }
  }

  /* ─────────────────────────────────────────────────
     AJAX ADD TO CART
  ───────────────────────────────────────────────── */
  (function () {
    const form   = document.getElementById('product-form');
    const btn    = document.getElementById('add-to-cart-btn');
    if (!form || !btn) return;

    function setBtnLoading() {
      btn.disabled = true;
      btn.style.opacity = '0.65';
      btn.innerHTML = 'Adding...';
    }

    function setBtnSuccess() {
      btn.innerHTML = 'Added!';
      btn.style.opacity = '1';
      btn.disabled = false;
      setTimeout(resetBtn, 1600);
    }

    function setBtnError(msg) {
      btn.innerHTML = msg || 'Try again';
      btn.style.opacity = '1';
      btn.disabled = false;
      setTimeout(resetBtn, 2000);
    }

    function resetBtn() {
      btn.innerHTML = 'Add to Cart';
      btn.disabled  = false;
      btn.style.opacity = '1';
    }

    function refreshCartCount() {
      fetch('/cart.js')
        .then(r => r.json())
        .then(cart => {
          const countEl = document.getElementById('cd-count');
          if (countEl) {
            const n = cart.item_count;
            countEl.textContent = n + (n === 1 ? ' item' : ' items');
          }
          document.querySelectorAll('.cart-count').forEach(el => {
            el.textContent = cart.item_count;
            el.style.display = cart.item_count > 0 ? '' : 'none';
          });
          const subtotalEl = document.getElementById('cd-subtotal');
          if (subtotalEl) {
            subtotalEl.textContent = (cart.total_price / 100).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + ' {{ shop.currency }}';
          }
        })
        .catch(() => {});
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      const variantId = document.getElementById('selected-variant-id')?.value;
      const quantity  = parseInt(document.getElementById('qty-input')?.value || 1);

      if (!variantId) { form.submit(); return; }

      setBtnLoading();

      fetch('/cart/add.js', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: parseInt(variantId), quantity: quantity }),
      })
      .then(async r => {
        if (!r.ok) {
          const err = await r.json().catch(() => ({}));
          throw new Error(err.description || 'Could not add item');
        }
        return r.json();
      })
      .then(() => {
        setBtnSuccess();
        refreshCartCount();

        if (typeof window.CartDrawer !== 'undefined') {
          window.CartDrawer.open();
        }
      })
      .catch(err => {
        setBtnError(err.message);
      });
    });
  })();

  /* ── Pairs Well With Carousel ── */
  function updatePairsArrows(track) {
    if (!track) return;
    const THRESHOLD = 1; // px — tolerates floating-point rounding
    const atStart = track.scrollLeft <= THRESHOLD;
    const atEnd   = track.scrollLeft + track.clientWidth >= track.scrollWidth - THRESHOLD;

    // Scope buttons to this track's parent container only
    const container = track.parentElement;
    if (!container) return;
    const btnLeft  = container.querySelector('[data-carousel-dir="-1"]');
    const btnRight = container.querySelector('[data-carousel-dir="1"]');

    if (btnLeft)  btnLeft.style.backgroundColor  = atStart ? '#888888' : '#000000';
    if (btnRight) btnRight.style.backgroundColor = atEnd   ? '#888888' : '#000000';
  }

  function scrollPairsCarousel(dir) {
    const track = document.getElementById('pairs-carousel-track');
    if (!track) return;
    const card = track.querySelector('.pairs-card');
    const scrollAmt = card ? card.offsetWidth + 12 : 200;
    track.scrollBy({ left: dir * scrollAmt, behavior: 'smooth' });
    // Arrow state update is handled by the scroll event listener below
  }

  /* Wire scroll + resize listeners once DOM is ready */
  (function initPairsCarouselArrows() {
    const track = document.getElementById('pairs-carousel-track');
    if (!track) return;

    // Initial state
    updatePairsArrows(track);

    // Update on scroll (fires during smooth scroll too)
    track.addEventListener('scroll', function () {
      updatePairsArrows(track);
    }, { passive: true });

    // Update on resize (viewport change can affect clientWidth / scrollWidth)
    window.addEventListener('resize', function () {
      updatePairsArrows(track);
    }, { passive: true });
  })();

  /* ─────────────────────────────────────────────────
     EVENT DELEGATION — replaces all inline handlers
  ───────────────────────────────────────────────── */
  document.addEventListener('click', function (e) {
    /* Size chart open */
    const openBtn = e.target.closest('[data-action="open-size-chart"]');
    if (openBtn) {
      const modal = document.getElementById('size-chart-modal');
      if (modal) modal.showModal();
      return;
    }

    /* Size chart close */
    const closeBtn = e.target.closest('[data-action="close-size-chart"]');
    if (closeBtn) {
      const modal = document.getElementById('size-chart-modal');
      if (modal) modal.close();
      return;
    }

    /* Option buttons (swatches & text) */
    const optBtn = e.target.closest('[data-option-position][data-option-value]');
    if (optBtn) {
      const optionName = optBtn.getAttribute('aria-label')
        ? null
        : null; /* resolved via dataset below */
      const pos   = optBtn.dataset.optionPosition;
      const value = optBtn.dataset.optionValue;
      /* derive option name from the nearest radiogroup legend / label span */
      const group = optBtn.closest('[role="radiogroup"]');
      let oName = '';
      if (group) {
        const nameEl = group.parentElement.querySelector('[id^="selected-"]');
        if (nameEl) oName = nameEl.id.replace('selected-', '').replace(/-/g, ' ');
      }
      selectOption(optBtn, oName, value);
      return;
    }

    /* Quantity buttons */
    const qtyBtn = e.target.closest('[data-qty-btn]');
    if (qtyBtn) {
      adjustQty(parseInt(qtyBtn.dataset.qtyBtn, 10));
      return;
    }

    /* Wishlist toggle */
    const wishBtn = e.target.closest('.btn-wishlist');
    if (wishBtn) {
      const svg = wishBtn.querySelector('svg');
      wishBtn.classList.toggle('wishlisted');
      if (svg) svg.style.fill = wishBtn.classList.contains('wishlisted') ? 'currentColor' : 'none';
      return;
    }

    /* Carousel navigation buttons */
    const carouselBtn = e.target.closest('[data-carousel-dir]');
    if (carouselBtn) {
      scrollPairsCarousel(parseInt(carouselBtn.dataset.carouselDir, 10));
      return;
    }

    /* Thumbnail buttons — update main product image */
    const thumbBtn = e.target.closest('[data-thumb-url]');
    if (thumbBtn) {
      const main = document.getElementById('ProductMainImage');
      if (main) main.src = thumbBtn.dataset.thumbUrl;
      return;
    }

    /* Accordion triggers */
    const accordionBtn = e.target.closest('.product-accordion-trigger');
    if (accordionBtn) {
      toggleAccordion(accordionBtn);
      return;
    }
  });

  /* Hover opacity for carousel nav buttons */
  document.addEventListener('mouseover', function (e) {
    const btn = e.target.closest('[data-carousel-dir]');
    if (btn) btn.style.opacity = '0.8';
  });
  document.addEventListener('mouseout', function (e) {
    const btn = e.target.closest('[data-carousel-dir]');
    if (btn) btn.style.opacity = '1';
  });

  /* Hover background for text-option buttons */
  document.addEventListener('mouseover', function (e) {
    const btn = e.target.closest('[data-option-value]');
    if (btn && !btn.classList.contains('active') && btn.classList.contains('size-btn')) {
      btn.style.backgroundColor = '#f5f5f5';
    }
  });
  document.addEventListener('mouseout', function (e) {
    const btn = e.target.closest('[data-option-value]');
    if (btn && !btn.classList.contains('active') && btn.classList.contains('size-btn')) {
      btn.style.backgroundColor = 'transparent';
    }
  });
</script>

{%- comment -%}── Product Image Lightbox ────────────────────────────────────{%- endcomment -%}

<style>
/* ── Lightbox overlay ─────────────────────────────────── */
.pxl-lightbox {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.88);

  /* enter: invisible + slightly-zoomed-in */
  opacity: 0;
  pointer-events: none;
  transition: opacity .28s ease;
}
.pxl-lightbox.pxl-is-open {
  opacity: 1;
  pointer-events: all;
}

/* ── Inner image wrapper ──────────────────────────────── */
.pxl-lightbox__inner {
  position: relative;
  max-width: min(90vw, 900px);
  max-height: 92vh;
  transform: scale(.92);
  transition: transform .28s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pxl-lightbox.pxl-is-open .pxl-lightbox__inner {
  transform: scale(1);
}

/* ── Main image ───────────────────────────────────────── */
.pxl-lightbox__img {
  max-width: 100%;
  max-height: 92vh;
  object-fit: contain;
  border-radius: 4px;
  display: block;
  user-select: none;
  -webkit-user-drag: none;
  /* crossfade between images */
  transition: opacity .18s ease;
}
.pxl-lightbox__img.pxl-img-fade {
  opacity: 0;
}

/* ── Close button ─────────────────────────────────────── */
.pxl-lightbox__close {
  position: fixed;
  top: 1.2rem;
  right: 1.4rem;
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: rgba(255,255,255,.15);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  transition: background .18s ease, transform .15s ease;
  z-index: 1;
}
.pxl-lightbox__close:hover,
.pxl-lightbox__close:focus-visible {
  background: rgba(255,255,255,.32);
  transform: scale(1.12);
  outline: 2px solid rgba(255,255,255,.6);
  outline-offset: 2px;
}

/* ── Prev / Next buttons ──────────────────────────────── */
.pxl-lightbox__nav {
  position: fixed;
  top: 50%;
  transform: translateY(-50%);
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: rgba(255,255,255,.15);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  z-index: 1;
  transition: background .18s ease, transform .15s ease;
}
.pxl-lightbox__nav:hover,
.pxl-lightbox__nav:focus-visible {
  background: rgba(255,255,255,.32);
  transform: translateY(-50%) scale(1.12);
  outline: 2px solid rgba(255,255,255,.6);
  outline-offset: 2px;
}
.pxl-lightbox__prev { left: 1.2rem; }
.pxl-lightbox__next { right: 1.2rem; }
.pxl-lightbox__nav.pxl-nav-hidden { display: none; }

/* ── Counter ──────────────────────────────────────────── */
.pxl-lightbox__counter {
  position: fixed;
  bottom: 1.2rem;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255,255,255,.7);
  font-size: .85rem;
  pointer-events: none;
  letter-spacing: .04em;
}

/* ── Main image clickable cursor ──────────────────────── */
#ProductMainImage,
.product-thumbnail-btn img {
  cursor: zoom-in;
}
</style>

{%- comment -%} Lightbox dialog HTML — rendered once per section {%- endcomment -%}
<div
  id="pxl-lightbox-{{ section.id }}"
  class="pxl-lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Product image preview"
  tabindex="-1"
>
  <button class="pxl-lightbox__close" aria-label="Close preview">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M3 3l14 14M17 3L3 17" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
    </svg>
  </button>

  <button class="pxl-lightbox__nav pxl-lightbox__prev" aria-label="Previous image">
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
      <path d="M11 14L6 9l5-5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="pxl-lightbox__inner" aria-live="polite">
    <img class="pxl-lightbox__img" src="" alt="Product preview" draggable="false">
  </div>

  <button class="pxl-lightbox__nav pxl-lightbox__next" aria-label="Next image">
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
      <path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <span class="pxl-lightbox__counter" aria-hidden="true"></span>
</div>

<script>
/* ── Product Lightbox — idempotent init ────────────────── */
(function initProductLightbox() {
  /* Guard: don't bind twice (Shopify Theme Editor re-renders the <script>) */
  const INIT_KEY = 'pxl-lb-{{ section.id }}';
  if (window[INIT_KEY]) return;
  window[INIT_KEY] = true;

  /* ── Elements ─────────────────────────────────────────── */
  const lb       = document.getElementById('pxl-lightbox-{{ section.id }}');
  if (!lb) return;

  const lbImg    = lb.querySelector('.pxl-lightbox__img');
  const lbClose  = lb.querySelector('.pxl-lightbox__close');
  const lbPrev   = lb.querySelector('.pxl-lightbox__prev');
  const lbNext   = lb.querySelector('.pxl-lightbox__next');
  const lbCtr    = lb.querySelector('.pxl-lightbox__counter');

  /* ── State ────────────────────────────────────────────── */
  let images        = [];  /* [{ src, alt }] */
  let currentIndex  = 0;
  let triggerEl     = null;  /* element that opened the lightbox */

  /* ── Collect all gallery images (main + thumbs) ──────── */
  function collectImages() {
    const list = [];
    /* Main image */
    const mainImg = document.getElementById('ProductMainImage');
    if (mainImg && mainImg.src) {
      list.push({ src: mainImg.src, alt: mainImg.alt || 'Product image' });
    }
    /* Thumbnails — each has data-thumb-url pointing to 1200px version */
    document.querySelectorAll('[data-thumb-url]').forEach(function (btn) {
      const url = btn.dataset.thumbUrl;
      const alt = btn.querySelector('img') ? btn.querySelector('img').alt : 'Product image';
      if (url) list.push({ src: url, alt: alt });
    });
    return list;
  }

  /* ── Show image at index ──────────────────────────────── */
  function showImage(idx) {
    if (!images.length) return;
    currentIndex = (idx + images.length) % images.length;

    /* Crossfade */
    lbImg.classList.add('pxl-img-fade');
    setTimeout(function () {
      lbImg.src = images[currentIndex].src;
      lbImg.alt = images[currentIndex].alt;
      lbImg.classList.remove('pxl-img-fade');
    }, 130);

    /* Counter */
    if (images.length > 1) {
      lbCtr.textContent = (currentIndex + 1) + ' / ' + images.length;
    } else {
      lbCtr.textContent = '';
    }

    /* Nav visibility */
    if (images.length <= 1) {
      lbPrev.classList.add('pxl-nav-hidden');
      lbNext.classList.add('pxl-nav-hidden');
    } else {
      lbPrev.classList.remove('pxl-nav-hidden');
      lbNext.classList.remove('pxl-nav-hidden');
    }
  }

  /* ── Open ─────────────────────────────────────────────── */
  function openLightbox(idx, trigger) {
    images = collectImages();
    triggerEl = trigger || null;
    currentIndex = idx || 0;

    showImage(currentIndex);

    lb.classList.add('pxl-is-open');
    document.body.style.overflow = 'hidden';

    /* Move focus into modal */
    lb.focus();
  }

  /* ── Close ────────────────────────────────────────────── */
  function closeLightbox() {
    lb.classList.remove('pxl-is-open');
    document.body.style.overflow = '';

    /* Return focus to trigger */
    if (triggerEl) {
      triggerEl.focus();
      triggerEl = null;
    }
  }

  /* ── Event: close button ──────────────────────────────── */
  lbClose.addEventListener('click', closeLightbox);

  /* ── Event: backdrop click ────────────────────────────── */
  lb.addEventListener('click', function (e) {
    if (e.target === lb) closeLightbox();
  });

  /* ── Event: prev / next ───────────────────────────────── */
  lbPrev.addEventListener('click', function (e) {
    e.stopPropagation();
    showImage(currentIndex - 1);
  });
  lbNext.addEventListener('click', function (e) {
    e.stopPropagation();
    showImage(currentIndex + 1);
  });

  /* ── Event: keyboard ──────────────────────────────────── */
  document.addEventListener('keydown', function (e) {
    if (!lb.classList.contains('pxl-is-open')) return;

    if (e.key === 'Escape')        { closeLightbox(); return; }
    if (e.key === 'ArrowRight')    { showImage(currentIndex + 1); return; }
    if (e.key === 'ArrowLeft')     { showImage(currentIndex - 1); return; }

    /* Focus trap */
    if (e.key === 'Tab') {
      const focusable = Array.from(lb.querySelectorAll(
        'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
      )).filter(function (el) { return !el.disabled && el.offsetParent !== null; });
      if (!focusable.length) { e.preventDefault(); return; }
      const first = focusable[0];
      const last  = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault(); last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault(); first.focus();
      }
    }
  });

  /* ── Wire: main image click ───────────────────────────── */
  const mainImgEl = document.getElementById('ProductMainImage');
  if (mainImgEl) {
    mainImgEl.style.cursor = 'zoom-in';
    mainImgEl.addEventListener('click', function (e) {
      /* Main image is always index 0 in our list */
      openLightbox(0, mainImgEl);
    });
  }

  /* ── Wire: thumbnail click → open at correct index ────── */
  document.querySelectorAll('[data-thumb-url]').forEach(function (btn, i) {
    btn.addEventListener('click', function (e) {
      /* Thumbs: in gallery list, they start at index 1 (after main image) */
      openLightbox(i + 1, btn);
    });
  });

})();
</script>





