                  {% if option_name_lower == 'color' or option_name_lower == 'colour' or option_name_lower == 'màu' %}
                    <!-- Color Swatches -->
                    <div class="flex flex-wrap gap-2" role="radiogroup" aria-label="{{ option.name }}">
                      {% for value in option.values %}
                        {%- assign swatch_color = value | downcase | replace: ' ', '-' -%}
                        <button
                          type="button"
                          class="color-swatch {% if value == option.selected_value %}active{% endif %}"
                          style="background-color: {{ value | downcase }}; border: 1px solid #ddd;"
                          title="{{ value }}"
                          aria-label="{{ value }}"
                          data-option-position="{{ option.position }}"
                          data-option-value="{{ value }}"
                        ></button>
                      {% endfor %}
                    </div>

                  {% else %}
                    <!-- Size / Generic Option Buttons -->
                    <div class="flex flex-wrap gap-2" role="radiogroup" aria-label="{{ option.name }}">
                      {% for value in option.values %}
                        <button
                          type="button"
                          class="size-btn {% if value == option.selected_value %}active{% endif %}"
                          style="min-width: 64px; height: 48px; border: 1px solid #111; border-radius: 4px; font-weight: 500; font-size: 0.95rem; display: flex; align-items: center; justify-content: center; background: transparent; cursor: pointer; transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;"
                          data-option-position="{{ option.position }}"
                          data-option-value="{{ value }}"
                          aria-label="{{ option.name }}: {{ value }}"

                        >
                          {{ value }}
                        </button>
                      {% endfor %}
                    </div>
                    <style>
                      .size-btn.active {
                        background-color: #111 !important;
                        color: #fff !important;
                        border-color: #111 !important;
                      }
                      @keyframes sizePop {
                        0% { transform: scale(1); }
                        40% { transform: scale(0.9); }
                        70% { transform: scale(1.08); }
                        100% { transform: scale(1); }
                      }
                      .size-btn.size-pop {
                        animation: sizePop 0.35s cubic-bezier(0.16, 1, 0.3, 1);
                      }
                    </style>
                  {% endif %}

                </div>
              {% endfor %}
            </div>
          {% endunless %}

          <!-- ── Quantity ── -->
          <div style="margin-bottom: 2rem; padding: 0 1rem; width: 100%; box-sizing: border-box;">
            <p style="font-weight: 700; font-size: 0.95rem; margin-bottom: 0.75rem;">Quantity</p>
            <div style="display: inline-flex; border: 1px solid var(--color-text); border-radius: 6px; overflow: hidden; width: 140px; height: 50px;">
              <button
                type="button"
                style="flex: 1; display: inline-flex; align-items: center; justify-content: center; background: transparent; border: none; cursor: pointer; font-size: 1.5rem; font-weight: 300;"
                aria-label="Decrease quantity"
                data-qty-btn="-1"
              >−</button>
              <input
                id="qty-input"
                type="number"
                name="quantity"
                value="1"
                min="1"
                style="flex: 1; min-width: 0; text-align: center; border: none; font-family: var(--font-body); font-size: 1.1rem; color: var(--color-text); background: transparent; appearance: textfield;"
              />
              <button
                type="button"
                style="flex: 1; display: inline-flex; align-items: center; justify-content: center; background: transparent; border: none; cursor: pointer; font-size: 1.5rem; font-weight: 400;"
                aria-label="Increase quantity"
                data-qty-btn="1"
              >+</button>
            </div>
          </div>

          <!-- ── Stock Indicator (Dynamic) ── -->
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 2rem; font-size: 1.05rem; padding: 0 1rem; width: 100%; box-sizing: border-box;">
            <svg id="variant-stock-icon" width="20" height="20" viewBox="0 0 24 24" fill="#00a82d" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM10 17L5 12L6.41 10.59L10 14.17L17.59 6.58L19 8L10 17Z" fill="currentColor"/>
            </svg>
            <span id="variant-stock-display" style="font-weight: 400;">
              {% assign current_variant = product.selected_or_first_available_variant %}
              {% if current_variant.inventory_management and current_variant.inventory_quantity > 0 %}
                {{ current_variant.inventory_quantity }} in stock
              {% elsif current_variant.available %}
                In stock
              {% else %}
                Out of stock
              {% endif %}
            </span>
          </div>

          <!-- ── Pickup Availability ── -->
          <div style="padding: 0 1rem; width: 100%; box-sizing: border-box; margin-bottom: 2rem;">
            <div style="background-color: #eefbf1; border: 1px solid #d4ebd9; border-radius: 6px; padding: 1.25rem; display: flex; gap: 1rem; align-items: flex-start;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-top: 2px;">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
              <div style="flex: 1;">
                <p style="font-weight: 700; font-size: 0.95rem; margin-bottom: 0.25rem; line-height: 1.3;">
                  {{ section.settings.pickup_title | default: 'Pickup available at California Warehouse' }}
                </p>
                <p style="font-size: 0.9rem; color: #333; margin-bottom: 0.75rem;">
                  {{ section.settings.pickup_time | default: 'Usually ready in 24 hours' }}
                </p>
                <a href="#" style="font-size: 0.85rem; text-decoration: underline; color: var(--color-text);">Check availability at other stores</a>
              </div>
            </div>
          </div>

          <!-- ── Trust Badges ── -->
          <div style="display: flex; gap: 1rem; justify-content: space-between; border-top: 1px solid #eee; border-bottom: 1px solid #eee; padding: 1.5rem 1rem; margin-bottom: 3rem; width: 100%; box-sizing: border-box;">
            <div style="display: flex; align-items: center; gap: 10px;">
               <svg fill="none" height="24" viewBox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.5"><path d="m11.5 5h-7.5c-1.10457 0-2 .89543-2 2v9c0 1.1046.89543 2 2 2h1m6-13h3.5l4 4v5.5c0 1.1046-.8954 2-2 2h-1m-11 0c0 1.1046.89543 2 2 2s2-.8954 2-2m-4 0c0-1.1046.89543-2 2-2s2 .8954 2 2m5 0h2m-4 0c0 1.1046.8954 2 2 2s2-.8954 2-2m-4 0c0-1.1046.8954-2 2-2s2 .8954 2 2m-14-6h17m-17 3h15" stroke-linecap="round" stroke-linejoin="round"/></svg>
               <span style="font-size: 0.95rem;">{{ section.settings.delivery_text | default: 'Free delivery within 2 days' }}</span>
            </div>
            <div style="width: 1px; height: 24px; background-color: #eee;"></div>
            <div style="display: flex; align-items: center; gap: 10px;">
               <svg fill="none" height="24" viewBox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.5"><path d="m3 9a9 9 0 1 0 5-6.5l-3 2"/><path d="m2 2v6h6"/><path d="m9 11v6l3-1.5 3 1.5v-6z" stroke-linecap="round" stroke-linejoin="round"/></svg>
               <span style="font-size: 0.95rem; padding: 2px 4px; border-radius: 4px;">{{ section.settings.returns_text | default: 'Free + easy returns' }}</span>
            </div>
          </div>

          <!-- Add to Cart (Re-styled a bit) -->
          <div class="mb-5 flex gap-3" style="max-width: 100%; box-sizing: border-box; flex-wrap: wrap; padding: 0 1rem;">
            <button
              type="submit"
              name="add"
              id="add-to-cart-btn"
              class="btn-add-to-cart"
              {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
              style="border-radius: 8px; border: 1px solid #111; font-weight: 700; font-size: 0.9rem; letter-spacing: 0em; text-transform: none; flex: 1 1 auto; min-width: 200px; height: 60px; padding: 0 10px; box-sizing: border-box;"
            >
              <span class="atc-bubble" aria-hidden="true"></span>
              <span class="atc-bubble" aria-hidden="true"></span>
              <span class="atc-bubble" aria-hidden="true"></span>
              <span class="atc-bubble" aria-hidden="true"></span>
              <span style="position:relative;z-index:1;">
                {% if product.selected_or_first_available_variant.available %}
                  Add to Cart
                {% else %}
                  Sold Out
                {% endif %}
              </span>
            </button>
            <button
              type="button"
              class="btn-wishlist"
              aria-label="Add to wishlist"

              style="border-radius: 8px; height: 60px; width: 60px; border: 1px solid var(--color-border);"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </button>
          </div>

          <!-- Dynamic Checkout -->
          <div class="mt-3" style="max-width: 100%; overflow: hidden; padding: 0 1rem; box-sizing: border-box;">
            <style>
              .shopify-payment-button__button {
                border-radius: 8px !important;
                min-height: 60px !important;
                max-width: 100% !important;
                box-sizing: border-box !important;
              }
              .shopify-payment-button {
                max-width: 100% !important;
              }
            </style>
            {{ form | payment_button }}
          </div>

          <!-- ── PAIRS WELL WITH Carousel ── -->

          {%- comment -%}
            TAG-BASED PAIRS WELL WITH LOGIC
            ─────────────────────────────────────────────
            Source pool priority:
              1. section.settings.pairs_collection  (if set)
              2. product.collections.first          (fallback)
              3. collections['all']                 (last resort)

            Selection priority:
              Pass 1 – products sharing ≥1 tag with current product.
              Pass 2 – any product from source pool (if pass-1 count < pairs_limit).

            Always excludes the current product and deduplicates.
          {%- endcomment -%}

          {%- assign pairs_limit = section.settings.pairs_limit | default: 6 -%}

          {%- comment -%} ── Step 1: Determine source pool ── {%- endcomment -%}
          {%- if section.settings.pairs_collection != blank -%}
            {%- assign pairs_pool = section.settings.pairs_collection.products -%}
          {%- elsif product.collections.first != blank -%}
            {%- assign pairs_pool = product.collections.first.products -%}
          {%- else -%}
            {%- assign pairs_pool = collections['all'].products -%}
          {%- endif -%}

          {%- comment -%} ── Step 2: Pass 1 – collect tag-matched products ── {%- endcomment -%}
          {%- assign pairs_tagged = '' -%}
          {%- assign pairs_tagged_ids = '' -%}
          {%- assign pairs_tagged_count = 0 -%}

          {%- for candidate in pairs_pool -%}
            {%- if pairs_tagged_count >= pairs_limit -%}{%- break -%}{%- endif -%}
            {%- if candidate.id == product.id -%}{%- continue -%}{%- endif -%}

            {%- comment -%} Check if candidate shares at least one tag {%- endcomment -%}
            {%- assign tag_matched = false -%}
            {%- for current_tag in product.tags -%}
              {%- if candidate.tags contains current_tag -%}
                {%- assign tag_matched = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}

            {%- if tag_matched -%}
              {%- comment -%} Deduplicate by id string {%- endcomment -%}
              {%- assign cid_str = candidate.id | prepend: ',' | append: ',' -%}
              {%- unless pairs_tagged_ids contains cid_str -%}
                {%- assign pairs_tagged_ids = pairs_tagged_ids | append: cid_str -%}
                {%- assign pairs_tagged_count = pairs_tagged_count | plus: 1 -%}
              {%- endunless -%}
            {%- endif -%}
          {%- endfor -%}

          {%- comment -%} ── Step 3: Pass 2 fallback – fill up to pairs_limit ── {%- endcomment -%}
          {%- assign pairs_fallback_ids = pairs_tagged_ids -%}
          {%- assign pairs_fallback_count = pairs_tagged_count -%}

          {%- if pairs_fallback_count < pairs_limit -%}
            {%- for candidate in pairs_pool -%}
              {%- if pairs_fallback_count >= pairs_limit -%}{%- break -%}{%- endif -%}
              {%- if candidate.id == product.id -%}{%- continue -%}{%- endif -%}

              {%- assign cid_str = candidate.id | prepend: ',' | append: ',' -%}
              {%- unless pairs_fallback_ids contains cid_str -%}
                {%- assign pairs_fallback_ids = pairs_fallback_ids | append: cid_str -%}
                {%- assign pairs_fallback_count = pairs_fallback_count | plus: 1 -%}
              {%- endunless -%}
            {%- endfor -%}
          {%- endif -%}

          {%- comment -%} ── Step 4: Render carousel ── {%- endcomment -%}
          {%- if pairs_fallback_count > 0 -%}
          <div style="margin-top: 3.5rem; margin-bottom: 0.5rem; padding: 0 1rem; max-width: 100%; min-width: 0; overflow: hidden; box-sizing: border-box;">
            <!-- Header -->
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem;">
              <h2 style="font-family: var(--font-heading, sans-serif); font-weight: 800; font-size: 1.35rem; letter-spacing: 0em; text-transform: uppercase; margin: 0; color: #000;">{{ section.settings.pairs_heading | default: 'PAIRS WELL WITH' }}</h2>
              <div style="display: flex; gap: 10px;">
                <button type="button" data-carousel-dir="-1" style="width: 36px; height: 36px; border-radius: 50%; background-color: #888888; color: #ffffff; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: opacity 0.2s;">
                  <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
                </button>
                <button type="button" data-carousel-dir="1" style="width: 36px; height: 36px; border-radius: 50%; background-color: #000000; color: #ffffff; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: opacity 0.2s;">
                  <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
                </button>
              </div>
            </div>

            <!-- Carousel Track -->
            <div id="pairs-carousel-track" style="display: flex; gap: 12px; overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none; padding-bottom: 0.5rem; width: 100%; scroll-behavior: smooth;">
              <style>
                #pairs-carousel-track::-webkit-scrollbar { display: none; }
                @media (min-width: 768px) { .pairs-card { flex: 0 0 calc(33.333% - 8px) !important; } }
              </style>

              {%- comment -%} Re-loop source pool, render only ids collected above {%- endcomment -%}
              {%- assign pairs_rendered = 0 -%}
              {%- for p in pairs_pool -%}
                {%- if pairs_rendered >= pairs_limit -%}{%- break -%}{%- endif -%}
                {%- if p.id == product.id -%}{%- continue -%}{%- endif -%}
                {%- assign pid_str = p.id | prepend: ',' | append: ',' -%}
                {%- unless pairs_fallback_ids contains pid_str -%}{%- continue -%}{%- endunless -%}

              <div class="pairs-card" style="scroll-snap-align: start; flex: 0 0 calc(42% - 8px); min-width: 130px;">
                <a href="{{ p.url }}" style="text-decoration: none; color: inherit; display: block;">
                  <div style="background-color: #d1d5db; border-radius: 1.25rem; overflow: hidden; aspect-ratio: 1/1; position: relative; margin-bottom: 0.75rem;">
                    {%- if p.featured_image -%}
                      {{ p.featured_image | image_url: width: 400 | image_tag: alt: p.title, loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;' }}
                    {%- endif -%}
                  </div>
                  <p style="font-family: var(--font-body, sans-serif); font-weight: 700; font-size: 0.85rem; line-height: 1.3; text-align: center; color: #000; margin: 0 0 0.4rem 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; white-space: normal;">{{ p.title }}</p>
                  <p style="font-family: var(--font-body, sans-serif); font-weight: 400; font-size: 0.85rem; text-align: center; color: #000; margin: 0;">{{ p.price | money }} {{ shop.currency }}</p>
                </a>
              </div>

                {%- assign pairs_rendered = pairs_rendered | plus: 1 -%}
              {%- endfor -%}
            </div>
          </div>
          {%- endif -%}

          <!-- ── Social Icons (Dynamic Blocks) ── -->
          {% assign social_blocks = section.blocks | where: "type", "social_icon" %}
          {% if social_blocks.size > 0 %}
          <div style="display: flex; align-items: center; gap: 1rem; margin-top: 3rem;">
            <strong style="font-size: 1.1rem; font-weight: 700;">Social:</strong>
            <div style="display: flex; gap: 1.25rem; align-items: center;">
              {% for block in social_blocks %}
                <a href="{{ block.settings.social_url | default: '#' }}" target="_blank" rel="noopener noreferrer" style="display: flex; justify-content: center; align-items: center; width: 40px; height: 40px; color: #111;" {{ block.shopify_attributes }}>
                  {% if block.settings.social_icon_svg != blank %}
                    {{ block.settings.social_icon_svg }}
                  {% else %}
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg>
                  {% endif %}
                </a>
              {% endfor %}
            </div>
          </div>
          {% endif %}



        {%- endform -%}

      </div>
    </div>
    <!-- / Right Column -->

  </div>
</div>

<!-- ── Full Width Accordion Area ── -->
{% assign has_accordions = false %}
{% for block in section.blocks %}
  {% if block.type == 'description' or block.type == 'accordion' %}
    {% assign has_accordions = true %}
    {% break %}
  {% endif %}
{% endfor %}

{% if has_accordions %}
<div class="accordion-full-width-wrapper">
