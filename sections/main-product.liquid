      <div class="product-accordion">
        <div class="product-accordion-item">
          <button type="button" class="product-accordion-trigger" aria-expanded="true">
            <span>DESCRIPTION</span>
            <div class="accordion-icon-circle">
              <svg class="accordion-icon-plus" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              <svg class="accordion-icon-minus" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </div>
          </button>
          <div class="product-accordion-body open">
            <div class="prose" style="padding-bottom: 1.25rem;">
              {% if product.description != blank %}
                {{ product.description }}
              {% else %}
