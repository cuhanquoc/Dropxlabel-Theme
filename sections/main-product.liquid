<section class="w-full bg-white text-[#0a0a0a] pb-12" data-section-id="{{ section.id }}" data-product-handle="{{ product.handle }}">
  <style>
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    
    /* Optional: Custom style for dynamic checkout button */
    .shopify-payment-button__button {
      border-radius: 0 !important;
      height: 3.5rem !important;
      font-family: inherit !important;
      font-weight: bold !important;
      letter-spacing: 0.1em !important;
      text-transform: uppercase !important;
    }
  </style>

  <div class="max-w-[1440px] mx-auto xl:px-10 xl:flex xl:gap-12 xl:items-start pt-16 md:pt-24 md:pb-12">
    
    <!-- GALLERY (Mobile First) -->
    <div class="w-full xl:w-1/2 xl:sticky xl:top-[120px]">
      <!-- Main Image -->
      <div class="w-full relative bg-[#f4f4f4] aspect-[4/5] xl:rounded-lg overflow-hidden">
        {% if product.featured_image %}
          <img id="ProductMainImage" src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }}" class="w-full h-full object-cover transition-opacity duration-300">
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'w-full h-full text-gray-300' }}
        {% endif %}
      </div>
      
      <!-- Thumbnail Slider -->
      {% if product.media.size > 1 %}
        <div class="overflow-x-auto snap-x flex gap-[2px] mt-[2px] hide-scrollbar relative pb-2" id="ProductThumbnails">
          {% for media in product.media %}
            <button type="button" 
                    class="shrink-0 w-[calc(33.333%-1.33px)] aspect-[4/5] bg-[#f4f4f4] snap-start relative group outline-none"
                    onclick="document.getElementById('ProductMainImage').src='{{ media.preview_image | image_url: width: 1200 }}'">
              <img src="{{ media.preview_image | image_url: width: 400 }}" alt="{{ media.alt | escape }}" class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity">
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- PRODUCT INFO -->
    <div class="w-full px-5 py-8 xl:px-0 xl:w-1/2 xl:max-w-xl">
      <!-- Title & Price -->
      <h1 class="text-2xl md:text-3xl font-heading font-bold mb-3 tracking-tight">{{ product.title }}</h1>
      <div class="text-3xl md:text-4xl font-heading font-bold mb-2">
        <span id="ProductPrice">{{ product.selected_or_first_available_variant.price | money }} {{ cart.currency.iso_code }}</span>
        {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
          <s class="text-[#888] text-lg ml-2" id="ProductComparePrice">{{ product.selected_or_first_available_variant.compare_at_price | money }}</s>
        {% endif %}
      </div>
      <p class="text-sm text-[#444] mb-8">Taxes included. <a href="#" class="underline">Shipping</a> calculated at checkout.</p>

      <hr class="border-[#eaeaea] mb-8">

      <!-- Product Form -->
      {%- form 'product', product, id: 'ProductForm', class: 'block' -%}
        <input type="hidden" name="id" id="VariantSelector" value="{{ product.selected_or_first_available_variant.id }}">

        <!-- Variants -->
        {%- unless product.has_only_default_variant -%}
          <div class="space-y-8 mb-8">
            {%- for option in product.options_with_values -%}
              <div>
                <div class="flex justify-between items-end mb-4">
                  <label class="text-sm font-bold uppercase tracking-wider">{{ option.name }}: <span class="font-medium ml-1 text-[#666]" id="OptionValue-{{ forloop.index0 }}">{{ option.selected_value }}</span></label>
                  {% if option.name == 'Size' or option.name == 'Kích thước' %}
                    <button type="button" class="text-sm border-b border-black flex items-center font-bold">
                       Size chart 
                       <svg class="ml-2 w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10v4a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-4"/><path d="M8 10v4"/><path d="M12 10v4"/><path d="M16 10v4"/></svg>
                    </button>
                  {% endif %}
                </div>
                
                <div class="flex flex-wrap gap-3">
                  {%- liquid
                     assign is_color = false
                     assign downcased_option = option.name | downcase
                     if downcased_option == 'color' or downcased_option == 'colour' or downcased_option == 'màu sắc' or downcased_option == 'màu'
                       assign is_color = true
                     endif
                  -%}
                  {%- for value in option.values -%}
                    <label class="relative cursor-pointer">
                      <input type="radio" class="sr-only peer" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %} data-option-index="{{ forloop.parentloop.index0 }}" onchange="updateVariant(this)">
                      
                      {% if is_color %}
                        {%- assign variant_image = blank -%}
                        {%- for variant in product.variants -%}
                          {%- if variant.options[forloop.parentloop.index0] == value and variant.image -%}
                            {%- assign variant_image = variant.image -%}
                            {%- break -%}
                          {%- endif -%}
                        {%- endfor -%}
                        
                        <div class="w-12 h-12 rounded overflow-hidden border-2 border-transparent peer-checked:border-black p-[2px] transition-all">
                          <div class="w-full h-full rounded-sm overflow-hidden bg-gray-200">
                            {% if variant_image != blank %}
                              <img src="{{ variant_image | image_url: width: 100 }}" class="w-full h-full object-cover" alt="{{ value }}">
                            {% else %}
                              <div class="w-full h-full" style="background-color: {{ value | split: ' ' | last | downcase | remove: '"' | remove: "'" }};"></div>
                            {% endif %}
                          </div>
                        </div>
                      {% else %}
                        <div class="min-w-[4.5rem] h-12 px-4 flex items-center justify-center border border-gray-300 rounded font-medium text-sm peer-checked:bg-black peer-checked:text-white peer-checked:border-black transition-all">
                          {{ value }}
                        </div>
                      {% endif %}
                    </label>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <!-- Quantity & Stock -->
        <div class="mb-4">
          <label class="text-sm font-bold uppercase tracking-wider mb-4 block">Quantity</label>
          <div class="flex items-center w-36 h-14 border border-gray-300 rounded">
            <button type="button" class="w-12 h-full flex items-center justify-center text-2xl hover:bg-gray-50 outline-none" onclick="document.getElementById('QuantityInput').stepDown()">−</button>
            <input type="number" id="QuantityInput" name="quantity" class="w-full h-full text-center text-lg font-medium bg-transparent outline-none appearance-none" value="1" min="1" aria-label="Quantity">
            <button type="button" class="w-12 h-full flex items-center justify-center text-2xl hover:bg-gray-50 outline-none" onclick="document.getElementById('QuantityInput').stepUp()">+</button>
          </div>
        </div>

        <div class="flex items-center gap-2 text-sm font-medium mb-8">
          <div class="w-5 h-5 rounded-full bg-[#00a852] flex items-center justify-center text-white shrink-0">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
          <span class="text-[#00a852]">
            {% if product.selected_or_first_available_variant.inventory_quantity > 0 %}
              {{ product.selected_or_first_available_variant.inventory_quantity }} in stock
            {% else %}
              {% if product.available %}In stock{% else %}Out of stock{% endif %}
            {% endif %}
          </span>
        </div>

        <!-- Pickup Info Box -->
        <div class="bg-[#f0faef] p-5 rounded-md flex gap-4 mb-8">
          <div class="mt-1 shrink-0 text-[#00a852]">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line>
            </svg>
          </div>
          <div class="text-[0.95rem]">
            <p class="font-bold text-[#0a0a0a] leading-tight mb-1">Pickup available at California Warehouse</p>
            <p class="text-[#666] mb-2">Usually ready in 24 hours</p>
            <a href="#" class="underline text-xs text-[#0a0a0a] font-medium">Check availability at other stores</a>
          </div>
        </div>

        <!-- Submit Buttons -->
        <div class="flex flex-col gap-3 mb-8">
          <button type="submit" class="w-full h-14 bg-white text-black border-[1.5px] border-black flex items-center justify-center text-sm font-bold tracking-widest uppercase hover:bg-black hover:text-white transition-colors duration-300">
            Add to cart
          </button>
          
          {%- if section.settings.show_dynamic_checkout -%}
            {{ form | payment_button }}
          {%- else -%}
            <!-- Fallback Buy Now if dynamic checkout is off but they still want a button -->
            <button type="button" class="w-full h-14 bg-black text-white flex items-center justify-center text-sm font-bold tracking-widest uppercase hover:opacity-80 transition-opacity duration-300">
              Buy it now
            </button>
          {%- endif -%}
        </div>

      {%- endform -%}

      <!-- Pointers / Trust Badges -->
      <hr class="border-[#eaeaea] mb-6">
      
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 text-sm font-medium mb-8">
         <div class="flex items-center gap-3">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
            Free delivery within 2 days
         </div>
         <div class="hidden md:block w-px h-6 bg-gray-300"></div>
         <div class="flex items-center gap-3">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><polyline points="3 3 3 8 8 8"></polyline></svg>
            Free + easy returns
         </div>
      </div>
      
      <!-- Socials -->
      <div class="flex items-center gap-4 text-sm font-bold pt-4">
         <span>Social:</span>
         <div class="flex items-center gap-5">
           <a href="#" class="hover:opacity-70 transition-opacity"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg></a>
           <a href="#" class="hover:opacity-70 transition-opacity"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5 2.8 11.2 2.8 11.2c.8.2 1.6.2 2.4.1C-1.1 9.4-1.2 3.4-1.2 3.4c1 .6 2 .9 3.1.9-3.7-2.6-2.5-8.5-2.5-8.5 3.3 3.6 8.5 6.3 14 6.6C12.7 1.9 14.5.3 17 1.3c1.5.6 2.7 1.8 3.3 3.3.1.3.1.5.2.8.2-.1.4-.2.6-.4.7-.6 1.4-1.1 2-1.7-.1.4-.3.7-.5 1 .3-.1.6-.2.9-.4-.1.4-.3.8-.5 1.1z"></path></svg></a>
           <a href="#" class="hover:opacity-70 transition-opacity"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2z"></path></svg></a>
         </div>
      </div>
      
    </div>
  </div>

  <script>
    // Extremely lightweight product variant update logic
    var productVariants = {{ product.variants | json }};
    function updateVariant(radio) {
      if(!radio.checked) return;
      
      // Update label display
      var index = radio.getAttribute('data-option-index');
      var displayElement = document.getElementById('OptionValue-' + index);
      if(displayElement) displayElement.textContent = radio.value;

      // Find selected variants from all radios
      var checkedOptions = Array.from(document.querySelectorAll('#ProductForm input[type="radio"]:checked')).map(r => r.value);
      var currentVariant = productVariants.find(v => {
        return checkedOptions.every((val, i) => v.options[i] === val);
      });

      if(currentVariant) {
        // Update Hidden ID
        document.getElementById('VariantSelector').value = currentVariant.id;
        
        // Update Price
        var priceFormatter = new Intl.NumberFormat('en-US', { style: 'currency', currency: '{{ cart.currency.iso_code }}' });
        document.getElementById('ProductPrice').textContent = priceFormatter.format(currentVariant.price / 100);
        
        // Update URL
        var newUrl = new URL(window.location.href);
        newUrl.searchParams.set('variant', currentVariant.id);
        window.history.replaceState({}, '', newUrl);
      }
    }
  </script>
</section>

{% schema %}
{
  "name": "Product Main",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Product Main Display"
    }
  ]
}
{% endschema %}
