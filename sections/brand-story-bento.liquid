<style>
  /* ═══════════════════════════════════════
     BRAND STORY BENTO — Fashion Showcase
  ═══════════════════════════════════════ */

  .bsb-section {
    position: relative;
    overflow: hidden;
    background-color: {{ section.settings.bg_color | default: '#f2f0ec' }};
    background-image:
      linear-gradient(45deg, rgba(0,0,0,0.018) 25%, transparent 25%, transparent 75%, rgba(0,0,0,0.018) 75%),
      linear-gradient(45deg, rgba(0,0,0,0.018) 25%, transparent 25%, transparent 75%, rgba(0,0,0,0.018) 75%);
    background-size: 20px 20px;
    background-position: 0 0, 10px 10px;
  }

  {% if section.settings.bg_image != blank %}
  .bsb-section {
    background-image: url('{{ section.settings.bg_image | image_url: width: 1920 }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  {% endif %}

  /* ── Horizontal Track: text + cards all in a row ── */
  .bsb-track-wrapper {
    overflow: hidden;
    padding: 5rem 0 3rem;
  }

  .bsb-track {
    display: flex;
    align-items: flex-start;
    gap: 3rem;
    padding: 0 3rem;
    will-change: transform;
  }

  /* ── Text Panel (inline in the track) ── */
  .bsb-text {
    flex: 0 0 380px;
    max-width: 380px;
    padding-top: 2rem;
  }

  .bsb-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: #0a0a0a;
    margin-bottom: 1.5rem;
  }

  .bsb-heading em {
    font-style: italic;
    font-weight: 800;
  }

  .bsb-desc {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.7;
    color: #555;
    max-width: 320px;
    margin-bottom: 2rem;
  }

  .bsb-cta-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .bsb-cta-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid #0a0a0a;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: #0a0a0a;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .bsb-cta-icon:hover {
    background-color: #0a0a0a;
    color: #fff;
  }

  .bsb-cta-btn {
    display: inline-block;
    padding: 0.7rem 1.6rem;
    border: 1.5px solid #0a0a0a;
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #0a0a0a;
    text-decoration: none;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .bsb-cta-btn:hover {
    background-color: #0a0a0a;
    color: #fff;
  }

  /* ── Single Card ── */
  .bsb-card {
    flex: 0 0 480px;
    max-width: 480px;
  }

  .bsb-card-img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: 16px;
    overflow: hidden;
    border: 5px solid rgba(255,255,255,0.85);
    box-shadow: 0 4px 30px rgba(0,0,0,0.06);
    background-color: #e8e5e0;
  }

  .bsb-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .bsb-card:hover .bsb-card-img {
    transform: scale(1.05);
  }

  /* Floating tag on image */
  .bsb-card-tag {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    background-color: rgba(255,255,255,0.92);
    backdrop-filter: blur(8px);
    padding: 0.6rem 1rem;
    border-radius: 10px;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    color: #0a0a0a;
    line-height: 1.4;
    max-width: 200px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }

  /* Card bottom: title + button stacked */
  .bsb-card-bottom {
    padding: 1.25rem 0.25rem 1.5rem;
  }

  .bsb-card-title {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 700;
    color: #0a0a0a;
    letter-spacing: -0.02em;
    margin-bottom: 0.85rem;
  }

  .bsb-card-link {
    display: inline-block;
    padding: 0.65rem 1.8rem;
    border: 2px solid #0a0a0a;
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0a0a0a;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .bsb-card-link:hover {
    background-color: #0a0a0a;
    color: #fff;
  }

  /* Separator */
  .bsb-card-sep {
    width: 100%;
    height: 2px;
    background: linear-gradient(to right, #b0ada8, #d6d3ce);
    margin-top: 0.25rem;
    border-radius: 2px;
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .bsb-track-wrapper {
      padding: 3rem 0 2rem;
    }

    .bsb-track {
      flex-direction: column;
      gap: 2rem;
      padding: 0 1.25rem;
    }

    .bsb-text {
      flex: 0 0 auto;
      max-width: 100%;
      padding-top: 0;
    }

    .bsb-heading {
      font-size: 2rem;
      margin-bottom: 1rem;
    }

    .bsb-desc {
      font-size: 0.8rem;
      margin-bottom: 1.5rem;
    }

    /* On mobile: cards become a horizontal swipe row */
    .bsb-mobile-cards {
      display: flex;
      gap: 1.25rem;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      padding-right: 1.25rem;
    }

    .bsb-mobile-cards::-webkit-scrollbar {
      display: none;
    }

    .bsb-card {
      flex: 0 0 80vw;
      max-width: 80vw;
      scroll-snap-align: start;
    }

    .bsb-card-title {
      font-size: 1.15rem;
    }

    .bsb-card-link {
      font-size: 0.65rem;
      padding: 0.45rem 1.2rem;
    }
  }

  /* ── Tablet ── */
  @media (min-width: 768px) and (max-width: 1024px) {
    .bsb-track {
      gap: 2rem;
      padding: 0 2rem;
    }

    .bsb-text {
      flex: 0 0 280px;
      max-width: 280px;
    }

    .bsb-card {
      flex: 0 0 380px;
      max-width: 380px;
    }
  }
</style>

<section class="bsb-section" id="brand-story-bento">

  <div class="bsb-track-wrapper">
    <div class="bsb-track" id="bsb-track">

      <!-- Text Panel (scrolls away to the left) -->
      <div class="bsb-text" id="bsb-text">
        <h2 class="bsb-heading">
          {{ section.settings.heading }}
        </h2>
        <p class="bsb-desc">
          {{ section.settings.description }}
        </p>
        <div class="bsb-cta-wrap">
          <a href="{{ section.settings.button_url | default: '#' }}" class="bsb-cta-icon" aria-label="Explore">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 7 10 10"/><path d="M17 7v10H7"/></svg>
          </a>
          <a href="{{ section.settings.button_url | default: '#' }}" class="bsb-cta-btn">
            {{ section.settings.button_text | default: 'Explore More' }}
          </a>
        </div>
      </div>

      <!-- Card 1 -->
      <div class="bsb-card">
        <div class="bsb-card-img-wrap">
          {% if section.settings.card1_image != blank %}
            <img
              src="{{ section.settings.card1_image | image_url: width: 800 }}"
              alt="{{ section.settings.card1_image.alt | default: section.settings.card1_title }}"
              class="bsb-card-img"
              loading="lazy"
              width="800"
              height="600"
            />
          {% else %}
            <img
              src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=800&q=85&auto=format&fit=crop"
              alt="Fashion Model"
              class="bsb-card-img"
              loading="lazy"
              width="800"
              height="600"
            />
          {% endif %}
          {% if section.settings.card1_tag != blank %}
            <div class="bsb-card-tag">{{ section.settings.card1_tag }}</div>
          {% endif %}
        </div>
        <div class="bsb-card-bottom">
          <h3 class="bsb-card-title">{{ section.settings.card1_title | default: 'Elegant Evening Wear' }}</h3>
          <a href="{{ section.settings.card1_url | default: '#' }}" class="bsb-card-link">
            {{ section.settings.card1_button | default: 'SHOP NOW' }}
          </a>
        </div>
        <div class="bsb-card-sep"></div>
      </div>

      <!-- Card 2 -->
      <div class="bsb-card">
        <div class="bsb-card-img-wrap">
          {% if section.settings.card2_image != blank %}
            <img
              src="{{ section.settings.card2_image | image_url: width: 800 }}"
              alt="{{ section.settings.card2_image.alt | default: section.settings.card2_title }}"
              class="bsb-card-img"
              loading="lazy"
              width="800"
              height="600"
            />
          {% else %}
            <img
              src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=800&q=85&auto=format&fit=crop"
              alt="Fashion Model"
              class="bsb-card-img"
              loading="lazy"
              width="800"
              height="600"
            />
          {% endif %}
          {% if section.settings.card2_tag != blank %}
            <div class="bsb-card-tag">{{ section.settings.card2_tag }}</div>
          {% endif %}
        </div>
        <div class="bsb-card-bottom">
          <h3 class="bsb-card-title">{{ section.settings.card2_title | default: 'Luxury Winter Collection' }}</h3>
          <a href="{{ section.settings.card2_url | default: '#' }}" class="bsb-card-link">
            {{ section.settings.card2_button | default: 'Shop Now' }}
          </a>
        </div>
        <div class="bsb-card-sep"></div>
      </div>

      <!-- Card 3 -->
      <div class="bsb-card">
        <div class="bsb-card-img-wrap">
          {% if section.settings.card3_image != blank %}
            <img
              src="{{ section.settings.card3_image | image_url: width: 800 }}"
              alt="{{ section.settings.card3_image.alt | default: section.settings.card3_title }}"
              class="bsb-card-img"
              loading="lazy"
              width="800"
              height="600"
            />
          {% else %}
            <img
              src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=800&q=85&auto=format&fit=crop"
              alt="Fashion Model"
              class="bsb-card-img"
              loading="lazy"
              width="800"
              height="600"
            />
          {% endif %}
          {% if section.settings.card3_tag != blank %}
            <div class="bsb-card-tag">{{ section.settings.card3_tag }}</div>
          {% endif %}
        </div>
        <div class="bsb-card-bottom">
          <h3 class="bsb-card-title">{{ section.settings.card3_title | default: 'Urban Street Style' }}</h3>
          <a href="{{ section.settings.card3_url | default: '#' }}" class="bsb-card-link">
            {{ section.settings.card3_button | default: 'SHOP NOW' }}
          </a>
        </div>
        <div class="bsb-card-sep"></div>
      </div>

    </div>
  </div>

</section>

<script>
  /* ═══════════════════════════════════════════════════
     BRAND STORY BENTO — Full Horizontal Scroll
     Text + Cards all slide left together on scroll.
     The text slides off-screen, revealing 3 cards.
  ═══════════════════════════════════════════════════ */

  gsap.registerPlugin(ScrollTrigger);

  (function initBentoGallery() {
    var track = document.getElementById('bsb-track');
    var section = document.getElementById('brand-story-bento');
    if (!track || !section) return;

    var isMobile = window.innerWidth < 768;

    if (!isMobile) {
      /* Desktop: scroll-driven horizontal slide
         Text + cards slide left together.
         Text fades out during scroll.
         Cards hold at the end before releasing. */

      var textEl = document.getElementById('bsb-text');
      var holdDuration = 400; /* extra px to hold at end */

      function getScrollAmount() {
        var cards = track.querySelectorAll('.bsb-card');
        var firstCard = cards[0];
        var lastCard = cards[cards.length - 1];
        var cardsStart = firstCard.offsetLeft;
        var cardsEnd = lastCard.offsetLeft + lastCard.offsetWidth;
        var cardsWidth = cardsEnd - cardsStart;
        var cardsCenter = cardsStart + cardsWidth / 2;
        var viewW = track.parentElement.offsetWidth;
        return -(cardsCenter - viewW / 2);
      }

      function getTotalEnd() {
        return Math.abs(getScrollAmount()) + holdDuration;
      }

      /* Main timeline — scrub-linked */
      var tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top top',
          end: function () { return '+=' + getTotalEnd(); },
          scrub: 1,
          pin: true,
          anticipatePin: 1,
          invalidateOnRefresh: true,
        }
      });

      /* Phase 1 (0% – 80%): slide the track left */
      tl.to(track, {
        x: getScrollAmount,
        ease: 'none',
        duration: 0.8
      }, 0);

      /* Phase 1a (0% – 25%): fade out the text panel */
      tl.to(textEl, {
        opacity: 0,
        ease: 'power2.in',
        duration: 0.25
      }, 0);

      /* Phase 2 (80% – 100%): hold — nothing moves, cards stay */
      tl.to({}, { duration: 0.2 });

      /* Entry animation (one-time, before scroll starts) */
      gsap.fromTo('#bsb-text',
        { x: -40, opacity: 0 },
        {
          x: 0, opacity: 1,
          duration: 1,
          ease: 'power3.out',
          scrollTrigger: { trigger: section, start: 'top 80%', once: true }
        }
      );

      gsap.fromTo('.bsb-card',
        { y: 50, opacity: 0 },
        {
          y: 0, opacity: 1,
          duration: 0.8,
          ease: 'power3.out',
          stagger: 0.15,
          scrollTrigger: { trigger: section, start: 'top 75%', once: true }
        }
      );

    } else {
      /* Mobile: stacked layout with simple entry animation */
      gsap.fromTo('#bsb-text',
        { y: 20, opacity: 0 },
        {
          y: 0, opacity: 1,
          duration: 0.6,
          ease: 'power3.out',
          scrollTrigger: { trigger: section, start: 'top 90%', once: true }
        }
      );

      gsap.fromTo('.bsb-card',
        { y: 20, opacity: 0 },
        {
          y: 0, opacity: 1,
          duration: 0.5,
          ease: 'power3.out',
          stagger: 0.08,
          scrollTrigger: { trigger: section, start: 'top 85%', once: true }
        }
      );
    }
  }());
</script>

