<style>
  /* ═══════════════════════════════════════
     BRAND STORY BENTO — Fashion Showcase
  ═══════════════════════════════════════ */

  .bsb-section {
    position: relative;
    overflow: hidden;
    background-color: {{ section.settings.bg_color | default: '#f2f0ec' }};
    background-image: url('{{ 'paper-texture-bg.png' | asset_url }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  {% if section.settings.bg_image != blank %}
  .bsb-section {
    background-image: url('{{ section.settings.bg_image | image_url: width: 1920 }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  {% endif %}

  /* ── Horizontal Track: text + cards all in a row ── */
  .bsb-track-wrapper {
    overflow: hidden;
    padding: 5rem 0 0;
  }

  .bsb-track {
    display: flex;
    align-items: flex-start;
    gap: 3rem;
    padding: 0 3rem;
    will-change: transform;
  }

  /* ── Text Panel (inline in the track) ── */
  .bsb-text {
    flex: 0 0 380px;
    max-width: 380px;
    padding-top: 2rem;
  }

  .bsb-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: 0.02em;
    color: #0a0a0a;
    margin-bottom: 1.5rem;
  }

  .bsb-heading em {
    font-style: italic;
    font-weight: 800;
  }

  .bsb-desc {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.85;
    color: #555;
    max-width: 320px;
    margin-bottom: 2rem;
  }

  .bsb-cta-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .bsb-cta-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid #0a0a0a;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: #0a0a0a;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .bsb-cta-icon:hover {
    background-color: #0a0a0a;
    color: #fff;
  }

  .bsb-cta-btn {
    display: inline-block;
    padding: 0.7rem 1.6rem;
    border: 1.5px solid #0a0a0a;
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #0a0a0a;
    text-decoration: none;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .bsb-cta-btn:hover {
    background-color: #0a0a0a;
    color: #fff;
  }

  /* ── Single Card ── */
  .bsb-card {
    flex: 0 0 480px;
    max-width: 480px;
  }

  .bsb-card-img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: 16px;
    overflow: hidden;
    border: 5px solid rgba(255,255,255,0.85);
    box-shadow: 0 4px 30px rgba(0,0,0,0.06);
    background-color: #e8e5e0;
  }

  .bsb-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .bsb-card:hover .bsb-card-img {
    transform: scale(1.05);
  }

  /* Floating tag on image */
  .bsb-card-tag {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    background-color: rgba(255,255,255,0.92);
    backdrop-filter: blur(8px);
    padding: 0.6rem 1rem;
    border-radius: 10px;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    color: #0a0a0a;
    line-height: 1.4;
    max-width: 200px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }

  /* Card bottom: title + button stacked */
  .bsb-card-bottom {
    padding: 1.25rem 0.25rem 1.5rem;
  }

  .bsb-card-title {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 700;
    color: #0a0a0a;
    letter-spacing: -0.02em;
    margin-bottom: 0.85rem;
  }

  .bsb-card-link {
    display: inline-block;
    padding: 0.65rem 1.8rem;
    border: 2px solid #0a0a0a;
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0a0a0a;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .bsb-card-link:hover {
    background-color: #0a0a0a;
    color: #fff;
  }

  /* Separator */
  .bsb-card-sep {
    width: 100%;
    height: 2px;
    background: linear-gradient(to right, #b0ada8, #d6d3ce);
    margin-top: 0.25rem;
    border-radius: 2px;
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .bsb-track-wrapper {
      padding: 3rem 0 2rem;
      overflow: visible;
    }

    .bsb-track {
      flex-direction: column;
      gap: 2rem;
      padding: 0 1.25rem;
      overflow: visible;
    }

    .bsb-text {
      flex: 0 0 auto;
      max-width: 100%;
      padding-top: 0;
    }

    .bsb-heading {
      font-size: 2rem;
      margin-bottom: 1rem;
    }

    .bsb-desc {
      font-size: 0.8rem;
      margin-bottom: 1.5rem;
    }

    /* On mobile: cards become a horizontal swipe row */
    .bsb-mobile-cards {
      display: flex;
      gap: 1.25rem;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      padding: 0 1.25rem;
      margin: 0 -1.25rem;
      scroll-behavior: smooth;
    }

    .bsb-mobile-cards::-webkit-scrollbar {
      display: none;
    }

    .bsb-card {
      flex: 0 0 80vw;
      min-width: 80vw;
      max-width: 80vw;
      scroll-snap-align: start;
    }

    .bsb-card-title {
      font-size: 1.15rem;
    }

    .bsb-card-link {
      font-size: 0.65rem;
      padding: 0.45rem 1.2rem;
    }

    /* ── Scroll Progress Bar ── */
    .bsb-scroll-bar-track {
      display: block;
      margin: 1.5rem 1.25rem 0;
      height: 3px;
      background: rgba(0,0,0,0.08);
      border-radius: 3px;
      overflow: hidden;
    }

    .bsb-scroll-bar-thumb {
      display: block;
      height: 100%;
      background: #0a0a0a;
      border-radius: 3px;
      width: 33%;
      transition: transform 150ms ease;
    }
  }

  /* ── Tablet ── */
  @media (min-width: 768px) and (max-width: 1024px) {
    .bsb-track {
      gap: 2rem;
      padding: 0 2rem;
    }

    .bsb-text {
      flex: 0 0 280px;
      max-width: 280px;
    }

    .bsb-card {
      flex: 0 0 380px;
      max-width: 380px;
    }
  }

  /* Desktop: show desktop cards, hide mobile cards */
  @media (min-width: 768px) {
    .bsb-mobile-cards {
      display: none;
    }
    .bsb-scroll-bar-track {
      display: none;
    }
    .bsb-desktop-card {
      display: block;
    }
  }

  /* Mobile: show mobile cards, hide desktop cards */
  @media (max-width: 767px) {
    .bsb-desktop-card {
      display: none;
    }
  }
</style>

<section class="bsb-section" id="brand-story-bento">

  <div class="bsb-track-wrapper">
    <div class="bsb-track" id="bsb-track">

      <!-- Text Panel -->
      <div class="bsb-text" id="bsb-text">
        <h2 class="bsb-heading">
          {{ section.settings.heading }}
        </h2>
        <p class="bsb-desc">
          {{ section.settings.description }}
        </p>
        <div class="bsb-cta-wrap">
          <a href="{{ section.settings.button_url | default: '#' }}" class="bsb-cta-icon" aria-label="Explore">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 7 10 10"/><path d="M17 7v10H7"/></svg>
          </a>
          <a href="{{ section.settings.button_url | default: '#' }}" class="bsb-cta-btn">
            {{ section.settings.button_text | default: 'Explore More' }}
          </a>
        </div>
      </div>

      <!-- Desktop Cards (inside track for horizontal GSAP scroll) -->
      {%- assign collection_handles = 'card1_collection,card2_collection,card3_collection' | split: ',' -%}
      {%- for handle_key in collection_handles -%}
        {%- assign col = section.settings[handle_key] -%}
        {%- if col != blank -%}
          {%- assign card_image = col.image | default: col.products.first.featured_image -%}
          <div class="bsb-card bsb-desktop-card">
            <div class="bsb-card-img-wrap">
              {% if card_image != blank %}
                <img
                  src="{{ card_image | image_url: width: 800 }}"
                  alt="{{ card_image.alt | default: col.title }}"
                  class="bsb-card-img"
                  loading="lazy"
                  width="800"
                  height="600"
                />
              {% else %}
                {{ 'collection-1' | placeholder_svg_tag: 'bsb-card-img' }}
              {% endif %}
              <div class="bsb-card-tag">{{ col.title }}</div>
            </div>
            <div class="bsb-card-bottom">
              <h3 class="bsb-card-title">{{ col.title }}</h3>
              <a href="{{ col.url }}" class="bsb-card-link">SHOP NOW</a>
            </div>
            <div class="bsb-card-sep"></div>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>

  <!-- Mobile Cards (OUTSIDE overflow-hidden wrapper for swipe to work) -->
  <div class="bsb-mobile-cards">
    {%- for handle_key in collection_handles -%}
      {%- assign col = section.settings[handle_key] -%}
      {%- if col != blank -%}
        {%- assign card_image = col.image | default: col.products.first.featured_image -%}
        <div class="bsb-card">
          <div class="bsb-card-img-wrap">
            {% if card_image != blank %}
              <img
                src="{{ card_image | image_url: width: 800 }}"
                alt="{{ card_image.alt | default: col.title }}"
                class="bsb-card-img"
                loading="lazy"
                width="800"
                height="600"
              />
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'bsb-card-img' }}
            {% endif %}
            <div class="bsb-card-tag">{{ col.title }}</div>
          </div>
          <div class="bsb-card-bottom">
            <h3 class="bsb-card-title">{{ col.title }}</h3>
            <a href="{{ col.url }}" class="bsb-card-link">SHOP NOW</a>
          </div>
          <div class="bsb-card-sep"></div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <!-- Scroll Progress Bar (mobile only) -->
  <div class="bsb-scroll-bar-track" id="bsb-scroll-bar">
    <div class="bsb-scroll-bar-thumb" id="bsb-scroll-thumb"></div>
  </div>

</section>

<script>
  (function() {
    var container = document.querySelector('.bsb-mobile-cards');
    var thumb = document.getElementById('bsb-scroll-thumb');
    if (!container || !thumb) return;

    function updateThumb() {
      var scrollWidth = container.scrollWidth - container.clientWidth;
      if (scrollWidth <= 0) return;
      var progress = container.scrollLeft / scrollWidth;
      var trackWidth = thumb.parentElement.clientWidth;
      var thumbWidth = thumb.clientWidth;
      var maxTranslate = trackWidth - thumbWidth;
      thumb.style.transform = 'translateX(' + (progress * maxTranslate) + 'px)';
    }

    container.addEventListener('scroll', updateThumb, { passive: true });
    window.addEventListener('resize', updateThumb);
    updateThumb();
  })();
</script>

{% schema %}
{
  "name": "Brand Story Bento",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading (HTML supported)",
      "default": "<em>FASHION</em> THAT<br>FLOWS WITH<br>THE SEASONS"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Explore our latest collection of timeless fashion. From classic styles to modern trends, find the perfect look for every season. Shop now and elevate your wardrobe!"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Explore More"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image",
      "info": "Recommended: 1920 × 1080px. If empty, uses textured color background."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color (fallback)",
      "default": "#f2f0ec",
      "info": "Used when no background image is set."
    },
    {
      "type": "header",
      "content": "── Collection Cards ──"
    },
    {
      "type": "collection",
      "id": "card1_collection",
      "label": "Card 1 — Collection"
    },
    {
      "type": "collection",
      "id": "card2_collection",
      "label": "Card 2 — Collection"
    },
    {
      "type": "collection",
      "id": "card3_collection",
      "label": "Card 3 — Collection"
    }
  ],
  "presets": [
    {
      "name": "Brand Story Bento"
    }
  ]
}
{% endschema %}
