<style>
  /* ─────────────────────────────────────────
     BRAND STORY BENTO — Styles
  ───────────────────────────────────────── */

  /* Titanium Silver Gradient for Block 2 */
  .bento-gradient {
    background: linear-gradient(
      145deg,
      #e8e4de 0%,    /* Warm pearl      */
      #d6d0c8 35%,   /* Silver sand     */
      #c9c3bb 60%,   /* Titanium mid    */
      #bfb9b0 100%   /* Deep warm grey  */
    );
  }

  /* Accent pill tag */
  .bento-tag {
    display: inline-block;
    padding: 0.35rem 1.1rem;
    border: 1px solid rgba(197, 168, 128, 0.6);
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
  }

  /* Block 1 — image overlay gradient */
  .bento-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(20, 18, 16, 0.78) 0%,
      rgba(20, 18, 16, 0.15) 55%,
      transparent 100%
    );
    border-radius: inherit;
  }

  /* Block 1 — floating text at bottom */
  .bento-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2.25rem;
  }

  .bento-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    border-radius: inherit;
    transform: scale(1.15);
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    will-change: transform;
  }

  .bento-block:hover .bento-img {
    transform: scale(1.22);
  }

  /* Number counter style */
  .bento-stat-number {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .bento-stat-label {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-top: 0.3rem;
  }

  /* Divider line */
  .bento-divider {
    width: 32px;
    height: 1.5px;
    background-color: var(--color-accent);
    margin: 1.25rem 0;
  }
</style>

<section
  id="brand-story"
  class="py-12 md:py-24 px-6 md:px-10"
  style="background-color: var(--color-bg);"
>
  <div class="max-w-screen-xl mx-auto">

    <!-- ── Bento Grid: 3 blocks ── -->
    <div
      class="grid gap-6 md:gap-8"
      style="grid-template-columns: 1fr; grid-template-rows: auto;"
    >
    <style>
      @media (min-width: 768px) {
        #brand-story .grid { grid-template-columns: 1fr 1fr !important; grid-template-rows: auto auto !important; }
      }
      /* Mobile: force all blocks into single column */
      @media (max-width: 767px) {
        #brand-story .bento-block {
          grid-column: 1 !important;
          grid-row: auto !important;
          aspect-ratio: 1/1 !important;
        }
        #brand-story .bento-gradient {
          min-height: 280px !important;
          padding: 1.75rem !important;
        }
        #brand-story .bento-block[style*="16/9"] {
          aspect-ratio: 16/9 !important;
        }
        .bento-caption {
          padding: 1.5rem;
        }
        .bento-block {
          border-radius: 20px !important;
        }
      }
    </style>

      <!-- ════════════════════════════════
           BLOCK 1 — Left, Large (2 rows)
      ════════════════════════════════ -->
      <div
        class="bento-block relative overflow-hidden rounded-[20px] md:rounded-[60px]"
        style="grid-column: 1; grid-row: 1 / span 2; aspect-ratio: 1/1;"
        data-bento="block"
      >
      <style>
        @media (min-width: 768px) {
          #brand-story .bento-block[style*="span 2"] { aspect-ratio: 3/4 !important; }
        }
      </style>
        <!-- Background Image -->
        {% if section.settings.block1_image != blank %}
          <img
            src="{{ section.settings.block1_image | image_url: width: 900 }}"
            alt="{{ section.settings.block1_image.alt | default: section.settings.block1_heading }}"
            class="bento-img absolute inset-0"
            loading="lazy"
            width="900"
            height="1200"
          />
        {% else %}
          <img
            src="https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=900&q=85&auto=format&fit=crop"
            alt="Journey of Style — editorial fashion"
            class="bento-img absolute inset-0"
            loading="lazy"
            width="900"
            height="1200"
          />
        {% endif %}

        <!-- Overlay -->
        <div class="bento-img-overlay"></div>

        <!-- Text content at bottom -->
        <div class="bento-caption">
          <span class="bento-tag">{{ section.settings.block1_tag }}</span>

          <h2
            style="
              font-family: var(--font-heading);
              font-size: clamp(1.8rem, 3vw, 2.8rem);
              font-weight: 600;
              color: #ffffff;
              line-height: 1.1;
              letter-spacing: -0.01em;
              margin-bottom: 0.9rem;
            "
          >
            {{ section.settings.block1_heading }}
          </h2>

          <p
            style="
              font-family: var(--font-body);
              font-size: 0.82rem;
              line-height: 1.8;
              color: rgba(255,255,255,0.68);
              max-width: 340px;
            "
          >
            {{ section.settings.block1_description }}
          </p>
        </div>

      </div>
      <!-- /BLOCK 1 -->


      <!-- ════════════════════════════════
           BLOCK 2 — Right, Top
           Titanium Gradient — Timeless Pieces
      ════════════════════════════════ -->
      <div
        class="bento-block bento-gradient rounded-[40px] md:rounded-[60px] flex flex-col justify-between"
        style="grid-column: 2; grid-row: 1; padding: 2.5rem; min-height: 320px;"
        data-bento="block"
      >

        <!-- Top row: stats -->
        <div class="flex items-start gap-10">
          <div>
            <p class="bento-stat-number">{{ section.settings.stat1_number }}<span style="color: var(--color-accent);">+</span></p>
            <p class="bento-stat-label">{{ section.settings.stat1_label }}</p>
          </div>
          <div>
            <p class="bento-stat-number">{{ section.settings.stat2_number }}</p>
            <p class="bento-stat-label">{{ section.settings.stat2_label }}</p>
          </div>
        </div>

        <!-- Bottom: heading + copy -->
        <div>
          <div class="bento-divider"></div>

          <h3
            style="
              font-family: var(--font-heading);
              font-size: clamp(1.5rem, 2.5vw, 2rem);
              font-weight: 600;
              color: var(--color-text);
              letter-spacing: -0.01em;
              line-height: 1.15;
              margin-bottom: 0.85rem;
            "
          >
            {{ section.settings.block2_heading }}
          </h3>

          <p
            style="
              font-family: var(--font-body);
              font-size: 0.82rem;
              line-height: 1.85;
              color: var(--color-muted);
              max-width: 320px;
            "
          >
            {{ section.settings.block2_description }}
          </p>
        </div>

      </div>
      <!-- /BLOCK 2 -->


      <!-- ════════════════════════════════
           BLOCK 3 — Right, Bottom
      ════════════════════════════════ -->
      <div
        class="bento-block relative overflow-hidden rounded-[40px] md:rounded-[60px]"
        style="grid-column: 2; grid-row: 2; aspect-ratio: 16/9;"
        data-bento="block"
      >
        <!-- Background Image -->
        {% if section.settings.block3_image != blank %}
          <img
            src="{{ section.settings.block3_image | image_url: width: 900 }}"
            alt="{{ section.settings.block3_image.alt | default: section.settings.block3_heading }}"
            class="bento-img absolute inset-0"
            loading="lazy"
            width="900"
            height="506"
          />
        {% else %}
          <img
            src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=900&q=85&auto=format&fit=crop"
            alt="Fabric texture — material detail"
            class="bento-img absolute inset-0"
            loading="lazy"
            width="900"
            height="506"
          />
        {% endif %}

        <!-- Subtle overlay -->
        <div
          class="absolute inset-0"
          style="
            background: linear-gradient(
              to right,
              rgba(10,9,8,0.55) 0%,
              transparent 55%
            );
            border-radius: inherit;
          "
        ></div>

        <!-- Text overlay -->
        <div
          style="
            position: absolute;
            bottom: 0;
            left: 0;
            padding: 2rem;
          "
        >
          <span class="bento-tag" style="border-color: rgba(255,255,255,0.35); color: rgba(255,255,255,0.85);">
            {{ section.settings.block3_tag }}
          </span>
          <p
            style="
              font-family: var(--font-heading);
              font-size: clamp(1rem, 1.8vw, 1.4rem);
              font-weight: 500;
              color: #ffffff;
              letter-spacing: 0.02em;
              line-height: 1.3;
            "
          >
            {{ section.settings.block3_heading }}
          </p>
        </div>

      </div>
      <!-- /BLOCK 3 -->

    </div>
    <!-- / Bento Grid -->

  </div>
</section>


<script>
  /* ─────────────────────────────────────────────────────
     BRAND STORY BENTO — Quiet Luxury Scroll Animation
  ───────────────────────────────────────────────────── */

  gsap.registerPlugin(ScrollTrigger);

  let mmBento = gsap.matchMedia();

  mmBento.add("(min-width: 768px)", () => {
    gsap.fromTo('#brand-story [data-bento="block"]',
      { y: 50, opacity: 0, immediateRender: false },
      {
        scrollTrigger: { trigger: '#brand-story', start: 'top 85%', once: true },
        y: 0, opacity: 1, duration: 1.5, ease: 'power4.out', stagger: 0.2,
      }
    );
  });

  mmBento.add("(max-width: 767px)", () => {
    gsap.fromTo('#brand-story [data-bento="block"]',
      { y: 20, opacity: 0, immediateRender: false },
      {
        scrollTrigger: { trigger: '#brand-story', start: 'top 90%', once: true },
        y: 0, opacity: 1, duration: 0.8, ease: 'power3.out', stagger: 0.08,
      }
    );
  });

  /* ═══════════════════════════════════════════════════
     IMAGE PARALLAX SCROLL — GSAP ScrollTrigger
     .bento-img scale(1.15) → yPercent: 15, scrub: 1
  ═══════════════════════════════════════════════════ */
  (function initBentoParallax() {
    var blocks = document.querySelectorAll('.bento-block');
    blocks.forEach(function (block) {
      var img = block.querySelector('.bento-img');
      if (!img) return;

      gsap.to(img, {
        yPercent: 15,
        ease: 'none',
        scrollTrigger: {
          trigger: block,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 1,
        },
      });
    });
  }());
</script>

{% schema %}
{
  "name": "Brand Story Bento",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Block 1 — Large Image"
    },
    {
      "type": "image_picker",
      "id": "block1_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "block1_tag",
      "label": "Tag Text",
      "default": "Since 2021"
    },
    {
      "type": "textarea",
      "id": "block1_heading",
      "label": "Heading",
      "default": "Journey<br>of Style"
    },
    {
      "type": "textarea",
      "id": "block1_description",
      "label": "Description",
      "default": "Born from a quiet obsession with fabric, form, and feeling — every piece carries the weight of intention."
    },
    {
      "type": "header",
      "content": "Block 2 — Stats & Info"
    },
    {
      "type": "text",
      "id": "stat1_number",
      "label": "Stat 1 Number",
      "default": "200"
    },
    {
      "type": "text",
      "id": "stat1_label",
      "label": "Stat 1 Label",
      "default": "Curated Pieces"
    },
    {
      "type": "text",
      "id": "stat2_number",
      "label": "Stat 2 Number",
      "default": "12"
    },
    {
      "type": "text",
      "id": "stat2_label",
      "label": "Stat 2 Label",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "block2_heading",
      "label": "Heading",
      "default": "Timeless Pieces"
    },
    {
      "type": "textarea",
      "id": "block2_description",
      "label": "Description",
      "default": "Crafted for the woman who understands that true luxury whispers — in the press of pure linen, the weight of Italian crepe, the silence of a perfect silhouette."
    },
    {
      "type": "header",
      "content": "Block 3 — Bottom Image"
    },
    {
      "type": "image_picker",
      "id": "block3_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "block3_tag",
      "label": "Tag Text",
      "default": "Material"
    },
    {
      "type": "textarea",
      "id": "block3_heading",
      "label": "Heading",
      "default": "Italian Wool & Pure Linen.<br><span style=\"font-weight: 400; font-style: italic; color: rgba(255,255,255,0.7);\">Feel the difference.</span>"
    }
  ],
  "presets": [
    {
      "name": "Brand Story Bento"
    }
  ]
}
{% endschema %}
