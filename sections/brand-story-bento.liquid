<style>
  /* ═══════════════════════════════════════
     BRAND STORY BENTO — Fashion Showcase
  ═══════════════════════════════════════ */

  .bsb-section {
    position: relative;
    padding: 5rem 0 3rem;
    overflow: hidden;
    background-color: {{ section.settings.bg_color | default: '#f2f0ec' }};
    /* Subtle cross-hatch texture */
    background-image:
      linear-gradient(45deg, rgba(0,0,0,0.018) 25%, transparent 25%, transparent 75%, rgba(0,0,0,0.018) 75%),
      linear-gradient(45deg, rgba(0,0,0,0.018) 25%, transparent 25%, transparent 75%, rgba(0,0,0,0.018) 75%);
    background-size: 20px 20px;
    background-position: 0 0, 10px 10px;
  }

  /* ── Top Layout: text left + gallery right ── */
  .bsb-top {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 3rem;
    align-items: start;
    padding: 0 3rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* ── Left Text Panel ── */
  .bsb-text {
    padding-top: 2rem;
    position: sticky;
    top: 8rem;
  }

  .bsb-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: #0a0a0a;
    margin-bottom: 1.5rem;
  }

  .bsb-heading em {
    font-style: italic;
    font-weight: 800;
  }

  .bsb-desc {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.7;
    color: #555;
    max-width: 320px;
    margin-bottom: 2rem;
  }

  .bsb-cta-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .bsb-cta-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid #0a0a0a;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: #0a0a0a;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .bsb-cta-icon:hover {
    background-color: #0a0a0a;
    color: #fff;
  }

  .bsb-cta-btn {
    display: inline-block;
    padding: 0.7rem 1.6rem;
    border: 1.5px solid #0a0a0a;
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #0a0a0a;
    text-decoration: none;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .bsb-cta-btn:hover {
    background-color: #0a0a0a;
    color: #fff;
  }

  /* ── Right: Scrolling Gallery ── */
  .bsb-gallery-track {
    display: flex;
    gap: 2rem;
    will-change: transform;
  }

  /* ── Single Card ── */
  .bsb-card {
    flex: 0 0 420px;
    max-width: 420px;
  }

  .bsb-card-img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 3/4;
    border-radius: 16px;
    overflow: hidden;
    border: 4px solid rgba(255,255,255,0.8);
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
    background-color: #e8e5e0;
  }

  .bsb-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .bsb-card:hover .bsb-card-img {
    transform: scale(1.05);
  }

  /* Floating tag on image */
  .bsb-card-tag {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    background-color: rgba(255,255,255,0.92);
    backdrop-filter: blur(8px);
    padding: 0.5rem 0.85rem;
    border-radius: 10px;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    color: #0a0a0a;
    line-height: 1.4;
    max-width: 160px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }

  /* Card bottom: title + button */
  .bsb-card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0.25rem 1.25rem;
    border-bottom: 1.5px solid #c0bdb8;
  }

  .bsb-card-title {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
    color: #0a0a0a;
    letter-spacing: -0.01em;
  }

  .bsb-card-link {
    display: inline-block;
    padding: 0.5rem 1.2rem;
    border: 1.5px solid #0a0a0a;
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0a0a0a;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .bsb-card-link:hover {
    background-color: #0a0a0a;
    color: #fff;
  }

  /* ── Scroll progress line ── */
  .bsb-progress-wrap {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 3rem;
  }

  .bsb-progress {
    width: 100%;
    height: 2px;
    background-color: #d6d3ce;
    margin-top: 0.5rem;
    border-radius: 2px;
    overflow: hidden;
  }

  .bsb-progress-bar {
    height: 100%;
    width: 0%;
    background-color: #0a0a0a;
    border-radius: 2px;
    transition: width 0.1s linear;
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .bsb-section {
      padding: 3rem 0 2rem;
    }

    .bsb-top {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      padding: 0 1.25rem;
    }

    .bsb-text {
      position: static;
      padding-top: 0;
    }

    .bsb-heading {
      font-size: 2rem;
      margin-bottom: 1rem;
    }

    .bsb-desc {
      font-size: 0.8rem;
      margin-bottom: 1.5rem;
    }

    .bsb-gallery-track {
      gap: 1.25rem;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      padding-right: 1.25rem;
    }

    .bsb-gallery-track::-webkit-scrollbar {
      display: none;
    }

    .bsb-card {
      flex: 0 0 75vw;
      max-width: 75vw;
      scroll-snap-align: start;
    }

    .bsb-card-title {
      font-size: 0.95rem;
    }

    .bsb-card-link {
      font-size: 0.6rem;
      padding: 0.4rem 0.9rem;
    }

    .bsb-progress-wrap {
      padding: 0 1.25rem;
    }
  }

  /* ── Tablet ── */
  @media (min-width: 768px) and (max-width: 1024px) {
    .bsb-top {
      grid-template-columns: 300px 1fr;
      gap: 2rem;
      padding: 0 2rem;
    }

    .bsb-card {
      flex: 0 0 340px;
      max-width: 340px;
    }

    .bsb-progress-wrap {
      padding: 0 2rem;
    }
  }
</style>

<section class="bsb-section" id="brand-story-bento">

  <!-- ── Top: Text + Gallery ── -->
  <div class="bsb-top">

    <!-- Left: Text Panel -->
    <div class="bsb-text">
      <h2 class="bsb-heading">
        {{ section.settings.heading }}
      </h2>
      <p class="bsb-desc">
        {{ section.settings.description }}
      </p>
      <div class="bsb-cta-wrap">
        <a href="{{ section.settings.button_url | default: '#' }}" class="bsb-cta-icon" aria-label="Explore">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 7 10 10"/><path d="M17 7v10H7"/></svg>
        </a>
        <a href="{{ section.settings.button_url | default: '#' }}" class="bsb-cta-btn">
          {{ section.settings.button_text | default: 'Explore More' }}
        </a>
      </div>
    </div>

    <!-- Right: Gallery Track -->
    <div style="overflow: hidden;">
      <div class="bsb-gallery-track" id="bsb-gallery-track">
        {% for block in section.blocks %}
          {% if block.type == 'image_card' %}
            <div class="bsb-card" {{ block.shopify_attributes }}>
              <!-- Image -->
              <div class="bsb-card-img-wrap">
                {% if block.settings.image != blank %}
                  <img
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    alt="{{ block.settings.image.alt | default: block.settings.title }}"
                    class="bsb-card-img"
                    loading="lazy"
                    width="800"
                    height="1067"
                  />
                {% else %}
                  <div style="width:100%;height:100%;background:#ddd;display:flex;align-items:center;justify-content:center;color:#999;font-size:0.8rem;">
                    Upload Image
                  </div>
                {% endif %}

                {% if block.settings.tag_text != blank %}
                  <div class="bsb-card-tag">{{ block.settings.tag_text }}</div>
                {% endif %}
              </div>

              <!-- Title + Button -->
              <div class="bsb-card-bottom">
                <h3 class="bsb-card-title">{{ block.settings.title }}</h3>
                <a href="{{ block.settings.button_url | default: '#' }}" class="bsb-card-link">
                  {{ block.settings.button_text | default: 'Shop Now' }}
                </a>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

  </div>

  <!-- Progress Bar -->
  <div class="bsb-progress-wrap">
    <div class="bsb-progress">
      <div class="bsb-progress-bar" id="bsb-progress-bar"></div>
    </div>
  </div>

</section>

<script>
  /* ═══════════════════════════════════════════════════
     BRAND STORY BENTO — Scroll-Driven Gallery
  ═══════════════════════════════════════════════════ */

  gsap.registerPlugin(ScrollTrigger);

  (function initBentoGallery() {
    var track = document.getElementById('bsb-gallery-track');
    var progressBar = document.getElementById('bsb-progress-bar');
    var section = document.getElementById('brand-story-bento');
    if (!track || !section) return;

    var isMobile = window.innerWidth < 768;

    if (!isMobile) {
      /* Desktop: scroll-driven horizontal slide */
      var cards = track.querySelectorAll('.bsb-card');
      if (cards.length === 0) return;

      /* Calculate how far to scroll */
      function getScrollAmount() {
        return -(track.scrollWidth - track.parentElement.offsetWidth);
      }

      var tween = gsap.to(track, {
        x: getScrollAmount,
        ease: 'none',
        scrollTrigger: {
          trigger: section,
          start: 'top 20%',
          end: function () { return '+=' + Math.abs(getScrollAmount()); },
          scrub: 1,
          pin: true,
          invalidateOnRefresh: true,
          onUpdate: function (self) {
            if (progressBar) {
              progressBar.style.width = (self.progress * 100) + '%';
            }
          }
        }
      });

      /* Entry animation for cards */
      gsap.fromTo(cards,
        { y: 60, opacity: 0 },
        {
          y: 0, opacity: 1,
          duration: 0.8,
          ease: 'power3.out',
          stagger: 0.12,
          scrollTrigger: {
            trigger: section,
            start: 'top 75%',
            once: true
          }
        }
      );

      /* Entry animation for text */
      gsap.fromTo('.bsb-text',
        { y: 40, opacity: 0 },
        {
          y: 0, opacity: 1,
          duration: 1,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: section,
            start: 'top 80%',
            once: true
          }
        }
      );
    } else {
      /* Mobile: simple entry animation only */
      gsap.fromTo('.bsb-text',
        { y: 20, opacity: 0 },
        {
          y: 0, opacity: 1,
          duration: 0.6,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: section,
            start: 'top 90%',
            once: true
          }
        }
      );

      gsap.fromTo('.bsb-card',
        { y: 20, opacity: 0 },
        {
          y: 0, opacity: 1,
          duration: 0.5,
          ease: 'power3.out',
          stagger: 0.08,
          scrollTrigger: {
            trigger: track,
            start: 'top 90%',
            once: true
          }
        }
      );
    }
  }());
</script>

{% schema %}
{
  "name": "Brand Story Bento",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Text Content"
    },
    {
