{% comment %}
  ─────────────────────────────────────────
  CART DRAWER SECTION WRAPPER
  Exists so Shopify Section Rendering API can serve:
    fetch('/?sections=cart-drawer')
  The actual markup lives in snippets/cart-drawer.liquid.
  In layout/theme.liquid use:
    {% section 'cart-drawer' %}
  ─────────────────────────────────────────
{% endcomment %}

{% render 'cart-drawer', gift_wrap_variant_id: section.settings.gift_wrap_variant_id %}

{% schema %}
{
  "name": "Cart Drawer",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "gift_wrap_variant_id",
      "label": "Gift wrap variant ID",
      "info": "Enter the Shopify variant ID used for gift wrap item."
    }
  ]
}
{% endschema %}
