{%- liquid
  assign section_id = 'custom-liquid-' | append: section.id
  assign max_width = section.settings.max_width | default: 1200
-%}

<section
  id="{{ section_id }}"
  class="custom-liquid-section"
  style="background: {{ section.settings.background_color }};"
>
  <div
    class="custom-liquid-section__inner{% if section.settings.full_width %} custom-liquid-section__inner--full{% endif %}"
    style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
  >
    <div
      class="custom-liquid-section__content"
      style="max-width:{% if section.settings.full_width %}100%{% else %}{{ max_width }}px{% endif %}; margin: 0 auto;"
    >
      {{ section.settings.custom_liquid }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Liquid",
  "settings": [
    {
      "type": "liquid",
      "id": "custom_liquid",
      "label": "Custom Liquid",
      "info": "Add custom Liquid, HTML, or app snippets."
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Content max width",
      "min": 480,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1200,
      "info": "Used when Full width is off."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Custom Liquid"
    }
  ]
}
{% endschema %}
