<style>
  /* ─── Featured Collection ─── */

  /* Section heading underline accent */
  .fc-heading::after {
    content: '';
    display: block;
    width: 40px;
    height: 1.5px;
    background-color: var(--color-accent);
    margin: 1rem auto 0;
  }

  /* Product name subtle hover */
  .product-title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: #222222;
    transition: color 250ms ease;
    line-height: 1.25;
  }

  .product-card:hover .product-title {
    color: var(--color-accent);
  }

  /* Price */
  .product-price {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    margin-top: 0.35rem;
  }

  /* Quick View button */
  .quick-view-btn {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    background-color: #ffffff;
    color: var(--color-text);
    border: none;
    border-radius: 9999px;
    padding: 0.45rem 1rem 0.45rem 0.65rem;
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
    /* MAYA: default hidden, slide-up on hover */
    opacity: 0;
    transform: translateY(15px);
    transition:
      opacity 0.5s cubic-bezier(0.25, 1, 0.5, 1) 0.1s,
      transform 0.5s cubic-bezier(0.25, 1, 0.5, 1) 0.1s,
      background-color 250ms ease,
      color 250ms ease,
      box-shadow 250ms ease;
    will-change: transform, opacity;
  }

  .quick-view-btn:hover {
    background-color: var(--color-accent);
    color: #ffffff;
    box-shadow: 0 4px 18px rgba(197, 168, 128, 0.35);
  }

  /* ═══ MAYA Product Card Hover System ═══ */
  .pc-img-primary,
  .pc-img-secondary {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    will-change: transform, opacity;
  }

  .pc-img-primary {
    opacity: 1;
    transform: scale(1);
    transition:
      opacity 1.2s cubic-bezier(0.25, 1, 0.5, 1),
      transform 1.2s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .pc-img-secondary {
    opacity: 0;
    transform: scale(1.03);
    transition:
      opacity 1.2s cubic-bezier(0.25, 1, 0.5, 1),
      transform 1.2s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* ── Hover state ── */
  .product-card:hover .pc-img-primary {
    opacity: 0;
    transform: scale(1.08);
  }

  .product-card:hover .pc-img-secondary {
    opacity: 1;
    transform: scale(1);
  }

  .product-card:hover .quick-view-btn {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<section id="featured-collection" class="py-16 md:py-32 lg:py-40" style="background-color: var(--color-bg);">
  <style>
    @media (max-width: 767px) {
      #featured-collection { padding-top: 3rem; padding-bottom: 3rem; }
      #featured-collection .text-center.mb-16 { margin-bottom: 2.5rem; }
      #featured-collection .text-center.mt-16 { margin-top: 2.5rem; }
    }
  </style>
  <div class="max-w-screen-xl mx-auto px-6 md:px-10">

    <!-- Section Heading -->
    <div class="text-center mb-16">
      <h2
        class="fc-heading"
        id="fc-heading"
        style="
          font-family: var(--font-heading);
          font-size: clamp(2rem, 5vw, 3.5rem);
          font-weight: 600;
          letter-spacing: 0.12em;
          text-transform: uppercase;
          color: var(--color-text);
          overflow: hidden;
        "
      >
        {{ section.settings.heading }}
      </h2>
    </div>

    <!-- Product Grid -->
    <div id="fc-grid" class="grid grid-cols-2 md:grid-cols-4 gap-x-4 gap-y-8 md:gap-x-12 md:gap-y-16">

      {%- assign collection = section.settings.collection -%}
      {%- assign limit = section.settings.products_count -%}

      {% if collection != blank and collection.products.size > 0 %}

        {% for product in collection.products limit: limit %}
          <!-- Product Card #{{ forloop.index }} -->
          <a
            href="{{ product.url }}"
            class="product-card group block cursor-pointer"
            aria-label="{{ product.title }}"
          >

            <!-- ── Image Wrapper ── -->
            <div
              class="relative aspect-[3/4] overflow-hidden bg-gray-50"
              style="border-radius: 2px;"
            >

              <!-- Primary Image -->
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  class="pc-img-primary"
                  loading="lazy"
                  width="600"
                  height="800"
                />
              {% endif %}

              <!-- Hover / Second Image -->
              {% if product.images.size > 1 %}
                <img
                  src="{{ product.images[1] | image_url: width: 600 }}"
                  alt="{{ product.title | escape }} — lifestyle"
                  class="pc-img-secondary"
                  loading="lazy"
                  width="600"
                  height="800"
                />
              {% endif %}

              <!-- Quick View Button -->
              <button
                class="quick-view-btn"
                aria-label="Quick view {{ product.title | escape }}"
                onclick="event.preventDefault(); event.stopPropagation();"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
                Quick View
              </button>

            </div>
            <!-- ── / Image Wrapper ── -->

            <!-- ── Product Info ── -->
            <div class="text-center mt-6">
              <p class="product-title">{{ product.title }}</p>
              <p class="product-price">{{ product.price | money }}</p>
            </div>
            <!-- ── / Product Info ── -->

          </a>
          <!-- / Product Card #{{ forloop.index }} -->

        {% endfor %}

      {% else %}

        {%- comment -%} Placeholder cards when no collection assigned {%- endcomment -%}
        {% for i in (1..8) %}
          <div class="product-card group block">
            <div class="relative aspect-[3/4] overflow-hidden bg-gray-100" style="border-radius: 2px;">
              <div class="flex items-center justify-center h-full text-gray-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
                  <circle cx="9" cy="9" r="2"/>
                  <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
                </svg>
              </div>
            </div>
            <div class="text-center mt-6">
              <p class="product-title" style="color: var(--color-muted);">Select a collection</p>
              <p class="product-price" style="color: var(--color-border);">in theme settings</p>
            </div>
          </div>
        {% endfor %}

      {% endif %}

    </div>
    <!-- / Product Grid -->

    <!-- View All CTA -->
    {% if collection != blank %}
      <div class="text-center mt-16">
        <a
          href="{{ collection.url }}"
          style="
            display: inline-block;
            padding: 0.85rem 3rem;
            border: 1px solid var(--color-text);
            font-family: var(--font-body);
            font-size: 0.65rem;
            letter-spacing: 0.22em;
            text-transform: uppercase;
            color: var(--color-text);
            border-radius: 9999px;
            text-decoration: none;
            transition: background-color 350ms ease, color 350ms ease, border-color 350ms ease;
          "
          onmouseover="this.style.backgroundColor='var(--color-text)';this.style.color='var(--color-bg)';"
          onmouseout="this.style.backgroundColor='transparent';this.style.color='var(--color-text)';"
        >
          {{ section.settings.cta_text }}
        </a>
      </div>
    {% endif %}

  </div>
</section>

<script>
  /* ─────────────────────────────────────────────────────
     FEATURED COLLECTION — Water Slide In Animation
     Scroll Down → characters slide up with wave stagger
     Scroll Up   → heading fades out smoothly
  ───────────────────────────────────────────────────── */

  gsap.registerPlugin(ScrollTrigger);

  /* ── Water Slide: Split heading into characters ── */
  (function () {
    const heading = document.getElementById('fc-heading');
    if (!heading) return;

    const text = heading.textContent.trim();
    heading.innerHTML = '';

    /* Split every character into a span inside a wrapper (for overflow clip) */
    text.split('').forEach(function (char) {
      const wrapper = document.createElement('span');
      wrapper.style.display = 'inline-block';
      wrapper.style.overflow = 'hidden';
      wrapper.style.verticalAlign = 'top';

      const span = document.createElement('span');
      span.textContent = char === ' ' ? '\u00A0' : char;
      span.style.display = 'inline-block';
      span.style.willChange = 'transform, opacity';
      span.className = 'fc-char';

      wrapper.appendChild(span);
      heading.appendChild(wrapper);
    });

    const chars = heading.querySelectorAll('.fc-char');

    let mm = gsap.matchMedia();

    /* ── Desktop: full water slide ── */
    mm.add('(min-width: 768px)', function () {
      /* Initial state: hidden below */
      gsap.set(chars, { y: '110%', opacity: 0 });

      /* Scroll down → Water Slide In */
      ScrollTrigger.create({
        trigger: '#featured-collection',
        start: 'top 80%',
        onEnter: function () {
          gsap.to(chars, {
            y: '0%',
            opacity: 1,
            duration: 1.0,
            stagger: 0.03,
            ease: 'expo.out',
          });
        },
        /* Scroll up → Fade Out */
        onLeaveBack: function () {
          gsap.to(chars, {
            y: '110%',
            opacity: 0,
            duration: 0.5,
            stagger: 0.015,
            ease: 'power2.in',
          });
        },
      });
    });

    /* ── Mobile: lighter version ── */
    mm.add('(max-width: 767px)', function () {
      gsap.set(chars, { y: '100%', opacity: 0 });

      ScrollTrigger.create({
        trigger: '#featured-collection',
        start: 'top 90%',
        onEnter: function () {
          gsap.to(chars, {
            y: '0%',
            opacity: 1,
            duration: 0.7,
            stagger: 0.02,
            ease: 'expo.out',
          });
        },
        onLeaveBack: function () {
          gsap.to(chars, {
            y: '100%',
            opacity: 0,
            duration: 0.35,
            stagger: 0.01,
            ease: 'power2.in',
          });
        },
      });
    });
  }());

  /* ── Product Cards animation (unchanged) ── */
  (function () {
    let mm2 = gsap.matchMedia();

    mm2.add('(min-width: 768px)', function () {
      gsap.fromTo('#fc-grid .product-card',
        { y: 60, opacity: 0, immediateRender: false },
        {
          scrollTrigger: { trigger: '#fc-grid', start: 'top 85%', once: true },
          y: 0, opacity: 1, duration: 1.4, stagger: 0.15, ease: 'power3.out',
        }
      );
    });

    mm2.add('(max-width: 767px)', function () {
      gsap.fromTo('#fc-grid .product-card',
        { y: 20, opacity: 0, immediateRender: false },
        {
          scrollTrigger: { trigger: '#fc-grid', start: 'top 90%', once: true },
          y: 0, opacity: 1, duration: 0.8, stagger: 0.05, ease: 'power3.out',
        }
      );
    });
  }());

</script>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trending Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "View All"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
