<style>
  /* ─── Featured Collection ─── */

  /* Section heading underline accent */
  .fc-heading::after {
    content: '';
    display: block;
    width: 40px;
    height: 1.5px;
    background-color: var(--color-accent);
    margin: 1rem auto 0;
  }

  /* Staggered entrance animation */
  @keyframes cardFadeUp {
    from {
      opacity: 0;
      transform: translateY(32px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .product-card {
    animation: cardFadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Stagger delays for 8 cards */
  .product-card:nth-child(1) { animation-delay: 0.05s; }
  .product-card:nth-child(2) { animation-delay: 0.12s; }
  .product-card:nth-child(3) { animation-delay: 0.19s; }
  .product-card:nth-child(4) { animation-delay: 0.26s; }
  .product-card:nth-child(5) { animation-delay: 0.33s; }
  .product-card:nth-child(6) { animation-delay: 0.40s; }
  .product-card:nth-child(7) { animation-delay: 0.47s; }
  .product-card:nth-child(8) { animation-delay: 0.54s; }

  /* Product name subtle hover */
  .product-title {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    color: var(--color-text);
    transition: color 250ms ease;
  }

  .product-card:hover .product-title {
    color: var(--color-accent);
  }

  /* Price */
  .product-price {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    margin-top: 0.35rem;
  }

  /* Quick View button */
  .quick-view-btn {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    background-color: #ffffff;
    color: var(--color-text);
    border: none;
    border-radius: 9999px;
    padding: 0.45rem 1rem 0.45rem 0.65rem;
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
    transition:
      background-color 250ms ease,
      color 250ms ease,
      box-shadow 250ms ease;
  }

  .quick-view-btn:hover {
    background-color: var(--color-accent);
    color: #ffffff;
    box-shadow: 0 4px 18px rgba(197, 168, 128, 0.35);
  }
</style>

