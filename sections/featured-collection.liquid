{% comment %} Featured Collection — Revamped Trending Products UI {% endcomment %}

{%- liquid
  assign fc_section_id = 'fcv2-' | append: section.id
  assign fc_source = section.settings.product_list
  assign fc_limit = section.settings.max_products | default: 12
  if fc_source == blank and section.settings.collection != blank
    assign fc_source = section.settings.collection.products
  endif

  assign fc_initial = section.settings.items_initial | default: 4
  assign fc_per_load = section.settings.items_per_load | default: 4
  assign fc_more_label = section.settings.more_label | default: 'More'
  assign fc_heading_line_1 = section.settings.heading_line_1 | default: 'TRENDING'
  assign fc_heading_line_2 = section.settings.heading_line_2 | default: 'PRODUCTS'
  assign fc_eyebrow = section.settings.eyebrow | default: 'Curated selections from our digital atelier.'
  assign fc_helper_text = section.settings.helper_text | default: 'Hover cards to reveal Quick View • Tap thumbnails to switch color'
  assign fc_quick_view_label = section.settings.quick_view_label | default: 'Quick View'
  assign fc_modal_quantity_label = section.settings.modal_quantity_label | default: 'Quantity'
  assign fc_modal_add_to_cart_label = section.settings.modal_add_to_cart_label | default: 'Add to cart'
  assign fc_modal_buy_now_label = section.settings.modal_buy_now_label | default: 'Buy it now'
  assign fc_sale_badge_label = section.settings.sale_badge_label | default: 'SALE'
  assign fc_new_badge_label = section.settings.new_badge_label | default: 'NEW'
  assign fc_sold_out_badge_label = section.settings.sold_out_badge_label | default: 'SOLD OUT'
  assign fc_show_quick_view = section.settings.show_quick_view
  assign fc_show_badges = section.settings.show_badges
  assign fc_show_swatches = section.settings.show_swatches
  assign fc_show_modal_gallery_controls = section.settings.show_modal_gallery_controls
  assign fc_modal_close_label = section.settings.modal_close_label | default: 'Close quick view'
  assign fc_modal_prev_label = section.settings.modal_prev_label | default: 'Previous image'
  assign fc_modal_next_label = section.settings.modal_next_label | default: 'Next image'
  assign fc_qty_decrease_label = section.settings.qty_decrease_label | default: 'Decrease quantity'
  assign fc_qty_increase_label = section.settings.qty_increase_label | default: 'Increase quantity'
  assign fc_show_qty_selector = section.settings.show_qty_selector
  assign fc_show_buy_now_button = section.settings.show_buy_now_button
  assign fc_show_compare_price_in_modal = section.settings.show_compare_price_in_modal
  assign fc_show_variant_picker_in_modal = section.settings.show_variant_picker_in_modal
  assign fc_swatches_limit = section.settings.swatches_limit | default: 5
-%}

<featured-collection class="fcv2 block relative overflow-hidden" data-section-id="{{ section.id }}">
  <div class="fcv2__header">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'section_heading' %}
            <div class="fcv2__heading-row" {{ block.shopify_attributes }}>
              {% if block.settings.section_index != blank %}
                <span class="fcv2__index">{{ block.settings.section_index }}</span>
              {% endif %}
              <h2 class="fcv2__heading" aria-label="{{ block.settings.heading_line_1 | default: fc_heading_line_1 }} {{ block.settings.heading_line_2 | default: fc_heading_line_2 }}">
                <span class="fcv2__heading-line fcv2__heading-line--top">{{ block.settings.heading_line_1 | default: fc_heading_line_1 }}</span>
                <span class="fcv2__heading-line fcv2__heading-line--bottom">{{ block.settings.heading_line_2 | default: fc_heading_line_2 }}</span>
              </h2>
            </div>
          {% when 'section_eyebrow' %}
            <p class="fcv2__eyebrow" {{ block.shopify_attributes }}>{{ block.settings.text | default: fc_eyebrow }}</p>
          {% when 'helper_note' %}
            {% if block.settings.text != blank %}
              <p class="fcv2__eyebrow" style="margin-top: 0.9rem; color:#7a7978;" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
            {% endif %}
        {% endcase %}
      {% endfor %}
    {% else %}
      <div class="fcv2__heading-row">
        <span class="fcv2__index">01</span>
        <h2 class="fcv2__heading" aria-label="{{ fc_heading_line_1 }} {{ fc_heading_line_2 }}">
          <span class="fcv2__heading-line fcv2__heading-line--top">{{ fc_heading_line_1 }}</span>
          <span class="fcv2__heading-line fcv2__heading-line--bottom">{{ fc_heading_line_2 }}</span>
        </h2>
      </div>
      <p class="fcv2__eyebrow">{{ fc_eyebrow }}</p>
      {% if fc_helper_text != blank %}
        <p class="fcv2__eyebrow" style="margin-top: 0.9rem; color:#7a7978;">{{ fc_helper_text }}</p>
      {% endif %}
    {% endif %}
    <div class="fcv2__header-rule"></div>
  </div>

  <div class="fcv2__body">
    <div
      class="fcv2__track"
      id="fcv2-track"
      role="list"
      aria-label="Trending products"
      data-fc-initial="{{ fc_initial }}"
      data-fc-per-load="{{ fc_per_load }}"
    >
      {%- if fc_source != blank -%}
        {%- for product in fc_source limit: fc_limit -%}
          {%- assign product_subtitle = product.metafields.custom.card_subtitle.value | default: product.metafields.custom.subtitle.value | default: '' -%}

          {%- assign variants_json = '[' -%}
          {%- for variant in product.variants -%}
            {%- assign variant_img = '' -%}
            {%- assign variant_swatch = '' -%}
            {%- if variant.featured_image != blank -%}
              {%- assign variant_img = variant.featured_image | image_url: width: 900 -%}
              {%- assign variant_swatch = variant.featured_image | image_url: width: 120 -%}
            {%- elsif product.images[forloop.index0] != blank -%}
              {%- assign variant_img = product.images[forloop.index0] | image_url: width: 900 -%}
              {%- assign variant_swatch = product.images[forloop.index0] | image_url: width: 120 -%}
            {%- elsif product.featured_image != blank -%}
              {%- assign variant_img = product.featured_image | image_url: width: 900 -%}
              {%- assign variant_swatch = product.featured_image | image_url: width: 120 -%}
            {%- endif -%}
            {%- assign variant_compare = variant.compare_at_price | default: 0 -%}
            {%- capture variant_entry -%}
              {"id":{{ variant.id | json }},"title":{{ variant.title | json }},"price":{{ variant.price }},"compare":{{ variant_compare }},"available":{{ variant.available }},"img":{{ variant_img | json }},"swatch":{{ variant_swatch | json }},"option1":{{ variant.option1 | json }},"option2":{{ variant.option2 | json }},"option3":{{ variant.option3 | json }}}
            {%- endcapture -%}
            {%- assign variants_json = variants_json | append: variant_entry | strip_newlines -%}
            {%- unless forloop.last -%}{%- assign variants_json = variants_json | append: ',' -%}{%- endunless -%}
          {%- endfor -%}
          {%- assign variants_json = variants_json | append: ']' -%}

          {%- assign images_json = '[' -%}
          {%- for image in product.images limit: 8 -%}
            {%- capture image_entry -%}{{ image | image_url: width: 900 | json }}{%- endcapture -%}
            {%- assign images_json = images_json | append: image_entry -%}
            {%- unless forloop.last -%}{%- assign images_json = images_json | append: ',' -%}{%- endunless -%}
          {%- endfor -%}
          {%- assign images_json = images_json | append: ']' -%}

          {%- assign featured_variant = product.selected_or_first_available_variant -%}
          {%- assign main_image = featured_variant.featured_media.preview_image | default: product.featured_media.preview_image -%}
          {%- assign badge_label = '' -%}
          {%- if product.compare_at_price_max > product.price -%}
            {%- assign badge_label = fc_sale_badge_label -%}
          {%- elsif product.tags contains 'new' or product.tags contains 'NEW' -%}
            {%- assign badge_label = fc_new_badge_label -%}
          {%- endif -%}

          <article
            class="fcv2__card"
            role="listitem"
            data-fcv2-card
            data-product-id="{{ product.id }}"
            data-product-title="{{ product.title | escape }}"
            data-product-subtitle="{{ product_subtitle | escape }}"
            data-product-url="{{ product.url }}"
            data-product-money="{{ product.price | money }}"
            data-product-compare-money="{{ product.compare_at_price_min | money }}"
            data-product-variants="{{ variants_json | escape }}"
            data-product-images="{{ images_json | escape }}"
          >
            <div class="fcv2__media-wrap">
              <a href="{{ product.url }}" class="fcv2__image-link" tabindex="-1" aria-hidden="true">
                {% if main_image != blank %}
                  {{ main_image | image_url: width: 900 | image_tag:
                    class: 'fcv2__image',
                    loading: 'lazy',
                    widths: '300, 450, 600, 900',
                    sizes: '(max-width: 767px) 72vw, (max-width: 1023px) 40vw, 300px',
                    alt: product.title,
                    width: main_image.width,
                    height: main_image.height
                  }}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'fcv2__image fcv2__image--placeholder' }}
                {% endif %}
              </a>

              {% if badge_label != blank %}
                <div class="fcv2__badge{% if badge_label == 'SALE' %} is-sale{% else %} is-new{% endif %}">
                  {% if badge_label == 'SALE' %}<span class="fcv2__badge-ring" aria-hidden="true"></span>{% endif %}
                  <span class="fcv2__badge-pill">{{ badge_label }}</span>
                  {% if badge_label == 'NEW' %}<span class="fcv2__badge-shimmer" aria-hidden="true"></span>{% endif %}
                </div>
              {% endif %}

              <button type="button" class="fcv2__quick-view" data-card-id="{{ product.id }}" aria-label="{{ fc_quick_view_label }} {{ product.title | escape }}">
                <span>{{ fc_quick_view_label }}</span>
                <span class="fcv2__quick-view-plus" aria-hidden="true">+</span>
              </button>
            </div>

            <div class="fcv2__content">
              <div class="fcv2__title-wrap">
                <a href="{{ product.url }}" class="fcv2__title-row">
                  <span class="fcv2__title">{{ product.title }}</span>
                </a>
                <button type="button" class="fcv2__wishlist" aria-label="Wishlist" data-fcv2-wishlist>
                  <span class="fcv2__wishlist-burst" aria-hidden="true"></span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 21-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.18Z"/></svg>
                </button>
              </div>

              <div class="fcv2__price-row">
                <span class="fcv2__price">{{ product.price | money }}</span>
                {% if product.compare_at_price_min > product.price %}
                  <span class="fcv2__compare">{{ product.compare_at_price_min | money }}</span>
                {% endif %}
              </div>

              {% if product.variants.size > 1 %}
                {% if fc_show_swatches %}<div class="fcv2__swatches">
                  {% for variant in product.variants limit: 6 %}
                    {% liquid
                      assign swatch_image = variant.featured_media.preview_image | default: product.images[forloop.index0] | default: product.featured_media.preview_image
                    %}
                    <button
                      type="button"
                      class="fcv2__swatch{% if forloop.first %} is-active{% endif %}"
                      aria-label="{{ variant.title | escape }}"
                      data-variant-id="{{ variant.id }}"
                    >
                      {% if swatch_image != blank %}
                        {{ swatch_image | image_url: width: 120 | image_tag:
                          class: 'fcv2__swatch-image',
                          loading: 'lazy',
                          alt: variant.title,
                          width: swatch_image.width,
                          height: swatch_image.height
                        }}
                      {% else %}
                        <span class="fcv2__swatch-fallback">{{ variant.option1 | default: variant.title | slice: 0, 1 }}</span>
                      {% endif %}
                    </button>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div class="fcv2__progress-wrap">
      <div class="fcv2__pager" id="{{ fc_section_id }}-pager" aria-hidden="true"></div>
    </div>

    <div class="fcv2__more-wrap" id="{{ fc_section_id }}-more-wrap"{% if fc_source == blank %} style="display:none"{% endif %}>
      <button type="button" class="fcv2__more-btn" id="{{ fc_section_id }}-more-btn" aria-label="{{ fc_more_label }}">
        <span>{{ fc_more_label }}</span>
        <span class="fcv2__more-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
        </span>
      </button>
    </div>

  </div>
</featured-collection>

<div id="{{ fc_section_id }}-qv-modal" class="fcv2-modal" role="dialog" aria-modal="true" aria-hidden="true" aria-label="Quick view">
  <button class="fcv2-modal__backdrop" id="{{ fc_section_id }}-qv-backdrop" aria-label="{{ fc_modal_close_label }}"></button>
  <div class="fcv2-modal__panel" id="{{ fc_section_id }}-qv-panel" role="document">
    <div class="fcv2-modal__header">
      <div class="fcv2-modal__handle"></div>
      <button class="fcv2-modal__close" id="{{ fc_section_id }}-qv-close-btn" aria-label="{{ fc_modal_close_label }}">×</button>
    </div>
    <div class="fcv2-modal__scroll">
      <div class="fcv2-modal__gallery-shell">
        <div class="fcv2-modal__gallery-track" id="{{ fc_section_id }}-qv-gallery-track"></div>
        <button class="fcv2-modal__arrow is-prev" id="{{ fc_section_id }}-qv-prev" aria-label="{{ fc_modal_prev_label }}">‹</button>
        <button class="fcv2-modal__arrow is-next" id="{{ fc_section_id }}-qv-next" aria-label="{{ fc_modal_next_label }}">›</button>
        <div class="fcv2-modal__dots" id="{{ fc_section_id }}-qv-dots"></div>
      </div>
      <div class="fcv2-modal__info">
        <a href="#" class="fcv2-modal__title" id="{{ fc_section_id }}-qv-title"></a>
        <div class="fcv2-modal__price-row">
          <span class="fcv2-modal__price" id="{{ fc_section_id }}-qv-price"></span>
          <span class="fcv2-modal__compare hidden" id="{{ fc_section_id }}-qv-compare"></span>
        </div>
        {% if fc_show_variant_picker_in_modal %}<div class="fcv2-modal__variants" id="{{ fc_section_id }}-qv-variants"></div>{% endif %}
        <div class="fcv2-modal__qty-row" id="{{ fc_section_id }}-qv-qty-row">
          <span class="fcv2-modal__qty-label">{{ fc_modal_quantity_label }}</span>
          <div class="fcv2-modal__qty-ctrl">
            <button type="button" id="{{ fc_section_id }}-qv-qty-dec" aria-label="{{ fc_qty_decrease_label }}">−</button>
            <span id="{{ fc_section_id }}-qv-qty-val">1</span>
            <button type="button" id="{{ fc_section_id }}-qv-qty-inc" aria-label="{{ fc_qty_increase_label }}">+</button>
          </div>
        </div>
      </div>
    </div>
    <div class="fcv2-modal__footer">
      <button type="button" class="fcv2-modal__button is-secondary" id="{{ fc_section_id }}-qv-atc">{{ fc_modal_add_to_cart_label }}</button>
      {% if fc_show_buy_now_button %}<button type="button" class="fcv2-modal__button is-primary" id="{{ fc_section_id }}-qv-bin">{{ fc_modal_buy_now_label }}</button>{% endif %}
    </div>
  </div>
</div>

<style>
.fcv2 {
  position: relative;
  background: #f8f7f3;
  color: #1a1c1b;
}

.fcv2::before {
  content: 'CELISIRA';
  position: absolute;
  left: 50%;
  top: 52%;
  transform: translate(-50%, -50%) rotate(-46deg);
  font-family: var(--font-heading-family, var(--font-body-family));
  font-size: min(22vw, 300px);
  color: rgba(26, 28, 27, 0.03);
  letter-spacing: 0.02em;
  white-space: nowrap;
  pointer-events: none;
  z-index: 0;
}

.fcv2__eyebrow {
  margin: 0;
  max-width: 58ch;
  color: #5f5e5e;
  font-family: var(--font-heading-family, var(--font-body-family));
  font-size: 16px;
  font-style: italic;
  font-weight: 400;
  line-height: 1.46;
}

.fcv2__header {
  position: relative;
  z-index: 1;
  max-width: 1520px;
  margin: 0 auto;
  padding: 56px 24px 0;
}

.fcv2__heading-row {
  display: flex;
  align-items: baseline;
  gap: 14px;
}

.fcv2__index {
  color: #8d8478;
  font-family: var(--font-heading-family, var(--font-body-family));
  font-size: 10px;
  font-style: italic;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  flex: 0 0 auto;
}

.fcv2__heading {
  margin: 0;
  color: #1a1c1b;
  font-family: var(--font-heading, var(--font-heading-family, serif));
  font-size: clamp(2.05rem, 5.3vw, 3.35rem);
  font-weight: 500;
  letter-spacing: -0.02em;
  line-height: 0.98;
  text-transform: uppercase;
}

.fcv2__heading-line {
  display: inline;
}

.fcv2__heading-line--bottom::before {
  content: ' ';
}

.fcv2__header-rule {
  height: 1px;
  margin-top: 20px;
  background: rgba(127, 118, 106, 0.28);
}

.fcv2__body {
  position: relative;
  z-index: 1;
  max-width: 1520px;
  margin: 0 auto;
  padding: 32px 0 54px;
}

.fcv2__track {
  display: flex;
  gap: 22px;
  overflow-x: auto;
  overflow-y: hidden;
  padding: 0 24px 10px;
  scroll-behavior: smooth;
  scroll-snap-type: x mandatory;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.fcv2__track::-webkit-scrollbar {
  display: none;
}

.fcv2__card {
  flex: 0 0 auto;
  width: min(85vw, 318px);
  max-width: calc(100vw - 48px);
  scroll-snap-align: center;
}

.fcv2__media-wrap {
  position: relative;
  aspect-ratio: 3 / 4;
  overflow: hidden;
  border-radius: 0;
  background: #efeeec;
  transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}

.fcv2__image-link,
.fcv2__image,
.fcv2__image--placeholder {
  display: block;
  width: 100%;
  height: 100%;
}

.fcv2__image {
  object-fit: cover;
  filter: grayscale(0.12);
  transition: transform 0.65s cubic-bezier(0.22, 1, 0.36, 1), filter 0.4s ease;
}

.fcv2__card:hover .fcv2__image,
.fcv2__card:focus-within .fcv2__image {
  transform: scale(1.028);
  filter: grayscale(0);
}

.fcv2__badge {
  position: absolute;
  top: 12px;
  right: 12px;
  z-index: 2;
}

.fcv2__badge-pill {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 20px;
  padding: 0 10px;
  border-radius: 999px;
  font-family: var(--font-body-family);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.17em;
  text-transform: uppercase;
}

.fcv2__badge.is-sale .fcv2__badge-pill {
  background: rgba(197, 168, 128, 0.9);
  color: #513d1d;
}

.fcv2__badge-ring {
  display: none;
}

.fcv2__badge.is-new {
  overflow: hidden;
  border-radius: 999px;
}

.fcv2__badge.is-new .fcv2__badge-pill {
  background: rgba(255, 255, 255, 0.92);
  color: #1a1c1b;
}

.fcv2__badge-shimmer {
  display: none;
}

.fcv2__wishlist {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  color: #7f766a;
  cursor: pointer;
  transition: color 0.24s ease;
}

.fcv2__wishlist-burst,
.fcv2__wishlist-burst::before,
.fcv2__wishlist-burst::after {
  content: '';
  position: absolute;
  width: 6px;
  height: 6px;
  border-radius: 999px;
  background: #ef4444;
  opacity: 0;
}

.fcv2__wishlist.is-liked .fcv2__wishlist-burst {
  animation: fcv2-burst-1 0.55s ease-out;
}
.fcv2__wishlist.is-liked .fcv2__wishlist-burst::before {
  animation: fcv2-burst-2 0.55s ease-out;
}
.fcv2__wishlist.is-liked .fcv2__wishlist-burst::after {
  animation: fcv2-burst-3 0.55s ease-out;
}

@keyframes fcv2-burst-1 {
  0% { opacity: 1; transform: translate(0,0) scale(0); }
  100% { opacity: 0; transform: translate(16px,-14px) scale(1); }
}
@keyframes fcv2-burst-2 {
  0% { opacity: 1; transform: translate(0,0) scale(0); }
  100% { opacity: 0; transform: translate(-17px,-10px) scale(1); }
}
@keyframes fcv2-burst-3 {
  0% { opacity: 1; transform: translate(0,0) scale(0); }
  100% { opacity: 0; transform: translate(0,18px) scale(1); }
}

.fcv2__wishlist.is-liked svg {
  fill: #725b38;
  stroke: #725b38;
  animation: fcv2-heart-pop 0.45s ease-out;
}

@keyframes fcv2-heart-pop {
  0% { transform: scale(1); }
  35% { transform: scale(1.35); }
  100% { transform: scale(1); }
}

.fcv2__quick-view {
  position: absolute;
  left: 50%;
  right: auto;
  bottom: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 178px;
  padding: 12px 22px;
  border: 0;
  border-radius: 2px;
  background: rgba(255, 255, 255, 0.9);
  color: #1a1c1b;
  cursor: pointer;
  font-family: var(--font-body-family);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  opacity: 0;
  transform: translate(-50%, 10px);
  transition: opacity 0.24s ease, transform 0.24s ease, background 0.2s ease, color 0.2s ease;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.fcv2__card:hover .fcv2__quick-view,
.fcv2__card:focus-within .fcv2__quick-view {
  opacity: 1;
