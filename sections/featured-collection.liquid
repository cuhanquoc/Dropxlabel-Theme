</style>

<script>
(function () {
  'use strict';
  if (customElements.get('featured-collection')) return;

  let currentProduct = null;
  let currentVariantId = null;
  let galleryImages = [];
  let galleryIndex = 0;
  let quantity = 1;

  const modal = document.getElementById('{{ fc_section_id }}-qv-modal');
  const panel = document.getElementById('{{ fc_section_id }}-qv-panel');
  const backdrop = document.getElementById('{{ fc_section_id }}-qv-backdrop');
  const closeBtn = document.getElementById('{{ fc_section_id }}-qv-close-btn');
  const galleryTrack = document.getElementById('{{ fc_section_id }}-qv-gallery-track');
  const dotsWrap = document.getElementById('{{ fc_section_id }}-qv-dots');
  const prevBtn = document.getElementById('{{ fc_section_id }}-qv-prev');
  const nextBtn = document.getElementById('{{ fc_section_id }}-qv-next');
  const titleEl = document.getElementById('{{ fc_section_id }}-qv-title');
  const priceEl = document.getElementById('{{ fc_section_id }}-qv-price');
  const compareEl = document.getElementById('{{ fc_section_id }}-qv-compare');
  const variantsEl = document.getElementById('{{ fc_section_id }}-qv-variants');
  const qtyRow = document.getElementById('{{ fc_section_id }}-qv-qty-row');
  const qtyVal = document.getElementById('{{ fc_section_id }}-qv-qty-val');
  const qtyDec = document.getElementById('{{ fc_section_id }}-qv-qty-dec');
  const qtyInc = document.getElementById('{{ fc_section_id }}-qv-qty-inc');
  const atcBtn = document.getElementById('{{ fc_section_id }}-qv-atc');
  const buyBtn = document.getElementById('{{ fc_section_id }}-qv-bin');

  function formatMoney(cents) {
    if (!cents || cents === 0) return '';
    return '$' + (cents / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  function updateProgress(track) {
    const pager = document.getElementById('{{ fc_section_id }}-pager');
    if (!track) return;
    if (!pager) return;
    if (window.innerWidth >= 1024) {
      pager.innerHTML = '';
      return;
    }
    const max = Math.max(track.scrollWidth - track.clientWidth, 1);
    const progress = Math.min(100, Math.max(0, Math.round((track.scrollLeft / max) * 100)));
    const pageCount = Math.max(1, Math.round(max / Math.max(track.clientWidth * 0.82, 1)) + 1);
    if (pager.children.length !== pageCount) {
      pager.innerHTML = '';
      for (let index = 0; index < pageCount; index += 1) {
        const dot = document.createElement('span');
        dot.className = 'fcv2__pager-dot' + (index === 0 ? ' is-active' : '');
        pager.appendChild(dot);
      }
    }

    const active = Math.min(pageCount - 1, Math.round((progress / 100) * (pageCount - 1)));
    Array.prototype.forEach.call(pager.children, function (dot, dotIndex) {
      dot.classList.toggle('is-active', dotIndex === active);
    });
  }

  function buildGallery(images) {
    galleryImages = images || [];
    galleryIndex = 0;
    galleryTrack.innerHTML = '';
    dotsWrap.innerHTML = '';

    if (!galleryImages.length) {
      galleryTrack.innerHTML = '<div style="width:100%;height:100%;background:#f3f4f6;"></div>';
      prevBtn.style.display = 'none';
      nextBtn.style.display = 'none';
      return;
    }

    galleryImages.forEach(function (src, index) {
      var img = document.createElement('img');
      img.src = src;
      img.alt = '';
      img.loading = index === 0 ? 'eager' : 'lazy';
      galleryTrack.appendChild(img);

      if (galleryImages.length > 1) {
        var dot = document.createElement('button');
        dot.type = 'button';
        dot.className = index === 0 ? 'is-active' : '';
        dot.setAttribute('aria-label', 'Image ' + (index + 1));
        dot.addEventListener('click', function () {
          setGalleryIndex(index);
        });
        dotsWrap.appendChild(dot);
      }
    });

    prevBtn.style.display = galleryImages.length > 1 ? 'inline-flex' : 'none';
    nextBtn.style.display = galleryImages.length > 1 ? 'inline-flex' : 'none';
    setGalleryIndex(0);
  }

  function setGalleryIndex(index) {
    if (!galleryImages.length) return;
    galleryIndex = (index + galleryImages.length) % galleryImages.length;
    galleryTrack.style.transform = 'translateX(-' + (galleryIndex * 100) + '%)';
    dotsWrap.querySelectorAll('button').forEach(function (dot, dotIndex) {
      dot.classList.toggle('is-active', dotIndex === galleryIndex);
    });
  }

  function selectVariant(variant, button) {
    currentVariantId = variant.id;
    variantsEl.querySelectorAll('.fcv2-modal__variant').forEach(function (el) {
      el.classList.remove('is-active');
    });
    if (button) button.classList.add('is-active');

    priceEl.textContent = formatMoney(variant.price);
    if (variant.compare && variant.compare > variant.price) {
      compareEl.textContent = formatMoney(variant.compare);
      compareEl.classList.remove('hidden');
    } else {
      compareEl.classList.add('hidden');
      compareEl.textContent = '';
    }

    if (variant.img && galleryImages.indexOf(variant.img) !== -1) {
      setGalleryIndex(galleryImages.indexOf(variant.img));
    }

    atcBtn.disabled = variant.available === false;
    atcBtn.textContent = variant.available === false ? 'Sold out' : 'Add to cart';
  }

  function buildVariants(variants) {
    variantsEl.innerHTML = '';
    if (!variants || variants.length <= 1) return;

    variants.forEach(function (variant, index) {
      var button = document.createElement('button');
      button.type = 'button';
      button.className = 'fcv2-modal__variant' + (index === 0 ? ' is-active' : '');
      button.setAttribute('aria-label', variant.title || 'Variant');

      if (variant.swatch) {
        var img = document.createElement('img');
        img.src = variant.swatch;
        img.alt = variant.option1 || variant.title || '';
        img.loading = 'lazy';
        button.appendChild(img);
      } else {
        var swatch = document.createElement('span');
        swatch.className = 'fcv2-modal__variant-swatch';
        button.appendChild(swatch);
      }

      var label = document.createElement('span');
      label.textContent = variant.option1 || variant.title || 'Option';
      button.appendChild(label);

      button.addEventListener('click', function () {
        selectVariant(variant, button);
      });
      variantsEl.appendChild(button);
    });
  }

  function openModal(card) {
    if (!card) return;
    currentProduct = {
      id: card.dataset.productId,
      title: card.dataset.productTitle || '',
      subtitle: card.dataset.productSubtitle || '',
      url: card.dataset.productUrl || '#',
      money: card.dataset.productMoney || '',
      compare: card.dataset.productCompareMoney || '',
      variants: JSON.parse(card.dataset.productVariants || '[]'),
      images: JSON.parse(card.dataset.productImages || '[]')
    };

    currentVariantId = currentProduct.variants[0] ? currentProduct.variants[0].id : null;
    quantity = 1;
    qtyVal.textContent = '1';

    titleEl.textContent = currentProduct.subtitle ? currentProduct.title + ' — ' + currentProduct.subtitle : currentProduct.title;
    titleEl.href = currentProduct.url;
    priceEl.textContent = currentProduct.money;

    if (currentProduct.compare && currentProduct.compare !== currentProduct.money && currentProduct.compare !== '$0.00') {
      compareEl.textContent = currentProduct.compare;
      compareEl.classList.remove('hidden');
    } else {
      compareEl.classList.add('hidden');
      compareEl.textContent = '';
    }

    buildGallery(currentProduct.images);

    if (currentProduct.variants.length > 0) {
      buildVariants(currentProduct.variants);
      selectVariant(currentProduct.variants[0], variantsEl.querySelector('.fcv2-modal__variant'));
      qtyRow.style.display = 'flex';
    } else {
      variantsEl.innerHTML = '';
      qtyRow.style.display = 'none';
      atcBtn.disabled = false;
      atcBtn.textContent = 'Add to cart';
    }

    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  async function syncCartCount() {
    try {
      const response = await fetch('/cart.js');
      const cart = await response.json();
      document.querySelectorAll('.cart-count').forEach(function (el) {
        el.textContent = cart.item_count;
        el.style.display = cart.item_count > 0 ? '' : 'none';
      });
      var mobBadge = document.getElementById('mob-nav-cart-badge');
      if (mobBadge) {
        mobBadge.textContent = cart.item_count;
        mobBadge.style.display = cart.item_count > 0 ? '' : 'none';
      }
      document.dispatchEvent(new CustomEvent('cart:updated', { detail: { cart: cart } }));
    } catch (error) {}
  }

  if (atcBtn) {
    atcBtn.addEventListener('click', async function () {
      const variantId = currentVariantId || (currentProduct && currentProduct.variants[0] && currentProduct.variants[0].id);
      if (!variantId) return;
      atcBtn.disabled = true;
      atcBtn.textContent = 'Adding…';
      try {
        const res = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: variantId, quantity: quantity })
        });
        if (!res.ok) throw new Error('Failed');
        atcBtn.textContent = '✓ Added';
        await syncCartCount();
        setTimeout(function () {
          atcBtn.textContent = 'Add to cart';
          atcBtn.disabled = false;
          closeModal();
        }, 900);
      } catch (error) {
        atcBtn.textContent = 'Error — try again';
        atcBtn.disabled = false;
        setTimeout(function () { atcBtn.textContent = 'Add to cart'; }, 1200);
      }
    });
  }

  if (buyBtn) {
    buyBtn.addEventListener('click', async function () {
      const variantId = currentVariantId || (currentProduct && currentProduct.variants[0] && currentProduct.variants[0].id);
      if (!variantId) return;
      buyBtn.textContent = 'Processing…';
      try {
        await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: variantId, quantity: quantity })
        });
        window.location.href = '/checkout';
      } catch (error) {
        buyBtn.textContent = 'Buy it now';
      }
    });
  }

  qtyDec && qtyDec.addEventListener('click', function () {
    if (quantity > 1) quantity -= 1;
    qtyVal.textContent = String(quantity);
  });

  qtyInc && qtyInc.addEventListener('click', function () {
    quantity += 1;
    qtyVal.textContent = String(quantity);
  });

  prevBtn && prevBtn.addEventListener('click', function () { setGalleryIndex(galleryIndex - 1); });
  nextBtn && nextBtn.addEventListener('click', function () { setGalleryIndex(galleryIndex + 1); });
  backdrop && backdrop.addEventListener('click', closeModal);
  closeBtn && closeBtn.addEventListener('click', closeModal);
  document.addEventListener('keydown', function (event) {
    if (event.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
  });

  class FeaturedCollection extends HTMLElement {
    connectedCallback() {
      this.track = this.querySelector('#fcv2-track');
      this.moreWrap = this.querySelector('#{{ fc_section_id }}-more-wrap');
      this.moreBtn = this.querySelector('#{{ fc_section_id }}-more-btn');
      this.cards = Array.from(this.querySelectorAll('[data-fcv2-card]'));
      this.initial = parseInt(this.track.dataset.fcInitial, 10) || 4;
      this.perLoad = parseInt(this.track.dataset.fcPerLoad, 10) || 4;
      this.revealed = 0;

      this.initCards();
      this.initLoadMore();
      updateProgress(this.track);
      this.track.addEventListener('scroll', this.handleScroll, { passive: true });
      window.addEventListener('resize', this.handleResize, { passive: true });
    }

    disconnectedCallback() {
      this.track && this.track.removeEventListener('scroll', this.handleScroll);
      window.removeEventListener('resize', this.handleResize);
    }

    handleScroll = () => updateProgress(this.track);
    handleResize = () => updateProgress(this.track);

    initCards(scope) {
      const root = scope || this;

      root.querySelectorAll('[data-fcv2-wishlist]').forEach(function (button) {
        if (button.dataset.fcv2WishlistBound === 'true') return;
        button.dataset.fcv2WishlistBound = 'true';
        button.addEventListener('click', function () {
          button.classList.toggle('is-liked');
          if (button.classList.contains('is-liked')) {
            setTimeout(function () {
              button.classList.remove('is-liked');
              button.classList.add('is-persist');
            }, 560);
          } else {
            button.classList.remove('is-persist');
          }
        });
      });

      root.querySelectorAll('.fcv2__quick-view').forEach(function (button) {
        if (button.dataset.fcv2QuickviewBound === 'true') return;
        button.dataset.fcv2QuickviewBound = 'true';
        button.addEventListener('click', function (event) {
          event.preventDefault();
          event.stopPropagation();
          openModal(button.closest('[data-fcv2-card]'));
        });
      });

      root.querySelectorAll('.fcv2__swatch[data-variant-id]').forEach(function (button) {
        if (button.dataset.fcv2SwatchBound === 'true') return;
        button.dataset.fcv2SwatchBound = 'true';
        button.addEventListener('click', function () {
          const card = button.closest('[data-fcv2-card]');
          if (!card) return;
          const variants = JSON.parse(card.dataset.productVariants || '[]');
          const variant = variants.find(function (item) { return String(item.id) === String(button.dataset.variantId); });
          const image = card.querySelector('.fcv2__image');
          if (variant && variant.img && image) image.src = variant.img;
          card.querySelectorAll('.fcv2__swatch').forEach(function (swatch) { swatch.classList.remove('is-active'); });
          button.classList.add('is-active');
        });
      });
    }

    initLoadMore() {
      if (!this.moreBtn || this.cards.length <= this.initial) {
        if (this.moreWrap) this.moreWrap.style.display = this.cards.length > this.initial ? '' : 'none';
        return;
      }

      this.hiddenCards = this.cards.slice(this.initial);
      this.hiddenCards.forEach(function (card) {
        card.style.display = 'none';
        card.setAttribute('aria-hidden', 'true');
      });
      this.moreWrap.style.display = '';

      this.moreBtn.addEventListener('click', () => {
        const batch = this.hiddenCards.slice(this.revealed, this.revealed + this.perLoad);
        if (!batch.length) return;
        batch.forEach((card, index) => {
          card.style.display = '';
          card.style.opacity = '0';
          card.style.transform = 'translateY(18px)';
          card.removeAttribute('aria-hidden');
          setTimeout(() => {
            card.style.transition = 'opacity .35s ease, transform .35s ease';
            card.style.opacity = '1';
            card.style.transform = 'translateY(0)';
          }, 40 + index * 60);
        });
        this.revealed += batch.length;
        updateProgress(this.track);
        if (this.revealed >= this.hiddenCards.length) {
          this.moreWrap.style.display = 'none';
        }
      });
    }
  }

  if (!customElements.get('featured-collection')) {
    customElements.define('featured-collection', FeaturedCollection);
  }
})();
</script>

