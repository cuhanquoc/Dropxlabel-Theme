{% comment %} Featured Collection — Revamped Trending Products UI {% endcomment %}

{%- liquid
  assign fc_section_id = 'fcv2-' | append: section.id
  assign fc_source = section.settings.product_list
  assign fc_limit = section.settings.max_products | default: 12
  if fc_source == blank and section.settings.collection != blank
    assign fc_source = section.settings.collection.products
  endif

  assign fc_initial = section.settings.items_initial | default: 4
  assign fc_per_load = section.settings.items_per_load | default: 4
  assign fc_total_products = fc_source | size
  assign fc_remaining = fc_total_products | minus: fc_initial
  assign fc_more_label = section.settings.more_label | default: 'Load more'
  assign fc_heading_line_1 = section.settings.heading_line_1 | default: 'Featured'
  assign fc_heading_line_2 = section.settings.heading_line_2 | default: 'pieces'
  assign fc_eyebrow = section.settings.eyebrow | default: 'Curated selection'
  assign fc_helper_text = section.settings.helper_text | default: 'Scroll the rail for the full edit, or open Quick view for more detail.'
-%}

<featured-collection class="fcv2 block relative overflow-hidden bg-white text-[#0a0a0a]" data-section-id="{{ section.id }}">
  <div class="fcv2__surface">
    <div class="fcv2__shell">
      <header class="fcv2__header">
        <p class="fcv2__eyebrow">{{ fc_eyebrow }}</p>
        <div class="fcv2__header-grid">
          <h2 class="fcv2__heading" aria-label="{{ fc_heading_line_1 }} {{ fc_heading_line_2 }}">
            <span class="fcv2__heading-line">{{ fc_heading_line_1 }}</span>
            <span class="fcv2__heading-line fcv2__heading-line--muted">{{ fc_heading_line_2 }}</span>
          </h2>
          <div class="fcv2__header-copy">
            <p class="fcv2__helper">{{ fc_helper_text }}</p>
            <p class="fcv2__count">
              {% if fc_total_products > 0 %}
                {{ fc_total_products }} pieces in this edit
              {% else %}
                Curated products will appear here
              {% endif %}
            </p>
          </div>
        </div>
      </header>

      <div class="fcv2__body">
    <div
      class="fcv2__track"
      id="fcv2-track"
      role="list"
      aria-label="Trending products"
      data-fc-initial="{{ fc_initial }}"
      data-fc-per-load="{{ fc_per_load }}"
    >
      {%- if fc_source != blank -%}
        {%- for product in fc_source limit: fc_limit -%}
          {%- assign product_subtitle = product.metafields.custom.card_subtitle.value | default: product.metafields.custom.subtitle.value | default: '' -%}

          {%- assign variants_json = '[' -%}
          {%- for variant in product.variants -%}
            {%- assign variant_img = '' -%}
            {%- assign variant_swatch = '' -%}
            {%- if variant.featured_image != blank -%}
              {%- assign variant_img = variant.featured_image | image_url: width: 900 -%}
              {%- assign variant_swatch = variant.featured_image | image_url: width: 120 -%}
            {%- elsif product.images[forloop.index0] != blank -%}
              {%- assign variant_img = product.images[forloop.index0] | image_url: width: 900 -%}
              {%- assign variant_swatch = product.images[forloop.index0] | image_url: width: 120 -%}
            {%- elsif product.featured_image != blank -%}
              {%- assign variant_img = product.featured_image | image_url: width: 900 -%}
              {%- assign variant_swatch = product.featured_image | image_url: width: 120 -%}
            {%- endif -%}
            {%- assign variant_compare = variant.compare_at_price | default: 0 -%}
            {%- capture variant_entry -%}
              {"id":{{ variant.id }},"title":{{ variant.title | json }},"price":{{ variant.price }},"compare":{{ variant_compare }},"available":{{ variant.available }},"img":{{ variant_img | json }},"swatch":{{ variant_swatch | json }},"option1":{{ variant.option1 | json }},"option2":{{ variant.option2 | json }},"option3":{{ variant.option3 | json }}}
            {%- endcapture -%}
            {%- assign variants_json = variants_json | append: variant_entry | strip_newlines -%}
            {%- unless forloop.last -%}{%- assign variants_json = variants_json | append: ',' -%}{%- endunless -%}
          {%- endfor -%}
          {%- assign variants_json = variants_json | append: ']' -%}

          {%- assign images_json = '[' -%}
          {%- for image in product.images limit: 8 -%}
            {%- capture image_entry -%}{{ image | image_url: width: 900 | json }}{%- endcapture -%}
            {%- assign images_json = images_json | append: image_entry -%}
            {%- unless forloop.last -%}{%- assign images_json = images_json | append: ',' -%}{%- endunless -%}
          {%- endfor -%}
          {%- assign images_json = images_json | append: ']' -%}

          {%- assign featured_variant = product.selected_or_first_available_variant -%}
          {%- assign main_image = featured_variant.featured_media.preview_image | default: product.featured_media.preview_image -%}
          {%- assign badge_label = '' -%}
          {%- if product.compare_at_price_max > product.price -%}
            {%- assign badge_label = 'SALE' -%}
          {%- elsif product.tags contains 'new' or product.tags contains 'NEW' -%}
            {%- assign badge_label = 'NEW' -%}
          {%- endif -%}

          <article
            class="fcv2__card"
            role="listitem"
            data-fcv2-card
            data-product-id="{{ product.id }}"
            data-product-title="{{ product.title | escape }}"
            data-product-subtitle="{{ product_subtitle | escape }}"
            data-product-url="{{ product.url }}"
            data-product-money="{{ product.price | money }}"
            data-product-compare-money="{{ product.compare_at_price_min | money }}"
            data-product-variants="{{ variants_json | escape }}"
            data-product-images="{{ images_json | escape }}"
          >
            <div class="fcv2__media-wrap">
              <a href="{{ product.url }}" class="fcv2__image-link" tabindex="-1" aria-hidden="true">
                {% if main_image != blank %}
                  {{ main_image | image_url: width: 900 | image_tag:
                    class: 'fcv2__image',
                    loading: 'lazy',
                    widths: '300, 450, 600, 900',
                    sizes: '(max-width: 767px) 72vw, (max-width: 1023px) 40vw, 300px',
                    alt: product.title,
                    width: main_image.width,
                    height: main_image.height
                  }}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'fcv2__image fcv2__image--placeholder' }}
                {% endif %}
              </a>

              {% if badge_label != blank %}
                <div class="fcv2__badge{% if badge_label == 'SALE' %} is-sale{% else %} is-new{% endif %}">
                  {% if badge_label == 'SALE' %}<span class="fcv2__badge-ring" aria-hidden="true"></span>{% endif %}
                  <span class="fcv2__badge-pill">{{ badge_label }}</span>
                  {% if badge_label == 'NEW' %}<span class="fcv2__badge-shimmer" aria-hidden="true"></span>{% endif %}
                </div>
              {% endif %}

              <button type="button" class="fcv2__wishlist" aria-label="Save for later" data-fcv2-wishlist>
                <span class="fcv2__wishlist-burst" aria-hidden="true"></span>
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 21-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.18Z"/></svg>
              </button>

              <button type="button" class="fcv2__quick-view" data-card-id="{{ product.id }}" aria-label="Quick view {{ product.title | escape }}">
                <span class="fcv2__quick-view-label">Quick view</span>
                <span class="fcv2__quick-view-arrow" aria-hidden="true">↗</span>
              </button>
            </div>

            <div class="fcv2__content">
              <a href="{{ product.url }}" class="fcv2__title-row">
                <span class="fcv2__title">{{ product.title }}</span>
                {% if product_subtitle != blank %}
                  <span class="fcv2__subtitle">— {{ product_subtitle }}</span>
                {% endif %}
              </a>

              <div class="fcv2__price-row">
                <span class="fcv2__price">{{ product.price | money }}</span>
                {% if product.compare_at_price_min > product.price %}
                  <span class="fcv2__compare">{{ product.compare_at_price_min | money }}</span>
                {% endif %}
              </div>

              {% if product.variants.size > 1 %}
                <div class="fcv2__swatches">
                  {% for variant in product.variants limit: 6 %}
                    {% liquid
                      assign swatch_image = variant.featured_media.preview_image | default: product.images[forloop.index0] | default: product.featured_media.preview_image
                    %}
                    <button
                      type="button"
                      class="fcv2__swatch{% if forloop.first %} is-active{% endif %}"
                      aria-label="{{ variant.title | escape }}"
                      data-variant-id="{{ variant.id }}"
                    >
                      {% if swatch_image != blank %}
                        {{ swatch_image | image_url: width: 120 | image_tag:
                          class: 'fcv2__swatch-image',
                          loading: 'lazy',
                          alt: variant.title,
                          width: swatch_image.width,
                          height: swatch_image.height
                        }}
                      {% else %}
                        <span class="fcv2__swatch-fallback">{{ variant.option1 | default: variant.title | slice: 0, 1 }}</span>
                      {% endif %}
                    </button>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div class="fcv2__progress-wrap">
      <div class="fcv2__progress-track"><div class="fcv2__progress-fill" id="{{ fc_section_id }}-progress-fill"></div></div>
      <div class="fcv2__progress-value" id="{{ fc_section_id }}-progress-value">0%</div>
    </div>

    <div class="fcv2__more-wrap" id="{{ fc_section_id }}-more-wrap"{% if fc_source == blank or fc_total_products <= fc_initial %} style="display:none"{% endif %}>
      <div class="fcv2__more-copy">
        <p class="fcv2__more-title">More products</p>
        <p class="fcv2__more-subtitle">
          {% if fc_remaining > 0 %}
            {{ fc_remaining }} remaining in this edit
          {% else %}
            All products are already visible
          {% endif %}
        </p>
      </div>
      <button type="button" class="fcv2__more-btn" id="{{ fc_section_id }}-more-btn" aria-label="{{ fc_more_label }}">
        <span>{{ fc_more_label }}</span>
        <span class="fcv2__more-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
        </span>
      </button>
    </div>

    <div class="fcv2__more-grid" id="{{ fc_section_id }}-more-grid" aria-label="Additional products"></div>
    </div>
  </div>
  </div>
</featured-collection>

<div id="{{ fc_section_id }}-qv-modal" class="fcv2-modal" role="dialog" aria-modal="true" aria-hidden="true" aria-label="Quick view">
  <button class="fcv2-modal__backdrop" id="{{ fc_section_id }}-qv-backdrop" aria-label="Close quick view"></button>
  <div class="fcv2-modal__panel" id="{{ fc_section_id }}-qv-panel" role="document">
    <div class="fcv2-modal__header">
      <div class="fcv2-modal__handle"></div>
      <button class="fcv2-modal__close" id="{{ fc_section_id }}-qv-close-btn" aria-label="Close quick view">×</button>
    </div>
    <div class="fcv2-modal__scroll">
      <div class="fcv2-modal__gallery-shell">
        <div class="fcv2-modal__gallery-track" id="{{ fc_section_id }}-qv-gallery-track"></div>
        <button class="fcv2-modal__arrow is-prev" id="{{ fc_section_id }}-qv-prev" aria-label="Previous image">‹</button>
        <button class="fcv2-modal__arrow is-next" id="{{ fc_section_id }}-qv-next" aria-label="Next image">›</button>
        <div class="fcv2-modal__dots" id="{{ fc_section_id }}-qv-dots"></div>
      </div>
      <div class="fcv2-modal__info">
        <a href="#" class="fcv2-modal__title" id="{{ fc_section_id }}-qv-title"></a>
        <div class="fcv2-modal__price-row">
          <span class="fcv2-modal__price" id="{{ fc_section_id }}-qv-price"></span>
          <span class="fcv2-modal__compare hidden" id="{{ fc_section_id }}-qv-compare"></span>
        </div>
        <div class="fcv2-modal__variants" id="{{ fc_section_id }}-qv-variants"></div>
        <div class="fcv2-modal__qty-row" id="{{ fc_section_id }}-qv-qty-row">
          <span class="fcv2-modal__qty-label">Quantity</span>
          <div class="fcv2-modal__qty-ctrl">
            <button type="button" id="{{ fc_section_id }}-qv-qty-dec" aria-label="Decrease quantity">−</button>
            <span id="{{ fc_section_id }}-qv-qty-val">1</span>
            <button type="button" id="{{ fc_section_id }}-qv-qty-inc" aria-label="Increase quantity">+</button>
          </div>
        </div>
      </div>
    </div>
    <div class="fcv2-modal__footer">
      <button type="button" class="fcv2-modal__button is-secondary" id="{{ fc_section_id }}-qv-atc">Add to cart</button>
      <button type="button" class="fcv2-modal__button is-primary" id="{{ fc_section_id }}-qv-bin">Buy it now</button>
    </div>
  </div>
</div>

<style>
.fcv2 {
  position: relative;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.82), transparent 34%),
    radial-gradient(circle at top right, rgba(255, 245, 232, 0.82), transparent 30%),
    linear-gradient(180deg, #f6f1e9 0%, #fbf9f4 38%, #f7f3ec 100%);
  color: #111111;
}

.fcv2__surface {
  max-width: 1440px;
  margin: 0 auto;
  padding: 28px 0 40px;
}

.fcv2__shell {
  padding: 0 20px;
}

.fcv2__header {
  display: grid;
  gap: 18px;
  padding: 18px 0 26px;
  border-bottom: 1px solid rgba(17, 17, 17, 0.08);
}

.fcv2__eyebrow {
  margin: 0;
  color: rgba(17, 17, 17, 0.56);
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.22em;
  line-height: 1.4;
  text-transform: uppercase;
}

.fcv2__header-grid {
  display: grid;
  gap: 18px;
}

.fcv2__heading {
  margin: 0;
  display: grid;
  gap: 0.04em;
  max-width: 12ch;
  color: #111111;
  font-family: var(--font-heading);
  font-size: clamp(2.8rem, 8vw, 6rem);
  font-weight: 600;
  letter-spacing: -0.05em;
  line-height: 0.9;
  text-wrap: balance;
}

.fcv2__heading-line--muted {
  color: rgba(17, 17, 17, 0.46);
}

.fcv2__header-copy {
  display: grid;
  gap: 10px;
  max-width: 520px;
}

.fcv2__helper {
  margin: 0;
  color: rgba(17, 17, 17, 0.66);
  font-family: var(--font-body);
  font-size: 0.95rem;
  line-height: 1.7;
}

.fcv2__count {
  margin: 0;
  color: rgba(17, 17, 17, 0.44);
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.16em;
  line-height: 1.5;
  text-transform: uppercase;
}

.fcv2__body {
  padding: 24px 0 0;
}

.fcv2__track {
  display: flex;
  gap: 18px;
  overflow-x: auto;
  overflow-y: hidden;
  padding: 6px 0 10px;
  scroll-behavior: smooth;
  scroll-snap-type: x proximity;
  scrollbar-width: none;
  -ms-overflow-style: none;
  mask-image: linear-gradient(to right, transparent 0%, #000 4%, #000 96%, transparent 100%);
}

.fcv2__track::-webkit-scrollbar {
  display: none;
}

.fcv2__card {
  flex: 0 0 auto;
  width: min(340px, 84vw);
  scroll-snap-align: start;
}

.fcv2__media-wrap {
  position: relative;
  aspect-ratio: 4 / 5;
  overflow: hidden;
  border-radius: 28px;
  border: 1px solid rgba(17, 17, 17, 0.08);
  background: linear-gradient(180deg, #ece5db 0%, #f4efe8 100%);
  box-shadow: 0 24px 52px -30px rgba(31, 24, 16, 0.28);
}

.fcv2__media-wrap::after {
  content: '';
  position: absolute;
  inset: auto 0 0;
  height: 42%;
  background: linear-gradient(180deg, transparent 0%, rgba(17, 17, 17, 0.06) 100%);
  pointer-events: none;
}

.fcv2__image-link,
.fcv2__image,
.fcv2__image--placeholder {
  display: block;
  width: 100%;
  height: 100%;
}

.fcv2__image {
  object-fit: cover;
  transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1), filter 0.55s cubic-bezier(0.22, 1, 0.36, 1);
}

.fcv2__card:hover .fcv2__image,
.fcv2__card:focus-within .fcv2__image {
  transform: scale(1.03);
  filter: saturate(0.96) contrast(1.01);
}

.fcv2__badge {
  position: absolute;
  top: 16px;
  left: 16px;
  z-index: 2;
}

.fcv2__badge-pill {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 24px;
  padding: 0 11px;
  border-radius: 999px;
  border: 1px solid rgba(17, 17, 17, 0.08);
  background: rgba(255, 255, 255, 0.88);
  color: #111111;
  font-family: var(--font-body);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.16em;
  line-height: 1;
  text-transform: uppercase;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.fcv2__badge.is-sale .fcv2__badge-pill {
  border-color: transparent;
  background: rgba(17, 17, 17, 0.92);
  color: #ffffff;
}

.fcv2__badge.is-new {
  overflow: hidden;
  border-radius: 999px;
}

.fcv2__badge-ring,
.fcv2__badge-shimmer {
  display: none;
}

.fcv2__wishlist {
  position: absolute;
  top: 16px;
  right: 16px;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  padding: 0;
  border: 1px solid rgba(17, 17, 17, 0.08);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.88);
  color: #111111;
  cursor: pointer;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  transition: transform 0.22s cubic-bezier(0.22, 1, 0.36, 1), background 0.22s ease, border-color 0.22s ease, color 0.22s ease;
}

.fcv2__wishlist svg {
  transition: transform 0.2s ease, fill 0.2s ease, stroke 0.2s ease;
}

.fcv2__wishlist:hover,
.fcv2__wishlist:focus-visible {
  transform: translateY(-1px);
  border-color: rgba(17, 17, 17, 0.14);
}

.fcv2__wishlist-burst,
.fcv2__wishlist-burst::before,
.fcv2__wishlist-burst::after {
  display: none;
}

.fcv2__wishlist.is-liked svg,
.fcv2__wishlist.is-persist svg {
  fill: currentColor;
  stroke: currentColor;
  transform: scale(1.04);
}

.fcv2__quick-view {
  position: absolute;
  left: 16px;
  right: 16px;
  bottom: 16px;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  padding: 12px 14px;
  border: 1px solid rgba(17, 17, 17, 0.08);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.9);
  color: #111111;
  cursor: pointer;
  font-family: var(--font-body);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.18em;
  line-height: 1;
  text-transform: uppercase;
  opacity: 0;
  transform: translateY(10px);
  transition: opacity 0.24s ease, transform 0.24s cubic-bezier(0.22, 1, 0.36, 1), background 0.24s ease, border-color 0.24s ease;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.fcv2__card:hover .fcv2__quick-view,
.fcv2__card:focus-within .fcv2__quick-view {
  opacity: 1;
  transform: translateY(0);
}

@media (hover: none) {
  .fcv2__quick-view {
    opacity: 1;
    transform: translateY(0);
  }
}

.fcv2__quick-view-arrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  border: 1px solid currentColor;
  border-radius: 999px;
  font-size: 11px;
  line-height: 1;
}

.fcv2__content {
  display: grid;
  gap: 10px;
  padding: 14px 2px 0;
}

.fcv2__title-row {
  display: grid;
  gap: 4px;
  color: inherit;
  text-decoration: none;
  line-height: 1.35;
}

.fcv2__title {
  color: #111111;
  font-family: var(--font-heading);
  font-size: 1.08rem;
  font-weight: 600;
  letter-spacing: -0.03em;
  line-height: 1.25;
  text-wrap: balance;
}

.fcv2__subtitle {
  color: rgba(17, 17, 17, 0.5);
  font-family: var(--font-body);
  font-size: 0.9rem;
  font-weight: 400;
  line-height: 1.45;
}

.fcv2__price-row {
  display: flex;
  align-items: baseline;
  gap: 8px;
}

.fcv2__price {
  color: #111111;
  font-family: var(--font-body);
  font-size: 1.08rem;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.fcv2__compare {
  color: rgba(17, 17, 17, 0.44);
  font-family: var(--font-body);
  font-size: 0.86rem;
  font-weight: 400;
  text-decoration: line-through;
}

.fcv2__swatches {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.fcv2__swatch {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  padding: 0;
  border: 1px solid rgba(17, 17, 17, 0.08);
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.8);
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
}

.fcv2__swatch:hover,
.fcv2__swatch:focus-visible {
  transform: translateY(-1px);
  border-color: rgba(17, 17, 17, 0.16);
}

.fcv2__swatch.is-active {
  border-color: rgba(17, 17, 17, 0.86);
