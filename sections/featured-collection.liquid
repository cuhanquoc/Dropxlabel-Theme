{% comment %} FEATURED COLLECTION — Trending Products Carousel + Quick View Modal {% endcomment %}

{%- assign fc_title_size   = section.settings.title_font_size   | default: '1.4rem' -%}
{%- assign fc_title_color  = section.settings.title_color        | default: '#111111' -%}
{%- assign fc_title_weight = section.settings.title_font_weight  | default: '500' -%}
{%- assign fc_price_color  = section.settings.price_color        | default: '#111111' -%}
{%- assign fc_compare_color = section.settings.compare_color     | default: '#999999' -%}

<featured-collection class="block relative w-full overflow-hidden bg-white">

  <!-- ── Section Header ── -->
  <div class="pt-14 pb-6 px-5 md:px-10 text-center" style="max-width: 100%; overflow: hidden;">
    <h2
      class="font-body font-black uppercase leading-[0.88] tracking-[-0.02em]"
      style="font-size: {{ section.settings.heading_size | default: 'clamp(2.8rem,11vw,7.5rem)' }}; color: {{ section.settings.heading_color | default: '#0a0a0a' }}; word-break: keep-all; overflow-wrap: normal;"
    >
      <span class="fc-heading-motion" style="display: inline-block;">
        {{ section.settings.heading | default: 'TRENDING PRODUCTS' }}
      </span>
    </h2>
  </div>

  <!-- ── Carousel ── -->
  <div class="relative pb-16">
    <div
      class="fc-track flex gap-3 md:gap-4 overflow-x-auto snap-x snap-mandatory pb-3 px-5 md:px-10 scroll-px-5 md:scroll-px-10" style="scroll-behavior: smooth; -webkit-overflow-scrolling: touch;"
      id="fc-track"
      role="list"
      aria-label="Trending products"
    >

      {%- comment -%} Data source: product_list (individual picks) OR collection picker {%- endcomment -%}
      {%- assign fc_source = section.settings.product_list -%}
      {%- assign fc_limit   = section.settings.max_products | default: 12 -%}
      {%- if fc_source == blank and section.settings.collection != blank -%}
        {%- assign fc_source = section.settings.collection.products -%}
      {%- endif -%}

      {%- if fc_source != blank -%}
        {%- for product in fc_source limit: fc_limit -%}

          {%- comment -%} Build variant JSON for JS {%- endcomment -%}
          {%- assign v_json = '[' -%}
          {%- for v in product.variants -%}
            {%- assign v_img_url = '' -%}
            {%- if v.featured_image != blank -%}
              {%- assign v_img_url = v.featured_image | image_url: width: 900 -%}
            {%- elsif product.featured_image != blank -%}
              {%- assign v_img_url = product.featured_image | image_url: width: 900 -%}
            {%- endif -%}
            {%- assign v_swatch_url = '' -%}
            {%- if v.featured_image != blank -%}
              {%- assign v_swatch_url = v.featured_image | image_url: width: 120 -%}
            {%- endif -%}
            {%- assign v_compare = v.compare_at_price | default: 0 -%}
            {%- capture v_entry -%}{"id":{{ v.id }},"title":{{ v.title | json }},"price":{{ v.price }},"compare":{{ v_compare }},"available":{{ v.available }},"img":{{ v_img_url | json }},"swatch":{{ v_swatch_url | json }},"option1":{{ v.option1 | json }},"option2":{{ v.option2 | json }},"option3":{{ v.option3 | json }}}{%- endcapture -%}
            {%- assign v_json = v_json | append: v_entry -%}
            {%- unless forloop.last -%}{%- assign v_json = v_json | append: ',' -%}{%- endunless -%}
          {%- endfor -%}
          {%- assign v_json = v_json | append: ']' -%}

          {%- comment -%} Build images JSON {%- endcomment -%}
          {%- assign imgs_json = '[' -%}
          {%- for img in product.images limit: 8 -%}
            {%- capture img_entry -%}{{ img | image_url: width: 900 | json }}{%- endcapture -%}
            {%- assign imgs_json = imgs_json | append: img_entry -%}
            {%- unless forloop.last -%}{%- assign imgs_json = imgs_json | append: ',' -%}{%- endunless -%}
          {%- endfor -%}
          {%- assign imgs_json = imgs_json | append: ']' -%}

          {%- assign main_img = product.featured_image | image_url: width: 800 -%}
          {%- assign truncated_title = product.title -%}

          <!-- Card -->
          <div
            class="fc-card snap-start flex-none flex flex-col"
            role="listitem"
            data-fc-card
            data-product-id="{{ product.id }}"
            data-product-title="{{ product.title | escape }}"
            data-product-sku="{{ product.variants.first.sku | escape }}"
            data-product-url="{{ product.url }}"
            data-product-price="{{ product.price }}"
            data-product-compare="{{ product.compare_at_price_min | default: 0 }}"
            data-product-money="{{ product.price | money }}"
            data-product-compare-money="{{ product.compare_at_price_min | money }}"
            data-product-variants="{{ v_json | escape }}"
            data-product-images="{{ imgs_json | escape }}"
          >

            <!-- Image container -->
            <div class="fc-card-img-wrap relative rounded-2xl overflow-hidden bg-[#f2f2f2]" style="aspect-ratio:3/4; border: 1px solid rgba(0,0,0,0.06); box-shadow: 0 8px 24px rgba(0,0,0,0.06);">

              {% if product.featured_image != blank %}
                <a href="{{ product.url }}" class="absolute inset-0 w-full h-full z-0 cursor-pointer" tabindex="-1" style="display: block;">
                  <img
                    src="{{ main_img }}"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    class="fc-img w-full h-full object-cover" draggable="false"
                    loading="{% if forloop.index <= 2 %}eager{% else %}lazy{% endif %}"
                    width="800" height="1067"
                    style="width: 100%; height: 100%; object-fit: cover;"
                  />
                </a>
              {% else %}
                <div class="absolute inset-0 flex items-center justify-center opacity-30">
                  {{ 'product-1' | placeholder_svg_tag: 'w-24 h-24' }}
                </div>
              {% endif %}

              <!-- QUICK VIEW button -->
              <button
                class="fc-qv-trigger"
                aria-label="Quick view {{ product.title | escape }}"
                data-card-id="{{ product.id }}"
              >
                <span class="fc-qv-label">QUICK VIEW</span>
                <span class="fc-qv-plus" aria-hidden="true">+</span>
              </button>

            </div>
            <!-- /Image container -->

            <!-- Product info -->
            <div class="mt-3 px-0.5 text-left">

              <!-- Name -->
              <a
                href="{{ product.url }}"
                class="fc-product-name block font-body leading-tight hover:underline underline-offset-2"
                style="font-size:{{ fc_title_size }};color:{{ fc_title_color }};font-weight:{{ fc_title_weight }};"
                title="{{ product.title | escape }}"
              >{{ truncated_title }}</a>

              <!-- Price row -->
              <div class="flex items-center justify-start gap-2 mt-1 flex-wrap">
                <span class="fc-price font-body font-semibold" style="font-size:calc({{ fc_title_size }} * 1.15);color:{{ fc_price_color }};">
                  {{ product.price | money }}
                </span>
                {%- if product.compare_at_price_min > product.price -%}
                  <span class="fc-compare font-body line-through opacity-70" style="font-size:calc({{ fc_title_size }} * 0.7); color:{{ fc_compare_color }}; text-decoration: line-through !important; margin-left: 4px;">
                    {{ product.compare_at_price_min | money }}
                  </span>
                {%- endif -%}
              </div>

              <!-- Variant swatches -->
              {%- if product.variants.size > 1 -%}
                <div class="fc-swatches flex items-center justify-start gap-2 mt-2 flex-wrap">
                  {%- for variant in product.variants limit: 6 -%}
                    {%- assign sw_img = '' -%}
                    {%- if variant.featured_image != blank -%}
                      {%- assign sw_img = variant.featured_image | image_url: width: 120 -%}
                    {%- endif -%}
                    <button
                      class="fc-swatch{% if forloop.first %} active{% endif %}"
                      aria-label="{{ variant.title | escape }}"
                      data-variant-id="{{ variant.id }}"
                      data-card="{{ product.id }}"
                      {% if sw_img != blank %}
                        style="background-image:url('{{ sw_img }}');"
                      {% endif %}
                    >
                      {%- if sw_img == blank -%}
                        <span class="sr-only">{{ variant.option1 }}</span>
                      {%- endif -%}
                    </button>
                  {%- endfor -%}
                  {%- if product.variants.size > 6 -%}
                    <span class="fc-swatch-more font-body text-[10px] text-[#999]">+{{ product.variants.size | minus: 6 }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}

            </div>
            <!-- /Product info -->

          </div>
          <!-- /Card -->

        {%- endfor -%}

      {%- else -%}

        <!-- Placeholder cards -->
        {%- assign ph_names  = "Full Sleeve Round Neck T-shirt|Distressed Knit Crewneck|Oversized Cargo Jacket|Minimal Linen Trousers|Ribbed Tank Essential|Wide-leg Denim|Tailored Bomber|Relaxed Polo" | split: "|" -%}
        {%- assign ph_prices = "$45.00|$68.00|$110.00|$72.00|$38.00|$88.00|$125.00|$55.00" | split: "|" -%}
        {%- assign ph_cmp    = "$0|$90.00|$0|$95.00|$0|$0|$160.00|$0" | split: "|" -%}
        {%- assign ph_imgs   = "photo-1515886657613-9f3515b0c78f|photo-1558769132-cb1aea458c5e|photo-1539109136881-3be0616acf4b|photo-1509631179647-0177331693ae|photo-1485968579580-b6d095142e6e|photo-1472396961693-142e6e269027|photo-1490481651871-ab68de25d43d|photo-1469334031218-e382a71b716b" | split: "|" -%}
        {%- assign ph_colors = "#5B5B4A,#8B7355,#3A3A3A,#1A1A1A|#8B7355,#3A3A3A|#4A6741,#101010|#F5F0E8,#C5A880|#FFFFFF,#1A1A1A|#3A3A3A,#1A1A1A|#101010,#4A6741|#FFFFFF,#3A3A3A" | split: "|" -%}

        {%- for i in (1..8) -%}
          {%- assign idx = forloop.index0 -%}
          {%- assign ph_name  = ph_names[idx]  -%}
          {%- assign ph_price = ph_prices[idx] -%}
          {%- assign ph_c     = ph_cmp[idx]    -%}
          {%- assign ph_img   = ph_imgs[idx]   -%}
          {%- assign ph_color = ph_colors[idx] | split: "," -%}
          {%- comment -%} placeholder card — no external image {%- endcomment -%}

          <div
            class="fc-card snap-start flex-none flex flex-col"
            role="listitem"
            data-fc-card
            data-product-id="{{ forloop.index }}"
            data-product-title="{{ ph_name }}"
            data-product-sku="DEMO-{{ forloop.index }}"
            data-product-url="#"
            data-product-money="{{ ph_price }}"
            data-product-compare-money="{{ ph_c }}"
            data-product-variants="[]"
            data-product-images='[]'
          >
            <div class="fc-card-img-wrap relative rounded-2xl overflow-hidden bg-[#f2f2f2]" style="aspect-ratio:3/4; border: 1px solid rgba(0,0,0,0.06); box-shadow: 0 8px 24px rgba(0,0,0,0.06);">
              <a href="#" class="absolute inset-0 w-full h-full z-0 cursor-pointer" tabindex="-1" style="display: block;">
                <div
                  style="width:100%;height:100%;background:#e8e8e8;display:block;"
                  aria-hidden="true"
                ></div>
              </a>
              <button class="fc-qv-trigger" aria-label="Quick view {{ ph_name }}" data-card-id="{{ forloop.index }}">
                <span class="fc-qv-label">QUICK VIEW</span>
                <span class="fc-qv-plus" aria-hidden="true">+</span>
              </button>
            </div>

            <div class="mt-3 px-0.5 text-left">
              <p class="fc-product-name font-body leading-tight" style="font-size:{{ fc_title_size }};color:{{ fc_title_color }};font-weight:{{ fc_title_weight }};">{{ trunc_name }}</p>
              <div class="flex items-center justify-start gap-2 mt-1 flex-wrap">
                <span class="fc-price font-body font-semibold" style="font-size:calc({{ fc_title_size }} * 1.15);color:{{ fc_price_color }};">{{ ph_price }}</span>
                {%- if ph_c != '$0' and ph_c != '' -%}
                  <span class="fc-compare font-body line-through opacity-70" style="font-size:calc({{ fc_title_size }} * 0.7); color:{{ fc_compare_color }}; text-decoration: line-through !important; margin-left: 4px;">{{ ph_c }}</span>
                {%- endif -%}
              </div>
              <!-- Demo swatches -->
              <div class="fc-swatches flex items-center justify-start gap-2 mt-2 flex-wrap">
                {%- for col in ph_color -%}
                  <button
                    class="fc-swatch{% if forloop.first %} active{% endif %}"
                    aria-label="Color {{ forloop.index }}"
                    style="background-color:{{ col }};"
                  ></button>
                {%- endfor -%}
              </div>
            </div>
          </div>

        {%- endfor -%}

      {%- endif -%}

    </div>
    <!-- /Carousel track -->
  </div>



</featured-collection>

<!-- ══════════════════════════════════════════════
     QUICK VIEW MODAL (global, single instance)
══════════════════════════════════════════════ -->
<div id="fc-qv-modal" class="fc-qv-modal" role="dialog" aria-modal="true" aria-label="Quick view" aria-hidden="true">
  <!-- Top overlay — click to close -->
  <div class="fc-qv-overlay-top" id="fc-qv-backdrop" aria-label="Close quick view"></div>

  <!-- Bottom panel -->
  <div class="fc-qv-panel" id="fc-qv-panel" role="document">
    
    <!-- Top Handle & Close -->
    <div class="fc-qv-header">
      <div class="fc-qv-handle"></div>
      <button class="fc-qv-close-new" id="fc-qv-close-btn" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0a0a0a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Inner Scroll Area -->
    <div class="fc-qv-scroll-area disable-scrollbars">
      
      <!-- Gallery -->
      <div class="fc-qv-gallery">
        <div class="fc-qv-gallery-track" id="fc-qv-gallery-track"></div>
        <button class="fc-qv-arrow fc-qv-arrow-prev" id="fc-qv-prev" aria-label="Previous image">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0a0a0a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="fc-qv-arrow fc-qv-arrow-next" id="fc-qv-next" aria-label="Next image">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0a0a0a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
        </button>
        <div class="fc-qv-dots" id="fc-qv-dots"></div>
      </div>

      <!-- Product details -->
      <div class="fc-qv-info">
        <a class="fc-qv-title" id="fc-qv-title" href="#"></a>
        
        <div class="fc-qv-price-wrapper">
          <span class="fc-qv-price" id="fc-qv-price"></span>
          <span class="fc-qv-compare" id="fc-qv-compare"></span>
        </div>

        <div class="fc-qv-variants" id="fc-qv-variants"></div>

        <!-- Quantity -->
        <div class="fc-qv-qty-row hidden" id="fc-qv-qty-row">
          <div class="fc-qv-qty-label">Quantity</div>
          <div class="fc-qv-qty-ctrl-new">
            <button class="fc-qv-qty-btn-new" id="fc-qv-qty-dec" aria-label="Decrease">−</button>
            <span class="fc-qv-qty-val-new" id="fc-qv-qty-val">1</span>
            <button class="fc-qv-qty-btn-new" id="fc-qv-qty-inc" aria-label="Increase">+</button>
          </div>
        </div>

        <!-- Trust Badges -->
        <div class="fc-qv-badges">
          <div class="fc-qv-badge-card">
            <svg class="fc-qv-badge-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle><path d="M12 22s-2-3.5-3-6"></path></svg>
            <div class="fc-qv-badge-text-wrap">
               <div class="fc-qv-badge-title">Pickup available at California Warehouse</div>
               <div class="fc-qv-badge-subtitle">Usually ready in 24 hours</div>
            </div>
          </div>

          <div class="fc-qv-shipping-info">
            <div class="fc-qv-ship-item">
               <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#0a0a0a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
               <span>Free delivery on <strong>February 7th - 13th</strong></span>
            </div>
            <div class="fc-qv-ship-item">
               <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#0a0a0a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
               <span>Free + easy returns</span>
            </div>
          </div>
        </div>

      </div>
    </div> <!-- /Scroll Area -->

    <!-- Sticky Buttons -->
    <div class="fc-qv-sticky-footer">
      <div class="fc-qv-fade"></div>
      <button class="fc-qv-atc-new" id="fc-qv-atc">Add to Cart</button>
      <button class="fc-qv-bin-new" id="fc-qv-bin">Buy it now</button>
    </div>

  </div>
</div>




<!-- ══════════════════════════════════════════════
     STYLES
══════════════════════════════════════════════ -->
<style>
/* ── Heading Motion ── */
@keyframes fcHeadingFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}
.fc-heading-motion {
  display: inline-block;
  animation: fcHeadingFloat 4.5s ease-in-out infinite;
  will-change: transform;
}

/* ── Carousel track ── */
#fc-track {
  display: flex !important;
  flex-wrap: nowrap !important;
  overflow-x: auto !important;
  padding-left: 20px !important;
  padding-right: 20px !important;
  
  overflow-y: hidden !important;
  
  scroll-behavior: smooth !important;
  -webkit-overflow-scrolling: touch !important;
  overscroll-behavior-x: auto !important;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
@media (min-width: 768px) {
  #fc-track {
    padding-left: 40px !important;
    padding-right: 40px !important;
    
  }
}
#fc-track::-webkit-scrollbar { display: none; }

/* ── Card sizing ── */
.fc-card {
  flex: 0 0 auto !important; /* Đảm bảo thẻ KHÔNG bị bóp méo khi không đủ chỗ */
  width: 72vw !important;    /* Mobile: Hiện đúng 1 thẻ và 1 góc của thẻ tiếp theo */
  max-width: none !important;
  
  
}
@media (min-width: 640px) {
  .fc-card { width: calc(50% - 12px) !important; } /* Tablet: 2 thẻ + 1 góc */
}
@media (min-width: 1024px) {
  .fc-card { width: calc(33.333% - 16px) !important; } /* Desktop: 3 thẻ + 1 góc */
}
@media (min-width: 1280px) {
  .fc-card { width: calc(25% - 16px) !important; } /* Màn to: 4 thẻ + 1 góc */
}

/* ── Card image zoom ── */
.fc-img {
  transition: transform 0.55s cubic-bezier(0.25,0.46,0.45,0.94);
  will-change: transform;
}
.fc-card-img-wrap:hover .fc-img { transform: scale(1.04); }

/* ── Quick View trigger ── */
.fc-qv-trigger {
  position: absolute;
  bottom: 10px;
  left: 10px;
  right: 10px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 14px;
  border: none;
  border-radius: 999px;
  cursor: pointer;
  background: rgba(248,248,248,0.85);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #0a0a0a;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.26s ease, transform 0.26s ease;
}
.fc-card-img-wrap:hover .fc-qv-trigger,
.fc-card-img-wrap:focus-within .fc-qv-trigger { opacity: 1; transform: translateY(0); }
@media (hover: none) { .fc-qv-trigger { opacity: 1; transform: translateY(0); } }
.fc-qv-trigger:hover { background: rgba(255,255,255,0.97); }
.fc-qv-plus { font-size: 1.2rem; font-weight: 300; line-height: 1; }

/* ── Product text truncation ── */
.fc-product-name {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: normal;
  max-width: 100%;
}
/* ── Variant swatches ── */
.fc-swatch {
  width: 34px;
  height: 44px;
  border-radius: 6px;
  border: 2px solid transparent;
  cursor: pointer;
  background-size: cover;
  background-position: center;
  background-color: #ddd;
  transition: border-color 0.2s, transform 0.2s;
  flex-shrink: 0;
}
.fc-swatch.active,
.fc-swatch:hover { border-color: #0a0a0a; transform: scale(1.12); }
.fc-swatch-more { line-height: 26px; }



/* ── Quick View Modal ── */
.fc-qv-modal {
  position: fixed; inset: 0; z-index: 99999;
  display: flex; flex-direction: column;
  pointer-events: none; opacity: 0;
  transition: opacity 0.3s ease;
}
.fc-qv-modal.fc-qv-open { opacity: 1; pointer-events: auto; }

.fc-qv-overlay-top {
  flex: 1;
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(4px);
  cursor: pointer;
}

.fc-qv-panel {
  flex: 0 0 auto;
  max-height: 94vh;
  background: #fff;
  border-radius: 20px 20px 0 0;
  transform: translateY(100%);
  transition: transform 0.42s cubic-bezier(0.32,0.72,0,1);
  display: flex; flex-direction: column;
  overflow: hidden;
}
.fc-qv-modal.fc-qv-open .fc-qv-panel { transform: translateY(0); }

/* Header */
.fc-qv-header {
  flex-shrink: 0; width: 100%; position: relative;
  display: flex; justify-content: center; padding: 16px 0; z-index: 10;
}
.fc-qv-handle { width: 48px; height: 5px; border-radius: 99px; background: #e4e4e4; }
.fc-qv-close-new {
  position: absolute; top: 12px; right: 16px;
  width: 32px; height: 32px; border-radius: 50%;
  background: #f4f4f4; border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
}

/* Scroll area */
.fc-qv-scroll-area {
  flex: 1; overflow-y: auto; padding: 0 20px 24px;
  overscroll-behavior: contain;
  scrollbar-width: none; -ms-overflow-style: none;
}
.fc-qv-scroll-area::-webkit-scrollbar { display: none; }

/* Gallery */
.fc-qv-gallery {
  position: relative; background: #f4f4f4; border-radius: 12px;
  aspect-ratio: 3/4; width: 100%; overflow: hidden;
}
.fc-qv-gallery-track {
  display: flex; height: 100%; transition: transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94);
}
.fc-qv-gallery-track img {
  flex: 0 0 100%; width: 100%; height: 100%; object-fit: cover;
}
.fc-qv-arrow {
  position: absolute; top: 50%; transform: translateY(-50%);
  width: 36px; height: 36px; border-radius: 50%; border: none;
  background: rgba(255,255,255,0.85); color: #0a0a0a; z-index: 2;
  display: flex; align-items: center; justify-content: center; cursor: pointer;
  box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}
.fc-qv-arrow-prev { left: 12px; }
.fc-qv-arrow-next { right: 12px; }

/* Dots */
.fc-qv-dots {
  position: absolute; bottom: 12px; left: 50%; transform: translateX(-50%);
  display: flex; gap: 6px;
}
.fc-qv-dot {
  width: 6px; height: 6px; border-radius: 50%; border: none;
  background: rgba(0,0,0,0.2); transition: all 0.2s; cursor: pointer;
}
.fc-qv-dot.active { background: #0a0a0a; transform: scale(1.3); }

/* Typography */
.fc-qv-title {
  font-family: var(--font-body-family, 'Inter', sans-serif);
  font-weight: 700; color: #0a0a0a; font-size: 1.15rem; line-height: 1.3;
  text-decoration: none; display: block; margin-top: 16px;
}
.fc-qv-price-wrapper { display: flex; align-items: center; gap: 8px; margin-top: 8px; flex-wrap: wrap; }
.fc-qv-price { font-family: var(--font-body-family); font-weight: 700; font-size: 1.1rem; color: #0a0a0a; }
.fc-qv-compare { font-family: var(--font-body-family); font-size: 0.8rem; color: #999; text-decoration: line-through; display: none; }


/* Variant buttons in modal */
.fc-qv-variants { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 24px; padding-top: 20px; border-top: 1px solid #f0f0f0; }
.fc-qv-v-btn {
  display: flex; align-items: center; gap: 6px; padding: 5px 10px 5px 5px;
  border: 1.5px solid #e0e0e0; border-radius: 999px; background: transparent; cursor: pointer;
  font-family: var(--font-body-family, 'Inter', sans-serif); font-size: 0.7rem; font-weight: 500; color: #0a0a0a;
  transition: border-color 0.2s, background 0.2s;
}
.fc-qv-v-btn.active { border-color: #0a0a0a; background: #f8f8f8; }
.fc-qv-v-btn.unavailable { opacity: 0.38; cursor: not-allowed; }
.fc-qv-v-btn img { width: 26px; height: 26px; border-radius: 50%; object-fit: cover; }
.fc-qv-v-btn .fc-qv-v-dot { width: 22px; height: 22px; border-radius: 50%; flex-shrink: 0; }


/* Quantity */
.fc-qv-qty-row { margin-top: 24px; }
.fc-qv-qty-label { font-family: var(--font-body-family); font-size: 1rem; font-weight: 700; color: #0a0a0a; margin-bottom: 12px; }
.fc-qv-qty-ctrl-new {
  display: flex; align-items: center; justify-content: space-between;
  border: 1px solid #d1d5db; border-radius: 10px; width: 130px; height: 48px; padding: 0 4px;
}
.fc-qv-qty-btn-new {
  width: 40px; height: 100%; border: none; background: none; cursor: pointer;
  font-size: 24px; color: #555; display: flex; align-items: center; justify-content: center;
}
.fc-qv-qty-val-new { font-family: var(--font-body-family); font-weight: 600; font-size: 1.1rem; color: #0a0a0a; }

/* Setup & Badges */
.fc-qv-badges { margin-top: 32px; }
.fc-qv-badge-card {
  background: #f2fcf5; padding: 16px; border-radius: 12px; display: flex; gap: 12px;
  border: 1px solid #e1f5e8; margin-bottom: 24px;
}
.fc-qv-badge-icon { width: 20px; height: 20px; flex-shrink: 0; margin-top: 2px; color: #0a0a0a; }
.fc-qv-badge-title { font-weight: 700; color: #0a0a0a; font-size: 0.85rem; line-height: 1.2; font-family: var(--font-body-family); }
.fc-qv-badge-subtitle { color: #333; margin-top: 4px; font-size: 0.8rem; font-family: var(--font-body-family); }

.fc-qv-shipping-info { font-family: var(--font-body-family); font-size: 0.875rem; color: #333; margin-bottom: 32px; display: flex; flex-direction: column; gap: 16px; }
.fc-qv-ship-item { display: flex; align-items: center; gap: 12px; }
.fc-qv-ship-item svg { width: 24px; height: 24px; flex-shrink: 0; }
.fc-qv-ship-item strong { font-weight: 700; color: #0a0a0a; }

/* Sticky Footer */
.fc-qv-sticky-footer {
  flex-shrink: 0; background: #fff; padding: 16px 20px 32px;
  border-top: 1px solid #f0f0f0; position: relative;
  display: flex; flex-direction: column; gap: 10px;
}
.fc-qv-fade {
  position: absolute; bottom: 100%; left: 0; width: 100%; height: 24px;
  background: linear-gradient(to top, rgba(255,255,255,1), rgba(255,255,255,0)); pointer-events: none;
}
.fc-qv-atc-new, .fc-qv-bin-new {
  width: 100%; padding: 14px 0; border-radius: 99px; font-family: var(--font-body-family); font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.8rem; cursor: pointer; transition: opacity 0.2s; border: 1px solid #0a0a0a;
}
.fc-qv-atc-new { background: #fff; color: #0a0a0a; }
.fc-qv-bin-new { background: #0a0a0a; color: #fff; }
.fc-qv-atc-new:hover, .fc-qv-bin-new:hover { opacity: 0.8; }

</style>

<!-- ══════════════════════════════════════════════
     SCRIPT
══════════════════════════════════════════════ -->
<script>
(function () {
  'use strict';
  if (customElements.get('featured-collection')) return;

  /* ──────────────────────────────────────────
     State
  ────────────────────────────────────────── */
  let currentProduct   = null;
  let currentVariantId = null;
  let galleryIndex     = 0;
  let galleryImages    = [];
  let qty              = 1;

  /* ──────────────────────────────────────────
     DOM refs
  ────────────────────────────────────────── */
  const modal       = document.getElementById('fc-qv-modal');
  const panel       = document.getElementById('fc-qv-panel');
  const backdrop    = document.getElementById('fc-qv-backdrop');
  const closeBtn    = document.getElementById('fc-qv-close-btn');
  const galleryTrack= document.getElementById('fc-qv-gallery-track');
  const dotsWrap    = document.getElementById('fc-qv-dots');
  const prevBtn     = document.getElementById('fc-qv-prev');
  const nextBtn     = document.getElementById('fc-qv-next');
  const titleEl     = document.getElementById('fc-qv-title');
  const priceEl     = document.getElementById('fc-qv-price');
  const compareEl   = document.getElementById('fc-qv-compare');
  const variantsEl  = document.getElementById('fc-qv-variants');
  const atcBtn      = document.getElementById('fc-qv-atc');
  const binBtn      = document.getElementById('fc-qv-bin');
  const qtyRow      = document.getElementById('fc-qv-qty-row');
  const qtyVal      = document.getElementById('fc-qv-qty-val');
  const qtyDec      = document.getElementById('fc-qv-qty-dec');
  const qtyInc      = document.getElementById('fc-qv-qty-inc');


  /* ──────────────────────────────────────────
     Helpers
  ────────────────────────────────────────── */
  function formatMoney(cents) {
    if (!cents || cents === 0) return '';
    return '$' + (cents / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  function setGalleryIndex(i) {
    const total = galleryImages.length;
    if (total === 0) return;
    galleryIndex = (i + total) % total;
    galleryTrack.style.transform = `translateX(-${galleryIndex * 100}%)`;
    document.querySelectorAll('.fc-qv-dot').forEach((d, idx) => {
      d.classList.toggle('active', idx === galleryIndex);
    });
  }

  function buildGallery(images) {
    galleryImages = images || [];
    galleryIndex = 0;
    galleryTrack.innerHTML = '';
    dotsWrap.innerHTML = '';

    if (galleryImages.length === 0) {
      galleryTrack.innerHTML = '<div style="width:100%;height:100%;background:#eee;"></div>';
      return;
    }

    galleryImages.forEach((src, i) => {
      const img = document.createElement('img');
      img.src = src;
      img.alt = '';
      img.loading = i === 0 ? 'eager' : 'lazy';
      img.style.cssText = 'flex:0 0 100%;width:100%;height:100%;object-fit:cover;';
      galleryTrack.appendChild(img);

      if (galleryImages.length > 1) {
        const dot = document.createElement('button');
        dot.className = 'fc-qv-dot' + (i === 0 ? ' active' : '');
        dot.setAttribute('aria-label', `Image ${i + 1}`);
        dot.addEventListener('click', () => setGalleryIndex(i));
        dotsWrap.appendChild(dot);
      }
    });

    prevBtn.style.display = galleryImages.length > 1 ? 'flex' : 'none';
    nextBtn.style.display = galleryImages.length > 1 ? 'flex' : 'none';
  }

  function buildVariants(variants) {
    variantsEl.innerHTML = '';
    if (!variants || variants.length <= 1) return;

    variants.forEach((v, i) => {
      const btn = document.createElement('button');
      btn.className = 'fc-qv-v-btn' + (i === 0 ? ' active' : '') + (v.available === false ? ' unavailable' : '');
      btn.setAttribute('data-variant-id', v.id);
      btn.setAttribute('aria-label', v.title);

      if (v.swatch) {
        const img = document.createElement('img');
        img.src = v.swatch;
        img.alt = v.option1 || '';
        img.loading = 'lazy';
        btn.appendChild(img);
      } else if (v.option1) {
        const dot = document.createElement('span');
        dot.className = 'fc-qv-v-dot';
        dot.style.background = '#ddd';
        btn.appendChild(dot);
      }

      const label = document.createElement('span');
      label.textContent = v.option1 || v.title;
      btn.appendChild(label);

      btn.addEventListener('click', () => selectVariant(v, btn));
      variantsEl.appendChild(btn);
    });
  }

  function selectVariant(v, clickedBtn) {
    currentVariantId = v.id;

    // Update active state
    document.querySelectorAll('.fc-qv-v-btn').forEach(b => b.classList.remove('active'));
    if (clickedBtn) clickedBtn.classList.add('active');

    // Update price
    priceEl.textContent = formatMoney(v.price);
    if (v.compare && v.compare > v.price) {
      compareEl.textContent = formatMoney(v.compare);
      compareEl.classList.remove('hidden');
    } else {
      compareEl.classList.add('hidden');
    }

    // Switch gallery image if variant has its own image
    if (v.img && galleryImages.includes(v.img)) {
      setGalleryIndex(galleryImages.indexOf(v.img));
    } else if (v.img && galleryImages.length > 0) {
      setGalleryIndex(0);
    }

    // Update ATC
    atcBtn.disabled = v.available === false;
    atcBtn.textContent = v.available === false ? 'Sold Out' : 'Add to Cart';
  }

  function openModal(cardEl) {
    if (!cardEl) return;
    currentProduct = {
      id:       cardEl.dataset.productId,
      title:    cardEl.dataset.productTitle || '',
      sku:      cardEl.dataset.productSku   || '',
      url:      cardEl.dataset.productUrl   || '#',
      money:    cardEl.dataset.productMoney || '',
      compare:  cardEl.dataset.productCompareMoney || '',
      variants: JSON.parse(cardEl.dataset.productVariants || '[]'),
      images:   JSON.parse(cardEl.dataset.productImages   || '[]'),
    };
    qty = 1;
    qtyVal.textContent = 1;

    // Populate
    titleEl.textContent = currentProduct.title;
    titleEl.href        = currentProduct.url;
    priceEl.textContent = currentProduct.money;

    if (currentProduct.compare && currentProduct.compare !== currentProduct.money && currentProduct.compare !== '$0.00') {
      compareEl.textContent = currentProduct.compare;
      compareEl.classList.remove('hidden');
    } else {
      compareEl.textContent = '';
      compareEl.classList.add('hidden');
    }

    buildGallery(currentProduct.images);

    if (currentProduct.variants.length > 0) {
      currentVariantId = currentProduct.variants[0].id;
      atcBtn.disabled  = currentProduct.variants[0].available === false;
      atcBtn.textContent = currentProduct.variants[0].available === false ? 'Sold Out' : 'Add to Cart';
      buildVariants(currentProduct.variants);
      qtyRow.classList.remove('hidden');
    } else {
      currentVariantId = null;
      variantsEl.innerHTML = '';
      atcBtn.disabled = false;
      atcBtn.textContent = 'Add to Cart';
      qtyRow.classList.add('hidden');
    }

    modal.classList.add('fc-qv-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    setTimeout(() => closeBtn.focus(), 420);
  }

  function closeModal() {
    modal.classList.remove('fc-qv-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  /* ──────────────────────────────────────────
     Add to Cart (Shopify AJAX)
  ────────────────────────────────────────── */
  atcBtn && atcBtn.addEventListener('click', async () => {
    if (!currentVariantId && (!currentProduct || !currentProduct.id)) {
      closeModal();
      return;
    }
    const variantId = currentVariantId || (currentProduct.variants[0] && currentProduct.variants[0].id);
    if (!variantId) return;

    atcBtn.textContent = 'Adding…';
    atcBtn.disabled = true;

    try {
      const res = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: qty }),
      });
      if (res.ok) {
        atcBtn.textContent = '✓ Added';
        setTimeout(() => {
          atcBtn.textContent = 'Add to Cart';
          atcBtn.disabled = false;
          // Update cart count if element exists
          const cartCount = document.querySelector('[data-cart-count], .cart-count, .header-cart-count');
          if (cartCount) {
            fetch('/cart.js')
              .then(r => r.json())
              .then(c => { cartCount.textContent = c.item_count; })
              .catch(() => {});
          }
          closeModal();
        }, 1200);
      } else {
        throw new Error('Failed');
      }
    } catch {
      atcBtn.textContent = 'Error — try again';
      atcBtn.disabled = false;
      setTimeout(() => { atcBtn.textContent = 'Add to Cart'; }, 1800);
    }
  });

  /* Buy it now */
  binBtn && binBtn.addEventListener('click', async () => {
    const variantId = currentVariantId || (currentProduct && currentProduct.variants[0] && currentProduct.variants[0].id);
    if (!variantId) return;
    binBtn.textContent = 'Processing…';
    try {
      await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: qty }),
      });
      window.location.href = '/checkout';
    } catch {
      binBtn.textContent = 'Buy it now';
    }
  });

  /* Qty controls */
  qtyDec && qtyDec.addEventListener('click', () => {
    if (qty > 1) { qty--; qtyVal.textContent = qty; }
  });
  qtyInc && qtyInc.addEventListener('click', () => {
    qty++;
    qtyVal.textContent = qty;
  });

  /* Gallery arrows */
  prevBtn && prevBtn.addEventListener('click', () => setGalleryIndex(galleryIndex - 1));
  nextBtn && nextBtn.addEventListener('click', () => setGalleryIndex(galleryIndex + 1));

  /* Close */
  backdrop && backdrop.addEventListener('click', closeModal);
  closeBtn && closeBtn.addEventListener('click', e => { e.stopPropagation(); closeModal(); });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && modal.classList.contains('fc-qv-open')) closeModal();
    if (!modal.classList.contains('fc-qv-open')) return;
    if (e.key === 'ArrowLeft') setGalleryIndex(galleryIndex - 1);
    if (e.key === 'ArrowRight') setGalleryIndex(galleryIndex + 1);
  });

  /* Swipe on gallery */
  let touchStartX = 0;
  galleryTrack && galleryTrack.addEventListener('touchstart', e => { touchStartX = e.changedTouches[0].clientX; }, { passive: true });
  galleryTrack && galleryTrack.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 40) setGalleryIndex(dx < 0 ? galleryIndex + 1 : galleryIndex - 1);
  });

  /* ──────────────────────────────────────────
     Web Component
  ────────────────────────────────────────── */
  class FeaturedCollection extends HTMLElement {
    connectedCallback() {
      
      this._initCards();
      
      this._initGSAP();
    }

    disconnectedCallback() {

      window.removeEventListener('scroll', this._scrollHandler);
      if (this._gsapCtx) this._gsapCtx.revert();
    }



    _initCards() {
      this.querySelectorAll('.fc-qv-trigger').forEach(btn => {
        btn.addEventListener('click', e => {
          e.preventDefault(); e.stopPropagation();
          const card = btn.closest('[data-fc-card]');
          openModal(card);
        });
      });

      // Card-level swatch hover: update card image preview
      this.querySelectorAll('.fc-swatch[data-variant-id]').forEach(sw => {
        sw.addEventListener('click', () => {
          const card   = sw.closest('[data-fc-card]');
          if (!card) return;
          const cardImg = card.querySelector('.fc-img');
          if (!cardImg) return;
          const variants = JSON.parse(card.dataset.productVariants || '[]');
          const v = variants.find(x => String(x.id) === sw.dataset.variantId);
          if (v && v.img) cardImg.src = v.img;
          card.querySelectorAll('.fc-swatch').forEach(s => s.classList.remove('active'));
          sw.classList.add('active');
        });
      });
    }


    _initGSAP() {
      if (typeof gsap === 'undefined') return;
      if (typeof ScrollTrigger !== 'undefined') gsap.registerPlugin(ScrollTrigger);
      this._gsapCtx = gsap.context(() => {
        const heading = this.querySelector('h2');
        if (heading) {
          gsap.from(heading, { scrollTrigger: { trigger: heading, start: 'top 88%', once: true }, opacity: 0, y: 36, duration: 0.85, ease: 'power3.out' });
        }
        const cards = this.querySelectorAll('[data-fc-card]');
        if (cards.length) {
          gsap.from(cards, {
            scrollTrigger: { trigger: this.querySelector('#fc-track'), start: 'top 82%', once: true },
            opacity: 0, x: 40, duration: 0.7, ease: 'power2.out', stagger: 0.09,
          });
        }
      }, this);
    }
  }

  customElements.define('featured-collection', FeaturedCollection);
})();
</script>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "class": "featured-collection-section",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "TRENDING PRODUCTS"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#0a0a0a"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "options": [
        { "value": "clamp(2rem,8vw,5rem)",    "label": "Small" },
        { "value": "clamp(2.8rem,11vw,7.5rem)", "label": "Default" },
        { "value": "clamp(3.5rem,13vw,9rem)",  "label": "Large" },
        { "value": "clamp(4rem,16vw,11rem)",   "label": "Extra Large" }
      ],
      "default": "clamp(2.8rem,11vw,7.5rem)"
    },
    {
      "type": "header",
      "content": "Products Source"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Show from Collection",
      "info": "Auto-populates from a collection. Overridden if Chosen Products below are set."
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max Products to Show",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 12
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Hand-pick Products (overrides collection)",
      "limit": 24,
      "info": "Select specific products to feature. Takes priority over Collection picker above."
    },
    {
      "type": "header",
      "content": "Card Typography"
    },
    {
      "type": "select",
      "id": "title_font_size",
      "label": "Product Name Size",
      "options": [
        { "value": "1.0rem", "label": "Small (16px)" },
        { "value": "1.2rem", "label": "Medium (19px)" },
        { "value": "1.4rem", "label": "Large (22px)" },
        { "value": "1.65rem", "label": "Extra Large (26px)" }
      ],
      "default": "1.4rem"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Name Color",
      "default": "#111111"
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Name Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "500"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "compare_color",
      "label": "Compare-at (strikethrough) Color",
      "default": "#999999"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
