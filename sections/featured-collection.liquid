{% comment %} FEATURED COLLECTION — Trending Products Carousel {% endcomment %}

{%- assign fc_heading_size = section.settings.heading_size | default: 'clamp(3rem,12vw,8rem)' -%}
{%- assign fc_title_size   = section.settings.title_font_size | default: '0.88rem' -%}
{%- assign fc_title_color  = section.settings.title_color | default: '#222222' -%}
{%- assign fc_title_weight = section.settings.title_font_weight | default: '400' -%}
{%- assign fc_price_size   = section.settings.price_font_size | default: '0.82rem' -%}
{%- assign fc_price_color  = section.settings.price_color | default: '#8A8A8A' -%}

<featured-collection class="block relative w-full overflow-hidden bg-white">

  <!-- ── Section Header ── -->
  <div class="pt-16 pb-8 px-5 md:px-10 text-center">
    <h2
      class="font-body font-black uppercase leading-[0.88] tracking-[-0.02em] text-[#0a0a0a]"
      style="font-size: {{ fc_heading_size }}; color: {{ section.settings.heading_color | default: '#0a0a0a' }};"
    >
      {{ section.settings.heading | default: 'TRENDING PRODUCTS' }}
    </h2>
  </div>
  <!-- / Section Header -->

  <!-- ── Product Carousel ── -->
  <div class="fc-carousel-wrapper relative px-5 md:px-10 pb-20">

    <!-- Scroll Track -->
    <div
      class="fc-carousel-track flex gap-4 overflow-x-auto snap-x snap-mandatory pb-4 cursor-grab select-none"
      id="fc-track"
      aria-label="Trending products carousel"
    >

      {%- if section.settings.collection != blank -%}
        {%- assign fc_products = section.settings.collection.products -%}
      {%- else -%}
        {%- assign fc_products = null -%}
      {%- endif -%}

      {% if fc_products != null and fc_products.size > 0 %}

        {% for product in fc_products limit: section.settings.products_to_show %}
          {%- assign fc_img   = product.featured_image -%}
          {%- assign fc_name  = product.title -%}
          {%- assign fc_price = product.price | money -%}
          {%- assign fc_url   = product.url -%}

          <!-- Product Card -->
          <div class="fc-card snap-start flex-none w-[80vw] max-w-[340px] md:w-[320px] flex flex-col" data-fc-card>

            <!-- Image Wrapper -->
            <a href="{{ fc_url }}" class="block relative overflow-hidden rounded-2xl bg-gray-100" style="aspect-ratio: 3/4;">

              {% if fc_img != blank %}
                <img
                  src="{{ fc_img | image_url: width: 800 }}"
                  alt="{{ fc_img.alt | default: fc_name | escape }}"
                  class="fc-card-img"
                  loading="{% if forloop.index <= 2 %}eager{% else %}lazy{% endif %}"
                  width="800"
                  height="{{ 800 | divided_by: 0.75 | round }}"
                />
              {% else %}
                <!-- Placeholder image (no product img) -->
                <div class="absolute inset-0 flex items-end justify-center pb-6">
                  {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover opacity-40' }}
                </div>
              {% endif %}

              <!-- Quick View Overlay Button -->
              <button
                class="fc-quick-view-btn"
                aria-label="Quick view {{ fc_name | escape }}"
                data-product-url="{{ fc_url }}"
                data-product-id="{{ product.id }}"
                onclick="event.preventDefault(); event.stopPropagation(); window.openQuickView && window.openQuickView('{{ product.handle }}');"
              >
                <span class="fc-quick-view-label">QUICK VIEW</span>
                <span class="fc-quick-view-icon" aria-hidden="true">+</span>
              </button>

            </a>
            <!-- / Image Wrapper -->

            <!-- Product Info -->
            <div class="mt-3 px-1 text-center">
              <a
                href="{{ fc_url }}"
                class="block font-body leading-snug hover:underline underline-offset-2 transition-all"
                style="
                  font-size: {{ fc_title_size }};
                  color: {{ fc_title_color }};
                  font-weight: {{ fc_title_weight }};
                "
              >
                {{ fc_name }}
              </a>
              <p
                class="font-body mt-1"
                style="
                  font-size: {{ fc_price_size }};
                  color: {{ fc_price_color }};
                "
              >
                {{ fc_price }}
              </p>
            </div>
            <!-- / Product Info -->

          </div>
          <!-- / Product Card -->

        {% endfor %}

      {% else %}

        <!-- ── Placeholder cards (no collection set) ── -->
        {%- assign fc_placeholder_names  = "Full Sleeve Round Neck T-shirt|Distressed Knit Crewneck|Oversized Cargo Jacket|Minimal Linen Trousers|Ribbed Tank Essential|Wide-leg Denim|Tailored Bomber|Relaxed Polo" | split: "|" -%}
        {%- assign fc_placeholder_prices = "$45.00|$68.00|$110.00|$72.00|$38.00|$88.00|$125.00|$55.00" | split: "|" -%}
        {%- assign fc_placeholder_imgs   = "photo-1515886657613-9f3515b0c78f|photo-1558769132-cb1aea458c5e|photo-1539109136881-3be0616acf4b|photo-1509631179647-0177331693ae|photo-1485968579580-b6d095142e6e|photo-1472396961693-142e6e269027|photo-1490481651871-ab68de25d43d|photo-1469334031218-e382a71b716b" | split: "|" -%}

        {% for i in (1..8) %}
          {%- assign idx     = forloop.index0 -%}
          {%- assign ph_name  = fc_placeholder_names[idx] -%}
          {%- assign ph_price = fc_placeholder_prices[idx] -%}
          {%- assign ph_img   = fc_placeholder_imgs[idx] -%}

          <!-- Placeholder Card #{{ forloop.index }} -->
          <div class="fc-card snap-start flex-none w-[80vw] max-w-[340px] md:w-[320px] flex flex-col" data-fc-card>

            <div class="block relative overflow-hidden rounded-2xl bg-gray-100" style="aspect-ratio: 3/4;">
              <img
                src="https://images.unsplash.com/{{ ph_img }}?w=800&q=82&auto=format&fit=crop"
                alt="{{ ph_name }}"
                class="fc-card-img"
                loading="{% if forloop.index <= 2 %}eager{% else %}lazy{% endif %}"
                width="800"
                height="1067"
              />

              <!-- Quick View Overlay Button -->
              <button
                class="fc-quick-view-btn"
                aria-label="Quick view {{ ph_name }}"
              >
                <span class="fc-quick-view-label">QUICK VIEW</span>
                <span class="fc-quick-view-icon" aria-hidden="true">+</span>
              </button>
            </div>

            <!-- Product Info -->
            <div class="mt-3 px-1 text-center">
              <p
                class="font-body leading-snug"
                style="
                  font-size: {{ fc_title_size }};
                  color: {{ fc_title_color }};
                  font-weight: {{ fc_title_weight }};
                "
              >
                {{ ph_name }}
              </p>
              <p
                class="font-body mt-1"
                style="
                  font-size: {{ fc_price_size }};
                  color: {{ fc_price_color }};
                "
              >
                {{ ph_price }}
              </p>
            </div>
          </div>
          <!-- / Placeholder Card #{{ forloop.index }} -->

        {% endfor %}
      {% endif %}

    </div>
    <!-- / Scroll Track -->

  </div>
  <!-- / Product Carousel -->

  <!-- ── CTA: View All ── -->
  {% if section.settings.show_view_all and section.settings.collection != blank %}
    <div class="pb-16 text-center">
      <a
        href="{{ section.settings.collection.url }}"
        class="fc-view-all font-body uppercase tracking-[0.2em] text-[0.7rem] font-semibold text-[#0a0a0a] border border-[#0a0a0a] rounded-full px-8 py-3 inline-block hover:bg-[#0a0a0a] hover:text-white transition-all duration-300"
      >
        {{ section.settings.view_all_text | default: 'View All' }}
      </a>
    </div>
  {% endif %}

</featured-collection>

<!-- ── Scroll-to-Top Button (fixed, bottom-right) ── -->
<button
  id="fc-scroll-top"
  class="fc-scroll-top-btn"
  aria-label="Scroll to top"
  onclick="window.scrollTo({ top: 0, behavior: 'smooth' });"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 19V5M5 12l7-7 7 7"/>
  </svg>
</button>

<script>
/* ─────────────────────────────────────────────────────
   FEATURED COLLECTION — Web Component Logic
───────────────────────────────────────────────────── */
(function () {
  'use strict';

  if (customElements.get('featured-collection')) return;

  class FeaturedCollection extends HTMLElement {
    constructor() {
      super();
      this._dragState = null;
      this._scrollTopBtn = null;
      this._scrollHandler = null;
      this._gsapCtx = null;
    }

    connectedCallback() {
      this._initCarousel();
      this._initScrollTopBtn();
      this._initGSAP();
    }

    disconnectedCallback() {
      const track = this.querySelector('#fc-track');
      if (track && this._trackListeners) {
        track.removeEventListener('mousedown', this._trackListeners.mousedown);
        track.removeEventListener('mousemove', this._trackListeners.mousemove);
        track.removeEventListener('mouseup',   this._trackListeners.mouseup);
        track.removeEventListener('mouseleave', this._trackListeners.mouseleave);
      }
      if (this._scrollHandler) {
        window.removeEventListener('scroll', this._scrollHandler);
      }
      if (this._gsapCtx) {
        this._gsapCtx.revert();
      }
    }

    /* ── Drag-to-scroll carousel ── */
    _initCarousel() {
      const track = this.querySelector('#fc-track');
      if (!track) return;

      let isDown = false;
      let startX  = 0;
      let scrollLeft = 0;

      const onMouseDown = (e) => {
        isDown = true;
        track.classList.add('cursor-grabbing');
        startX     = e.pageX - track.offsetLeft;
        scrollLeft = track.scrollLeft;
      };
      const onMouseLeave = () => {
        isDown = false;
        track.classList.remove('cursor-grabbing');
      };
      const onMouseUp = () => {
        isDown = false;
        track.classList.remove('cursor-grabbing');
      };
      const onMouseMove = (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x    = e.pageX - track.offsetLeft;
        const walk = (x - startX) * 1.4;
        track.scrollLeft = scrollLeft - walk;
      };

      track.addEventListener('mousedown',  onMouseDown);
      track.addEventListener('mouseleave', onMouseLeave);
      track.addEventListener('mouseup',    onMouseUp);
      track.addEventListener('mousemove',  onMouseMove);

      this._trackListeners = {
        mousedown: onMouseDown,
        mousemove: onMouseMove,
        mouseup:   onMouseUp,
        mouseleave: onMouseLeave,
      };
    }

    /* ── Scroll-to-top button visibility ── */
    _initScrollTopBtn() {
      const btn = document.getElementById('fc-scroll-top');
      if (!btn) return;
      this._scrollTopBtn = btn;

      const updateVisibility = () => {
        if (window.scrollY > 300) {
          btn.classList.add('fc-scroll-top-btn--visible');
        } else {
          btn.classList.remove('fc-scroll-top-btn--visible');
        }
      };

      this._scrollHandler = updateVisibility;
      window.addEventListener('scroll', this._scrollHandler, { passive: true });
      updateVisibility();
    }

    /* ── GSAP: stagger cards in on scroll ── */
    _initGSAP() {
      if (typeof gsap === 'undefined') return;
      if (typeof ScrollTrigger !== 'undefined') gsap.registerPlugin(ScrollTrigger);

      this._gsapCtx = gsap.context(() => {
        /* Heading reveal */
        const heading = this.querySelector('h2');
        if (heading) {
          gsap.from(heading, {
            scrollTrigger: {
              trigger: heading,
              start: 'top 88%',
              once: true,
            },
            opacity: 0,
            y: 40,
            duration: 0.9,
            ease: 'power3.out',
          });
        }

        /* Cards stagger */
        const cards = this.querySelectorAll('[data-fc-card]');
        if (cards.length) {
          gsap.from(cards, {
            scrollTrigger: {
              trigger: this.querySelector('#fc-track'),
              start: 'top 85%',
              once: true,
            },
            opacity: 0,
            x: 30,
            duration: 0.75,
            ease: 'power2.out',
            stagger: 0.1,
          });
        }
      }, this);
    }
  }

  customElements.define('featured-collection', FeaturedCollection);
})();
</script>

<style>
/* ═══ Featured Collection — component styles ═══ */

/* Hide scrollbar while keeping scroll functionality */
#fc-track {
  scrollbar-width: none;
  -ms-overflow-style: none;
}
#fc-track::-webkit-scrollbar {
  display: none;
}

/* Product image: cover fill, smooth hover zoom */
.fc-card-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  will-change: transform;
}
.fc-card:hover .fc-card-img {
  transform: scale(1.04);
}

/* Quick View button: sits at bottom of image card */
.fc-quick-view-btn {
  position: absolute;
  bottom: 12px;
  left: 12px;
  right: 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  padding: 11px 16px;
  background: rgba(245, 245, 245, 0.82);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: none;
  border-radius: 999px;
  cursor: pointer;
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #0a0a0a;
  opacity: 0;
  transform: translateY(6px);
  transition: opacity 0.28s ease, transform 0.28s ease, background 0.2s ease;
  white-space: nowrap;
  width: calc(100% - 24px);
}
.fc-card:hover .fc-quick-view-btn,
.fc-card:focus-within .fc-quick-view-btn {
  opacity: 1;
  transform: translateY(0);
}
.fc-quick-view-btn:hover {
  background: rgba(255, 255, 255, 0.95);
}
.fc-quick-view-label {
  flex: 1;
  text-align: left;
}
.fc-quick-view-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
  font-weight: 300;
  line-height: 1;
  color: #0a0a0a;
}

/* Mobile: always show Quick View (no hover on touch) */
@media (hover: none) {
  .fc-quick-view-btn {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ── Scroll-to-top fixed button ── */
.fc-scroll-top-btn {
  position: fixed;
  bottom: 24px;
  right: 20px;
  z-index: 200;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: transparent;
  border: 1.5px solid #0a0a0a;
  color: #0a0a0a;
  cursor: pointer;
  opacity: 0;
  pointer-events: none;
  transform: translateY(12px);
  transition: opacity 0.3s ease, transform 0.3s ease, background 0.2s ease, color 0.2s ease;
}
.fc-scroll-top-btn--visible {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}
.fc-scroll-top-btn:hover {
  background: #0a0a0a;
  color: #ffffff;
}
</style>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "class": "featured-collection-section",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "TRENDING PRODUCTS"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#0a0a0a"
    },
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Leave blank to show placeholder products in the editor."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 20,
      "step": 1,
      "default": 8,
      "label": "Products to Show"
    },
    {
      "type": "header",
      "content": "Product Card Typography"
    },
    {
      "type": "select",
      "id": "title_font_size",
      "label": "Product Title Size",
      "options": [
        { "value": "0.75rem", "label": "Small (12px)" },
        { "value": "0.82rem", "label": "Medium (13px)" },
        { "value": "0.88rem", "label": "Default (14px)" },
        { "value": "1rem",    "label": "Large (16px)" },
        { "value": "1.1rem",  "label": "X-Large (17px)" }
      ],
      "default": "0.88rem"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Product Title Color",
      "default": "#222222"
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Product Title Weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "price_font_size",
      "label": "Price Size",
      "options": [
        { "value": "0.72rem", "label": "Small (11px)" },
        { "value": "0.82rem", "label": "Default (13px)" },
        { "value": "0.88rem", "label": "Medium (14px)" },
        { "value": "1rem",    "label": "Large (16px)" }
      ],
      "default": "0.82rem"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price Color",
      "default": "#8A8A8A"
    },
    {
      "type": "header",
      "content": "View All Button"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View All' Button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "Button Text",
      "default": "View All"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
