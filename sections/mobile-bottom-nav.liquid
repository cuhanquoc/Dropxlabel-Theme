      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 18,
      "max": 32,
      "step": 2,
      "default": 24,
      "label": "Icon Size (px)"
    },
    {
      "type": "range",
      "id": "label_size",
      "min": 8,
      "max": 14,
      "step": 1,
      "default": 10,
      "label": "Label Font Size (px)"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Cart Badge Background",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Cart Badge Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "── Home ──"
    },
    {
      "type": "text",
      "id": "home_label",
      "label": "Home Label",
      "default": "Home"
    },
    {
      "type": "url",
      "id": "home_url",
      "label": "Home URL"
    },
    {
      "type": "header",
      "content": "── Menu ──"
    },
    {
      "type": "text",
      "id": "menu_label",
      "label": "Menu Label",
      "default": "Menu"
    },
    {
      "type": "url",
      "id": "menu_url",
      "label": "Menu URL"
    },
    {
      "type": "header",
      "content": "── Search ──"
    },
    {
      "type": "text",
      "id": "search_label",
      "label": "Search Label",
      "default": "Search"
    },
    {
      "type": "url",
      "id": "search_url",
      "label": "Search URL"
    },
    {
      "type": "header",
      "content": "── Shop ──"
    },
    {
      "type": "text",
      "id": "shop_label",
      "label": "Shop Label",
      "default": "Shop"
    },
    {
      "type": "url",
      "id": "shop_url",
      "label": "Shop URL"
    },
    {
      "type": "header",
      "content": "── Account ──"
    },
    {
      "type": "text",
      "id": "account_label",
      "label": "Account Label",
      "default": "Account"
    },
    {
      "type": "url",
      "id": "account_url",
      "label": "Account URL"
    },
    {
      "type": "header",
      "content": "── Cart ──"
    },
    {
      "type": "text",
      "id": "cart_label",
      "label": "Cart Label",
      "default": "Cart"
    },
    {
      "type": "url",
      "id": "cart_url",
      "label": "Cart URL"
    }
  ]
}
{% endschema %}
