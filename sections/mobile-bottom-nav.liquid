{%- comment -%}
  mobile-bottom-nav.liquid
  5 fixed tabs: Home · Menu · Shop · Account · Cart
  — Shopify 2026 standards: HTML-first, Vanilla JS Web Component
  — WCAG 2.1: 44×44px touch targets, focus-visible, ARIA
  — Safe-area (notch/home indicator) support
{%- endcomment -%}

{%- liquid
  assign bg_color     = section.settings.bg_color     | default: '#ffffff'
  assign icon_color   = section.settings.icon_color   | default: '#6b7280'
  assign active_color = section.settings.active_color | default: '#111111'
  assign badge_bg     = section.settings.badge_bg     | default: '#111111'
  assign badge_color  = section.settings.badge_color  | default: '#ffffff'
  assign icon_px      = section.settings.icon_size    | default: 24
  assign label_px     = section.settings.label_size   | default: 10

  assign home_url     = section.settings.home_url
  if home_url == blank
    assign home_url = routes.root_url
  endif

  assign menu_url     = section.settings.menu_url
  if menu_url == blank
    assign menu_url = '/collections/all'
  endif

  assign shop_url     = section.settings.shop_url
  if shop_url == blank
    assign shop_url = '/collections'
  endif

  assign account_url  = routes.account_url
  assign cart_url     = routes.cart_url
-%}

<style>
  /* ─────────────────────────────────────────────────
     MOB-NAV — Reset layer (outside media query)
  ───────────────────────────────────────────────── */
  .mob-nav { display: none; }

  @media (max-width: 767px) {

    /* ── Wrapper ── */
    .mob-nav {
      display: block;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      width: 100%;
      z-index: 10000;
      background: {{ bg_color }};
      border-top: 1px solid rgba(0, 0, 0, 0.07);
      box-shadow: 0 -2px 16px rgba(0, 0, 0, 0.06);
      /* iOS safe area (home indicator) */
      padding-bottom: env(safe-area-inset-bottom, 0px);
      /* Slide-in animation */
      transform: translateY(100%);
      transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
      will-change: transform;
    }
    .mob-nav.visible {
      transform: translateY(0);
    }

    /* ── Track (5 equal columns) ── */
    .mob-nav__track {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      align-items: stretch;
      padding: 6px 0 4px;
      /* Prevent text/icon from creeping to edges */
      padding-left: env(safe-area-inset-left, 0px);
      padding-right: env(safe-area-inset-right, 0px);
    }

    /* ── Each tab item ── */
    .mob-nav__item {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 3px;
      text-decoration: none;
      color: {{ icon_color }};
      /* WCAG 2.1 — min 44×44px touch target */
      min-height: 44px;
      padding: 4px 0;
      position: relative;
      cursor: pointer;
      border: none;
      background: transparent;
      /* Smooth state transitions */
      transition:
        color 0.2s ease,
        transform 0.15s ease;
      -webkit-tap-highlight-color: transparent;
      user-select: none;
      /* Full-width within column */
      width: 100%;
    }

    /* Tap feedback */
    .mob-nav__item:active {
      transform: scale(0.88);
    }

    /* Active state */
    .mob-nav__item[aria-current="page"],
    .mob-nav__item.is-active {
      color: {{ active_color }};
    }

    /* Focus-visible (keyboard / accessibility) */
    .mob-nav__item:focus-visible {
      outline: 2px solid {{ active_color }};
      outline-offset: -2px;
      border-radius: 8px;
    }
    .mob-nav__item:focus:not(:focus-visible) {
      outline: none;
    }

    /* ── SVG icon — identical sizing on all tabs ── */
    .mob-nav__icon {
      width: {{ icon_px }}px;
      height: {{ icon_px }}px;
      stroke-width: 1.6;
      flex-shrink: 0;
      display: block;
      /* Prevent sub-pixel jitter */
      shape-rendering: geometricPrecision;
    }

    /* ── Label ── */
    .mob-nav__label {
      font-size: {{ label_px }}px;
      font-weight: 500;
      letter-spacing: 0.03em;
      line-height: 1;
      white-space: nowrap;
      font-family: var(--font-body-family, system-ui, sans-serif);
    }

    /* ── Cart badge ── */
    .mob-nav__badge {
      position: absolute;
      top: 2px;
      /* Centre over icon */
      left: 50%;
      transform: translateX(4px);
      min-width: 16px;
      height: 16px;
      padding: 0 4px;
      border-radius: 999px;
      background: {{ badge_bg }};
      color: {{ badge_color }};
      font-size: 9px;
      font-weight: 700;
      line-height: 16px;
      text-align: center;
      pointer-events: none;
      font-family: system-ui, sans-serif;
      /* Smooth count updates */
      transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    /* Pop animation when count changes */
    .mob-nav__badge.pop {
      transform: translateX(4px) scale(1.4);
    }

  } /* end @media */
</style>

<mob-bottom-nav class="mob-nav" role="navigation" aria-label="{{ 'general.navigation.mobile_nav' | t | default: 'Mobile navigation' }}">
  <div class="mob-nav__track">

    {%- comment -%} ── 1. HOME ── {%- endcomment -%}
    <a
      class="mob-nav__item"
      href="{{ home_url }}"
      aria-label="{{ section.settings.home_label | default: 'Home' }}"
      {%- if request.path == '/' %} aria-current="page"{%- endif -%}
    >
      <svg class="mob-nav__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <path d="M3 9.75 12 3l9 6.75V21a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V9.75Z"/>
        <path d="M9 22V12h6v10"/>
      </svg>
      <span class="mob-nav__label">{{ section.settings.home_label | default: 'Home' }}</span>
    </a>

    {%- comment -%} ── 2. MENU (opens Mobile Collection Menu overlay) ── {%- endcomment -%}
    <button
      type="button"
      class="mob-nav__item"
      aria-label="{{ section.settings.menu_label | default: 'Menu' }}"
      data-mob-menu-open
    >
      <svg class="mob-nav__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <line x1="3" y1="6"  x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <span class="mob-nav__label">{{ section.settings.menu_label | default: 'Menu' }}</span>
    </button>

    {%- comment -%} ── 3. SHOP ── {%- endcomment -%}
    <a
      class="mob-nav__item"
      href="{{ shop_url }}"
      aria-label="{{ section.settings.shop_label | default: 'Shop' }}"
      {%- if request.path == shop_url %} aria-current="page"{%- endif -%}
    >
      <svg class="mob-nav__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      <span class="mob-nav__label">{{ section.settings.shop_label | default: 'Shop' }}</span>
    </a>

    {%- comment -%} ── 4. ACCOUNT ── {%- endcomment -%}
    {%- if customer -%}
      {%- assign _acct_href = account_url -%}
    {%- else -%}
      {%- assign _acct_href = routes.account_login_url -%}
    {%- endif -%}
    <a
      class="mob-nav__item"
      href="{{ _acct_href }}"
      aria-label="{{ section.settings.account_label | default: 'Account' }}"
      {%- if request.path contains '/account' %} aria-current="page"{%- endif -%}
    >
      <svg class="mob-nav__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <circle cx="12" cy="8" r="4"/>
        <path d="M4 21v-1a8 8 0 0 1 16 0v1"/>
      </svg>
      <span class="mob-nav__label">{{ section.settings.account_label | default: 'Account' }}</span>
    </a>

    {%- comment -%} ── 5. CART ── {%- endcomment -%}
    <a
      class="mob-nav__item"
      href="{{ cart_url }}"
      aria-label="{{ section.settings.cart_label | default: 'Cart' }} ({{ cart.item_count }} {{ 'accessibility.cart_count' | t | default: 'items' }})"
      {%- if request.path == cart_url %} aria-current="page"{%- endif -%}
      data-mob-cart
    >
      <svg class="mob-nav__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <circle cx="9"  cy="21" r="1"/>
        <circle cx="20" cy="21" r="1"/>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
      </svg>
      {%- if cart.item_count > 0 -%}
        <span
          class="mob-nav__badge"
          id="mob-nav-cart-badge"
          aria-hidden="true"
        >{{ cart.item_count }}</span>
      {%- else -%}
        <span
          class="mob-nav__badge"
          id="mob-nav-cart-badge"
          aria-hidden="true"
          style="display:none"
        >0</span>
      {%- endif -%}
      <span class="mob-nav__label">{{ section.settings.cart_label | default: 'Cart' }}</span>
    </a>

  </div>
</mob-bottom-nav>

<script>
(function () {
  'use strict';

  /* ── Web Component: <mob-bottom-nav> ── */
  class MobBottomNav extends HTMLElement {
    connectedCallback() {
      this._initSlideIn();
      this._initCartBadge();
      this._initMenuButton();
      this._initActiveState();
    }

    disconnectedCallback() {
      if (this._onCartUpdated) {
        document.removeEventListener('cart:updated', this._onCartUpdated);
      }
      if (this._onVisibilityChange) {
        document.removeEventListener('visibilitychange', this._onVisibilityChange);
      }
      if (this._menuBtn && this._onMenuClick) {
        this._menuBtn.removeEventListener('click', this._onMenuClick);
      }
    }

    /* Slide in after 350ms (allow page paint first) */
    _initSlideIn() {
      requestAnimationFrame(() => {
        setTimeout(() => this.classList.add('visible'), 350);
      });
    }

    /* Sync cart badge with Shopify cart:updated event + fetch */
    _initCartBadge() {
      const badge = this.querySelector('#mob-nav-cart-badge');
      if (!badge) return;

      const update = (count) => {
        badge.textContent = count;
        badge.style.display = count > 0 ? '' : 'none';
        /* Pop animation */
        badge.classList.remove('pop');
        void badge.offsetWidth; // reflow
        if (count > 0) badge.classList.add('pop');
        setTimeout(() => badge.classList.remove('pop'), 300);
        /* Update aria-label on cart link */
        const link = this.querySelector('[data-mob-cart]');
        if (link) {
          const base = link.getAttribute('aria-label').replace(/\s*\(.*\)$/, '');
          link.setAttribute('aria-label', `${base} (${count} items)`);
        }
      };

      /* Listen to Shopify cart section render updates */
      this._onCartUpdated = (e) => {
        if (typeof e.detail?.cart?.item_count === 'number') {
          update(e.detail.cart.item_count);
        }
      };
      document.addEventListener('cart:updated', this._onCartUpdated);

      /* Also poll on page focus (user switches tabs) */
      this._onVisibilityChange = () => {
        if (document.visibilityState === 'visible') {
          fetch('/cart.js')
            .then(r => r.json())
            .then(d => update(d.item_count))
            .catch(() => {});
        }
      };
      document.addEventListener('visibilitychange', this._onVisibilityChange);
    }

    _initMenuButton() {
      this._menuBtn = this.querySelector('[data-mob-menu-open]');
      if (this._menuBtn) {
        this._onMenuClick = function () {
          if (typeof MobileCollectionMenu !== 'undefined') MobileCollectionMenu.open();
        };
        this._menuBtn.addEventListener('click', this._onMenuClick);
      }
    }

    /* Mark current page item active based on URL */
    _initActiveState() {
      const path = window.location.pathname;
      this.querySelectorAll('.mob-nav__item').forEach(item => {
        const href = item.getAttribute('href');
        if (!href) return;
        const isActive = href === path || (href !== '/' && path.startsWith(href));
        if (isActive) {
          item.classList.add('is-active');
          item.setAttribute('aria-current', 'page');
        }
      });
    }
  }

  if (!customElements.get('mob-bottom-nav')) {
    customElements.define('mob-bottom-nav', MobBottomNav);
  }

  /* ── Body padding so content isn't hidden behind nav ── */
  function applyBodyPadding() {
    const nav = document.querySelector('.mob-nav');
    if (!nav || window.innerWidth > 767) {
      document.body.style.paddingBottom = '';
      return;
    }
    const h = nav.getBoundingClientRect().height;
    document.body.style.paddingBottom = h + 'px';
  }
  window.addEventListener('resize', applyBodyPadding);
  document.addEventListener('DOMContentLoaded', applyBodyPadding);
  /* Run once immediately */
  applyBodyPadding();
})();
</script>

{% schema %}
{
  "name": "Mobile Bottom Nav",
  "tag": "section",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon colour (default)",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "active_color",
      "label": "Icon colour (active page)",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Cart badge background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Cart badge text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size (px)",
      "min": 18,
      "max": 32,
      "step": 1,
      "default": 24
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label size (px)",
      "min": 8,
      "max": 14,
      "step": 1,
      "default": 10
    },
    {
      "type": "header",
      "content": "Tab Labels"
    },
    {
      "type": "text",
      "id": "home_label",
      "label": "Home label",
      "default": "Home"
    },
    {
      "type": "text",
      "id": "menu_label",
      "label": "Menu label",
      "default": "Menu"
    },
    {
      "type": "text",
      "id": "shop_label",
      "label": "Shop label",
      "default": "Shop"
    },
    {
      "type": "text",
      "id": "account_label",
      "label": "Account label",
      "default": "Account"
    },
    {
      "type": "text",
      "id": "cart_label",
      "label": "Cart label",
      "default": "Cart"
    },
    {
      "type": "header",
      "content": "Links"
    },
    {
      "type": "url",
      "id": "home_url",
      "label": "Home URL",
      "info": "Leave blank → homepage"
    },
    {
      "type": "url",
      "id": "menu_url",
      "label": "Menu URL",
      "info": "Leave blank → /collections/all"
    },
    {
      "type": "url",
      "id": "shop_url",
      "label": "Shop URL",
      "info": "Leave blank → /collections (will update when new page is ready)"
    }
  ],
  "presets": [
    {
      "name": "Mobile Bottom Nav"
    }
  ]
}
{% endschema %}
