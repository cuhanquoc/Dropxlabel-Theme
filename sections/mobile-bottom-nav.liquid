{%- liquid
  assign nav_bg    = section.settings.bg_color     | default: '#ffffff'
  assign icon_col  = section.settings.icon_color   | default: '#1a1a1a'
  assign act_col   = section.settings.active_color | default: '#000000'
  assign icon_px   = section.settings.icon_size    | default: 24
  assign label_px  = section.settings.label_size   | default: 10
  assign badge_bg  = section.settings.badge_bg     | default: '#0a0a0a'
  assign badge_col = section.settings.badge_color  | default: '#ffffff'
-%}

<style>
  /* ═══════════════════════════════════════
     MOBILE BOTTOM NAV — Sticky Tab Bar
  ═══════════════════════════════════════ */

  .mob-nav { display: none; }

  @media (max-width: 767px) {
    .mob-nav {
      display: block;
      position: fixed;
      bottom: 0; left: 0; right: 0;
      width: 100%;
      z-index: 999;
      background: {{ nav_bg }};
      border-top: 1px solid rgba(0,0,0,0.08);
      box-shadow: 0 -4px 20px rgba(0,0,0,0.06);
      transform: translateY(100%);
      transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
      padding-bottom: env(safe-area-inset-bottom, 0px);
    }
    .mob-nav.mob-nav--visible { transform: translateY(0); }

    .mob-nav-track {
      display: flex;
      align-items: center;
      justify-content: space-around;
      padding: 0.5rem 0 0.25rem;
    }

    .mob-nav-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.25rem;
      text-decoration: none;
      color: {{ icon_col }};
      flex: 1;
      min-width: 0;
      min-height: 44px;
      padding: 0.25rem 0;
      position: relative;
      transition: color 0.2s ease, transform 0.18s ease;
      -webkit-tap-highlight-color: transparent;
    }
    .mob-nav-item:active { transform: scale(0.9); }
    .mob-nav-item.is-active { color: {{ act_col }}; }

    /* icon: SVG stroke */
    .mob-nav-item svg {
      width: {{ icon_px }}px;
      height: {{ icon_px }}px;
      stroke-width: 1.5;
      flex-shrink: 0;
      display: block;
    }

    /* icon: custom image */
    .mob-nav-item .mob-nav-img {
      width: {{ icon_px }}px;
      height: {{ icon_px }}px;
      object-fit: contain;
      display: block;
    }

    .mob-nav-label {
      font-family: var(--font-body, sans-serif);
      font-size: {{ label_px }}px;
      font-weight: 500;
      letter-spacing: 0.02em;
      line-height: 1;
      white-space: nowrap;
      overflow: hidden;
      max-width: 100%;
    }

    /* Cart badge */
    .mob-nav-badge {
      position: absolute;
      top: -2px;
      right: 50%;
      margin-right: -14px;
      min-width: 16px;
      height: 16px;
      border-radius: 9999px;
      background: {{ badge_bg }};
      color: {{ badge_col }};
      font-size: 10px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0 4px;
      line-height: 1;
    }

    body { padding-bottom: 64px; }
  }
</style>

<mobile-bottom-nav
  class="mob-nav"
  id="mob-bottom-nav"
  aria-label="Điều hướng"
  role="navigation"
>
  <div class="mob-nav-track">

    {%- for block in section.blocks -%}
      {%- liquid
        assign btype  = block.type
        assign b_url  = block.settings.url   | default: '/'
        assign b_lbl  = block.settings.label | default: btype
        assign b_img  = block.settings.custom_icon
        assign is_cart = false
        if btype == 'cart'
          assign is_cart = true
        endif
      -%}

      <a
        href="{{ b_url }}"
        class="mob-nav-item{% if request.path == b_url %} is-active{% endif %}"
        aria-label="{{ b_lbl }}"
        data-nav-type="{{ btype }}"
        {{ block.shopify_attributes }}
      >

        {%- comment -%} — Custom image icon (overrides SVG) — {%- endcomment -%}
        {%- if b_img != blank -%}
          <img
            src="{{ b_img | img_url: '64x64' }}"
            alt="{{ b_lbl }}"
            width="{{ icon_px }}"
            height="{{ icon_px }}"
            class="mob-nav-img"
            loading="lazy"
          >

        {%- else -%}
          {%- comment -%} — Built-in SVG presets — {%- endcomment -%}
          {%- case btype -%}

            {%- when 'home' -%}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z"/>
            </svg>

            {%- when 'menu' -%}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
              <line x1="3" y1="6" x2="21" y2="6"/>
              <line x1="3" y1="12" x2="21" y2="12"/>
              <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>

            {%- when 'search' -%}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/>
              <path d="M21 21l-4.35-4.35"/>
            </svg>

            {%- when 'cart' -%}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 01-8 0"/>
            </svg>

            {%- when 'account' -%}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="4"/>
              <path d="M4 21v-1a8 8 0 0116 0v1"/>
            </svg>

            {%- when 'shop' -%}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l1-7h16l1 7"/>
              <path d="M3 9a5 5 0 0010 0 5 5 0 0010 0"/>
              <path d="M5 21V9m14 0v12M5 21h14"/>
            </svg>

            {%- when 'wishlist' -%}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
            </svg>

            {%- when 'blog' -%}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/>
              <path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/>
            </svg>

            {%- when 'custom' -%}
            {%- comment -%} no built-in SVG — falls back to label only {%- endcomment -%}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="2"/>
              <circle cx="12" cy="5" r="1"/>
              <circle cx="12" cy="19" r="1"/>
            </svg>

          {%- endcase -%}
        {%- endif -%}

        {%- comment -%} Cart badge {%- endcomment -%}
        {%- if is_cart and cart.item_count > 0 -%}
          <span class="mob-nav-badge" id="mob-nav-badge" aria-hidden="true">
            {{ cart.item_count }}
          </span>
        {%- endif -%}

        {%- if b_lbl != blank -%}
          <span class="mob-nav-label">{{ b_lbl }}</span>
        {%- endif -%}
      </a>
    {%- endfor -%}

  </div>
</mobile-bottom-nav>

<script>
  (function () {
    if (customElements.get('mobile-bottom-nav')) return;
    customElements.define('mobile-bottom-nav', class extends HTMLElement {
      connectedCallback() {
        this._lastY     = window.scrollY;
        this._threshold = 10;
        this._ticking   = false;
        this._bound     = this._onScroll.bind(this);
        this._raf       = this._raf_fn.bind(this);
        window.addEventListener('scroll', this._bound, { passive: true });
        // Always show on load; auto-hide on scroll-down
        this.classList.add('mob-nav--visible');

        /* ── Intercept search tab → open overlay ── */
        this.addEventListener('click', function (e) {
          var item = e.target.closest('[data-nav-type="search"]');
          if (!item) return;
          e.preventDefault();
          if (window.PredictiveSearch) {
            window.PredictiveSearch.open();
          }
        });
      }
      disconnectedCallback() {
        window.removeEventListener('scroll', this._bound);
      }
      _onScroll() {
        if (!this._ticking) {
          requestAnimationFrame(this._raf);
          this._ticking = true;
        }
      }
      _raf_fn() {
        var y     = window.scrollY;
        var delta = y - this._lastY;
        if (delta > this._threshold) {
          // scrolling DOWN — hide nav
          this.classList.remove('mob-nav--visible');
        } else if (delta < -this._threshold) {
          // scrolling UP — show nav
          this.classList.add('mob-nav--visible');
        }
        this._lastY   = y;
        this._ticking = false;
      }
    });
  })();
</script>

