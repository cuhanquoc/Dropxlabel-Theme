{%- comment -%}
  ════════════════════════════════════════════════════════
  MOBILE BOTTOM NAV — Sticky Tab Bar
  Web Component: <mobile-bottom-nav>
  Shows on scroll-down, hides on scroll-up. Mobile only.
  ════════════════════════════════════════════════════════
{%- endcomment -%}

<mobile-bottom-nav
  id="mob-bottom-nav"
  class="
    hidden
    md:!hidden
    fixed bottom-0 inset-x-0 z-[999]
    bg-white border-t border-black/[0.08]
    shadow-[0_-4px_20px_rgba(0,0,0,0.06)]
    translate-y-full
    transition-transform duration-300 ease-[cubic-bezier(0.25,1,0.5,1)]
    pb-[env(safe-area-inset-bottom,0px)]
    max-[767px]:block
  "
  aria-label="Mobile navigation"
  role="navigation"
>
  <div class="flex items-center justify-around px-0 pt-2 pb-1">

    {%- comment -%} ── HOME ── {%- endcomment -%}
    <a href="{{ section.settings.home_url | default: '/' }}"
       class="mob-nav-item flex flex-col items-center justify-center gap-1 flex-1 py-1 no-underline transition-all duration-200 active:scale-[0.92]"
       style="color: {{ section.settings.icon_color | default: '#1a1a1a' }}; -webkit-tap-highlight-color: transparent;">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
           class="shrink-0" style="width:{{ section.settings.icon_size | default: 24 }}px; height:{{ section.settings.icon_size | default: 24 }}px; stroke-width:1.5;">
        <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z"/>
      </svg>
      <span class="font-body font-medium leading-none whitespace-nowrap"
            style="font-size:{{ section.settings.label_size | default: 10 }}px; letter-spacing:0.02em;">
        {{ section.settings.home_label | default: 'Home' }}
      </span>
    </a>

    {%- comment -%} ── MENU ── {%- endcomment -%}
    <a href="{{ section.settings.menu_url | default: '/collections' }}"
       class="mob-nav-item flex flex-col items-center justify-center gap-1 flex-1 py-1 no-underline transition-all duration-200 active:scale-[0.92]"
       style="color: {{ section.settings.icon_color | default: '#1a1a1a' }}; -webkit-tap-highlight-color: transparent;">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
           class="shrink-0" style="width:{{ section.settings.icon_size | default: 24 }}px; height:{{ section.settings.icon_size | default: 24 }}px; stroke-width:1.5;">
        <rect x="3" y="3" width="7" height="7" rx="1"/>
        <rect x="14" y="3" width="7" height="7" rx="1"/>
        <rect x="3" y="14" width="7" height="7" rx="1"/>
        <rect x="14" y="14" width="7" height="7" rx="1"/>
      </svg>
      <span class="font-body font-medium leading-none whitespace-nowrap"
            style="font-size:{{ section.settings.label_size | default: 10 }}px; letter-spacing:0.02em;">
        {{ section.settings.menu_label | default: 'Menu' }}
      </span>
    </a>

    {%- comment -%} ── SEARCH ── {%- endcomment -%}
    <a href="{{ section.settings.search_url | default: '/search' }}"
       class="mob-nav-item flex flex-col items-center justify-center gap-1 flex-1 py-1 no-underline transition-all duration-200 active:scale-[0.92]"
       style="color: {{ section.settings.icon_color | default: '#1a1a1a' }}; -webkit-tap-highlight-color: transparent;">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
           class="shrink-0" style="width:{{ section.settings.icon_size | default: 24 }}px; height:{{ section.settings.icon_size | default: 24 }}px; stroke-width:1.5;">
        <circle cx="11" cy="11" r="8"/>
        <path d="M21 21l-4.35-4.35"/>
      </svg>
      <span class="font-body font-medium leading-none whitespace-nowrap"
            style="font-size:{{ section.settings.label_size | default: 10 }}px; letter-spacing:0.02em;">
        {{ section.settings.search_label | default: 'Search' }}
      </span>
    </a>

    {%- comment -%} ── SHOP (Catalog) ── {%- endcomment -%}
    <a href="{{ section.settings.shop_url | default: routes.collections_url }}"
       class="mob-nav-item flex flex-col items-center justify-center gap-1 flex-1 py-1 no-underline transition-all duration-200 active:scale-[0.92]"
       style="color: {{ section.settings.icon_color | default: '#1a1a1a' }}; -webkit-tap-highlight-color: transparent;">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
           class="shrink-0" style="width:{{ section.settings.icon_size | default: 24 }}px; height:{{ section.settings.icon_size | default: 24 }}px; stroke-width:1.5;">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
        <circle cx="7" cy="6" r="1.5" fill="currentColor"/>
        <circle cx="7" cy="12" r="1.5" fill="currentColor"/>
        <circle cx="7" cy="18" r="1.5" fill="currentColor"/>
      </svg>
      <span class="font-body font-medium leading-none whitespace-nowrap"
            style="font-size:{{ section.settings.label_size | default: 10 }}px; letter-spacing:0.02em;">
        {{ section.settings.shop_label | default: 'Shop' }}
      </span>
    </a>

    {%- comment -%} ── ACCOUNT ── {%- endcomment -%}
    <a href="{{ section.settings.account_url | default: '/account' }}"
       class="mob-nav-item flex flex-col items-center justify-center gap-1 flex-1 py-1 no-underline transition-all duration-200 active:scale-[0.92]"
       style="color: {{ section.settings.icon_color | default: '#1a1a1a' }}; -webkit-tap-highlight-color: transparent;">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
           class="shrink-0" style="width:{{ section.settings.icon_size | default: 24 }}px; height:{{ section.settings.icon_size | default: 24 }}px; stroke-width:1.5;">
        <circle cx="12" cy="8" r="4"/>
        <path d="M4 21v-1a5 5 0 0110 0v1"/>
        <path d="M20 21v-1a5 5 0 00-4-4.9"/>
      </svg>
      <span class="font-body font-medium leading-none whitespace-nowrap"
            style="font-size:{{ section.settings.label_size | default: 10 }}px; letter-spacing:0.02em;">
        {{ section.settings.account_label | default: 'Account' }}
      </span>
    </a>

    {%- comment -%} ── CART ── {%- endcomment -%}
    <a href="{{ section.settings.cart_url | default: '/cart' }}"
       class="mob-nav-item relative flex flex-col items-center justify-center gap-1 flex-1 py-1 no-underline transition-all duration-200 active:scale-[0.92]"
       id="mob-nav-cart"
       style="color: {{ section.settings.icon_color | default: '#1a1a1a' }}; -webkit-tap-highlight-color: transparent;">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
           class="shrink-0" style="width:{{ section.settings.icon_size | default: 24 }}px; height:{{ section.settings.icon_size | default: 24 }}px; stroke-width:1.5;">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 01-8 0"/>
      </svg>
      {% if cart.item_count > 0 %}
        <span class="absolute -top-0.5 right-1/2 -mr-4 min-w-[16px] h-4 rounded-full flex items-center justify-center px-1 text-[9px] font-bold leading-none"
              style="background:{{ section.settings.badge_bg | default: '#0a0a0a' }}; color:{{ section.settings.badge_color | default: '#ffffff' }};"
              id="mob-nav-badge">
          {{ cart.item_count }}
        </span>
      {% endif %}
      <span class="font-body font-medium leading-none whitespace-nowrap"
            style="font-size:{{ section.settings.label_size | default: 10 }}px; letter-spacing:0.02em;">
        {{ section.settings.cart_label | default: 'Cart' }}
      </span>
    </a>

  </div>
</mobile-bottom-nav>

<script>
  /* ═══ Web Component: <mobile-bottom-nav> ═══
     Show on scroll-down, hide on scroll-up.
     Scoped DOM queries via this.querySelector().
  ═══════════════════════════════════════════ */
  customElements.define('mobile-bottom-nav', class extends HTMLElement {
    connectedCallback() {
      this._lastY = window.scrollY;
      this._threshold = 10;
      this._ticking = false;

      this._onScroll = this._onScroll.bind(this);
      this._handleScroll = this._handleScroll.bind(this);

      window.addEventListener('scroll', this._handleScroll, { passive: true });

      /* Show if already scrolled down on page load */
      if (window.scrollY > 100) this.classList.add('!translate-y-0');
    }

    disconnectedCallback() {
      window.removeEventListener('scroll', this._handleScroll);
    }

    _handleScroll() {
      if (!this._ticking) {
        requestAnimationFrame(this._onScroll);
        this._ticking = true;
      }
    }

    _onScroll() {
      var y = window.scrollY;
      var delta = y - this._lastY;

      if (delta > this._threshold) {
        /* Scrolling DOWN → show */
        this.classList.add('!translate-y-0');
      } else if (delta < -this._threshold) {
        /* Scrolling UP → hide */
        this.classList.remove('!translate-y-0');
      }

      this._lastY = y;
      this._ticking = false;
    }
  });
</script>

{% schema %}
{
  "name": "Mobile Bottom Nav",
  "settings": [
    {
      "type": "header",
      "content": "── Appearance ──"
    },
    {
      "type": "color",
