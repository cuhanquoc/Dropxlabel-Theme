{% comment %} MAIN COLLECTION — CSS → src/input.css {% endcomment %}

{% liquid
  assign sort_by_label = section.settings.sort_by_label | default: 'Sort by'
  assign filter_and_sort_label = section.settings.filter_and_sort_label | default: 'Filter & Sort'
  assign empty_heading = section.settings.empty_heading | default: 'No products found in this collection.'
  assign show_secondary_image = section.settings.show_secondary_image
  assign show_badges = section.settings.show_badges
  assign show_compare_price = section.settings.show_compare_price
  assign sale_badge_label = section.settings.sale_badge_label | default: 'Sale'
  assign sold_out_badge_label = section.settings.sold_out_badge_label | default: 'Sold out'
  assign price_from_label = section.settings.price_from_label | default: 'From'
  assign show_price = section.settings.show_price
  assign card_corner_radius = section.settings.card_corner_radius | default: 18
  assign image_corner_radius = section.settings.image_corner_radius | default: 18
%}

<div id="main-collection">

  <!-- ── Collection Hero Header ── -->
  <div
    class="pt-20 pb-9 px-6 md:px-10 text-center"
    style="background-color: var(--color-bg);"
  >
    <!-- Collection Tag -->
    {% if section.settings.show_tag %}
    <p style="
      font-family: var(--font-body);
      font-size: 0.6rem;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: {{ section.settings.tag_color }};
      margin-bottom: 0.9rem;
    ">{{ collection.metafields.custom.season | default: section.settings.tag_fallback }}</p>
    {% endif %}

    <!-- Collection Title -->
    <h1 style="
      font-family: var(--font-heading);
      font-size: {{ section.settings.heading_size }};
      font-weight: 600;
      text-transform: uppercase;
      color: {{ section.settings.heading_color }};
      letter-spacing: -0.02em;
      line-height: 1;
      margin-bottom: 0.95rem;
    ">
      {{ collection.title | default: 'All Products' }}
    </h1>

    <!-- Collection Description -->
    {% if section.settings.show_description %}
      {% if collection.description != blank %}
        <p style="
          font-family: var(--font-body);
          font-size: 0.88rem;
          line-height: 1.72;
          color: {{ section.settings.desc_color }};
          max-width: 520px;
          margin: 0 auto;
        ">{{ collection.description }}</p>
      {% elsif section.settings.fallback_description != blank %}
        <p style="
          font-family: var(--font-body);
          font-size: 0.88rem;
          line-height: 1.72;
          color: {{ section.settings.desc_color }};
          max-width: 520px;
          margin: 0 auto;
        ">{{ section.settings.fallback_description }}</p>
      {% endif %}
    {% endif %}
  </div>
  <!-- / Hero Header -->

  <!-- ── Main Content: Toolbar + Grid ── -->
  <div class="px-6 md:px-10 pb-32" style="background-color: var(--color-bg);">
    <div class="max-w-screen-xl mx-auto">

      <!-- Filter Panel (collapsible) -->
      <div class="mc-filter-panel" id="mc-filter-panel">
        <div class="py-5 flex flex-wrap gap-2 items-center">
          <span style="font-family: var(--font-body); font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-muted); margin-right: 0.5rem;">{{ sort_by_label }}</span>
          {%- assign sort_options = 'manual,Featured|date-descending,Newest|price-ascending,Price: Low to High|price-descending,Price: High to Low|title-ascending,A–Z|title-descending,Z–A' | split: '|' -%}
          {%- assign current_sort = collection.sort_by | default: collection.default_sort_by -%}
          {%- for opt in sort_options -%}
            {%- assign opt_parts = opt | split: ',' -%}
            {%- assign opt_value = opt_parts[0] -%}
            {%- assign opt_label = opt_parts[1] -%}
            <a href="{{ collection.url }}?sort_by={{ opt_value }}"
               class="mc-filter-tag {% if current_sort == opt_value %}active{% endif %}"
               data-filter>{{ opt_label }}</a>
          {%- endfor -%}
        </div>
      </div>

      <!-- Toolbar -->
      <div class="border-y flex justify-between items-center py-4 mb-9 md:mb-12" style="border-color: #e5e7eb;">

        <!-- Left: Filter button + count -->
        <div class="flex items-center gap-5">
          <button
            class="mc-toolbar-btn"
            data-toggle-filter
            aria-expanded="false"
            aria-controls="mc-filter-panel"
          >
            <!-- Filter icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
            </svg>
            {{ filter_and_sort_label }}
          </button>
          <span class="mc-count">
            {{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}
          </span>
        </div>

        <!-- Right: Grid view toggles -->
        <div class="flex items-center gap-2">
          <!-- 2-col icon -->
          <button
            class="mc-grid-btn"
            aria-label="{{ section.settings.grid_two_columns_label | default: '2 column grid' | escape }}"
            data-grid-cols="2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3"  y="3"  width="8" height="18" rx="1"/>
              <rect x="13" y="3"  width="8" height="18" rx="1"/>
            </svg>
          </button>
          <!-- 4-col icon (default active) -->
          <button
            class="mc-grid-btn active"
            aria-label="{{ section.settings.grid_four_columns_label | default: '4 column grid' | escape }}"
            data-grid-cols="4"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3"  y="3"  width="4" height="10" rx="1"/>
              <rect x="10" y="3"  width="4" height="10" rx="1"/>
              <rect x="17" y="3"  width="4" height="10" rx="1"/>
              <rect x="3"  y="16" width="4" height="5"  rx="1"/>
              <rect x="10" y="16" width="4" height="5"  rx="1"/>
              <rect x="17" y="16" width="4" height="5"  rx="1"/>
            </svg>
          </button>
        </div>

      </div>
      <!-- / Toolbar -->

      <!-- Product Grid -->
      {%- assign default_cols = section.settings.products_per_row | default: 4 -%}
      <div
        id="mc-grid"
        class="grid grid-cols-2 md:grid-cols-{{ default_cols }} gap-x-6 gap-y-9 md:gap-y-12"
        data-default-cols="{{ default_cols }}"
      >

        {%- if collection.products.size == 0 -%}
          <div class="col-span-full text-center py-20">
            <p style="font-family: var(--font-body); font-size: 0.88rem; color: var(--color-muted); letter-spacing: 0.08em;">{{ empty_heading }}</p>
          </div>
        {%- else -%}

        {% for product in collection.products %}
          {%- assign featured_image   = product.featured_image -%}
          {%- assign secondary_image  = product.images[1] -%}

          <!-- Product Card: {{ product.title }} -->
          <a
            href="{{ product.url }}"
            class="mc-card"
            style="border-radius: {{ card_corner_radius }}px;"
            data-mc-card
            data-product-handle="{{ product.handle }}"
            aria-label="{{ product.title | escape }}"
          >

            <!-- Image Wrapper -->
            <div
              class="relative overflow-hidden bg-gray-50 mb-4"
              style="aspect-ratio: {{ section.settings.image_ratio }}; border-radius: 4px;"
            >
              <!-- Primary Image -->
              {%- if featured_image -%}
                <img
                  src="{{ featured_image | image_url: width: 600 }}"
                  alt="{{ featured_image.alt | default: product.title | escape }}"
                  class="mc-img-primary"
                  loading="{% if forloop.index <= 4 %}eager{% else %}lazy{% endif %}"
                  width="600"
                  height="800"
                />
              {%- else -%}
                <div class="mc-img-primary flex items-center justify-center bg-gray-100">
                  {{ 'image' | placeholder_svg_tag: 'w-16 h-16 text-gray-300' }}
                </div>
              {%- endif -%}

              <!-- Hover / Secondary Image -->
              {%- if secondary_image -%}
                <img
                  src="{{ secondary_image | image_url: width: 600 }}"
                  alt="{{ secondary_image.alt | default: product.title | escape }} — alt view"
                  class="mc-img-hover"
                  loading="lazy"
                  width="600"
                  height="800"
                />
              {%- elsif featured_image -%}
                <img
                  src="{{ featured_image | image_url: width: 600 }}"
                  alt="{{ featured_image.alt | default: product.title | escape }}"
                  class="mc-img-hover"
                  loading="lazy"
                  width="600"
                  height="800"
                />
              {%- endif -%}

              <!-- Quick View Button -->
              {% if section.settings.show_quick_view %}
              <button
                class="mc-quick-view"
                aria-label="{{ section.settings.quick_view_aria_prefix | default: 'Quick view' | escape }} {{ product.title | escape }}"
                data-product-handle="{{ product.handle }}"
                data-quick-view
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
                {{ section.settings.quick_view_label | default: 'Quick View' }}
              </button>
              {% endif %}

              <!-- Badges -->
              {%- if product.available == false -%}
                <span class="mc-badge mc-badge--sold" style="position:absolute;top:0.75rem;left:0.75rem;font-family:var(--font-body);font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;background:#0a0a0a;color:#fff;padding:0.3rem 0.6rem;">{{ sold_out_badge_label }}</span>
              {%- elsif product.compare_at_price > product.price -%}
                <span class="mc-badge mc-badge--sale" style="position:absolute;top:0.75rem;left:0.75rem;font-family:var(--font-body);font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;background:#c0392b;color:#fff;padding:0.3rem 0.6rem;">{{ sale_badge_label }}</span>
              {%- endif -%}
            </div>
            <!-- / Image Wrapper -->

            <!-- Product Info -->
            <div class="mc-card__meta text-left">
              <p class="mc-product-title">{{ product.title }}</p>
              {% if show_price %}<div class="mc-product-price-row">
                <p class="mc-product-price">
                  {%- if product.price_varies -%}
                    {{ price_from_label }} {{ product.price_min | money }}
                  {%- else -%}
                    {{ product.price | money }}
                  {%- endif -%}
                </p>
                {%- if show_compare_price and product.compare_at_price > product.price -%}
                  <p class="mc-product-compare">{{ product.compare_at_price | money }}</p>
                {%- endif -%}
              </div>
            </div>

          </a>
          <!-- / Product Card: {{ product.title }} -->

        {% endfor %}
        {%- endif -%}

      </div>
      <!-- / Product Grid -->

    </div>
  </div>
</div>

<style>
  @media (max-width: 767px) {
    #main-collection > div:first-child {
      padding-top: 4rem !important;
      padding-bottom: 1.45rem !important;
    }

    #main-collection > div:first-child > p:first-of-type {
      margin-bottom: 0.62rem !important;
      font-size: 0.58rem !important;
      letter-spacing: 0.22em !important;
    }

    #main-collection > div:first-child > h1 {
      margin-bottom: 0.55rem !important;
      line-height: 0.92 !important;
    }

    #main-collection > div:first-child > p:last-of-type {
      max-width: 18ch !important;
      line-height: 1.5 !important;
      font-size: 0.8rem !important;
    }

    #main-collection .border-y {
      margin-bottom: 1.45rem !important;
      padding-top: 0.85rem !important;
      padding-bottom: 0.85rem !important;
    }

    #main-collection #mc-grid {
      gap: 1.35rem 0.9rem !important;
    }

    #main-collection .mc-card {
      display: grid;
      align-content: start;
      gap: 0;
    }

    #main-collection .mc-card__meta {
      padding-inline: 0.1rem;
      display: grid;
      gap: 0.3rem;
      margin-top: 0.65rem;
    }

    #main-collection .mc-card > div.relative {
      margin-bottom: 0 !important;
      border-radius: 0.35rem !important;
    }

    #main-collection .mc-product-title {
      margin: 0;
      font-family: var(--font-heading, serif);
      font-size: 0.84rem;
      line-height: 1.18;
      letter-spacing: -0.01em;
      font-weight: 500;
      color: #151515;
      text-align: left;
      text-wrap: pretty;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    #main-collection .mc-product-price-row {
      display: flex;
      align-items: baseline;
      gap: 0.56rem;
      margin-top: 0.02rem;
      flex-wrap: wrap;
    }

    #main-collection .mc-product-price {
      margin: 0;
      font-family: var(--font-body-family, system-ui, sans-serif);
      font-size: 0.82rem;
      line-height: 1;
      font-weight: 600;
      letter-spacing: 0.015em;
      color: #c5a16d;
    }

    #main-collection .mc-product-compare {
      margin: 0;
      font-family: var(--font-body-family, system-ui, sans-serif);
      font-size: 0.72rem;
      line-height: 1;
      font-weight: 500;
      letter-spacing: 0.01em;
      color: rgba(74, 74, 74, 0.6);
      text-decoration: line-through;
      text-decoration-thickness: 1px;
      text-decoration-color: rgba(74, 74, 74, 0.48);
      text-underline-offset: 0.14em;
    }

    #main-collection .mc-quick-view {
      bottom: 0.7rem;
      left: 0.75rem;
      right: 0.75rem;
      width: auto;
      justify-content: center;
      gap: 0.4rem;
      padding: 0.58rem 0.78rem;
      min-height: 38px;
      font-size: 0.58rem;
      line-height: 1;
      letter-spacing: 0.11em;
      white-space: nowrap;
      border-radius: 999px !important;
    }

    #main-collection .mc-quick-view svg {
      width: 11px;
      height: 11px;
      flex-shrink: 0;
    }

    #main-collection .mc-badge {
      top: 0.6rem !important;
      left: 0.6rem !important;
      padding: 0.28rem 0.58rem !important;
      font-size: 0.56rem !important;
      letter-spacing: 0.11em !important;
    }

    #main-collection .mc-toolbar-btn {
      font-size: 0.62rem !important;
      letter-spacing: 0.15em !important;
      gap: 0.5rem !important;
      min-height: 42px;
    }

    #main-collection .mc-count {
      font-size: 0.58rem !important;
      letter-spacing: 0.1em !important;
    }

    #main-collection .mc-grid-btn {
      width: 2.85rem !important;
      height: 2.85rem !important;
    }
  }
</style>


<script>
  /* ─────────────────────────────────────────────────────
     MAIN COLLECTION — Grid interactions + GSAP entrance
  ───────────────────────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', function () {

    /* ── Ensure all cards are visible immediately ── */
    document.querySelectorAll('[data-mc-card]').forEach(function(card) {
      card.style.opacity = '1';
      card.style.transform = 'none';
    });

    /* ── GSAP: Cards stagger in on page load ── */
    if (typeof gsap !== 'undefined') {
      gsap.fromTo('[data-mc-card]',
        { opacity: 0, y: 30 },
        {
          opacity: 1,
          y: 0,
          duration: 0.6,
          ease: 'power2.out',
          stagger: 0.06,
          delay: 0.1,
        }
      );
    }

    /* ── Grid column toggle (delegation) ── */
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-grid-cols]');
      if (!btn) return;
      var cols = Number(btn.dataset.gridCols);
      var grid = document.getElementById('mc-grid');
      var allBtns = document.querySelectorAll('.mc-grid-btn');
      allBtns.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      grid.classList.remove('grid-cols-1', 'grid-cols-2', 'grid-cols-4', 'md:grid-cols-2', 'md:grid-cols-4');
      if (cols === 2) {
        grid.classList.add('grid-cols-1', 'md:grid-cols-2');
      } else {
        grid.classList.add('grid-cols-2', 'md:grid-cols-4');
      }
    });

    /* ── Filter panel toggle (delegation) ── */
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-toggle-filter]');
      if (!btn) return;
      var panel = document.getElementById('mc-filter-panel');
      if (!panel) return;
      panel.classList.toggle('open');
      btn.setAttribute('aria-expanded', panel.classList.contains('open'));
    });

    /* ── Quick View (delegation) ── */
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-quick-view]');
      if (!btn) return;
      e.preventDefault();
      e.stopPropagation();
      if (window.QuickView) QuickView.open(btn.dataset.productHandle);
    });

  });
</script>

{% schema %}
{
  "name": "Collection Grid",
  "tag": "section",
  "class": "main-collection-section",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "checkbox",
      "id": "show_tag",
      "label": "Show collection tag",
      "default": true
    },
    {
      "type": "text",
      "id": "tag_fallback",
      "label": "Tag fallback text",
      "default": "Curated Collection",
      "info": "Shown when collection has no season metafield"
    },
    {
      "type": "color",
      "id": "tag_color",
      "label": "Tag colour",
      "default": "#b8956a"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "clamp(1.8rem,5vw,3rem)",   "label": "Small" },
        { "value": "clamp(2.5rem,7vw,4.5rem)", "label": "Medium" },
        { "value": "clamp(3rem,9vw,6rem)",      "label": "Large" },
        { "value": "clamp(3.5rem,11vw,8rem)",  "label": "Extra Large" }
      ],
      "default": "clamp(2.5rem,7vw,4.5rem)"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading colour",
      "default": "#0a0a0a"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "textarea",
      "id": "fallback_description",
      "label": "Fallback description",
      "default": "Refined silhouettes. Enduring materials. Pieces made without compromise.",
      "info": "Shown when collection has no description set in Shopify Admin"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Description colour",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Product Grid"
    },
    {
      "type": "select",
      "id": "products_per_row",
      "label": "Products per row (desktop)",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Card image ratio",
      "options": [
        { "value": "1/1",  "label": "Square (1:1)" },
        { "value": "3/4",  "label": "Portrait (3:4) — default" },
        { "value": "2/3",  "label": "Tall (2:3)" },
        { "value": "4/3",  "label": "Landscape (4:3)" }
      ],
      "default": "3/4"
    },
    {
      "type": "checkbox",
      "id": "show_quick_view",
      "label": "Show Quick View button",
      "default": true
    },
    {
      "type": "text",
      "id": "quick_view_label",
      "label": "Quick View button text",
      "default": "Quick View"
    },
    {
      "type": "text",
      "id": "quick_view_aria_prefix",
      "label": "Quick View aria label prefix",
      "default": "Quick view"
    },
    {
      "type": "text",
      "id": "sort_by_label",
      "label": "Sort by label",
      "default": "Sort by"
    },
    {
      "type": "text",
      "id": "filter_and_sort_label",
      "label": "Filter button label",
      "default": "Filter & Sort"
    },
    {
      "type": "text",
      "id": "grid_two_columns_label",
      "label": "2-column grid toggle aria label",
      "default": "2 column grid"
    },
    {
      "type": "text",
      "id": "grid_four_columns_label",
      "label": "4-column grid toggle aria label",
      "default": "4 column grid"
    },
    {
      "type": "text",
      "id": "empty_heading",
      "label": "Empty state heading",
      "default": "No products found in this collection."
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show secondary image on hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "Show product badges",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_compare_price",
      "label": "Show compare-at price",
      "default": true
    },
    {
      "type": "text",
      "id": "sale_badge_label",
      "label": "Sale badge label",
      "default": "Sale"
    },
    {
      "type": "text",
      "id": "sold_out_badge_label",
      "label": "Sold out badge label",
      "default": "Sold out"
    },
    {
      "type": "text",
      "id": "price_from_label",
      "label": "Price varies prefix",
      "default": "From"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show product price",
      "default": true
    },
    {
      "type": "range",
      "id": "card_corner_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "image_corner_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    }
  ],
  "presets": [
    {
      "name": "Collection Grid"
    }
  ]
}
{% endschema %}
