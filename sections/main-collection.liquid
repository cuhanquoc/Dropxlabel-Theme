{%- assign mc_primary = "photo-1515886657613-9f3515b0c78f|photo-1469334031218-e382a71b716b|photo-1485968579580-b6d095142e6e|photo-1509631179647-0177331693ae|photo-1479064555552-3ef4d0d87f10|photo-1490481651871-ab68de25d43d|photo-1572804013309-59a88b7e92f1|photo-1539109136881-3be0616acf4b|photo-1558769132-cb1aea458c5e|photo-1496747611176-843222e1e57c|photo-1434389677669-e08b4cac3105|photo-1445205170230-053b83016050" | split: "|" -%}
{%- assign mc_hover   = "photo-1539109136881-3be0616acf4b|photo-1479064555552-3ef4d0d87f10|photo-1509631179647-0177331693ae|photo-1485968579580-b6d095142e6e|photo-1490481651871-ab68de25d43d|photo-1469334031218-e382a71b716b|photo-1515886657613-9f3515b0c78f|photo-1572804013309-59a88b7e92f1|photo-1496747611176-843222e1e57c|photo-1558769132-cb1aea458c5e|photo-1445205170230-053b83016050|photo-1434389677669-e08b4cac3105" | split: "|" -%}
{%- assign mc_names   = "Sculptural Linen Coat|Minimal Silk Blouse|The Cashmere Set|Draped Crepe Dress|Tailored Wide Trousers|Raw Edge Knit Top|The Atelier Blazer|Asymmetric Hem Skirt|Oversized Linen Shirt|Slip Bias Dress|Structured Wool Coat|The Essential Turtleneck" | split: "|" -%}
{%- assign mc_prices  = "4.200.000đ|2.800.000đ|5.600.000đ|3.900.000đ|3.200.000đ|2.400.000đ|6.100.000đ|2.950.000đ|1.980.000đ|3.450.000đ|7.200.000đ|1.750.000đ" | split: "|" -%}

<div id="main-collection">

  <!-- ── Collection Hero Header ── -->
  <div
    class="pt-40 pb-16 px-6 md:px-10 text-center"
    style="background-color: var(--color-bg);"
  >
    <!-- Collection Tag -->
    <p style="
      font-family: var(--font-body);
      font-size: 0.6rem;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--color-accent);
      margin-bottom: 1rem;
    ">{{ collection.metafields.custom.season | default: 'Curated Collection' }}</p>

    <!-- Collection Title -->
    <h1 style="
      font-family: var(--font-heading);
      font-size: clamp(2.5rem, 7vw, 4.5rem);
      font-weight: 600;
      text-transform: uppercase;
      color: var(--color-text);
      letter-spacing: -0.02em;
      line-height: 1;
      margin-bottom: 1.25rem;
    ">
      {{ collection.title | default: 'All Products' }}
    </h1>

    <!-- Collection Description -->
    {% if collection.description != blank %}
      <p style="
        font-family: var(--font-body);
        font-size: 0.88rem;
        line-height: 1.85;
        color: var(--color-muted);
        max-width: 520px;
        margin: 0 auto;
      ">{{ collection.description }}</p>
    {% else %}
      <p style="
        font-family: var(--font-body);
        font-size: 0.88rem;
        line-height: 1.85;
        color: var(--color-muted);
        max-width: 520px;
        margin: 0 auto;
      ">Refined silhouettes. Enduring materials. Pieces made without compromise.</p>
    {% endif %}
  </div>
  <!-- / Hero Header -->

  <!-- ── Main Content: Toolbar + Grid ── -->
  <div class="px-6 md:px-10 pb-32" style="background-color: var(--color-bg);">
    <div class="max-w-screen-xl mx-auto">

      <!-- Filter Panel (collapsible) -->
      <div class="mc-filter-panel" id="mc-filter-panel">
        <div class="py-5 flex flex-wrap gap-2 items-center">
          <span style="font-family: var(--font-body); font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-muted); margin-right: 0.5rem;">Sort by</span>
          <button class="mc-filter-tag active" onclick="setFilter(this)">Featured</button>
          <button class="mc-filter-tag" onclick="setFilter(this)">Newest</button>
          <button class="mc-filter-tag" onclick="setFilter(this)">Price: Low to High</button>
          <button class="mc-filter-tag" onclick="setFilter(this)">Price: High to Low</button>
        </div>
      </div>

      <!-- Toolbar -->
      <div class="border-y flex justify-between items-center py-4 mb-12" style="border-color: #e5e7eb;">

        <!-- Left: Filter button + count -->
        <div class="flex items-center gap-5">
          <button
            class="mc-toolbar-btn"
            onclick="document.getElementById('mc-filter-panel').classList.toggle('open')"
            aria-expanded="false"
            aria-controls="mc-filter-panel"
          >
            <!-- Filter icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
            </svg>
            Filter &amp; Sort
          </button>
          <span class="mc-count">
            {{ collection.products_count | default: 12 }} {{ collection.products_count | default: 12 | pluralize: 'product', 'products' }}
          </span>
        </div>

        <!-- Right: Grid view toggles -->
        <div class="flex items-center gap-2">
          <!-- 2-col icon -->
          <button
            class="mc-grid-btn"
            aria-label="2 column grid"
            onclick="toggleGrid(this, 2)"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3"  y="3"  width="8" height="18" rx="1"/>
              <rect x="13" y="3"  width="8" height="18" rx="1"/>
            </svg>
          </button>
          <!-- 4-col icon (default active) -->
          <button
            class="mc-grid-btn active"
            aria-label="4 column grid"
            onclick="toggleGrid(this, 4)"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3"  y="3"  width="4" height="10" rx="1"/>
              <rect x="10" y="3"  width="4" height="10" rx="1"/>
              <rect x="17" y="3"  width="4" height="10" rx="1"/>
              <rect x="3"  y="16" width="4" height="5"  rx="1"/>
              <rect x="10" y="16" width="4" height="5"  rx="1"/>
              <rect x="17" y="16" width="4" height="5"  rx="1"/>
            </svg>
          </button>
        </div>

      </div>
      <!-- / Toolbar -->

      <!-- Product Grid -->
      <div
        id="mc-grid"
        class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-12"
      >

        {% for i in (1..12) %}
          {%- assign idx        = forloop.index0 -%}
          {%- assign primary_id = mc_primary[idx] | strip -%}
          {%- assign hover_id   = mc_hover[idx]   | strip -%}
          {%- assign prod_name  = mc_names[idx]   | strip -%}
          {%- assign prod_price = mc_prices[idx]  | strip -%}

          <!-- Product Card #{{ forloop.index }} -->
          <a
            href="#"
            class="mc-card"
            data-mc-card
            aria-label="{{ prod_name }}"
          >

            <!-- Image Wrapper -->
            <div
              class="relative overflow-hidden bg-gray-50 mb-4"
              style="aspect-ratio: 3/4; border-radius: 4px;"
            >
              <!-- Primary Image -->
              <img
                src="https://images.unsplash.com/{{ primary_id }}?w=600&q=80&auto=format&fit=crop"
                alt="{{ prod_name }}"
                class="mc-img-primary"
                loading="{% if forloop.index <= 4 %}eager{% else %}lazy{% endif %}"
                width="600"
                height="800"
              />

              <!-- Hover / Lifestyle Image -->
              <img
                src="https://images.unsplash.com/{{ hover_id }}?w=600&q=80&auto=format&fit=crop"
                alt="{{ prod_name }} — lifestyle"
                class="mc-img-hover"
                loading="lazy"
                width="600"
                height="800"
              />

              <!-- Quick View Button -->
              <button
                class="mc-quick-view"
                aria-label="Quick view {{ prod_name }}"
                onclick="event.preventDefault(); event.stopPropagation();"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
                Quick View
              </button>
            </div>
            <!-- / Image Wrapper -->

            <!-- Product Info -->
            <div class="text-center">
              <p class="mc-product-title">{{ prod_name }}</p>
              <p class="mc-product-price">{{ prod_price }}</p>
            </div>

          </a>
          <!-- / Product Card #{{ forloop.index }} -->

        {% endfor %}

      </div>
      <!-- / Product Grid -->

    </div>
  </div>
</div>


<script>
  /* ─────────────────────────────────────────────────────
     MAIN COLLECTION — Grid interactions + GSAP entrance
  ───────────────────────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', function () {

    /* ── GSAP: Cards stagger in on page load ── */
    if (typeof gsap !== 'undefined') {
      gsap.from('[data-mc-card]', {
        opacity: 0,
        y: 40,
        duration: 0.9,
        ease: 'power3.out',
        stagger: 0.08,
        delay: 0.15,
      });
    }

    /* ── Grid column toggle ── */
    window.toggleGrid = function (btn, cols) {
      const grid    = document.getElementById('mc-grid');
      const allBtns = document.querySelectorAll('.mc-grid-btn');

      allBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      /* Remove existing col classes */
      grid.classList.remove(
        'grid-cols-2', 'grid-cols-4',
        'md:grid-cols-2', 'md:grid-cols-4'
      );

      if (cols === 2) {
        grid.classList.add('grid-cols-1', 'md:grid-cols-2');
      } else {
        grid.classList.add('grid-cols-2', 'md:grid-cols-4');
      }
    };

    /* ── Filter tag toggle ── */
    window.setFilter = function (el) {
      document.querySelectorAll('.mc-filter-tag').forEach(t => t.classList.remove('active'));
      el.classList.add('active');
      /* TODO: re-fetch products via Shopify AJAX with sort_by param */
    };

  });
</script>
