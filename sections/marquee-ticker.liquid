{% comment %} MARQUEE TICKER — CSS → src/input.css {% endcomment %}


<marquee-ticker class="mt-section" style="background-color: {{ section.settings.bg_color | default: '#0a0a0a' }};" data-speed="{{ section.settings.speed | default: 30 }}">
  <div
    class="mt-track"
    style="
      --mt-speed: {{ section.settings.speed | default: 30 }}s;
      --mt-gap: {{ section.settings.gap | default: 24 }}px;
      --mt-card-w: {{ section.settings.card_width | default: 280 }}px;
    "
    id="mt-track"
  >
    {%- comment -%} First copy of blocks {%- endcomment -%}
    {% for block in section.blocks %}
      {% if block.type == 'ticker_card' %}
        <div class="mt-card" {{ block.shopify_attributes }}>
          <!-- Media -->
          <div class="mt-card-media">
            {% if block.settings.video != blank %}
              <video
                src="{{ block.settings.video.sources[0].url }}"
                autoplay muted loop playsinline
                poster="{% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 600 }}{% endif %}"
              ></video>
            {% elsif block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.title | default: 'Card' | escape }}"
                loading="lazy" width="600" height="450"
              />
            {% else %}
              <img
                src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=600&q=80&auto=format&fit=crop"
                alt="Placeholder" loading="lazy" width="600" height="450"
              />
            {% endif %}
          </div>

          <!-- Body -->
          <div class="mt-card-body">
            {% if block.settings.title != blank %}
              <p class="mt-card-title" style="font-family: {{ block.settings.font | default: 'var(--font-heading)' }};">
                {{ block.settings.title }}
              </p>
            {% endif %}
            {% if block.settings.description != blank %}
              <p class="mt-card-desc">{{ block.settings.description }}</p>
            {% endif %}
            {% if block.settings.link_text != blank %}
              <a
                href="{{ block.settings.link_url | default: '#' }}"
                class="mt-card-link"
                {% if block.settings.link_external %}target="_blank" rel="noopener"{% endif %}
              >{{ block.settings.link_text }}</a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}

    {%- comment -%} Duplicate for seamless loop {%- endcomment -%}
    {% for block in section.blocks %}
      {% if block.type == 'ticker_card' %}
        <div class="mt-card" aria-hidden="true">
          <div class="mt-card-media">
            {% if block.settings.video != blank %}
              <video
                src="{{ block.settings.video.sources[0].url }}"
                autoplay muted loop playsinline
                poster="{% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 600 }}{% endif %}"
              ></video>
            {% elsif block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.title | default: 'Card' | escape }}"
                loading="lazy" width="600" height="450"
              />
            {% else %}
              <img
                src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=600&q=80&auto=format&fit=crop"
                alt="Placeholder" loading="lazy" width="600" height="450"
              />
            {% endif %}
          </div>
          <div class="mt-card-body">
            {% if block.settings.title != blank %}
              <p class="mt-card-title" style="font-family: {{ block.settings.font | default: 'var(--font-heading)' }};">
                {{ block.settings.title }}
              </p>
            {% endif %}
            {% if block.settings.description != blank %}
              <p class="mt-card-desc">{{ block.settings.description }}</p>
            {% endif %}
            {% if block.settings.link_text != blank %}
              <a
                href="{{ block.settings.link_url | default: '#' }}"
                class="mt-card-link"
                tabindex="-1"
                {% if block.settings.link_external %}target="_blank" rel="noopener"{% endif %}
              >{{ block.settings.link_text }}</a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</marquee-ticker>

<script>
  customElements.define('marquee-ticker', class extends HTMLElement {
    connectedCallback() {
      this._track = this.querySelector('.mt-track');
      if (!this._track) return;

      /* Only run mobile transform logic on mobile */
      this._mq = window.matchMedia('(max-width: 767px)');
      if (!this._mq.matches) return;

      this._posX = 0;
      this._speed = 0.5;
      this._touching = false;
      this._startTouchX = 0;
      this._startPosX = 0;
      this._resumeTimer = null;
      this._halfWidth = 0;

      this._measureHalf();

      /* Bind methods */
      this._tick = this._tick.bind(this);
      this._onTouchStart = this._onTouchStart.bind(this);
      this._onTouchMove = this._onTouchMove.bind(this);
      this._onTouchEnd = this._onTouchEnd.bind(this);
      this._measureHalf = this._measureHalf.bind(this);

      /* Start auto-scroll */
      this._raf = requestAnimationFrame(this._tick);

      /* Touch listeners */
      this._track.addEventListener('touchstart', this._onTouchStart, { passive: true });
      this._track.addEventListener('touchmove', this._onTouchMove, { passive: true });
      this._track.addEventListener('touchend', this._onTouchEnd, { passive: true });
      window.addEventListener('resize', this._measureHalf);
    }

    disconnectedCallback() {
      if (this._raf) cancelAnimationFrame(this._raf);
      if (this._resumeTimer) clearTimeout(this._resumeTimer);
      if (this._track) {
        this._track.removeEventListener('touchstart', this._onTouchStart);
        this._track.removeEventListener('touchmove', this._onTouchMove);
        this._track.removeEventListener('touchend', this._onTouchEnd);
      }
      window.removeEventListener('resize', this._measureHalf);
    }

    _measureHalf() {
      this._halfWidth = this._track.scrollWidth / 2;
    }

    _tick() {
      if (!this._touching) {
        this._posX -= this._speed;
        if (Math.abs(this._posX) >= this._halfWidth) {
          this._posX += this._halfWidth;
        }
        this._track.style.transform = 'translateX(' + this._posX + 'px)';
      }
      this._raf = requestAnimationFrame(this._tick);
    }

    _onTouchStart(e) {
      this._touching = true;
      if (this._resumeTimer) clearTimeout(this._resumeTimer);
      this._startTouchX = e.touches[0].clientX;
      this._startPosX = this._posX;
    }

    _onTouchMove(e) {
      if (!this._touching) return;
      var dx = e.touches[0].clientX - this._startTouchX;
      this._posX = this._startPosX + dx;
      if (this._posX > 0) this._posX -= this._halfWidth;
      if (Math.abs(this._posX) >= this._halfWidth) this._posX += this._halfWidth;
      this._track.style.transform = 'translateX(' + this._posX + 'px)';
    }

    _onTouchEnd() {
      var self = this;
      this._resumeTimer = setTimeout(function() {
        self._touching = false;
      }, 1500);
    }
  });
</script>

{% schema %}
{
  "name": "Marquee Ticker",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0a0a0a"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 80,
      "step": 5,
      "default": 30,
      "label": "Scroll Speed (seconds)",
      "info": "Lower = faster"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24,
      "label": "Gap between cards (px)"
    },
    {
      "type": "range",
      "id": "card_width",
      "min": 200,
      "max": 400,
      "step": 20,
      "default": 280,
      "label": "Card Width (px)"
    }
  ],
  "blocks": [
    {
      "type": "ticker_card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Recommended: 600 × 450px (4:3)"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video (optional)",
          "info": "Overrides the image if provided. Upload via Files > Videos."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Style Title"
        },
        {
          "type": "font_picker",
          "id": "font",
          "label": "Title Font",
          "default": "assistant_n4"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "A short caption for this card."
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "Explore more",
          "info": "Subtle underlined link"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        },
        {
          "type": "checkbox",
          "id": "link_external",
          "label": "Open in new tab",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Ticker",
      "blocks": [
        { "type": "ticker_card", "settings": { "title": "Elegant Layers", "description": "Layered silhouettes that redefine sophistication.", "link_text": "Explore more" } },
        { "type": "ticker_card", "settings": { "title": "Urban Minimalism", "description": "Clean lines, muted tones, effortless cool.", "link_text": "View collection" } },
        { "type": "ticker_card", "settings": { "title": "Raw Denim Edit", "description": "Washed textures and vintage-inspired fits.", "link_text": "Shop now" } },
        { "type": "ticker_card", "settings": { "title": "The Silk Series", "description": "Fluid fabrics for after-hours elegance.", "link_text": "Discover" } },
        { "type": "ticker_card", "settings": { "title": "Street Luxe", "description": "Where streetwear meets high fashion.", "link_text": "See more" } },
        { "type": "ticker_card", "settings": { "title": "Monochrome Mood", "description": "Black, white, and everything in between.", "link_text": "Browse" } }
      ]
    }
  ]
}
{% endschema %}
