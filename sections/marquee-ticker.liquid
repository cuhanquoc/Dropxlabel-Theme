<style>
  /* ─────────────────────────────────────────
     MARQUEE TICKER — Infinite Scroll Blocks
  ───────────────────────────────────────── */

  .mt-section {
    background-color: #0a0a0a;
    padding: 2.5rem 0;
    overflow: hidden;
    position: relative;
  }

  /* Fade edges */
  .mt-section::before,
  .mt-section::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    width: 80px;
    z-index: 5;
    pointer-events: none;
  }
  .mt-section::before {
    left: 0;
    background: linear-gradient(to right, #0a0a0a, transparent);
  }
  .mt-section::after {
    right: 0;
    background: linear-gradient(to left, #0a0a0a, transparent);
  }

  /* Track: holds two copies for seamless loop */
  .mt-track {
    display: flex;
    width: max-content;
    animation: mt-scroll var(--mt-speed, 30s) linear infinite;
    gap: var(--mt-gap, 1.5rem);
  }

  .mt-section:hover .mt-track {
    animation-play-state: paused;
  }

  @keyframes mt-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Single block card */
  .mt-card {
    flex-shrink: 0;
    width: var(--mt-card-w, 280px);
    border-radius: 16px;
    overflow: hidden;
    background: #141414;
    border: 1px solid rgba(255,255,255,0.06);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .mt-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.4);
  }

  /* Media container (image or video) */
  .mt-card-media {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    position: relative;
  }

  .mt-card-media img,
  .mt-card-media video {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .mt-card:hover .mt-card-media img,
  .mt-card:hover .mt-card-media video {
    transform: scale(1.05);
  }

  /* Text area */
  .mt-card-body {
    padding: 1rem 1.15rem 1.25rem;
  }

  .mt-card-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1.3;
    margin-bottom: 0.4rem;
    letter-spacing: -0.01em;
  }

  .mt-card-desc {
    font-family: var(--font-body);
    font-size: 0.75rem;
    line-height: 1.6;
    color: #6b7280;
    margin-bottom: 0.75rem;
  }

  /* Subtle underlined link */
  .mt-card-link {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.5);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(255,255,255,0.2);
    transition: color 0.3s ease, text-decoration-color 0.3s ease;
  }

  .mt-card-link:hover {
    color: #ffffff;
    text-decoration-color: rgba(255,255,255,0.6);
  }

  /* ── Desktop (≥ 768px) ── */
  @media (min-width: 768px) {
    .mt-section { padding: 2.5rem 0; }
    .mt-card { width: 280px; }
    .mt-card-title { font-size: 0.95rem; }
    .mt-card-body { padding: 1rem 1.15rem 1.25rem; }
  }

  /* ── Large Desktop (≥ 1024px) ── */
  @media (min-width: 1024px) {
    .mt-section { padding: 3rem 0; }
    .mt-card { width: 320px; }
  }

  /* ── Mobile (< 768px) ── */
  @media (max-width: 767px) {
    .mt-section { padding: 1.5rem 0; }
    .mt-card { width: 220px; }
    .mt-card-title { font-size: 0.85rem; }
  }
</style>

<section class="mt-section" style="background-color: {{ section.settings.bg_color | default: '#0a0a0a' }};">
  <div
    class="mt-track"
    style="
      --mt-speed: {{ section.settings.speed | default: 30 }}s;
      --mt-gap: {{ section.settings.gap | default: 24 }}px;
      --mt-card-w: {{ section.settings.card_width | default: 280 }}px;
    "
    id="mt-track"
  >
    {%- comment -%} First copy of blocks {%- endcomment -%}
    {% for block in section.blocks %}
      {% if block.type == 'ticker_card' %}
        <div class="mt-card" {{ block.shopify_attributes }}>
          <!-- Media -->
          <div class="mt-card-media">
            {% if block.settings.video != blank %}
              <video
                src="{{ block.settings.video.sources[0].url }}"
                autoplay muted loop playsinline
                poster="{% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 600 }}{% endif %}"
              ></video>
            {% elsif block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.title | default: 'Card' | escape }}"
                loading="lazy" width="600" height="450"
              />
            {% else %}
              <img
                src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=600&q=80&auto=format&fit=crop"
                alt="Placeholder" loading="lazy" width="600" height="450"
              />
            {% endif %}
          </div>

          <!-- Body -->
          <div class="mt-card-body">
            {% if block.settings.title != blank %}
              <p class="mt-card-title" style="font-family: {{ block.settings.font | default: 'var(--font-heading)' }};">
                {{ block.settings.title }}
              </p>
            {% endif %}
            {% if block.settings.description != blank %}
              <p class="mt-card-desc">{{ block.settings.description }}</p>
            {% endif %}
            {% if block.settings.link_text != blank %}
              <a
                href="{{ block.settings.link_url | default: '#' }}"
                class="mt-card-link"
                {% if block.settings.link_external %}target="_blank" rel="noopener"{% endif %}
              >{{ block.settings.link_text }}</a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}

    {%- comment -%} Duplicate for seamless loop {%- endcomment -%}
    {% for block in section.blocks %}
      {% if block.type == 'ticker_card' %}
        <div class="mt-card" aria-hidden="true">
          <div class="mt-card-media">
            {% if block.settings.video != blank %}
              <video
                src="{{ block.settings.video.sources[0].url }}"
                autoplay muted loop playsinline
                poster="{% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 600 }}{% endif %}"
              ></video>
            {% elsif block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.title | default: 'Card' | escape }}"
                loading="lazy" width="600" height="450"
              />
            {% else %}
              <img
                src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=600&q=80&auto=format&fit=crop"
                alt="Placeholder" loading="lazy" width="600" height="450"
              />
            {% endif %}
          </div>
          <div class="mt-card-body">
            {% if block.settings.title != blank %}
              <p class="mt-card-title" style="font-family: {{ block.settings.font | default: 'var(--font-heading)' }};">
                {{ block.settings.title }}
              </p>
            {% endif %}
            {% if block.settings.description != blank %}
              <p class="mt-card-desc">{{ block.settings.description }}</p>
            {% endif %}
            {% if block.settings.link_text != blank %}
              <a
                href="{{ block.settings.link_url | default: '#' }}"
                class="mt-card-link"
                tabindex="-1"
                {% if block.settings.link_external %}target="_blank" rel="noopener"{% endif %}
              >{{ block.settings.link_text }}</a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Marquee Ticker",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0a0a0a"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 80,
      "step": 5,
      "default": 30,
      "label": "Scroll Speed (seconds)",
      "info": "Lower = faster"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24,
      "label": "Gap between cards (px)"
    },
    {
      "type": "range",
      "id": "card_width",
      "min": 200,
      "max": 400,
      "step": 20,
      "default": 280,
      "label": "Card Width (px)"
    }
  ],
  "blocks": [
    {
      "type": "ticker_card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Recommended: 600 × 450px (4:3)"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video (optional)",
          "info": "Overrides the image if provided. Upload via Files > Videos."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Style Title"
        },
        {
          "type": "font_picker",
          "id": "font",
          "label": "Title Font",
          "default": "assistant_n4"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "A short caption for this card."
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "Explore more",
          "info": "Subtle underlined link"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        },
        {
          "type": "checkbox",
          "id": "link_external",
          "label": "Open in new tab",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Ticker",
      "blocks": [
        { "type": "ticker_card", "settings": { "title": "Elegant Layers", "description": "Layered silhouettes that redefine sophistication.", "link_text": "Explore more" } },
        { "type": "ticker_card", "settings": { "title": "Urban Minimalism", "description": "Clean lines, muted tones, effortless cool.", "link_text": "View collection" } },
        { "type": "ticker_card", "settings": { "title": "Raw Denim Edit", "description": "Washed textures and vintage-inspired fits.", "link_text": "Shop now" } },
        { "type": "ticker_card", "settings": { "title": "The Silk Series", "description": "Fluid fabrics for after-hours elegance.", "link_text": "Discover" } },
        { "type": "ticker_card", "settings": { "title": "Street Luxe", "description": "Where streetwear meets high fashion.", "link_text": "See more" } },
        { "type": "ticker_card", "settings": { "title": "Monochrome Mood", "description": "Black, white, and everything in between.", "link_text": "Browse" } }
      ]
    }
  ]
}
{% endschema %}
