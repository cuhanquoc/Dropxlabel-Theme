{% comment %} Featured Edit - Product Cards with Blocks {% endcomment %}

<section
  class="relative overflow-hidden bg-[#f5f0e8] text-[#111111]"
  id="mt-firework-section"
  style="background-color: {{ section.settings.bg_color | default: '#f5f0e8' }};"
>
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute inset-x-0 top-0 h-56 bg-[radial-gradient(circle_at_20%_0%,rgba(255,255,255,0.72),transparent_48%),radial-gradient(circle_at_80%_12%,rgba(205,196,183,0.2),transparent_42%)]"></div>
    <div class="absolute inset-x-0 bottom-0 h-40 bg-[linear-gradient(180deg,rgba(245,240,232,0)_0%,rgba(245,240,232,0.58)_100%)]"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-6xl px-4 pb-14 pt-10 sm:px-6 md:px-8 md:pb-20 md:pt-12 lg:py-20">

    <div class="mb-8 max-w-[34rem] md:mb-10">
      <p class="mb-3 inline-flex min-h-11 items-center rounded-full border border-black/8 bg-white/72 px-3.5 py-1.5 text-[10px] font-semibold uppercase tracking-[0.24em] text-[#73695d] backdrop-blur-sm">
        Featured edit
      </p>
      <h2 style="font-family: var(--font-heading); font-size: clamp(1.9rem, 4.6vw, 3.1rem); font-weight: 700; line-height: 1.05; letter-spacing: -0.045em; color: #111111; margin-bottom: 0.85rem;">
        {{ section.settings.heading | default: 'A quieter product edit' }}
      </h2>

    {% if section.settings.description_1 != blank %}
      <p style="font-family: var(--font-body); font-size: 0.98rem; line-height: 1.75; color: rgba(17,17,17,0.62); margin-bottom: 0.85rem; max-width: 560px;">
        {{ section.settings.description_1 }}
      </p>
    {% endif %}

    {% if section.settings.description_2 != blank %}
      <p style="font-family: var(--font-body); font-size: 0.98rem; line-height: 1.75; color: rgba(17,17,17,0.62); margin-bottom: 1.5rem; max-width: 560px;">
        {{ section.settings.description_2 }}
      </p>
    {% endif %}
    </div>

    {% if section.settings.cta_text != blank %}
      <a
        href="{{ section.settings.cta_url | default: '/collections/all' }}"
        class="group mb-10 inline-flex min-h-11 items-center gap-3 rounded-full border border-black/10 bg-white/72 px-2 py-1.5 pr-6 shadow-[0_12px_28px_-24px_rgba(17,17,17,0.35)] transition-[transform,background-color,border-color,box-shadow] duration-300 [transition-timing-function:cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-[1px] hover:bg-white/88 md:mb-12"
      >
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[#111111] text-[#f5f0e8] transition-transform duration-300 [transition-timing-function:cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.03]">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.9">
            <path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10"/>
          </svg>
        </span>
        <span style="font-family: var(--font-body); font-size: 0.76rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #111111;">
          {{ section.settings.cta_text }}
        </span>
      </a>
    {% endif %}

    <!-- ── Product Cards from Blocks ── -->
    {% if section.blocks.size > 0 %}
      <div class="flex flex-col gap-3 rounded-[1.75rem] border border-black/6 bg-white/72 p-3 shadow-[0_22px_60px_-44px_rgba(17,17,17,0.35)] md:gap-4 md:p-4">
        {% for block in section.blocks %}
          {% if block.type == 'product_card' %}
            {% assign product = block.settings.product %}
            {% assign bg = block.settings.card_color | default: '#EFE8DE' %}

            {% if product != blank %}
              <a href="{{ product.url }}"
                 class="group flex min-h-[96px] items-center gap-4 rounded-xl border border-black/5 p-3 transition-[transform,border-color,background-color,box-shadow] duration-300 [transition-timing-function:cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-[1px] hover:border-black/8 hover:shadow-[0_14px_30px_-26px_rgba(17,17,17,0.28)] md:gap-5 md:rounded-2xl md:p-4"
                 style="background-color: {{ bg }};"
                 {{ block.shopify_attributes }}>
                <div class="h-[96px] w-[96px] shrink-0 overflow-hidden rounded-lg bg-white/20 md:h-[112px] md:w-[112px] md:rounded-xl">
                  {% if product.featured_image != blank %}
                    <img src="{{ product.featured_image | image_url: width: 280 }}"
                         alt="{{ product.title | escape }}"
                         loading="lazy" width="280" height="280"
                         class="w-full h-full object-cover">
                  {% endif %}
                </div>

                <div class="flex-1 min-w-0">
                  <p style="font-family: var(--font-heading); font-weight: 700; font-size: 1rem; line-height: 1.35; color: #111111; margin-bottom: 0.35rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                    {% if block.settings.custom_title != blank %}{{ block.settings.custom_title }}{% else %}{{ product.title }}{% endif %}
                  </p>
                  <div style="display: flex; align-items: center; gap: 0.5rem;">
                    {% if product.compare_at_price > product.price %}
                      <span style="font-family: var(--font-body); font-weight: 400; font-size: 0.78rem; color: rgba(17,17,17,0.42); text-decoration: line-through;">{{ product.compare_at_price | money }}</span>
                    {% endif %}
                    <span style="font-family: var(--font-body); font-weight: 600; font-size: 0.88rem; color: #111111;">{{ product.price | money }}</span>
                  </div>
                </div>

                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-black/10 text-[#111111] transition-colors duration-300 group-hover:border-black/20">
                  <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10"/>
                  </svg>
                </span>
              </a>
            {% else %}
              <div class="flex min-h-[96px] items-center gap-4 rounded-xl p-3 md:gap-5 md:rounded-2xl md:p-4"
                   style="background-color: {{ bg }};"
                   {{ block.shopify_attributes }}>
                <div class="h-[96px] w-[96px] shrink-0 overflow-hidden rounded-lg bg-white/30 md:h-[112px] md:w-[112px] md:rounded-xl">
                  {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
                <div class="flex-1 min-w-0">
                  <p style="font-family: var(--font-heading); font-weight: 700; font-size: 1rem; line-height: 1.35; color: #111111; margin-bottom: 0.35rem;">
                    Select a product
                  </p>
                  <p style="font-family: var(--font-body); font-weight: 600; font-size: 0.88rem; color: #0a0a0a;">
                    $0.00
                  </p>
                </div>
                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-black/10 text-[#111111]">
                  <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10"/>
                  </svg>
                </span>
              </div>
            {% endif %}
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Featured Edit",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Heading & Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
        "default": "A quieter product edit"
    },
    {
      "type": "textarea",
      "id": "description_1",
      "label": "Description Paragraph 1",
        "default": "Selected pieces from the current assortment, presented with a softer hand and a clearer hierarchy."
    },
    {
      "type": "textarea",
      "id": "description_2",
      "label": "Description Paragraph 2",
      "default": "Open any card for detail, or browse the full edit when you are ready to see the entire range."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
        "default": "Browse edit"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f5f0e8",
      "info": "Warm neutrals keep the section calmer and easier to scan"
    }
  ],
  "max_blocks": 8,
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Short Title (optional)",
          "info": "Override long product names with a short title, e.g. 'Summer Shirt'"
        },
        {
          "type": "color",
          "id": "card_color",
          "label": "Card Background Color",
          "default": "#EFE8DE"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Edit",
      "blocks": [
        { "type": "product_card", "settings": { "card_color": "#EFE8DE" } },
        { "type": "product_card", "settings": { "card_color": "#E8E1D6" } },
        { "type": "product_card", "settings": { "card_color": "#DDD7CF" } },
        { "type": "product_card", "settings": { "card_color": "#EDE4DB" } },
        { "type": "product_card", "settings": { "card_color": "#F0E9E1" } }
      ]
    }
  ]
}
{% endschema %}
