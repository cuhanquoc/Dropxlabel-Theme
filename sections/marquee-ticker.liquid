{% comment %} BIKINIES — Rounded Horizontal Gallery {% endcomment %}

{% assign section_bg = section.settings.bg_color | default: '#0a0a0a' %}
{% assign section_heading = section.settings.heading | default: 'BIKINIES' %}
{% assign has_intro_blocks = false %}
{% for block in section.blocks %}
  {% if block.type == 'intro_heading' or block.type == 'intro_description' or block.type == 'intro_cta' %}
    {% assign has_intro_blocks = true %}
    {% break %}
  {% endif %}
{% endfor %}

<section
  id="mt-gallery-{{ section.id }}"
  class="relative overflow-hidden text-white"
  style="background-color: {{ section_bg }};"
>
  <div class="mx-auto max-w-[1680px] px-4 py-14 md:px-8 md:py-16 xl:px-10 xl:py-20">
    <div class="grid gap-10 xl:grid-cols-[minmax(320px,0.72fr)_minmax(0,1.28fr)] xl:gap-12 2xl:gap-16">
      <div class="xl:sticky xl:top-28">
        {% if has_intro_blocks %}
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'intro_heading' %}
                <h2 class="font-heading text-[clamp(3.25rem,7vw,5.75rem)] font-medium uppercase tracking-[-0.06em] leading-[0.88] text-white" {{ block.shopify_attributes }}>
                  {{ block.settings.text | default: section_heading }}
                </h2>
              {% when 'intro_description' %}
                <p class="{% if block.settings.tone == 'secondary' %}mt-4 text-white/60{% else %}mt-6 text-white/68{% endif %} max-w-[38rem] font-body text-base leading-[1.65] md:text-[1.05rem]" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </p>
              {% when 'intro_cta' %}
                {% if block.settings.text != blank %}
                  <a
                    href="{{ block.settings.url | default: section.settings.cta_url | default: '/collections/all' }}"
                    class="group mt-9 inline-flex min-h-[56px] items-center gap-4 rounded-full border border-white/18 bg-transparent px-2 py-2 pr-7 text-white transition-[border-color,background-color,transform] duration-300 hover:border-white/28 hover:bg-white/5"
                    {{ block.shopify_attributes }}
                  >
                    <span class="flex h-11 w-11 items-center justify-center rounded-full bg-white text-black transition-transform duration-300 group-hover:scale-105">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10" />
                      </svg>
                    </span>
                    <span class="font-body text-[0.92rem] font-semibold uppercase tracking-[0.14em]">
                      {{ block.settings.text }}
                    </span>
                  </a>
                {% endif %}
            {% endcase %}
          {% endfor %}
        {% else %}
          <h2 class="font-heading text-[clamp(3.25rem,7vw,5.75rem)] font-medium uppercase tracking-[-0.06em] leading-[0.88] text-white">
            {{ section_heading }}
          </h2>

          {% if section.settings.description_1 != blank %}
            <p class="mt-6 max-w-[38rem] font-body text-base leading-[1.65] text-white/68 md:text-[1.05rem]">
              {{ section.settings.description_1 }}
            </p>
          {% endif %}

          {% if section.settings.description_2 != blank %}
            <p class="mt-4 max-w-[38rem] font-body text-base leading-[1.65] text-white/60 md:text-[1.05rem]">
              {{ section.settings.description_2 }}
            </p>
          {% endif %}

          {% if section.settings.cta_text != blank %}
            <a
              href="{{ section.settings.cta_url | default: '/collections/all' }}"
              class="group mt-9 inline-flex min-h-[56px] items-center gap-4 rounded-full border border-white/18 bg-transparent px-2 py-2 pr-7 text-white transition-[border-color,background-color,transform] duration-300 hover:border-white/28 hover:bg-white/5"
            >
              <span class="flex h-11 w-11 items-center justify-center rounded-full bg-white text-black transition-transform duration-300 group-hover:scale-105">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10" />
                </svg>
              </span>
              <span class="font-body text-[0.92rem] font-semibold uppercase tracking-[0.14em]">
                {{ section.settings.cta_text }}
              </span>
            </a>
          {% endif %}
        {% endif %}
      </div>

      {% if section.blocks.size > 0 %}
        <div class="rounded-[2rem] border border-white/[0.08] bg-black/10 p-2.5 md:p-3 xl:p-4">
          <div class="flex flex-col gap-3 md:gap-4">
            {% for block in section.blocks %}
              {% if block.type == 'product_card' %}
                {% assign product = block.settings.product %}
                {% assign card_bg = block.settings.card_color | default: '#F0E068' %}
                {% assign card_title = block.settings.custom_title | default: product.title %}

                {% if product != blank %}
                  <a
                    href="{{ product.url }}"
                    class="group grid grid-cols-[92px_minmax(0,1fr)_48px] items-center gap-4 rounded-[1.6rem] px-4 py-4 text-[#111111] transition-transform duration-300 hover:scale-[1.005] md:grid-cols-[112px_minmax(0,1fr)_56px] md:gap-5 md:px-5 md:py-5 xl:min-h-[146px] xl:grid-cols-[128px_minmax(0,1fr)_64px] xl:gap-6 xl:px-6"
                    style="background-color: {{ card_bg }};"
                    {{ block.shopify_attributes }}
                  >
                    <div class="h-[92px] w-[92px] overflow-hidden rounded-[1.1rem] bg-white/20 md:h-[112px] md:w-[112px] xl:h-[128px] xl:w-[128px] xl:rounded-[1.25rem]">
                      {{
                        product.featured_image
                        | image_url: width: 384
                        | image_tag:
                          class: 'h-full w-full object-cover transition-transform duration-500 group-hover:scale-105',
                          loading: 'lazy',
                          widths: '184,256,320,384'
                      }}
                    </div>

                    <div class="min-w-0">
                      <p class="font-heading text-[1.25rem] font-medium uppercase tracking-[-0.04em] leading-[1] text-[#111111] md:text-[1.55rem] xl:text-[1.75rem]">
                        {{ card_title }}
                      </p>
                      <div class="mt-3 flex flex-wrap items-end gap-x-3 gap-y-1">
                        {% if product.compare_at_price > product.price %}
                          <span class="font-body text-[0.92rem] font-normal text-black/38 line-through md:text-[1rem]">
                            {{ product.compare_at_price | money }}
                          </span>
                        {% endif %}
                        <span class="font-body text-[1.15rem] font-semibold tracking-[-0.02em] text-[#111111] md:text-[1.3rem]">
                          {{ product.price | money }}
                        </span>
                      </div>
                    </div>

                    <span class="flex h-12 w-12 items-center justify-center rounded-full border-2 border-black/16 text-[#111111] transition-colors duration-300 group-hover:border-black/28 md:h-14 md:w-14 xl:h-16 xl:w-16">
                      <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10" />
                      </svg>
                    </span>
                  </a>
                {% else %}
                  <div
                    class="grid grid-cols-[92px_minmax(0,1fr)_48px] items-center gap-4 rounded-[1.6rem] px-4 py-4 text-[#111111] md:grid-cols-[112px_minmax(0,1fr)_56px] md:gap-5 md:px-5 md:py-5 xl:min-h-[146px] xl:grid-cols-[128px_minmax(0,1fr)_64px] xl:gap-6 xl:px-6"
                    style="background-color: {{ card_bg }};"
                    {{ block.shopify_attributes }}
                  >
                    <div class="flex h-[92px] w-[92px] items-center justify-center overflow-hidden rounded-[1.1rem] bg-white/25 md:h-[112px] md:w-[112px] xl:h-[128px] xl:w-[128px] xl:rounded-[1.25rem]">
                      {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'h-full w-full object-cover opacity-55' }}
                    </div>

                    <div class="min-w-0">
                      <p class="font-heading text-[1.25rem] font-medium uppercase tracking-[-0.04em] leading-[1] text-[#111111] md:text-[1.55rem] xl:text-[1.75rem]">
                        Select a product
                      </p>
                      <div class="mt-3">
                        <span class="font-body text-[1.15rem] font-semibold tracking-[-0.02em] text-[#111111] md:text-[1.3rem]">
                          $0.00
                        </span>
                      </div>
                    </div>

                    <span class="flex h-12 w-12 items-center justify-center rounded-full border-2 border-black/16 text-[#111111] md:h-14 md:w-14 xl:h-16 xl:w-16">
                      <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10" />
                      </svg>
                    </span>
                  </div>
                {% endif %}
              {% endif %}
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trending Styles",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Heading & Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "TRENDING STYLES YOU CAN'T MISS!"
    },
    {
      "type": "textarea",
      "id": "description_1",
      "label": "Description Paragraph 1",
      "default": "Explore our collection of top-selling fashion favorites, featuring the latest trends and must-have styles loved by our customers. Each piece is thoughtfully selected for its quality, comfort, and popularity, making it easy to stay stylish without compromising on ease."
    },
    {
      "type": "textarea",
      "id": "description_2",
      "label": "Description Paragraph 2",
      "default": "From everyday essentials to standout statement looks, our bestsellers offer something for every wardrobe. Refresh your style with fashion that blends modern design and timeless appeal, and stay ahead of the curve with pieces that truly make an impact."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0a0a0a",
      "info": "Dark backgrounds work best with light-colored card accents"
    }
  ],
  "max_blocks": 12,
  "blocks": [
    {
      "type": "intro_heading",
      "name": "Intro heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Heading text",
          "default": "BIKINIES"
        }
      ]
    },
    {
      "type": "intro_description",
      "name": "Intro description",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Description text"
        },
        {
          "type": "select",
          "id": "tone",
          "label": "Tone",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" }
          ],
          "default": "primary"
        }
      ]
    },
    {
      "type": "intro_cta",
      "name": "Intro CTA",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Button text",
          "default": "SHOP NOW"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Button URL"
        }
      ]
    },
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Short Title (optional)",
          "info": "Override long product names with a short title, e.g. 'Summer Shirt'"
        },
        {
          "type": "color",
          "id": "card_color",
          "label": "Card Background Color",
          "default": "#F0E068"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trending Styles",
      "blocks": [
        { "type": "product_card", "settings": { "card_color": "#F0E068" } },
        { "type": "product_card", "settings": { "card_color": "#B8A8E8" } },
        { "type": "product_card", "settings": { "card_color": "#D88CC4" } },
        { "type": "product_card", "settings": { "card_color": "#C8E040" } },
        { "type": "product_card", "settings": { "card_color": "#E8A0B0" } }
      ]
    }
  ]
}
{% endschema %}
