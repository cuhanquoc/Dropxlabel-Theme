{% comment %} TRENDING STYLES — Product Cards with Blocks {% endcomment %}

<section class="relative overflow-hidden trending-styles-section" id="trending-styles-section" style="background-color: {{ section.settings.bg_color | default: '#0a0a0a' }};">

  <div class="relative z-10 max-w-[640px] mx-auto px-4 md:px-8 pt-2 pb-16 md:pt-4 md:pb-24">

    <!-- ── Hero Text ── -->
    <h2 style="font-family: var(--font-heading); font-size: clamp(2rem, 7vw, 3.2rem); font-weight: 800; line-height: 1.05; letter-spacing: 0.02em; text-transform: uppercase; color: #ffffff; margin-bottom: 2rem;">
      {{ section.settings.heading | default: "TRENDING STYLES YOU CAN'T MISS!" }}
    </h2>

    {% if section.settings.description_1 != blank %}
      <p style="font-family: var(--font-body); font-size: 0.92rem; line-height: 1.75; color: rgba(255,255,255,0.6); margin-bottom: 1.25rem; max-width: 560px;">
        {{ section.settings.description_1 }}
      </p>
    {% endif %}

    {% if section.settings.description_2 != blank %}
      <p style="font-family: var(--font-body); font-size: 0.92rem; line-height: 1.75; color: rgba(255,255,255,0.6); margin-bottom: 2.5rem; max-width: 560px;">
        {{ section.settings.description_2 }}
      </p>
    {% endif %}

    <!-- ── CTA Button ── -->
    {% if section.settings.cta_text != blank %}
      <a href="{{ section.settings.cta_url | default: '/collections/all' }}"
         class="inline-flex items-center gap-3 rounded-full border border-white/20 bg-transparent hover:bg-white/5 transition-[background-color,border-color,opacity] duration-300 pr-6 pl-1.5 py-1.5 mb-12 md:mb-16 min-h-[48px] group">
        <span class="w-10 h-10 rounded-full bg-white flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform duration-300">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#0a0a0a" stroke-width="2">
            <path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10"/>
          </svg>
        </span>
        <span style="font-family: var(--font-body); font-size: 0.82rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #ffffff;">
          {{ section.settings.cta_text }}
        </span>
      </a>
    {% endif %}

    <!-- ── Product Cards from Blocks ── -->
    {% if section.blocks.size > 0 %}
      <div class="rounded-2xl border border-white/[0.08] p-3 md:p-4 flex flex-col gap-3 md:gap-4">
        {% for block in section.blocks %}
          {% if block.type == 'product_card' %}
            {% assign product = block.settings.product %}
            {% assign bg = block.settings.card_color | default: '#F0E068' %}

            {% if product != blank %}
              <a href="{{ product.url }}"
                 class="flex items-center gap-4 md:gap-5 rounded-xl md:rounded-2xl p-3 md:p-4 transition-transform duration-300 hover:scale-[1.01] min-h-[100px] group"
                 style="background-color: {{ bg }};"
                 {{ block.shopify_attributes }}>
                <!-- Product Image -->
                <div class="w-[100px] h-[100px] md:w-[120px] md:h-[120px] rounded-lg md:rounded-xl overflow-hidden shrink-0 bg-white/20">
                  {% if product.featured_image != blank %}
                    <img src="{{ product.featured_image | image_url: width: 280 }}"
                         alt="{{ product.title | escape }}"
                         loading="lazy" width="280" height="280"
                         class="w-full h-full object-cover">
                  {% endif %}
                </div>

                <!-- Product Info -->
                <div class="flex-1 min-w-0">
                  <p style="font-family: var(--font-heading); font-weight: 700; font-size: 1.05rem; line-height: 1.3; color: #0a0a0a; margin-bottom: 0.35rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                    {% if block.settings.custom_title != blank %}{{ block.settings.custom_title }}{% else %}{{ product.title }}{% endif %}
                  </p>
                  <div style="display: flex; align-items: center; gap: 0.5rem;">
                    {% if product.compare_at_price > product.price %}
                      <span style="font-family: var(--font-body); font-weight: 400; font-size: 0.78rem; color: rgba(10,10,10,0.45); text-decoration: line-through;">{{ product.compare_at_price | money }}</span>
                    {% endif %}
                    <span style="font-family: var(--font-body); font-weight: 600; font-size: 0.88rem; color: #0a0a0a;">{{ product.price | money }}</span>
                  </div>
                </div>

                <!-- Arrow Icon -->
                <span class="w-11 h-11 rounded-full border-2 border-[#0a0a0a]/20 flex items-center justify-center shrink-0 group-hover:border-[#0a0a0a]/40 transition-colors duration-300">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#0a0a0a" stroke-width="1.8">
                    <path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10"/>
                  </svg>
                </span>
              </a>
            {% else %}
              <!-- Placeholder when no product selected -->
              <div class="flex items-center gap-4 md:gap-5 rounded-xl md:rounded-2xl p-3 md:p-4 min-h-[100px]"
                   style="background-color: {{ bg }};"
                   {{ block.shopify_attributes }}>
                <div class="w-[100px] h-[100px] md:w-[120px] md:h-[120px] rounded-lg md:rounded-xl overflow-hidden shrink-0 bg-white/30">
                  {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
                <div class="flex-1 min-w-0">
                  <p style="font-family: var(--font-heading); font-weight: 700; font-size: 1.05rem; line-height: 1.3; color: #0a0a0a; margin-bottom: 0.35rem;">
                    Select a product
                  </p>
                  <p style="font-family: var(--font-body); font-weight: 600; font-size: 0.88rem; color: #0a0a0a;">
                    $0.00
                  </p>
                </div>
                <span class="w-11 h-11 rounded-full border-2 border-[#0a0a0a]/20 flex items-center justify-center shrink-0">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#0a0a0a" stroke-width="1.8">
                    <path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10"/>
                  </svg>
                </span>
              </div>
            {% endif %}
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

  </div>
</section>

<script>
(function () {
  'use strict';

  var section = document.getElementById('trending-styles-section');
  if (!section || typeof IntersectionObserver === 'undefined') return;

  var fired = false;

  var observer = new IntersectionObserver(function (entries) {
    if (entries[0].isIntersecting && !fired) {
      fired = true;
      observer.disconnect();
      launchFireworks();
    }
  }, { threshold: 0.25 });

  observer.observe(section);

  function launchFireworks() {
    var canvas = document.createElement('canvas');
    canvas.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9999;';
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    document.body.appendChild(canvas);

    var ctx = canvas.getContext('2d');
    var W = canvas.width;
    var H = canvas.height;
    var particles = [];
    var colors = ['#C5A880', '#FFD700', '#ffffff', '#ff9ecd', '#87CEEB', '#a8e6cf', '#ffd3b6'];

    function burst(x, y, count) {
      for (var i = 0; i < count; i++) {
        var angle = (i / count) * Math.PI * 2 + (Math.random() - 0.5) * 0.5;
        var speed = 3 + Math.random() * 9;
        particles.push({
          x: x, y: y,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed - 2,
          life: 1,
          decay: 0.011 + Math.random() * 0.012,
          size: 2 + Math.random() * 3.5,
          color: colors[Math.floor(Math.random() * colors.length)]
        });
      }
    }

    var launches = [
      { x: W * 0.04, delay: 0 },
      { x: W * 0.96, delay: 180 },
      { x: W * 0.08, delay: 350 },
      { x: W * 0.92, delay: 520 },
      { x: W * 0.02, delay: 700 },
      { x: W * 0.98, delay: 850 }
    ];

    launches.forEach(function (l) {
      setTimeout(function () {
        var y = H * (0.25 + Math.random() * 0.35);
        burst(l.x, y, 65);
      }, l.delay);
    });

    function draw() {
      ctx.clearRect(0, 0, W, H);
      for (var i = particles.length - 1; i >= 0; i--) {
        var p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.18;
        p.vx *= 0.985;
        p.life -= p.decay;
        if (p.life <= 0) { particles.splice(i, 1); continue; }
        ctx.save();
        ctx.globalAlpha = p.life;
        ctx.fillStyle = p.color;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      }
      if (particles.length > 0) {
        requestAnimationFrame(draw);
      } else {
        canvas.remove();
      }
    }

    setTimeout(draw, 50);
  }
})();
</script>

{% schema %}
{
  "name": "Trending Styles",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Heading & Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "TRENDING STYLES YOU CAN'T MISS!"
    },
    {
      "type": "textarea",
      "id": "description_1",
      "label": "Description Paragraph 1",
      "default": "Explore our collection of top-selling fashion favorites, featuring the latest trends and must-have styles loved by our customers. Each piece is thoughtfully selected for its quality, comfort, and popularity, making it easy to stay stylish without compromising on ease."
    },
    {
      "type": "textarea",
      "id": "description_2",
      "label": "Description Paragraph 2",
      "default": "From everyday essentials to standout statement looks, our bestsellers offer something for every wardrobe. Refresh your style with fashion that blends modern design and timeless appeal, and stay ahead of the curve with pieces that truly make an impact."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0a0a0a",
      "info": "Dark backgrounds work best with light-colored card accents"
    }
  ],
  "max_blocks": 8,
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Short Title (optional)",
          "info": "Override long product names with a short title, e.g. 'Summer Shirt'"
        },
        {
          "type": "color",
          "id": "card_color",
          "label": "Card Background Color",
          "default": "#F0E068"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trending Styles",
      "blocks": [
        { "type": "product_card", "settings": { "card_color": "#F0E068" } },
        { "type": "product_card", "settings": { "card_color": "#B8A8E8" } },
        { "type": "product_card", "settings": { "card_color": "#D88CC4" } },
        { "type": "product_card", "settings": { "card_color": "#C8E040" } },
        { "type": "product_card", "settings": { "card_color": "#E8A0B0" } }
      ]
    }
  ]
}
{% endschema %}
