{{ 'footer-accordion.css' | asset_url | stylesheet_tag }}

<section class="fac-root" aria-label="Footer navigation">

  {%- comment -%} ── Accordion link groups ──────────────────── {%- endcomment -%}
  <ul class="fac-list" role="list">
    {%- for block in section.blocks -%}
      {%- if block.type == 'link_group' -%}
        {%- assign panel_id = 'fac-panel-' | append: block.id -%}
        <li class="fac-item" {{ block.shopify_attributes }}>
          <button
            class="fac-trigger"
            aria-expanded="false"
            aria-controls="{{ panel_id }}"
            type="button"
          >
            <span class="fac-trigger-label">
              {{- block.settings.title | default: 'Links' -}}
            </span>
            <span class="fac-icon" aria-hidden="true"></span>
          </button>

          <div
            class="fac-panel"
            id="{{ panel_id }}"
            role="region"
            aria-labelledby="{{ panel_id }}-btn"
          >
            <div class="fac-panel-inner">
              {%- if block.settings.menu != blank -%}
                <ul class="fac-links" role="list">
                  {%- for link in block.settings.menu.links -%}
                    <li>
                      <a href="{{ link.url }}">{{- link.title -}}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          </div>
        </li>
      {%- endif -%}
    {%- endfor -%}
  </ul>

  {%- comment -%} ── Social icons row ───────────────────────── {%- endcomment -%}
  <div class="fac-social">

    {%- if section.settings.social_facebook != blank -%}
      <a class="fac-social-link" href="{{ section.settings.social_facebook }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M24 12.073C24 5.404 18.627 0 12 0 5.383 0 0 5.404 0 12.073 0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
        </svg>
      </a>
    {%- endif -%}

    {%- if section.settings.social_x != blank -%}
      <a class="fac-social-link" href="{{ section.settings.social_x }}" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
    {%- endif -%}

    {%- if section.settings.social_instagram != blank -%}
      <a class="fac-social-link" href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4.5"/>
          <circle cx="17.5" cy="6.5" r=".8" fill="currentColor" stroke="none"/>
        </svg>
      </a>
    {%- endif -%}

    {%- if section.settings.social_youtube != blank -%}
      <a class="fac-social-link" href="{{ section.settings.social_youtube }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
        </svg>
      </a>
    {%- endif -%}

    {%- if section.settings.social_tiktok != blank -%}
      <a class="fac-social-link" href="{{ section.settings.social_tiktok }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.37 6.37 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.15 8.15 0 004.78 1.52V6.77a4.85 4.85 0 01-1.01-.08z"/>
        </svg>
      </a>
    {%- endif -%}

  </div>

  {%- comment -%} ── Legal address bar ──────────────────────── {%- endcomment -%}
  {%- if section.settings.address_text != blank -%}
    <p class="fac-address">{{ section.settings.address_text }}</p>
  {%- endif -%}

</section>

{%- comment -%} ── Floating chat button ───────────────────── {%- endcomment -%}
{%- if section.settings.show_chat_btn -%}
  <button
    class="fac-chat-btn"
    type="button"
    aria-label="{{ section.settings.chat_label | default: 'Open chat' }}"
    onclick="{{ section.settings.chat_onclick }}"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
    </svg>
  </button>
{%- endif -%}

<script>
(function () {
  'use strict';

  var isDesktop = window.matchMedia('(min-width: 768px)');

  function initAccordion() {
    document.querySelectorAll('.fac-trigger').forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (isDesktop.matches) return;          // no-op on desktop

        var expanded = this.getAttribute('aria-expanded') === 'true';
        var panelId  = this.getAttribute('aria-controls');
        var panel    = document.getElementById(panelId);

        /* Close all siblings first */
        var list = this.closest('.fac-list');
        if (list) {
          list.querySelectorAll('.fac-trigger').forEach(function (other) {
            if (other !== btn) {
              other.setAttribute('aria-expanded', 'false');
              var otherId = other.getAttribute('aria-controls');
              var otherPanel = document.getElementById(otherId);
              if (otherPanel) otherPanel.classList.remove('is-open');
            }
          });
        }

        /* Toggle this one */
        this.setAttribute('aria-expanded', String(!expanded));
        if (panel) panel.classList.toggle('is-open', !expanded);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAccordion);
  } else {
    initAccordion();
  }
})();
</script>

