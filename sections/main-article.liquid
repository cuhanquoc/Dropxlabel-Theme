{% comment %} MAIN ARTICLE — CSS → src/input.css {% endcomment %}

{%- comment -%}
  ─────────────────────────────────────────
  MAIN ARTICLE SECTION
  Used in: templates/article.json
  Context: article, blog
  ─────────────────────────────────────────
{%- endcomment -%}

<article id="main-article" itemscope itemtype="https://schema.org/BlogPosting">

  <!-- ══════════════════════════════════════
       1. ARTICLE HEADER (centred)
  ══════════════════════════════════════ -->
  <header class="pt-32 pb-12 px-6 text-center">

    <!-- Blog name tag -->
    <a
      href="{{ blog.url }}"
      style="
        font-family: var(--font-body);
        font-size: 0.6rem;
        letter-spacing: 0.26em;
        text-transform: uppercase;
        color: var(--color-accent);
        text-decoration: none;
        display: inline-block;
        margin-bottom: 1.5rem;
        transition: opacity 200ms ease;
      "
    >{{ blog.title | default: 'Journal' }}</a>

    <!-- Meta: date · author -->
    <div class="ma-meta mb-2">
      <time
        itemprop="datePublished"
        datetime="{{ article.published_at | date: '%Y-%m-%d' }}"
      >{{ article.published_at | date: '%B %d, %Y' | default: 'March 5, 2026' }}</time>
      <span class="ma-meta-dot" aria-hidden="true"></span>
      <span itemprop="author">{{ article.author | default: 'Shine Design' }}</span>
    </div>

    <!-- H1 Title -->
    <h1 class="ma-title" itemprop="headline">
      {{ article.title | default: 'The Art of Dressing With Restraint' }}
    </h1>

    <!-- Reading time estimate -->
    {% if section.settings.show_reading_time %}
    {%- assign words    = article.content | strip_html | split: ' ' -%}
    {%- assign word_cnt = words | size -%}
    {%- assign read_min = word_cnt | divided_by: 200 | plus: 1 -%}
    <p style="
      font-family: var(--font-body);
      font-size: 0.62rem;
      letter-spacing: 0.14em;
      color: var(--color-muted);
      margin-top: 1.25rem;
    ">{{ read_min }} min read</p>
    {% endif %}

  </header>
  <!-- / Article Header -->

  <!-- ══════════════════════════════════════
       2. FEATURED / COVER IMAGE
  ══════════════════════════════════════ -->
  {% if article.image %}
    <div class="ma-cover" itemprop="image">
      <img
        src="{{ article.image | image_url: width: 1200 }}"
        alt="{{ article.image.alt | default: article.title | escape }}"
        loading="eager"
        width="1200"
        height="{{ 1200 | divided_by: article.image.aspect_ratio | round }}"
      />
    </div>
  {% else %}
    <!-- Fallback cover -->
    <div class="ma-cover">
      <div
        style="border-radius: 12px; width: 100%; height: 480px; background: #1a1a1a; display: block;"
        aria-hidden="true"
      ></div>
    </div>
  {% endif %}

  <!-- ══════════════════════════════════════
       3. ARTICLE BODY
  ══════════════════════════════════════ -->
  <div class="max-w-3xl mx-auto px-6 py-16">

    <!-- Article prose content -->
    <div class="article-content" itemprop="articleBody">
      {{ article.content }}
    </div>

    <!-- Tags -->
    {% if section.settings.show_tags and article.tags.size > 0 %}
      <div style="margin-bottom: 2rem; display: flex; flex-wrap: wrap; gap: 0.5rem;">
        {% for tag in article.tags %}
          <a
            href="{{ blog.url }}/tagged/{{ tag | handleize }}"
            class="ma-tag-pill"
          >#{{ tag }}</a>
        {% endfor %}
      </div>
    {% endif %}

    <!-- ── Share Bar ── -->
    {% if section.settings.show_share %}
    <div class="ma-share-bar">
      <span class="ma-share-label">{{ section.settings.share_label | default: 'Share' }}</span>

      <!-- Twitter/X -->
      <a
        class="ma-share-btn"
        href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url }}&text={{ article.title | url_encode }}"
        target="_blank"
        rel="noopener"
        aria-label="{{ section.settings.share_x_aria_label | default: 'Share on X' | escape }}"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
        X
      </a>

      <!-- Pinterest -->
      <a
        class="ma-share-btn"
        href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ article.url }}&description={{ article.title | url_encode }}"
        target="_blank"
        rel="noopener"
        aria-label="{{ section.settings.share_pinterest_aria_label | default: 'Share on Pinterest' | escape }}"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83l1.22-5.16s-.31-.62-.31-1.54c0-1.45.84-2.53 1.88-2.53.89 0 1.32.67 1.32 1.47 0 .9-.57 2.24-.87 3.49-.25 1.04.52 1.88 1.54 1.88 1.85 0 3.09-2.37 3.09-5.18 0-2.14-1.45-3.74-4.07-3.74-2.96 0-4.79 2.21-4.79 4.67 0 .85.25 1.44.64 1.9.18.21.2.29.14.53l-.19.77c-.06.25-.25.33-.46.24-1.31-.54-1.92-1.98-1.92-3.6 0-2.67 2.25-5.87 6.72-5.87 3.6 0 5.97 2.61 5.97 5.41 0 3.71-2.06 6.49-5.1 6.49-1.02 0-1.97-.55-2.3-1.18l-.64 2.46c-.23.87-.69 1.74-1.06 2.42.8.24 1.64.37 2.52.37 5.52 0 10-4.48 10-10S17.52 2 12 2z"/>
        </svg>
        Pin
      </a>

      <!-- Copy link -->
      <button
        class="ma-share-btn"
        data-copy-link
        data-default-label="{{ section.settings.copy_link_label | default: 'Copy Link' | escape }}"
        data-copied-label="{{ section.settings.copied_link_label | default: '✓ Copied!' | escape }}"
        aria-label="{{ section.settings.copy_link_aria_label | default: 'Copy link' | escape }}"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
        </svg>
        {{ section.settings.copy_link_label | default: 'Copy Link' }}
      </button>
    </div>
    {% endif %}

    <!-- ── Author Card ── -->
    {% if section.settings.show_author %}
    <div class="ma-author-card">
      {% if article.user.image %}
        <img
          class="ma-author-avatar"
          src="{{ article.user.image | image_url: width: 112 }}"
          alt="{{ article.author | escape }}"
          loading="lazy"
          width="56"
          height="56"
        />
      {% else %}
        <div class="ma-author-avatar" style="background: linear-gradient(135deg, var(--color-accent), #b8975a);"></div>
      {% endif %}
      <div>
        <p class="ma-author-name">{{ section.settings.author_prefix | default: 'By' }} {{ article.author | default: section.settings.author_name_fallback }}</p>
        <p class="ma-author-bio">
          {{ article.user.bio | default: section.settings.author_bio_fallback }}
        </p>
      </div>
    </div>
    {% endif %}

    <!-- ── Related Articles & Promo Blocks ── -->
    {%- assign has_related = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'related_article' or block.type == 'promo_banner' -%}
        {%- assign has_related = true -%}
      {%- endif -%}
    {%- endfor -%}

    {% if has_related %}
    <div class="ma-blocks-wrap" style="margin-top: 4rem; border-top: 1px solid rgba(255,255,255,0.08); padding-top: 3rem;">

      <!-- Related Articles heading -->
      {%- assign related_count = 0 -%}
      {%- for block in section.blocks -%}{%- if block.type == 'related_article' -%}{%- assign related_count = related_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
      {% if related_count > 0 %}
      <p style="font-family: var(--font-body); font-size: 0.6rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--color-muted); margin-bottom: 1.5rem;">{{ section.settings.related_reading_label | default: 'Related Reading' }}</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.5rem; margin-bottom: 3rem;">
        {% for block in section.blocks %}
          {% if block.type == 'related_article' %}
          <a
            href="{{ block.settings.article_url | default: '#' }}"
            {{ block.shopify_attributes }}
            style="display: block; text-decoration: none; border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; overflow: hidden; transition: border-color 200ms ease;"
          >
            {% if block.settings.image %}
              <div style="aspect-ratio: 16/9; overflow: hidden;">
                <img
                  src="{{ block.settings.image | image_url: width: 480 }}"
                  alt="{{ block.settings.image.alt | escape }}"
                  loading="lazy"
                  width="480"
                  height="270"
                  style="width: 100%; height: 100%; object-fit: cover;"
                />
              </div>
            {% endif %}
            <div style="padding: 1rem;">
              <p style="font-family: var(--font-body); font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-accent); margin-bottom: 0.4rem;">{{ block.settings.category | default: 'Article' }}</p>
              <p style="font-family: var(--font-heading); font-size: 1rem; font-weight: 600; color: var(--color-fg); line-height: 1.3; margin: 0;">{{ block.settings.title | default: 'Read More' }}</p>
            </div>
          </a>
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}

      <!-- Promo Banners -->
      {% for block in section.blocks %}
        {% if block.type == 'promo_banner' %}
        <div
          {{ block.shopify_attributes }}
          style="
            border-radius: 12px;
            padding: 2rem 2.5rem;
            margin-bottom: 1.5rem;
            background: {{ block.settings.bg_color | default: 'rgba(255,255,255,0.04)' }};
            border: 1px solid rgba(255,255,255,0.1);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.5rem;
            flex-wrap: wrap;
          "
        >
          <div>
            <p style="font-family: var(--font-body); font-size: 0.58rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--color-accent); margin: 0 0 0.4rem;">{{ block.settings.eyebrow }}</p>
            <p style="font-family: var(--font-heading); font-size: 1.15rem; font-weight: 700; color: var(--color-fg); margin: 0 0 0.5rem;">{{ block.settings.heading }}</p>
            {% if block.settings.subtext != blank %}
              <p style="font-family: var(--font-body); font-size: 0.8rem; color: var(--color-muted); margin: 0;">{{ block.settings.subtext }}</p>
            {% endif %}
          </div>
          {% if block.settings.button_label != blank and block.settings.button_url != blank %}
          <a
            href="{{ block.settings.button_url }}"
            style="
              font-family: var(--font-body);
              font-size: 0.62rem;
              font-weight: 600;
              letter-spacing: 0.18em;
              text-transform: uppercase;
              color: var(--color-bg);
              background: var(--color-fg);
              padding: 0.7rem 1.5rem;
              border-radius: 6px;
              text-decoration: none;
              white-space: nowrap;
              flex-shrink: 0;
              transition: opacity 200ms ease;
            "
          >{{ block.settings.button_label }}</a>
          {% endif %}
        </div>
        {% endif %}
      {% endfor %}

    </div>
    {% endif %}

  </div>
  <!-- / Article Body -->

  <!-- ══════════════════════════════════════
       4. COMMENTS SECTION
  ══════════════════════════════════════ -->
  {% if blog.comments_enabled? and section.settings.show_comments %}
    <div class="max-w-3xl mx-auto px-6 pb-24">

      <!-- Existing Comments -->
      {% if article.comments_count > 0 %}
        <div style="margin-bottom: 4rem;">
          <p style="
            font-family: var(--font-body);
            font-size: 0.6rem;
            letter-spacing: 0.22em;
            text-transform: uppercase;
            color: var(--color-muted);
            margin-bottom: 1.5rem;
          ">{{ article.comments_count }} {{ article.comments_count | pluralize: 'Comment', 'Comments' }}</p>

          {% paginate article.comments by section.settings.comments_per_page %}
            {% for comment in article.comments %}
              <div class="ma-comment">
                <p class="ma-comment-author">{{ comment.author }}</p>
                <p class="ma-comment-date">
                  {{ comment.created_at | date: '%B %d, %Y' }}
                </p>
                <div class="ma-comment-body">{{ comment.content }}</div>
              </div>
            {% endfor %}
            {% if paginate.pages > 1 %}
              {{ paginate | default_pagination }}
            {% endif %}
          {% endpaginate %}
        </div>
      {% endif %}

      <!-- Comment Form -->
      <h2 class="ma-comment-section-title">{{ section.settings.comment_form_heading | default: 'Leave a Comment' }}</h2>

      {% form 'new_comment', article, id: 'article-comment-form' %}
        {{ form.errors | default_errors }}

        <!-- Name + Email row -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-0 md:gap-8">
          <div>
            <label for="comment-author" class="sr-only">Full Name</label>
            <input
              id="comment-author"
              name="comment[author]"
              type="text"
              class="ma-form-field"
              placeholder="Full Name *"
              required
              autocomplete="name"
              value="{{ form.author }}"
            />
          </div>
          <div>
            <label for="comment-email" class="sr-only">Email Address</label>
            <input
              id="comment-email"
              name="comment[email]"
              type="email"
              class="ma-form-field"
              placeholder="Email Address *"
              required
              autocomplete="email"
              value="{{ form.email }}"
            />
          </div>
        </div>

        <!-- Message -->
        <label for="comment-body" class="sr-only">Your Comment</label>
        <textarea
          id="comment-body"
          name="comment[body]"
          class="ma-form-field"
          placeholder="Your thoughts..."
          required
        >{{ form.body }}</textarea>

        <!-- Submit -->
        <button type="submit" class="ma-submit-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
          Post Comment
        </button>

      {% endform %}

    </div>
  {% endif %}
  <!-- / Comments Section -->

</article>


<script>
  /* ─────────────────────────────────────────────────────
     MAIN ARTICLE — GSAP entrance animations
  ───────────────────────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

    gsap.registerPlugin(ScrollTrigger);

    /* Article header elements cascade in */
    gsap.from('#main-article header > *', {
      opacity: 0,
      y: 28,
      duration: 1.0,
      ease: 'power3.out',
      stagger: 0.12,
      delay: 0.1,
    });

    /* Cover image fade up */
    gsap.from('.ma-cover', {
      scrollTrigger: { trigger: '.ma-cover', start: 'top 85%', once: true },
      opacity: 0,
      y: 40,
      duration: 1.0,
      ease: 'power3.out',
    });

    /* Article body paragraphs — stagger as they enter viewport */
    document.querySelectorAll('.article-content p, .article-content h2, .article-content h3, .article-content blockquote').forEach(el => {
      gsap.from(el, {
        scrollTrigger: { trigger: el, start: 'top 88%', once: true },
        opacity: 0,
        y: 20,
        duration: 0.75,
        ease: 'power2.out',
      });
    });

  });

  /* ─────────────────────────────────────────────────────
     Copy-link button delegation
  ───────────────────────────────────────────────────── */
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-copy-link]');
    if (!btn) return;
    navigator.clipboard.writeText(window.location.href).then(function () {
      btn.textContent = btn.dataset.copiedLabel || '✓ Copied!';
      setTimeout(function () { btn.textContent = btn.dataset.defaultLabel || 'Copy Link'; }, 2000);
    });
  });
</script>

{% schema %}
{
  "name": "Article",
  "tag": "section",
  "class": "main-article-section",
  "settings": [
    {
      "type": "header",
      "content": "Article Header"
    },
    {
      "type": "checkbox",
      "id": "show_reading_time",
      "label": "Show reading time",
      "default": true
    },
    {
      "type": "header",
      "content": "Content Options"
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Show article tags",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_share",
      "label": "Show share bar",
      "default": true
    },
    {
      "type": "text",
      "id": "share_label",
      "label": "Share section label",
      "default": "Share"
    },
    {
      "type": "text",
      "id": "share_x_aria_label",
      "label": "Share on X aria label",
      "default": "Share on X"
    },
    {
      "type": "text",
      "id": "share_pinterest_aria_label",
      "label": "Share on Pinterest aria label",
      "default": "Share on Pinterest"
    },
    {
      "type": "text",
      "id": "copy_link_label",
      "label": "Copy link button label",
      "default": "Copy Link"
    },
    {
      "type": "text",
      "id": "copied_link_label",
      "label": "Copied state label",
      "default": "✓ Copied!"
    },
    {
      "type": "text",
      "id": "copy_link_aria_label",
      "label": "Copy link aria label",
      "default": "Copy link"
    },
    {
      "type": "header",
      "content": "Author Card"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author card",
      "default": true
    },
    {
      "type": "text",
      "id": "author_prefix",
      "label": "Author prefix",
      "default": "By"
    },
    {
      "type": "text",
      "id": "author_name_fallback",
      "label": "Author name fallback",
      "default": "The Dropxlabel Team",
      "info": "Shown when article has no author set"
    },
    {
      "type": "textarea",
      "id": "author_bio_fallback",
      "label": "Author bio fallback",
      "default": "A storyteller at the intersection of craft and culture — writing about fashion as a form of personal language.",
      "info": "Shown when author has no bio in Shopify Admin"
    },
    {
      "type": "text",
      "id": "related_reading_label",
      "label": "Related reading heading",
      "default": "Related Reading"
    },
    {
      "type": "header",
      "content": "Comments"
    },
    {
      "type": "checkbox",
      "id": "show_comments",
      "label": "Show comments section",
      "default": true,
      "info": "Only appears if Comments are enabled in Blog settings"
    },
    {
      "type": "text",
      "id": "comment_form_heading",
      "label": "Comment form heading",
      "default": "Leave a Comment"
    },
    {
      "type": "range",
      "id": "comments_per_page",
      "label": "Comments per page",
      "min": 5,
      "max": 50,
      "step": 5,
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "related_article",
      "name": "Related Article",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Thumbnail Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Article Title",
          "default": "Another Story Worth Reading"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category Label",
          "default": "Style"
        },
        {
          "type": "url",
          "id": "article_url",
          "label": "Article URL"
        }
      ]
    },
    {
      "type": "promo_banner",
      "name": "Promo Banner",
      "settings": [
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow Text",
          "default": "New Arrival"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Explore the New Collection"
        },
        {
          "type": "textarea",
          "id": "subtext",
          "label": "Subtext",
          "default": "Thoughtfully designed for those who move with intention."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button URL"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color",
          "default": "#141414"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Article",
      "blocks": [
        {
          "type": "related_article",
          "settings": {
            "title": "The Anatomy of a Perfect Wardrobe",
            "category": "Style Guide"
          }
        },
        {
          "type": "related_article",
          "settings": {
            "title": "Dressing With Less, Living With More",
            "category": "Lifestyle"
          }
        }
      ]
    }
  ]
}
{% endschema %}
