<style>
  /* ─────────────────────────────────────────
     MAIN ARTICLE — Editorial Typography
  ───────────────────────────────────────── */

  /* Article meta line */
  .ma-meta {
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #6b7280; /* gray-500 */
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .ma-meta-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background-color: var(--color-accent);
    flex-shrink: 0;
  }

  /* Article H1 */
  .ma-title {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 5.5vw, 4rem);
    font-weight: 600;
    color: #222222;
    line-height: 1.08;
    letter-spacing: -0.02em;
    text-align: center;
    max-width: 820px;
    margin: 1.5rem auto 0;
  }

  /* Cover image frame */
  .ma-cover {
    max-width: 1024px;
    margin: 3rem auto 0;
    padding: 0 1.5rem;
  }

  .ma-cover img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 12px;
    object-fit: cover;
  }

  /* ── ARTICLE BODY TYPOGRAPHY ── */
  /* These rules carefully override Shopify's default prose styles */
  .article-content {
    font-family: var(--font-body);
    color: #4b5563;
  }

  .article-content p {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 2.0;
    color: #4b5563;
    margin-bottom: 2rem;
  }

  .article-content h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    font-weight: 600;
    color: #222222;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
  }

  .article-content h3 {
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 2.2vw, 1.65rem);
    font-weight: 600;
    color: #222222;
    line-height: 1.2;
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
  }

  .article-content img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 10px;
    margin: 2.5rem 0;
    object-fit: cover;
  }

  .article-content blockquote {
    border-left: 2px solid var(--color-accent);
    margin: 2.5rem 0;
    padding: 0.5rem 0 0.5rem 2rem;
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-style: italic;
    color: #222222;
    line-height: 1.5;
  }

  .article-content a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 200ms ease;
  }

  .article-content a:hover { opacity: 0.7; }

  .article-content ul,
  .article-content ol {
    font-size: 1.05rem;
    line-height: 1.9;
    color: #4b5563;
    margin-bottom: 2rem;
    padding-left: 1.5rem;
  }

  .article-content li { margin-bottom: 0.5rem; }

  .article-content hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3rem 0;
  }

  /* ── Share bar ── */
  .ma-share-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 4rem;
  }

  .ma-share-label {
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-right: 0.25rem;
  }

  .ma-share-btn {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    padding: 0.4rem 1rem;
    background: transparent;
    cursor: pointer;
    transition: background-color 250ms ease, border-color 250ms ease, color 250ms ease;
  }

  .ma-share-btn:hover {
    background-color: var(--color-text);
    border-color: var(--color-text);
    color: var(--color-bg);
  }

  /* ── Author card ── */
  .ma-author-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 2rem;
    background-color: #f9f9f7;
    border-radius: 16px;
    margin-bottom: 4rem;
  }

  .ma-author-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    background-color: var(--color-border);
  }

  .ma-author-name {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 0.2rem;
  }

  .ma-author-bio {
    font-family: var(--font-body);
    font-size: 0.8rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  /* ── Comment form ── */
  .ma-comment-section-title {
    font-family: var(--font-heading);
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    font-weight: 600;
    color: #222222;
    margin-bottom: 2rem;
  }

  .ma-form-field {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid #d1d5db; /* gray-300 */
    outline: none;
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--color-text);
    padding: 0.5rem 0 0.75rem;
    margin-bottom: 2rem;
    transition: border-color 300ms ease;
    letter-spacing: 0.02em;
  }

  .ma-form-field::placeholder {
    color: #9ca3af; /* gray-400 */
    letter-spacing: 0.02em;
  }

  .ma-form-field:focus {
    border-bottom-color: var(--color-text);
  }

  textarea.ma-form-field {
    resize: none;
    height: 120px;
  }

  .ma-submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background-color: var(--color-text);
    color: var(--color-bg);
    border: 2px solid var(--color-text);
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 0.75rem 2rem;
    cursor: pointer;
    transition: background-color 300ms ease, color 300ms ease;
  }

  .ma-submit-btn:hover {
    background-color: transparent;
    color: var(--color-text);
  }

  /* Existing comment display */
  .ma-comment {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .ma-comment-author {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 0.35rem;
  }

  .ma-comment-date {
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  .ma-comment-body {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.75;
    color: #4b5563;
  }

  /* Related posts strip */
  .ma-related-title {
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 2rem;
    text-align: center;
  }

  /* ─── Mobile Responsive ─── */
  @media (max-width: 767px) {
    #main-article header {
      padding-top: 7rem;
    }
    .ma-title {
      font-size: clamp(1.6rem, 6vw, 3rem);
    }
    .ma-share-bar {
      flex-wrap: wrap;
      gap: 0.6rem;
    }
    .ma-share-btn {
      font-size: 0.6rem;
      padding: 0.35rem 0.8rem;
    }
    .ma-author-card {
      flex-direction: column;
      text-align: center;
      align-items: center;
      padding: 1.5rem;
    }
    .ma-cover {
      padding: 0 0.75rem;
    }
    .article-content p {
      font-size: 1rem;
    }
  }
</style>

{%- comment -%}
  ─────────────────────────────────────────
  MAIN ARTICLE SECTION
  Used in: templates/article.json
  Context: article, blog
  ─────────────────────────────────────────
{%- endcomment -%}

<article id="main-article" itemscope itemtype="https://schema.org/BlogPosting">

  <!-- ══════════════════════════════════════
       1. ARTICLE HEADER (centred)
  ══════════════════════════════════════ -->
  <header class="pt-32 pb-12 px-6 text-center">

    <!-- Blog name tag -->
    <a
      href="{{ blog.url }}"
      style="
        font-family: var(--font-body);
        font-size: 0.6rem;
        letter-spacing: 0.26em;
        text-transform: uppercase;
        color: var(--color-accent);
        text-decoration: none;
        display: inline-block;
        margin-bottom: 1.5rem;
        transition: opacity 200ms ease;
      "
    >{{ blog.title | default: 'Journal' }}</a>

    <!-- Meta: date · author -->
    <div class="ma-meta mb-2">
      <time
        itemprop="datePublished"
        datetime="{{ article.published_at | date: '%Y-%m-%d' }}"
      >{{ article.published_at | date: '%B %d, %Y' | default: 'March 5, 2026' }}</time>
      <span class="ma-meta-dot" aria-hidden="true"></span>
      <span itemprop="author">{{ article.author | default: 'Shine Design' }}</span>
    </div>

    <!-- H1 Title -->
    <h1 class="ma-title" itemprop="headline">
      {{ article.title | default: 'The Art of Dressing With Restraint' }}
    </h1>

    <!-- Reading time estimate -->
    {%- assign words    = article.content | strip_html | split: ' ' -%}
    {%- assign word_cnt = words | size -%}
    {%- assign read_min = word_cnt | divided_by: 200 | plus: 1 -%}
    <p style="
      font-family: var(--font-body);
      font-size: 0.62rem;
      letter-spacing: 0.14em;
      color: var(--color-muted);
      margin-top: 1.25rem;
    ">{{ read_min }} min read</p>

  </header>
  <!-- / Article Header -->

  <!-- ══════════════════════════════════════
       2. FEATURED / COVER IMAGE
  ══════════════════════════════════════ -->
  {% if article.image %}
    <div class="ma-cover" itemprop="image">
      <img
        src="{{ article.image | image_url: width: 1200 }}"
        alt="{{ article.image.alt | default: article.title | escape }}"
        loading="eager"
        width="1200"
        height="{{ 1200 | divided_by: article.image.aspect_ratio | round }}"
      />
    </div>
  {% else %}
    <!-- Fallback cover -->
    <div class="ma-cover">
      <img
        src="https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=1200&q=85&auto=format&fit=crop"
        alt="Article cover — {{ article.title | default: 'Editorial' | escape }}"
        loading="eager"
        width="1200"
        height="800"
        style="border-radius: 12px; width: 100%;"
      />
    </div>
  {% endif %}

  <!-- ══════════════════════════════════════
       3. ARTICLE BODY
  ══════════════════════════════════════ -->
  <div class="max-w-3xl mx-auto px-6 py-16">

    <!-- Article prose content -->
    <div class="article-content" itemprop="articleBody">
      {{ article.content }}
    </div>

    <!-- Tags -->
    {% if article.tags.size > 0 %}
      <div style="margin-bottom: 2rem; display: flex; flex-wrap: wrap; gap: 0.5rem;">
        {% for tag in article.tags %}
          <a
            href="{{ blog.url }}/tagged/{{ tag | handleize }}"
            style="
              font-family: var(--font-body);
              font-size: 0.62rem;
              letter-spacing: 0.12em;
              text-transform: uppercase;
              padding: 0.35rem 0.9rem;
              border: 1px solid var(--color-border);
              border-radius: 9999px;
              color: var(--color-muted);
              text-decoration: none;
              transition: border-color 200ms, color 200ms;
            "
            onmouseover="this.style.color=getComputedStyle(document.documentElement).getPropertyValue('--color-text');this.style.borderColor=getComputedStyle(document.documentElement).getPropertyValue('--color-text')"
            onmouseout="this.style.color='';this.style.borderColor=''"
          >#{{ tag }}</a>
        {% endfor %}
      </div>
    {% endif %}

    <!-- ── Share Bar ── -->
    <div class="ma-share-bar">
      <span class="ma-share-label">Share</span>

      <!-- Twitter/X -->
      <a
        class="ma-share-btn"
        href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url }}&text={{ article.title | url_encode }}"
        target="_blank"
        rel="noopener"
        aria-label="Share on X"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
        X
      </a>

      <!-- Pinterest -->
      <a
        class="ma-share-btn"
        href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ article.url }}&description={{ article.title | url_encode }}"
        target="_blank"
        rel="noopener"
        aria-label="Share on Pinterest"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83l1.22-5.16s-.31-.62-.31-1.54c0-1.45.84-2.53 1.88-2.53.89 0 1.32.67 1.32 1.47 0 .9-.57 2.24-.87 3.49-.25 1.04.52 1.88 1.54 1.88 1.85 0 3.09-2.37 3.09-5.18 0-2.14-1.45-3.74-4.07-3.74-2.96 0-4.79 2.21-4.79 4.67 0 .85.25 1.44.64 1.9.18.21.2.29.14.53l-.19.77c-.06.25-.25.33-.46.24-1.31-.54-1.92-1.98-1.92-3.6 0-2.67 2.25-5.87 6.72-5.87 3.6 0 5.97 2.61 5.97 5.41 0 3.71-2.06 6.49-5.1 6.49-1.02 0-1.97-.55-2.3-1.18l-.64 2.46c-.23.87-.69 1.74-1.06 2.42.8.24 1.64.37 2.52.37 5.52 0 10-4.48 10-10S17.52 2 12 2z"/>
        </svg>
        Pin
      </a>

      <!-- Copy link -->
      <button
        class="ma-share-btn"
        onclick="navigator.clipboard.writeText(window.location.href);this.textContent='✓ Copied!';"
        aria-label="Copy link"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
        </svg>
        Copy Link
      </button>
    </div>

    <!-- ── Author Card ── -->
    <div class="ma-author-card">
      {% if article.user.image %}
        <img
          class="ma-author-avatar"
          src="{{ article.user.image | image_url: width: 112 }}"
          alt="{{ article.author | escape }}"
          loading="lazy"
          width="56"
          height="56"
        />
      {% else %}
        <div class="ma-author-avatar" style="background: linear-gradient(135deg, var(--color-accent), #b8975a);"></div>
      {% endif %}
      <div>
        <p class="ma-author-name">By {{ article.author | default: 'The Dropxlabel Team' }}</p>
        <p class="ma-author-bio">
          {{ article.user.bio | default: 'A storyteller at the intersection of craft and culture — writing about fashion as a form of personal language.' }}
        </p>
      </div>
    </div>

  </div>
  <!-- / Article Body -->

  <!-- ══════════════════════════════════════
       4. COMMENTS SECTION
  ══════════════════════════════════════ -->
  {% if blog.comments_enabled? %}
    <div class="max-w-3xl mx-auto px-6 pb-24">

      <!-- Existing Comments -->
      {% if article.comments_count > 0 %}
        <div style="margin-bottom: 4rem;">
          <p style="
            font-family: var(--font-body);
            font-size: 0.6rem;
            letter-spacing: 0.22em;
            text-transform: uppercase;
            color: var(--color-muted);
            margin-bottom: 1.5rem;
          ">{{ article.comments_count }} {{ article.comments_count | pluralize: 'Comment', 'Comments' }}</p>

          {% paginate article.comments by 10 %}
            {% for comment in article.comments %}
              <div class="ma-comment">
                <p class="ma-comment-author">{{ comment.author }}</p>
                <p class="ma-comment-date">
                  {{ comment.created_at | date: '%B %d, %Y' }}
                </p>
                <div class="ma-comment-body">{{ comment.content }}</div>
              </div>
            {% endfor %}
            {% if paginate.pages > 1 %}
              {{ paginate | default_pagination }}
            {% endif %}
          {% endpaginate %}
        </div>
      {% endif %}

      <!-- Comment Form -->
      <h2 class="ma-comment-section-title">Leave a Comment</h2>

      {% form 'new_comment', article, id: 'article-comment-form' %}
        {{ form.errors | default_errors }}

        <!-- Name + Email row -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-0 md:gap-8">
          <div>
            <label for="comment-author" class="sr-only">Full Name</label>
            <input
              id="comment-author"
              name="comment[author]"
              type="text"
              class="ma-form-field"
              placeholder="Full Name *"
              required
              autocomplete="name"
              value="{{ form.author }}"
            />
          </div>
          <div>
            <label for="comment-email" class="sr-only">Email Address</label>
            <input
              id="comment-email"
              name="comment[email]"
              type="email"
              class="ma-form-field"
              placeholder="Email Address *"
              required
              autocomplete="email"
              value="{{ form.email }}"
            />
          </div>
        </div>

        <!-- Message -->
        <label for="comment-body" class="sr-only">Your Comment</label>
        <textarea
          id="comment-body"
          name="comment[body]"
          class="ma-form-field"
          placeholder="Your thoughts..."
          required
        >{{ form.body }}</textarea>

        <!-- Submit -->
        <button type="submit" class="ma-submit-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
          Post Comment
        </button>

      {% endform %}

    </div>
  {% endif %}
  <!-- / Comments Section -->

</article>


<script>
  /* ─────────────────────────────────────────────────────
     MAIN ARTICLE — GSAP entrance animations
  ───────────────────────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

    gsap.registerPlugin(ScrollTrigger);

    /* Article header elements cascade in */
    gsap.from('#main-article header > *', {
      opacity: 0,
      y: 28,
      duration: 1.0,
      ease: 'power3.out',
      stagger: 0.12,
      delay: 0.1,
    });

    /* Cover image fade up */
    gsap.from('.ma-cover', {
      scrollTrigger: { trigger: '.ma-cover', start: 'top 85%', once: true },
      opacity: 0,
      y: 40,
      duration: 1.0,
      ease: 'power3.out',
    });

    /* Article body paragraphs — stagger as they enter viewport */
    document.querySelectorAll('.article-content p, .article-content h2, .article-content h3, .article-content blockquote').forEach(el => {
      gsap.from(el, {
        scrollTrigger: { trigger: el, start: 'top 88%', once: true },
        opacity: 0,
        y: 20,
        duration: 0.75,
        ease: 'power2.out',
      });
    });

  });
</script>
