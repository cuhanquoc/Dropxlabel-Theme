<style>
  /* ─────────────────────────────────────────
     ABOUT TEMPLATE — Editorial Magazine Style
  ───────────────────────────────────────── */

  /* Giant editorial quote */
  .at-quote {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4.5vw, 3.5rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-text);
    text-align: center;
    max-width: 880px;
    margin: 0 auto;
  }

  /* Eyebrow */
  .at-eyebrow {
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-align: center;
    margin-bottom: 1.75rem;
    display: block;
  }

  /* Parallax container */
  #at-parallax-wrap {
    width: 100%;
    position: relative;
    height: 80vh;
    overflow: hidden;
    margin-top: 5rem;
  }

  #at-parallax-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transform: scale(1.15); /* GSAP parallax headroom */
    will-change: transform;
  }

  /* Dark gradient overlay on parallax */
  #at-parallax-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(10,10,10,0.62) 0%,
      rgba(10,10,10,0.2) 50%,
      transparent 100%
    );
  }

  /* Hero text on parallax */
  .at-hero-text {
    position: absolute;
    bottom: 3rem;
    left: 3rem;
    right: 3rem;
  }

  @media (min-width: 768px) {
    .at-hero-text { left: 4rem; right: auto; max-width: 600px; }
  }

  .at-hero-headline {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 3.5rem);
    font-weight: 600;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  /* Floating Cards stack */
  .at-float-stack {
    position: absolute;
    bottom: 2.5rem;
    right: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: clamp(220px, 28vw, 320px);
  }

  @media (max-width: 640px) {
    .at-float-stack { display: none; }
  }

  .at-float-card {
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 32px;
    padding: 1.5rem;
    box-shadow: 0 20px 60px rgba(0,0,0,0.14);
    opacity: 0;           /* GSAP animates in */
    transform: translateY(50px);
    will-change: transform, opacity;
  }

  .at-float-card-tag {
    font-family: var(--font-body);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .at-float-card-title {
    font-family: var(--font-heading);
    font-size: clamp(0.9rem, 1.5vw, 1.15rem);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.25;
    margin-bottom: 1rem;
  }

  .at-float-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    padding: 0.45rem 1.1rem;
    transition: background-color 250ms ease, border-color 250ms ease, color 250ms ease;
  }

  .at-float-btn:hover {
    background-color: var(--color-text);
    border-color: var(--color-text);
    color: var(--color-bg);
    opacity: 1;
  }

  /* ── Brand values strip ── */
  .at-values-strip {
    display: flex;
    gap: 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .at-value-item {
    flex: 1;
    padding: 2rem 1.5rem;
    text-align: center;
    border-right: 1px solid var(--color-border);
  }

  .at-value-item:last-child { border-right: none; }

  .at-value-number {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .at-value-label {
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-top: 0.4rem;
  }

  /* ── Reviews horizontal scroll ── */
  .at-reviews-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.3rem, 3vw, 2.2rem);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.15;
    letter-spacing: -0.01em;
    max-width: 580px;
  }

  .at-reviews-strip {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    padding-bottom: 2rem;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .at-reviews-strip::-webkit-scrollbar { display: none; }

  .at-review-card {
    background: #f9f9f7;
    border-radius: 24px;
    padding: 2rem;
    width: 350px;
    flex-shrink: 0;
    scroll-snap-align: center;
    border: 1px solid var(--color-border);
  }

  .at-review-stars {
    color: var(--color-accent);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .at-review-text {
    font-family: var(--font-body);
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: 1.5rem;
    font-style: italic;
  }

  .at-review-author {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .at-review-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    background-color: var(--color-border);
    flex-shrink: 0;
  }

  .at-review-name {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .at-review-location {
    font-family: var(--font-body);
    font-size: 0.65rem;
    color: var(--color-muted);
    letter-spacing: 0.06em;
  }

  /* Drag cursor on reviews */
  .at-reviews-strip {
    cursor: grab;
  }
  .at-reviews-strip:active {
    cursor: grabbing;
  }

  /* Review scroll arrows */
  .at-scroll-arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    cursor: pointer;
    color: var(--color-text);
    transition: background-color 250ms ease, color 250ms ease, border-color 250ms ease;
    flex-shrink: 0;
  }

  .at-scroll-arrow:hover {
    background-color: var(--color-text);
    border-color: var(--color-text);
    color: var(--color-bg);
  }
</style>

