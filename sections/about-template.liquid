{%- liquid
  assign section_bg = section.settings.background_color | default: 'var(--color-base-background-1, #ffffff)'
  assign card_bg = section.settings.card_background_color | default: 'var(--color-base-background-1, #ffffff)'
  assign muted_text = section.settings.muted_text_color | default: 'rgba(17, 17, 17, 0.68)'
  assign hero_overlay = section.settings.hero_overlay_opacity | divided_by: 100.0
  assign style_overlay = section.settings.style_overlay_opacity | divided_by: 100.0
-%}

<section
  id="AboutTemplate-{{ section.id }}"
  class="abt"
  style="
    --abt-bg: {{ section_bg }};
    --abt-card-bg: {{ card_bg }};
    --abt-text: var(--color-base-text, var(--color-text, #111111));
    --abt-muted: {{ muted_text }};
    --abt-border: color-mix(in srgb, var(--abt-text) 12%, transparent);
    --abt-shadow: 0 12px 40px color-mix(in srgb, var(--abt-text) 8%, transparent);
    --abt-hero-overlay: {{ hero_overlay }};
    --abt-style-overlay: {{ style_overlay }};
    --abt-top: {{ section.settings.padding_top }}px;
    --abt-bottom: {{ section.settings.padding_bottom }}px;
    --abt-radius-xl: {{ section.settings.card_radius }}px;
    --abt-radius-lg: {{ section.settings.inner_radius }}px;
    --abt-button-radius: {{ section.settings.button_radius }}px;
  "
>
  <div class="abt__shell">
    <header class="abt__hero abt-reveal" role="banner">
      <div class="abt__hero-media">
        {%- if section.settings.hero_image != blank -%}
          {{
            section.settings.hero_image
            | image_url: width: 1600
            | image_tag:
              class: 'abt__hero-image',
              loading: 'eager',
              fetchpriority: 'high',
              widths: '480, 720, 960, 1200, 1600',
              sizes: '(max-width: 767px) 100vw, 480px',
              alt: section.settings.hero_image_alt
          }}
        {%- else -%}
          <div class="abt__hero-placeholder" aria-hidden="true"></div>
        {%- endif -%}
        <div class="abt__hero-overlay" aria-hidden="true"></div>
      </div>

      <div class="abt__hero-copy">
        {%- if section.settings.hero_heading != blank -%}
          <h1 class="abt__hero-heading">{{ section.settings.hero_heading }}</h1>
        {%- endif -%}
        {%- if section.settings.hero_subheading != blank -%}
          <p class="abt__hero-subheading">{{ section.settings.hero_subheading }}</p>
        {%- endif -%}
      </div>
    </header>

    <div class="abt__content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'story_quote' -%}
            <section class="abt-story abt-reveal" {{ block.shopify_attributes }}>
              {%- if block.settings.text != blank -%}
                <div class="abt-story__text rte">{{ block.settings.text }}</div>
              {%- endif -%}

              <div class="abt-story__media abt-reveal-soft">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 1200
                    | image_tag:
                      class: 'abt-story__image',
                      loading: 'lazy',
                      widths: '480, 720, 960, 1200',
                      sizes: '(max-width: 767px) 100vw, 480px',
                      alt: block.settings.image_alt
                  }}
                {%- else -%}
                  <div class="abt-story__placeholder" aria-hidden="true"></div>
                {%- endif -%}
              </div>
            </section>

          {%- when 'mission_story' -%}
            <section class="abt-mission abt-reveal" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <div class="abt-mission__heading">{{ block.settings.heading }}</div>
              {%- endif -%}

              {%- if block.settings.body_1 != blank -%}
                <div class="abt-mission__body rte">{{ block.settings.body_1 }}</div>
              {%- endif -%}

              {%- if block.settings.body_2 != blank -%}
                <div class="abt-mission__body rte">{{ block.settings.body_2 }}</div>
              {%- endif -%}

              <div class="abt-mission__media abt-reveal-soft">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 1400
                    | image_tag:
                      class: 'abt-mission__image',
                      loading: 'lazy',
                      widths: '480, 720, 960, 1200, 1400',
                      sizes: '(max-width: 767px) 100vw, 480px',
                      alt: block.settings.image_alt
                  }}
                {%- else -%}
                  <div class="abt-mission__placeholder" aria-hidden="true"></div>
                {%- endif -%}
              </div>
            </section>

          {%- when 'style_feature' -%}
            <section class="abt-style abt-reveal" {{ block.shopify_attributes }}>
              <div class="abt-style__hero">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 1400
                    | image_tag:
                      class: 'abt-style__image',
                      loading: 'lazy',
                      widths: '480, 720, 960, 1200, 1400',
                      sizes: '(max-width: 767px) 100vw, 480px',
                      alt: block.settings.image_alt
                  }}
                {%- else -%}
                  <div class="abt-style__placeholder" aria-hidden="true"></div>
                {%- endif -%}
                <div class="abt-style__overlay" aria-hidden="true"></div>
                {%- if block.settings.overlay_heading != blank -%}
                  <div class="abt-style__headline-wrap">
                    <h2 class="abt-style__headline">{{ block.settings.overlay_heading }}</h2>
                  </div>
                {%- endif -%}
              </div>

              <div class="abt-style__card abt-reveal-soft">
                {%- if block.settings.card_title != blank -%}
                  <h3 class="abt-style__card-title">{{ block.settings.card_title }}</h3>
                {%- endif -%}

                {%- if block.settings.card_text != blank -%}
                  <div class="abt-style__card-text rte">{{ block.settings.card_text }}</div>
                {%- endif -%}

                {%- if block.settings.button_label != blank -%}
                  <a class="abt-style__button" href="{{ block.settings.button_link | default: routes.collections_url }}">
                    <span>{{ block.settings.button_label }}</span>
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </a>
                {%- endif -%}
              </div>
            </section>
        {%- endcase -%}
      {%- endfor -%}

      <section class="abt-testimonials" aria-labelledby="abt-testimonials-title-{{ section.id }}">
        <div class="abt-testimonials__inner">
          {%- if section.settings.testimonials_eyebrow != blank -%}
            <p class="abt-testimonials__eyebrow abt-reveal">{{ section.settings.testimonials_eyebrow }}</p>
          {%- endif -%}

          {%- if section.settings.testimonials_heading != blank -%}
            <h2 id="abt-testimonials-title-{{ section.id }}" class="abt-testimonials__heading abt-reveal">
              {{ section.settings.testimonials_heading }}
            </h2>
          {%- endif -%}

          <div class="abt-testimonials__track abt-reveal" data-abt-track>
            {%- assign has_testimonials = false -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'testimonial' -%}
                {%- assign has_testimonials = true -%}
                <article class="abt-testimonials__card" data-abt-card {{ block.shopify_attributes }}>
                  {%- if block.settings.text != blank -%}
                    <div class="abt-testimonials__text rte">{{ block.settings.text }}</div>
                  {%- endif -%}

                  <div class="abt-testimonials__author">
                    <div class="abt-testimonials__avatar-wrap">
                      {%- if block.settings.avatar != blank -%}
                        {{
                          block.settings.avatar
                          | image_url: width: 160
                          | image_tag:
                            class: 'abt-testimonials__avatar',
                            loading: 'lazy',
                            widths: '80, 120, 160',
                            sizes: '56px',
                            alt: block.settings.name
                        }}
                      {%- else -%}
                        <div class="abt-testimonials__avatar-placeholder" aria-hidden="true">
                          {{ block.settings.name | default: 'A' | slice: 0 }}
                        </div>
                      {%- endif -%}
                    </div>

                    <div class="abt-testimonials__author-copy">
                      {%- if block.settings.name != blank -%}
                        <p class="abt-testimonials__name">{{ block.settings.name }}</p>
                      {%- endif -%}
                      {%- if block.settings.location != blank -%}
                        <p class="abt-testimonials__location">{{ block.settings.location }}</p>
                      {%- endif -%}
                    </div>
                  </div>
                </article>
              {%- endif -%}
            {%- endfor -%}

            {%- unless has_testimonials -%}
              <article class="abt-testimonials__card">
                <p class="abt-testimonials__empty">Add testimonial blocks in the Theme Editor.</p>
              </article>
            {%- endunless -%}
          </div>

          <div class="abt-testimonials__dots" role="tablist" aria-label="Testimonial pagination">
            {%- assign testimonial_count = 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'testimonial' -%}
                <button
                  class="abt-testimonials__dot{% if testimonial_count == 0 %} is-active{% endif %}"
                  type="button"
                  role="tab"
                  aria-selected="{% if testimonial_count == 0 %}true{% else %}false{% endif %}"
                  aria-label="Go to testimonial {{ testimonial_count | plus: 1 }}"
                  data-abt-dot
                  data-abt-index="{{ testimonial_count }}"
                ></button>
                {%- assign testimonial_count = testimonial_count | plus: 1 -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </section>
    </div>
  </div>
</section>

<style>
  #AboutTemplate-{{ section.id }} {
    padding-top: var(--abt-top);
    padding-bottom: var(--abt-bottom);
    background: var(--abt-bg);
    color: var(--abt-text);
  }

  #AboutTemplate-{{ section.id }} .abt__shell {
    width: 100%;
    max-width: 480px;
    margin-inline: auto;
    background: var(--abt-bg);
  }

  #AboutTemplate-{{ section.id }} .abt__content {
    display: grid;
    gap: 0;
  }

  #AboutTemplate-{{ section.id }} .abt__hero {
    position: relative;
    width: 100%;
  }

  #AboutTemplate-{{ section.id }} .abt__hero-media {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  #AboutTemplate-{{ section.id }} .abt__hero-image,
  #AboutTemplate-{{ section.id }} .abt__hero-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #AboutTemplate-{{ section.id }} .abt__hero-placeholder,
  #AboutTemplate-{{ section.id }} .abt-story__placeholder,
  #AboutTemplate-{{ section.id }} .abt-mission__placeholder,
  #AboutTemplate-{{ section.id }} .abt-style__placeholder {
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--abt-text) 10%, transparent), transparent),
      color-mix(in srgb, var(--abt-card-bg) 88%, var(--abt-text) 5%);
  }

  #AboutTemplate-{{ section.id }} .abt__hero-image {
    transform: scale(1.12);
    animation: abtHeroZoom-{{ section.id }} 1.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  #AboutTemplate-{{ section.id }} .abt__hero-overlay,
  #AboutTemplate-{{ section.id }} .abt-style__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--abt-hero-overlay));
  }

  #AboutTemplate-{{ section.id }} .abt__hero-copy {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px;
    text-align: center;
    color: var(--color-base-solid-button-labels, #ffffff);
  }

  #AboutTemplate-{{ section.id }} .abt__hero-heading,
  #AboutTemplate-{{ section.id }} .abt__hero-subheading {
    margin: 0;
    opacity: 0;
    transform: translateY(24px);
    animation: abtHeroText-{{ section.id }} 0.9s ease-out forwards;
  }

  #AboutTemplate-{{ section.id }} .abt__hero-heading {
    font-size: clamp(1.75rem, 6vw, 2.3rem);
    line-height: 1.15;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    animation-delay: 0.5s;
  }

  #AboutTemplate-{{ section.id }} .abt__hero-subheading {
    max-width: 30ch;
    margin-top: 16px;
    font-size: 0.95rem;
    line-height: 1.65;
    opacity: 0;
    animation-delay: 0.85s;
  }

  #AboutTemplate-{{ section.id }} .abt-story,
  #AboutTemplate-{{ section.id }} .abt-mission,
  #AboutTemplate-{{ section.id }} .abt-style,
  #AboutTemplate-{{ section.id }} .abt-testimonials {
    padding-inline: 20px;
  }

  #AboutTemplate-{{ section.id }} .abt-story {
    padding-top: 40px;
    padding-bottom: 40px;
  }

  #AboutTemplate-{{ section.id }} .abt-story__text {
    color: var(--abt-text);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.6;
    text-align: center;
  }

  #AboutTemplate-{{ section.id }} .abt-story__text p {
    margin: 0;
  }

  #AboutTemplate-{{ section.id }} .abt-story__media,
  #AboutTemplate-{{ section.id }} .abt-mission__media {
    margin-top: 40px;
    overflow: hidden;
    margin-inline: -20px;
  }

  #AboutTemplate-{{ section.id }} .abt-story__image,
  #AboutTemplate-{{ section.id }} .abt-mission__image {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
  }

  #AboutTemplate-{{ section.id }} .abt-story__placeholder,
  #AboutTemplate-{{ section.id }} .abt-mission__placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
  }

  #AboutTemplate-{{ section.id }} .abt-mission {
    padding-bottom: 40px;
  }

  #AboutTemplate-{{ section.id }} .abt-mission__heading {
    margin: 0;
    font-size: 1.375rem;
    line-height: 1.25;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  #AboutTemplate-{{ section.id }} .abt-mission__heading u {
    text-underline-offset: 0.12em;
  }

  #AboutTemplate-{{ section.id }} .abt-mission__body {
    margin-top: 20px;
    color: var(--abt-muted);
    font-size: 0.95rem;
    line-height: 1.72;
  }

  #AboutTemplate-{{ section.id }} .abt-mission__body p {
    margin: 0;
  }

  #AboutTemplate-{{ section.id }} .abt-style {
    padding-inline: 0;
  }

  #AboutTemplate-{{ section.id }} .abt-style__hero {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  #AboutTemplate-{{ section.id }} .abt-style__image,
  #AboutTemplate-{{ section.id }} .abt-style__placeholder {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  #AboutTemplate-{{ section.id }} .abt-style__image {
    transform: scale(1.12);
  }

  #AboutTemplate-{{ section.id }} .abt-style.is-visible .abt-style__image {
    animation: abtHeroZoom-{{ section.id }} 1.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  #AboutTemplate-{{ section.id }} .abt-style__overlay {
    background: rgba(0, 0, 0, var(--abt-style-overlay));
  }

  #AboutTemplate-{{ section.id }} .abt-style__headline-wrap {
    position: absolute;
    top: 24px;
    left: 20px;
    right: 20px;
    z-index: 1;
  }

  #AboutTemplate-{{ section.id }} .abt-style__headline {
    margin: 0;
    color: var(--color-base-solid-button-labels, #ffffff);
    font-size: 1.5rem;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  #AboutTemplate-{{ section.id }} .abt-style__card {
    margin: 0 20px;
    margin-top: -16px;
    position: relative;
    z-index: 1;
    background: var(--abt-card-bg);
    border: 1px solid var(--abt-border);
    border-radius: var(--abt-radius-lg);
    padding: 24px;
    box-shadow: var(--abt-shadow);
  }

  #AboutTemplate-{{ section.id }} .abt-style__card-title {
    margin: 0;
    font-size: 1.125rem;
    line-height: 1.3;
  }

  #AboutTemplate-{{ section.id }} .abt-style__card-text {
    margin-top: 12px;
    color: var(--abt-muted);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  #AboutTemplate-{{ section.id }} .abt-style__card-text p {
    margin: 0;
  }

  #AboutTemplate-{{ section.id }} .abt-style__button {
    margin-top: 20px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: 48px;
    padding: 0 28px;
    border-radius: var(--abt-button-radius);
    border: 2px solid var(--abt-text);
    background: var(--abt-text);
    color: var(--color-base-background-1, #ffffff);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8125rem;
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      color 180ms ease,
      border-color 180ms ease;
  }

  #AboutTemplate-{{ section.id }} .abt-style__button:hover {
    background: transparent;
    color: var(--abt-text);
  }

  #AboutTemplate-{{ section.id }} .abt-style__button:active {
    transform: scale(0.97);
  }

  #AboutTemplate-{{ section.id }} .abt-style__button svg {
    width: 15px;
    height: 15px;
    stroke: currentColor;
  }

  #AboutTemplate-{{ section.id }} .abt-testimonials {
    padding-top: 48px;
    padding-bottom: 48px;
    background: color-mix(in srgb, var(--abt-bg) 92%, var(--abt-text) 4%);
    overflow: hidden;
  }

  #AboutTemplate-{{ section.id }} .abt-testimonials__eyebrow {
    margin: 0;
    color: var(--abt-muted);
    font-size: 0.8125rem;
    line-height: 1.5;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
  }

  #AboutTemplate-{{ section.id }} .abt-testimonials__heading {
    margin: 8px 0 0;
    font-size: 1.5rem;
    line-height: 1.2;
    text-transform: uppercase;
  }

  #AboutTemplate-{{ section.id }} .abt-testimonials__track {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    margin-top: 32px;
    padding-bottom: 4px;
  }

  #AboutTemplate-{{ section.id }} .abt-testimonials__track::-webkit-scrollbar {
    display: none;
  }

  #AboutTemplate-{{ section.id }} .abt-testimonials__card {
    flex: 0 0 82%;
    min-height: 280px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    scroll-snap-align: center;
    background: var(--abt-card-bg);
    border: 1px solid var(--abt-border);
    border-radius: var(--abt-radius-xl);
    padding: 24px;
    box-shadow: 0 8px 24px color-mix(in srgb, var(--abt-text) 6%, transparent);
  }

  #AboutTemplate-{{ section.id }} .abt-testimonials__text {
    color: color-mix(in srgb, var(--abt-text) 88%, transparent);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  #AboutTemplate-{{ section.id }} .abt-testimonials__text p {
    margin: 0;
  }

  #AboutTemplate-{{ section.id }} .abt-testimonials__author {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 24px;
  }

  #AboutTemplate-{{ section.id }} .abt-testimonials__avatar,
  #AboutTemplate-{{ section.id }} .abt-testimonials__avatar-placeholder {
    width: 56px;
    height: 56px;
    border-radius: 999px;
    display: block;
    object-fit: cover;
  }

  #AboutTemplate-{{ section.id }} .abt-testimonials__avatar-placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--abt-text) 10%, var(--abt-card-bg));
    color: var(--abt-muted);
    font-weight: 600;
  }

  #AboutTemplate-{{ section.id }} .abt-testimonials__name,
  #AboutTemplate-{{ section.id }} .abt-testimonials__location,
  #AboutTemplate-{{ section.id }} .abt-testimonials__empty {
    margin: 0;
  }

  #AboutTemplate-{{ section.id }} .abt-testimonials__name {
    font-size: 0.95rem;
    line-height: 1.4;
    font-weight: 600;
  }

  #AboutTemplate-{{ section.id }} .abt-testimonials__location,
  #AboutTemplate-{{ section.id }} .abt-testimonials__empty {
    margin-top: 2px;
    color: var(--abt-muted);
    font-size: 0.8125rem;
    line-height: 1.5;
  }

  #AboutTemplate-{{ section.id }} .abt-testimonials__dots {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
  }

  #AboutTemplate-{{ section.id }} .abt-testimonials__dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    border: 0;
    padding: 0;
    background: color-mix(in srgb, var(--abt-text) 16%, transparent);
    transition:
      width 280ms cubic-bezier(0.22, 1, 0.36, 1),
      background-color 280ms ease;
    cursor: pointer;
  }

  #AboutTemplate-{{ section.id }} .abt-testimonials__dot.is-active {
    width: 28px;
    background: var(--abt-text);
  }

  #AboutTemplate-{{ section.id }} .abt-reveal,
  #AboutTemplate-{{ section.id }} .abt-reveal-soft {
    opacity: 0;
    transform: translateY(32px);
    transition:
      opacity 720ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 720ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  #AboutTemplate-{{ section.id }} .abt-reveal-soft {
    transform: translateY(24px);
    transition-duration: 620ms;
  }

  #AboutTemplate-{{ section.id }} .abt-reveal.is-visible,
  #AboutTemplate-{{ section.id }} .abt-reveal-soft.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes abtHeroZoom-{{ section.id }} {
    from { transform: scale(1.12); }
    to { transform: scale(1); }
  }

  @keyframes abtHeroText-{{ section.id }} {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  (function () {
    var root = document.getElementById('AboutTemplate-{{ section.id }}');
    if (!root || root.dataset.abtInit === 'true') return;
    root.dataset.abtInit = 'true';

    var revealItems = root.querySelectorAll('.abt-reveal, .abt-reveal-soft');
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.14, rootMargin: '0px 0px -8% 0px' });

      revealItems.forEach(function (item) { observer.observe(item); });
    } else {
      revealItems.forEach(function (item) { item.classList.add('is-visible'); });
    }

    var track = root.querySelector('[data-abt-track]');
    var dots = Array.prototype.slice.call(root.querySelectorAll('[data-abt-dot]'));
    if (!track || !dots.length) return;

    function setActive(index) {
      dots.forEach(function (dot, dotIndex) {
        var active = dotIndex === index;
        dot.classList.toggle('is-active', active);
        dot.setAttribute('aria-selected', active ? 'true' : 'false');
      });
    }

    function getIndexFromScroll() {
      var cards = track.querySelectorAll('[data-abt-card]');
      if (!cards.length) return 0;
      var cardWidth = cards[0].offsetWidth + 16;
      if (!cardWidth) return 0;
      return Math.max(0, Math.min(cards.length - 1, Math.round(track.scrollLeft / cardWidth)));
    }

    var rafId = null;
    track.addEventListener('scroll', function () {
      if (rafId) cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(function () {
        setActive(getIndexFromScroll());
      });
    }, { passive: true });

    dots.forEach(function (dot, index) {
      dot.addEventListener('click', function () {
        var cards = track.querySelectorAll('[data-abt-card]');
        var target = cards[index];
        if (!target) return;
        track.scrollTo({
          left: target.offsetLeft - track.offsetLeft,
          behavior: 'smooth'
        });
        setActive(index);
      });
    });
  })();
</script>

