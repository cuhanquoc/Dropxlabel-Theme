          "id": "avatar",
          "label": "Avatar Photo",
          "info": "Recommended: 80 × 80px (square). Displayed as circular."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Page",
      "blocks": [
        { "type": "value_item", "settings": { "number": "200", "suffix": "+", "label": "Curated Pieces" } },
        { "type": "value_item", "settings": { "number": "12", "suffix": "", "label": "Collections" } },
        { "type": "value_item", "settings": { "number": "5K", "suffix": "+", "label": "Happy Clients" } },
        { "type": "value_item", "settings": { "number": "4", "suffix": "", "label": "Years of Craft" } },
        { "type": "review_card", "settings": { "text": "The quality of the fabric is unlike anything I have found at this price point. Minimal, considered, and completely my style.", "name": "Linh N.", "location": "Hà Nội" } },
        { "type": "review_card", "settings": { "text": "Wearing Dropxlabel feels like wearing confidence. The linen coat fits perfectly and drapes beautifully.", "name": "Anh T.", "location": "TP. Hồ Chí Minh" } },
        { "type": "review_card", "settings": { "text": "Every piece I have ordered has exceeded expectations. The attention to detail is evident in every seam.", "name": "Mai P.", "location": "Đà Nẵng" } },
        { "type": "review_card", "settings": { "text": "Understated, sophisticated, timeless. Exactly what I was looking for. The silk edit is perfection.", "name": "Thanh H.", "location": "Hà Nội" } }
      ]
    }
  ]
}
