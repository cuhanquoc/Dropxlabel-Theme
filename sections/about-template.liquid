{% comment %} ABOUT TEMPLATE — CSS → src/input.css {% endcomment %}

{%- comment -%}
  ─────────────────────────────────────────
  ABOUT TEMPLATE SECTION
  Used in: templates/page.about.json
  ─────────────────────────────────────────
{%- endcomment -%}

{%- comment -%} Review data declared within the review loop below using pipe delimiters {%- endcomment -%}

<div id="about-page">

  <!-- ══════════════════════════════════════
       1. EDITORIAL INTRO
  ══════════════════════════════════════ -->
  <section class="pt-40 pb-20 px-6 md:px-10" style="background-color: var(--color-bg);">
    <div class="max-w-screen-xl mx-auto">

      <span class="at-eyebrow">{{ section.settings.eyebrow }}</span>
      <p class="at-quote" id="at-quote">
        {{ section.settings.quote_text }}
      </p>

    </div>
  </section>

  <!-- ══════════════════════════════════════
       2. PARALLAX HERO + FLOATING CARDS
  ══════════════════════════════════════ -->
  <div id="at-parallax-wrap">

    <!-- Parallax Background Image -->
    {% if section.settings.parallax_image != blank %}
      <img
        id="at-parallax-img"
        src="{{ section.settings.parallax_image | image_url: width: 1920 }}"
        alt="{{ section.settings.parallax_image.alt | default: 'About us hero' }}"
        loading="lazy"
        width="1920"
        height="1280"
      />
    {% else %}
      <div
        id="at-parallax-img"
        style="width:100%;height:100%;min-height:600px;background:#1a1a1a;display:block;"
        aria-hidden="true"
      ></div>
    {% endif %}

    <!-- Overlay -->
    <div id="at-parallax-overlay"></div>

    <!-- Hero Text (bottom-left) -->
    <div class="at-hero-text">
      <h2 class="at-hero-headline">
        {{ section.settings.hero_headline }}
      </h2>
    </div>

    <!-- Floating Cards (bottom-right) -->
    <div class="at-float-stack">

      <!-- Card 1 -->
      <div class="at-float-card" data-float-card>
        <p class="at-float-card-tag">Everyday Edit</p>
        <p class="at-float-card-title">Explore Edgy<br>Everyday Wear</p>
        <a href="{{ routes.collections_url }}" class="at-float-btn">
          Explore
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Card 2 -->
      <div class="at-float-card" data-float-card>
        <p class="at-float-card-tag">Signature Collection</p>
        <p class="at-float-card-title">The Tailored<br>Wardrobe Essentials</p>
        <a href="{{ routes.collections_url }}" class="at-float-btn">
          Shop Now
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

    </div>
    <!-- / Floating Cards -->

  </div>
  <!-- / Parallax Section -->

  <!-- ══════════════════════════════════════
       3. BRAND VALUES STRIP
  ══════════════════════════════════════ -->
  <div class="at-values-strip px-0" style="background-color: var(--color-bg);">
    {% for block in section.blocks %}
      {% if block.type == 'value_item' %}
        <div class="at-value-item" {{ block.shopify_attributes }}>
          <p class="at-value-number">{{ block.settings.number }}<span style="color: var(--color-accent);">{{ block.settings.suffix }}</span></p>
          <p class="at-value-label">{{ block.settings.label }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <!-- ══════════════════════════════════════
       4. CUSTOMER REVIEWS (Horizontal)
  ══════════════════════════════════════ -->
  <section class="py-24" style="background-color: var(--color-bg);">
    <div class="max-w-screen-xl mx-auto">

      <!-- Heading row -->
      <div class="flex justify-between items-end gap-8 px-6 md:px-10 mb-10">
        <h2 class="at-reviews-heading" id="at-reviews-head">
          Success Stories That Inspire —<br>
          <em style="font-weight: 400;">See What Real Customers Say</em>
        </h2>

        <!-- Scroll arrows -->
        <div class="hidden md:flex gap-3" style="flex-shrink: 0;">
          <button class="at-scroll-arrow" onclick="scrollReviews(-1)" aria-label="Previous reviews">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </button>
          <button class="at-scroll-arrow" onclick="scrollReviews(1)" aria-label="Next reviews">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>

      <!-- Horizontal review strip -->
      <div class="at-reviews-strip px-6 md:px-10" id="at-reviews-strip">

        {% for block in section.blocks %}
          {% if block.type == 'review_card' %}
            <article class="at-review-card" data-review-card {{ block.shopify_attributes }}>

              <!-- Stars -->
              <p class="at-review-stars" aria-label="{{ block.settings.stars }} stars">
                {% for i in (1..5) %}{% if i <= block.settings.stars %}★{% else %}☆{% endif %}{% endfor %}
              </p>

              <!-- Review text -->
              <blockquote class="at-review-text">"{{ block.settings.text }}"</blockquote>

              <!-- Author -->
              <div class="at-review-author">
                {% if block.settings.avatar != blank %}
                  <img
                    src="{{ block.settings.avatar | image_url: width: 80 }}"
                    alt="{{ block.settings.name }}"
                    class="at-review-avatar"
                    loading="lazy"
                    width="40"
                    height="40"
                  />
                {% else %}
                  <div class="at-review-avatar" style="background: var(--color-border); display: flex; align-items: center; justify-content: center; font-size: 1rem; color: var(--color-muted);">{{ block.settings.name | slice: 0 }}</div>
                {% endif %}
                <div>
                  <p class="at-review-name">{{ block.settings.name }}</p>
                  <p class="at-review-location">{{ block.settings.location }}</p>
                </div>
              </div>

            </article>
          {% endif %}
        {% endfor %}

      </div>
      <!-- / Review strip -->

    </div>
  </section>

</div>
<!-- / #about-page -->


{% schema %}
{
  "name": "About Page",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Editorial Intro"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "The Journey of Style"
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Quote Text",
      "default": "From the soft drape of a blouse to the structured silhouette of a tailored jacket, every element is curated to empower you — not define you."
    },
    {
      "type": "header",
      "content": "Parallax Hero"
    },
    {
      "type": "image_picker",
      "id": "parallax_image",
      "label": "Hero Image",
      "info": "Recommended: 1920×1280px"
    },
    {
      "type": "textarea",
      "id": "hero_headline",
      "label": "Hero Headline",
      "default": "Where Street Style<br>Meets High Fashion."
    },
    {
      "type": "header",
      "content": "Reviews Section"
    },
    {
      "type": "textarea",
      "id": "reviews_heading",
      "label": "Reviews Heading",
      "default": "Success Stories That Inspire —<br><em style=\"font-weight: 400;\">See What Real Customers Say</em>"
    }
  ],
  "blocks": [
    {
      "type": "value_item",
      "name": "Brand Value",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "200"
        },
        {
          "type": "text",
          "id": "suffix",
          "label": "Suffix (e.g. +)",
          "default": "+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Curated Pieces"
        }
      ]
    },
    {
      "type": "review_card",
      "name": "Customer Review",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "label": "Star Rating"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review Text",
          "default": "The quality of the fabric is unlike anything I have found at this price point."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer Name",
          "default": "Customer Name"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "City"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar Photo",
          "info": "Recommended: 80 × 80px (square). Displayed as circular."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Page",
      "blocks": [
        { "type": "value_item", "settings": { "number": "200", "suffix": "+", "label": "Curated Pieces" } },
        { "type": "value_item", "settings": { "number": "12", "suffix": "", "label": "Collections" } },
        { "type": "value_item", "settings": { "number": "5K", "suffix": "+", "label": "Happy Clients" } },
        { "type": "value_item", "settings": { "number": "4", "suffix": "", "label": "Years of Craft" } },
        { "type": "review_card", "settings": { "text": "The quality of the fabric is unlike anything I have found at this price point. Minimal, considered, and completely my style.", "name": "Linh N.", "location": "Hà Nội" } },
        { "type": "review_card", "settings": { "text": "Wearing Dropxlabel feels like wearing confidence. The linen coat fits perfectly and drapes beautifully.", "name": "Anh T.", "location": "TP. Hồ Chí Minh" } },
        { "type": "review_card", "settings": { "text": "Every piece I have ordered has exceeded expectations. The attention to detail is evident in every seam.", "name": "Mai P.", "location": "Đà Nẵng" } },
        { "type": "review_card", "settings": { "text": "Understated, sophisticated, timeless. Exactly what I was looking for. The silk edit is perfection.", "name": "Thanh H.", "location": "Hà Nội" } }
      ]
    }
  ]
}
{% endschema %}
