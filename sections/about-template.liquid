{%- liquid
  assign section_id = 'AboutTemplate-' | append: section.id
  assign section_bg = section.settings.background_color | default: 'var(--color-base-background-1, #ffffff)'
  assign card_bg = section.settings.card_background_color | default: 'var(--color-base-background-1, #ffffff)'
  assign muted_text = section.settings.muted_text_color | default: 'rgba(17, 17, 17, 0.68)'
  assign section_tint = 'color-mix(in srgb, ' | append: section_bg | append: ' 92%, var(--abt-text) 4%)'
  assign hero_overlay = section.settings.hero_overlay_opacity | divided_by: 100.0
  assign street_overlay = section.settings.street_overlay_opacity | divided_by: 100.0
-%}

<section
  id="{{ section_id }}"
  class="abt3"
  style="
    --abt-bg: {{ section_bg }};
    --abt-card-bg: {{ card_bg }};
    --abt-text: var(--color-base-text, var(--color-text, #111111));
    --abt-muted: {{ muted_text }};
    --abt-border: color-mix(in srgb, var(--abt-text) 12%, transparent);
    --abt-shadow: 0 12px 30px color-mix(in srgb, var(--abt-text) 6%, transparent);
    --abt-section-tint: {{ section_tint }};
    --abt-hero-overlay: {{ hero_overlay }};
    --abt-street-overlay: {{ street_overlay }};
    --abt-top: {{ section.settings.padding_top }}px;
    --abt-bottom: {{ section.settings.padding_bottom }}px;
    --abt-card-radius: {{ section.settings.card_radius }}px;
    --abt-button-radius: {{ section.settings.button_radius }}px;
    --abt-wave-height: 40px;
  "
>
  <div class="abt3__shell">
    <section class="abt3-hero">
      <div class="abt3-hero__media">
        <div class="abt3-hero__img-wrap abt3-anim--hero-zoom">
          {%- if section.settings.hero_image != blank -%}
            {{
              section.settings.hero_image
              | image_url: width: 1600
              | image_tag:
                class: 'abt3-hero__img',
                loading: 'eager',
                fetchpriority: 'high',
                widths: '480, 720, 960, 1200, 1600',
                sizes: '(max-width: 767px) 100vw, 480px',
                alt: section.settings.hero_heading
            }}
          {%- else -%}
            <div class="abt3__placeholder abt3-hero__placeholder" aria-hidden="true"></div>
          {%- endif -%}
        </div>
        <div class="abt3-hero__overlay abt3-anim--fade-in" aria-hidden="true"></div>
        <div class="abt3-hero__content">
          {%- if section.settings.hero_heading != blank -%}
            <h1 class="abt3-hero__heading abt3-anim--slide-up" style="animation-delay: 0.6s;">
              {{ section.settings.hero_heading }}
            </h1>
          {%- endif -%}
          {%- if section.settings.hero_subheading != blank -%}
            <div class="abt3-hero__subheading abt3-anim--slide-up" style="animation-delay: 1s;">
              {{ section.settings.hero_subheading }}
            </div>
          {%- endif -%}
        </div>
      </div>
    </section>

    <section class="abt3-brand" data-anim-section>
      <div class="abt3-brand__text abt3-scroll-anim" data-anim="fade-up">
        {%- if section.settings.brand_text != blank -%}
          <div class="abt3-brand__paragraph rte">{{ section.settings.brand_text }}</div>
        {%- endif -%}
      </div>
      <div class="abt3-brand__media abt3-scroll-anim" data-anim="scale-in" data-anim-delay="0.3">
        {%- if section.settings.brand_image != blank -%}
          {{
            section.settings.brand_image
            | image_url: width: 1600
            | image_tag:
              class: 'abt3-brand__img',
              loading: 'lazy',
              widths: '480, 720, 960, 1200, 1600',
              sizes: '(max-width: 767px) 100vw, 480px',
              alt: section.settings.brand_image_alt
          }}
        {%- else -%}
          <div class="abt3__placeholder abt3-brand__placeholder" aria-hidden="true"></div>
        {%- endif -%}
      </div>
    </section>

    <section class="abt3-mission" data-anim-section>
      {%- if section.settings.mission_heading != blank -%}
        <div class="abt3-mission__heading abt3-scroll-anim" data-anim="slide-left">
          {{ section.settings.mission_heading }}
        </div>
      {%- endif -%}

      {%- if section.settings.mission_text_1 != blank -%}
        <div class="abt3-mission__text rte abt3-scroll-anim" data-anim="fade-up" data-anim-delay="0.2">
          {{ section.settings.mission_text_1 }}
        </div>
      {%- endif -%}

      {%- if section.settings.mission_text_2 != blank -%}
        <div class="abt3-mission__text rte abt3-scroll-anim" data-anim="fade-up" data-anim-delay="0.4">
          {{ section.settings.mission_text_2 }}
        </div>
      {%- endif -%}

      <div class="abt3-mission__media abt3-scroll-anim" data-anim="zoom-reveal">
        {%- if section.settings.mission_image != blank -%}
          {{
            section.settings.mission_image
            | image_url: width: 1600
            | image_tag:
              class: 'abt3-mission__img',
              loading: 'lazy',
              widths: '480, 720, 960, 1200, 1600',
              sizes: '(max-width: 767px) 100vw, 480px',
              alt: section.settings.mission_image_alt
          }}
        {%- else -%}
          <div class="abt3__placeholder abt3-mission__placeholder" aria-hidden="true"></div>
        {%- endif -%}
      </div>
    </section>

    <section class="abt3-street" data-anim-section>
      <div class="abt3-street__media abt3-scroll-anim" data-anim="fade-in">
        <div class="abt3-street__img-wrap abt3-scroll-anim" data-anim="hero-zoom">
          {%- if section.settings.street_image != blank -%}
            {{
              section.settings.street_image
              | image_url: width: 1600
              | image_tag:
                class: 'abt3-street__img',
                loading: 'lazy',
                widths: '480, 720, 960, 1200, 1600',
                sizes: '(max-width: 767px) 100vw, 480px',
                alt: section.settings.street_image_alt
            }}
          {%- else -%}
            <div class="abt3__placeholder abt3-street__placeholder" aria-hidden="true"></div>
          {%- endif -%}
        </div>
        <div class="abt3-street__overlay" aria-hidden="true"></div>
        <div class="abt3-street__heading-wrap">
          {%- if section.settings.street_heading != blank -%}
            <h2 class="abt3-street__heading abt3-scroll-anim" data-anim="fade-up" data-anim-delay="0.4">
              {{ section.settings.street_heading }}
            </h2>
          {%- endif -%}
        </div>
      </div>

      <div class="abt3-street__card-wrap">
        <div class="abt3-street__card abt3-scroll-anim" data-anim="fade-up">
          {%- if section.settings.street_card_title != blank -%}
            <h3 class="abt3-street__card-title">{{ section.settings.street_card_title }}</h3>
          {%- endif -%}
          {%- if section.settings.street_card_text != blank -%}
            <div class="abt3-street__card-text rte">{{ section.settings.street_card_text }}</div>
          {%- endif -%}
          {%- if section.settings.street_cta_text != blank -%}
            <a
              href="{{ section.settings.street_cta_link | default: routes.collections_url }}"
              class="abt3-street__btn"
            >
              {{ section.settings.street_cta_text }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </section>

    <section class="abt3-testimonials" data-anim-section>
      <svg class="abt3-testimonials__wave" viewBox="0 0 375 40" fill="none" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0 40V20C62.5 0 125 0 187.5 20C250 40 312.5 40 375 20V40H0Z" fill="currentColor"></path>
      </svg>

      <div class="abt3-testimonials__header">
        {%- if section.settings.testimonials_subtitle != blank -%}
          <p class="abt3-testimonials__subtitle abt3-scroll-anim" data-anim="fade-up">
            {{ section.settings.testimonials_subtitle }}
          </p>
        {%- endif -%}
        {%- if section.settings.testimonials_heading != blank -%}
          <h2 class="abt3-testimonials__heading abt3-scroll-anim" data-anim="fade-up" data-anim-delay="0.15">
            {{ section.settings.testimonials_heading }}
          </h2>
        {%- endif -%}
      </div>

      <div class="abt3-testimonials__carousel abt3-scroll-anim" data-anim="slide-right" data-anim-delay="0.3" data-abt3-carousel>
        {%- assign testimonial_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'testimonial' -%}
            {%- assign testimonial_count = testimonial_count | plus: 1 -%}
            <article class="abt3-testimonials__card" data-abt3-card {{ block.shopify_attributes }}>
              {%- if block.settings.review_text != blank -%}
                <div class="abt3-testimonials__review rte">{{ block.settings.review_text }}</div>
              {%- endif -%}
              <div class="abt3-testimonials__author">
                {%- if block.settings.avatar != blank -%}
                  {{
                    block.settings.avatar
                    | image_url: width: 112
                    | image_tag:
                      class: 'abt3-testimonials__avatar',
                      loading: 'lazy',
                      widths: '56, 80, 112',
                      sizes: '56px',
                      alt: block.settings.name
                  }}
                {%- else -%}
                  <div class="abt3-testimonials__avatar-placeholder" aria-hidden="true">
                    {{ block.settings.name | default: 'A' | slice: 0 }}
                  </div>
                {%- endif -%}
                <div>
                  {%- if block.settings.name != blank -%}
                    <p class="abt3-testimonials__name">{{ block.settings.name }}</p>
                  {%- endif -%}
                  {%- if block.settings.location != blank -%}
                    <p class="abt3-testimonials__location">{{ block.settings.location }}</p>
                  {%- endif -%}
                </div>
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}

        {%- if testimonial_count == 0 -%}
          <article class="abt3-testimonials__card">
            <p class="abt3-testimonials__empty">Add testimonial blocks in the Theme Editor.</p>
          </article>
        {%- endif -%}
      </div>

      {%- if testimonial_count > 0 -%}
        <div class="abt3-testimonials__dots" data-abt3-dots>
          {%- assign dot_index = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'testimonial' -%}
              <button
                class="abt3-testimonials__dot{% if dot_index == 0 %} is-active{% endif %}"
                type="button"
                aria-label="Go to testimonial {{ dot_index | plus: 1 }}"
                aria-selected="{% if dot_index == 0 %}true{% else %}false{% endif %}"
                data-abt3-dot
                data-index="{{ dot_index }}"
              ></button>
              {%- assign dot_index = dot_index | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </section>
  </div>
</section>

<style>
  #{{ section_id }} {
    padding-top: var(--abt-top);
    padding-bottom: var(--abt-bottom);
    background: var(--abt-bg);
    color: var(--abt-text);
  }

  #{{ section_id }} .abt3__shell {
    width: 100%;
    max-width: 480px;
    margin-inline: auto;
    background: var(--abt-bg);
    overflow: clip;
  }

  #{{ section_id }} .abt3__placeholder {
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--abt-text) 8%, transparent), transparent),
      color-mix(in srgb, var(--abt-card-bg) 88%, var(--abt-text) 6%);
  }

  #{{ section_id }} .abt3-hero__media,
  #{{ section_id }} .abt3-street__media {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  #{{ section_id }} .abt3-hero__img-wrap,
  #{{ section_id }} .abt3-street__img-wrap {
    width: 100%;
    height: 100%;
  }

  #{{ section_id }} .abt3-hero__img,
  #{{ section_id }} .abt3-street__img,
  #{{ section_id }} .abt3-brand__img,
  #{{ section_id }} .abt3-mission__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #{{ section_id }} .abt3-hero__placeholder,
  #{{ section_id }} .abt3-street__placeholder {
    width: 100%;
    height: 100%;
  }

  #{{ section_id }} .abt3-hero__overlay,
  #{{ section_id }} .abt3-street__overlay {
    position: absolute;
    inset: 0;
  }

  #{{ section_id }} .abt3-hero__overlay {
    background: rgba(0, 0, 0, var(--abt-hero-overlay));
  }

  #{{ section_id }} .abt3-street__overlay {
    background: rgba(0, 0, 0, var(--abt-street-overlay));
  }

  #{{ section_id }} .abt3-hero__content {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0 24px;
    text-align: center;
    color: var(--color-base-solid-button-labels, #ffffff);
  }

  #{{ section_id }} .abt3-hero__heading {
    margin: 0;
    color: inherit;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: clamp(1.75rem, 6vw, 2.3rem);
    line-height: 1.15;
  }

  #{{ section_id }} .abt3-hero__subheading {
    margin-top: 16px;
    max-width: 32ch;
    color: color-mix(in srgb, var(--color-base-solid-button-labels, #ffffff) 85%, transparent);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  #{{ section_id }} .abt3-hero__subheading p {
    margin: 0;
  }

  #{{ section_id }} .abt3-brand {
    padding: 40px 0;
  }

  #{{ section_id }} .abt3-brand__text,
  #{{ section_id }} .abt3-mission,
  #{{ section_id }} .abt3-testimonials__header,
  #{{ section_id }} .abt3-testimonials__dots {
    padding-inline: 20px;
  }

  #{{ section_id }} .abt3-brand__paragraph {
    text-align: center;
    color: var(--abt-text);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.6;
  }

  #{{ section_id }} .abt3-brand__paragraph p,
  #{{ section_id }} .abt3-mission__text p,
  #{{ section_id }} .abt3-street__card-text p,
  #{{ section_id }} .abt3-testimonials__review p {
    margin: 0;
  }

  #{{ section_id }} .abt3-brand__media {
    margin-top: 40px;
    width: 100%;
    overflow: hidden;
  }

  #{{ section_id }} .abt3-brand__img,
  #{{ section_id }} .abt3-brand__placeholder,
  #{{ section_id }} .abt3-mission__img,
  #{{ section_id }} .abt3-mission__placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
  }

  #{{ section_id }} .abt3-mission {
    padding-bottom: 40px;
  }

  #{{ section_id }} .abt3-mission__heading {
    margin: 0;
    color: var(--abt-text);
    text-transform: uppercase;
    font-size: 1.375rem;
    line-height: 1.25;
    letter-spacing: 0.03em;
  }

  #{{ section_id }} .abt3-mission__heading em,
  #{{ section_id }} .abt3-mission__heading u,
  #{{ section_id }} .abt3-mission__heading span {
    text-underline-offset: 0.12em;
  }

  #{{ section_id }} .abt3-mission__text {
    margin-top: 20px;
    color: var(--abt-muted);
    font-size: 0.95rem;
    line-height: 1.72;
  }

  #{{ section_id }} .abt3-mission__media {
    margin-top: 32px;
    margin-inline: -20px;
    overflow: hidden;
  }

  #{{ section_id }} .abt3-street__heading-wrap {
    position: absolute;
    top: 24px;
    left: 20px;
    right: 20px;
    z-index: 1;
  }

  #{{ section_id }} .abt3-street__heading {
    margin: 0;
    color: var(--color-base-solid-button-labels, #ffffff);
    text-transform: uppercase;
    font-size: 1.5rem;
    line-height: 1.2;
    letter-spacing: 0.03em;
  }

  #{{ section_id }} .abt3-street__card-wrap {
    background: var(--abt-bg);
    padding: 24px 20px;
  }

  #{{ section_id }} .abt3-street__card {
    background: var(--abt-card-bg);
    border-radius: var(--abt-card-radius);
    border: 1px solid var(--abt-border);
    padding: 24px;
    box-shadow: 0 6px 18px color-mix(in srgb, var(--abt-text) 6%, transparent);
  }

  #{{ section_id }} .abt3-street__card-title {
    margin: 0;
    color: var(--abt-text);
    font-size: 1.125rem;
    line-height: 1.3;
  }

  #{{ section_id }} .abt3-street__card-text {
    margin-top: 12px;
    color: var(--abt-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  #{{ section_id }} .abt3-street__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    margin-top: 20px;
    padding: 0 32px;
    border-radius: var(--abt-button-radius);
    border: 2px solid var(--abt-text);
    background: var(--abt-text);
    color: var(--color-base-background-1, #ffffff);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.8125rem;
    line-height: 1;
    transition:
      background-color 200ms ease,
      color 200ms ease,
      transform 160ms ease;
  }

  #{{ section_id }} .abt3-street__btn:hover {
    background: transparent;
    color: var(--abt-text);
  }

  #{{ section_id }} .abt3-street__btn:active {
    transform: scale(0.97);
  }

  #{{ section_id }} .abt3-testimonials {
    position: relative;
    width: 100%;
    padding: 48px 0;
    background: var(--abt-section-tint);
    color: var(--abt-section-tint);
  }

  #{{ section_id }} .abt3-testimonials__wave {
    position: absolute;
    top: calc(var(--abt-wave-height) * -1 + 1px);
    left: 0;
    width: 100%;
    height: var(--abt-wave-height);
    color: var(--abt-section-tint);
  }

  #{{ section_id }} .abt3-testimonials__subtitle,
  #{{ section_id }} .abt3-testimonials__heading {
    margin: 0;
    color: var(--abt-text);
  }

  #{{ section_id }} .abt3-testimonials__subtitle {
    color: var(--abt-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.8125rem;
    font-weight: 600;
  }

  #{{ section_id }} .abt3-testimonials__heading {
    margin-top: 8px;
    text-transform: uppercase;
    font-size: 1.5rem;
    line-height: 1.2;
  }

  #{{ section_id }} .abt3-testimonials__carousel {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    margin-top: 32px;
    padding: 0 20px 16px;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  #{{ section_id }} .abt3-testimonials__carousel::-webkit-scrollbar {
    display: none;
  }

  #{{ section_id }} .abt3-testimonials__card {
    flex: 0 0 82%;
    min-height: 280px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    scroll-snap-align: center;
    background: var(--abt-card-bg);
    border-radius: var(--abt-card-radius);
    border: 1px solid var(--abt-border);
    padding: 24px;
    box-shadow: var(--abt-shadow);
    color: var(--abt-text);
  }

  #{{ section_id }} .abt3-testimonials__review {
    color: color-mix(in srgb, var(--abt-text) 88%, transparent);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  #{{ section_id }} .abt3-testimonials__author {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 24px;
  }

  #{{ section_id }} .abt3-testimonials__avatar,
  #{{ section_id }} .abt3-testimonials__avatar-placeholder {
    width: 56px;
    height: 56px;
    display: block;
    border-radius: 999px;
    object-fit: cover;
    flex: 0 0 auto;
  }

  #{{ section_id }} .abt3-testimonials__avatar-placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--abt-text) 10%, var(--abt-card-bg));
    color: var(--abt-muted);
    font-weight: 600;
  }

  #{{ section_id }} .abt3-testimonials__name,
  #{{ section_id }} .abt3-testimonials__location,
  #{{ section_id }} .abt3-testimonials__empty {
    margin: 0;
  }

  #{{ section_id }} .abt3-testimonials__name {
    color: var(--abt-text);
    font-size: 0.95rem;
    font-weight: 600;
  }

  #{{ section_id }} .abt3-testimonials__location,
  #{{ section_id }} .abt3-testimonials__empty {
    margin-top: 2px;
    color: var(--abt-muted);
    font-size: 0.8125rem;
    line-height: 1.5;
  }

  #{{ section_id }} .abt3-testimonials__dots {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
  }

  #{{ section_id }} .abt3-testimonials__dot {
    width: 10px;
    height: 10px;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: color-mix(in srgb, var(--abt-text) 16%, transparent);
    transition:
      width 350ms cubic-bezier(0.34, 1.56, 0.64, 1),
      background-color 300ms ease;
    cursor: pointer;
  }

  #{{ section_id }} .abt3-testimonials__dot.is-active {
    width: 28px;
    background: var(--abt-text);
  }

  #{{ section_id }} .abt3-anim--hero-zoom {
    animation: abt3HeroZoom-{{ section.id }} 1.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  #{{ section_id }} .abt3-anim--fade-in {
    opacity: 0;
    animation: abt3FadeIn-{{ section.id }} 1.2s ease-out 0.3s forwards;
  }

  #{{ section_id }} .abt3-anim--slide-up {
    opacity: 0;
    animation: abt3SlideUp-{{ section.id }} 0.9s ease-out forwards;
  }

  #{{ section_id }} .abt3-scroll-anim {
    opacity: 0;
    will-change: transform, opacity;
  }

  #{{ section_id }} .abt3-scroll-anim.abt3-anim--visible[data-anim='fade-up'] {
    animation: abt3FadeUp-{{ section.id }} 0.8s ease-out forwards;
  }

  #{{ section_id }} .abt3-scroll-anim.abt3-anim--visible[data-anim='scale-in'] {
    animation: abt3ScaleIn-{{ section.id }} 1s ease-out forwards;
  }

  #{{ section_id }} .abt3-scroll-anim.abt3-anim--visible[data-anim='slide-left'] {
    animation: abt3SlideLeft-{{ section.id }} 0.7s ease-out forwards;
  }

  #{{ section_id }} .abt3-scroll-anim.abt3-anim--visible[data-anim='zoom-reveal'] {
    animation: abt3ZoomReveal-{{ section.id }} 0.9s ease-out forwards;
  }

  #{{ section_id }} .abt3-scroll-anim.abt3-anim--visible[data-anim='fade-in'] {
    animation: abt3FadeIn-{{ section.id }} 0.8s ease-out forwards;
  }

  #{{ section_id }} .abt3-scroll-anim.abt3-anim--visible[data-anim='hero-zoom'] {
    animation: abt3HeroZoom-{{ section.id }} 1.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    opacity: 1;
  }

  #{{ section_id }} .abt3-scroll-anim.abt3-anim--visible[data-anim='slide-right'] {
    animation: abt3SlideRight-{{ section.id }} 0.8s ease-out forwards;
  }

  @keyframes abt3HeroZoom-{{ section.id }} {
    from { transform: scale(1.15); }
    to { transform: scale(1); }
  }

  @keyframes abt3FadeIn-{{ section.id }} {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes abt3SlideUp-{{ section.id }} {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes abt3FadeUp-{{ section.id }} {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes abt3ScaleIn-{{ section.id }} {
    from { opacity: 0; transform: scale(1.05); }
    to { opacity: 1; transform: scale(1); }
  }

  @keyframes abt3SlideLeft-{{ section.id }} {
    from { opacity: 0; transform: translateX(-30px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes abt3ZoomReveal-{{ section.id }} {
    from { opacity: 0; transform: translateY(50px) scale(1.1); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes abt3SlideRight-{{ section.id }} {
    from { opacity: 0; transform: translateX(60px); }
    to { opacity: 1; transform: translateX(0); }
  }
</style>

<script>
  (function() {
    var root = document.getElementById('{{ section_id }}');
    if (!root || root.dataset.abt3Init === 'true') return;
    root.dataset.abt3Init = 'true';

    var animElements = root.querySelectorAll('.abt3-scroll-anim');
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            var el = entry.target;
            var delay = el.getAttribute('data-anim-delay') || '0';
            el.style.animationDelay = delay + 's';
            el.classList.add('abt3-anim--visible');
            observer.unobserve(el);
          }
        });
      }, { threshold: 0.15, rootMargin: '-60px 0px' });

      animElements.forEach(function(el) {
        observer.observe(el);
      });
    } else {
      animElements.forEach(function(el) {
        el.classList.add('abt3-anim--visible');
      });
    }

    var carousel = root.querySelector('[data-abt3-carousel]');
    var dots = Array.prototype.slice.call(root.querySelectorAll('[data-abt3-dot]'));
    if (!carousel || !dots.length) return;

    var activeIndex = 0;

    function updateDots(nextIndex) {
      if (nextIndex === activeIndex) return;
      dots.forEach(function(dot, index) {
        var isActive = index === nextIndex;
        dot.classList.toggle('is-active', isActive);
        dot.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      activeIndex = nextIndex;
    }

    carousel.addEventListener('scroll', function() {
      var cardWidth = carousel.offsetWidth * 0.82;
      var nextIndex = Math.round(carousel.scrollLeft / (cardWidth + 16));
      if (nextIndex >= 0 && nextIndex < dots.length) {
        updateDots(nextIndex);
      }
    }, { passive: true });

    dots.forEach(function(dot, index) {
      dot.addEventListener('click', function() {
        var cards = root.querySelectorAll('[data-abt3-card]');
        var target = cards[index];
        if (!target) return;
        carousel.scrollTo({
          left: target.offsetLeft - carousel.offsetLeft,
          behavior: 'smooth'
        });
        updateDots(index);
      });
    });
  })();
</script>

