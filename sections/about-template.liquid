<script>
  /* ─────────────────────────────────────────────────────
     ABOUT PAGE — GSAP Animations
     1. Parallax on scroll (background image slower movement)
     2. Floating cards stagger entrance
     3. Editorial quote + review heading fade-up
     4. Mouse-drag for review strip
  ───────────────────────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', function () {

    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

    gsap.registerPlugin(ScrollTrigger);

    /* ── 1. Parallax: image moves at 40% scroll speed ── */
    gsap.to('#at-parallax-img', {
      scrollTrigger: {
        trigger: '#at-parallax-wrap',
        start:  'top bottom',
        end:    'bottom top',
        scrub:  1.5,        /* smooth lag */
      },
      yPercent: 18,         /* image travels 18% vertically while section scrolls 100% */
      ease: 'none',
    });

    /* ── 2. Floating cards stagger in ── */
    gsap.to('[data-float-card]', {
      scrollTrigger: {
        trigger: '#at-parallax-wrap',
        start:   'top 70%',
        once:    true,
      },
      opacity:  1,
      y:        0,
      duration: 1.2,
      ease:     'power4.out',
      stagger:  0.2,
    });

    /* ── 3. Editorial quote fade up ── */
    gsap.from('#at-quote', {
      scrollTrigger: { trigger: '#at-quote', start: 'top 80%', once: true },
      opacity: 0, y: 40, duration: 1.1, ease: 'power3.out',
    });

    /* ── 4. Reviews heading + cards ── */
    gsap.from('#at-reviews-head', {
      scrollTrigger: { trigger: '#at-reviews-head', start: 'top 82%', once: true },
      opacity: 0, x: -30, duration: 1, ease: 'power3.out',
    });

    gsap.from('[data-review-card]', {
      scrollTrigger: { trigger: '#at-reviews-strip', start: 'top 85%', once: true },
      opacity: 0, y: 32, duration: 0.8, ease: 'power3.out', stagger: 0.15,
    });

  });

  /* ── Arrow scroll for review strip ── */
  function scrollReviews(dir) {
    const strip = document.getElementById('at-reviews-strip');
    strip.scrollBy({ left: dir * 374, behavior: 'smooth' });
  }

  /* ── Mouse drag on review strip ── */
  (function () {
    const strip = document.getElementById('at-reviews-strip');
    let   isDown = false, startX, scrollLeft;

    strip.addEventListener('mousedown',  e => { isDown = true; startX = e.pageX - strip.offsetLeft; scrollLeft = strip.scrollLeft; strip.style.cursor = 'grabbing'; });
    strip.addEventListener('mouseleave', ()  => { isDown = false; strip.style.cursor = 'grab'; });
    strip.addEventListener('mouseup',    ()  => { isDown = false; strip.style.cursor = 'grab'; });
    strip.addEventListener('mousemove',  e => {
      if (!isDown) return;
      e.preventDefault();
      const x    = e.pageX - strip.offsetLeft;
      const walk = (x - startX) * 1.5;
      strip.scrollLeft = scrollLeft - walk;
    });
  }());
</script>
