<style>
  /* ─────────────────────────────────────────
     ABOUT TEMPLATE — Editorial Magazine Style
  ───────────────────────────────────────── */

  /* Giant editorial quote */
  .at-quote {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4.5vw, 3.5rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-text);
    text-align: center;
    max-width: 880px;
    margin: 0 auto;
  }

  /* Eyebrow */
  .at-eyebrow {
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-align: center;
    margin-bottom: 1.75rem;
    display: block;
  }

  /* Parallax container */
  #at-parallax-wrap {
    width: 100%;
    position: relative;
    height: 80vh;
    overflow: hidden;
    margin-top: 5rem;
  }

  #at-parallax-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transform: scale(1.15); /* GSAP parallax headroom */
    will-change: transform;
  }

  /* Dark gradient overlay on parallax */
  #at-parallax-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(10,10,10,0.62) 0%,
      rgba(10,10,10,0.2) 50%,
      transparent 100%
    );
  }

  /* Hero text on parallax */
  .at-hero-text {
    position: absolute;
    bottom: 3rem;
    left: 3rem;
    right: 3rem;
  }

  @media (min-width: 768px) {
    .at-hero-text { left: 4rem; right: auto; max-width: 600px; }
  }

  .at-hero-headline {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 3.5rem);
    font-weight: 600;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  /* Floating Cards stack */
  .at-float-stack {
    position: absolute;
    bottom: 2.5rem;
    right: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: clamp(220px, 28vw, 320px);
  }

  @media (max-width: 640px) {
    .at-float-stack { display: none; }
  }

  .at-float-card {
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 32px;
    padding: 1.5rem;
    box-shadow: 0 20px 60px rgba(0,0,0,0.14);
    opacity: 0;           /* GSAP animates in */
    transform: translateY(50px);
    will-change: transform, opacity;
  }

  .at-float-card-tag {
    font-family: var(--font-body);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .at-float-card-title {
    font-family: var(--font-heading);
    font-size: clamp(0.9rem, 1.5vw, 1.15rem);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.25;
    margin-bottom: 1rem;
  }

  .at-float-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    padding: 0.45rem 1.1rem;
    transition: background-color 250ms ease, border-color 250ms ease, color 250ms ease;
  }

  .at-float-btn:hover {
    background-color: var(--color-text);
    border-color: var(--color-text);
    color: var(--color-bg);
    opacity: 1;
  }

  /* ── Brand values strip ── */
  .at-values-strip {
    display: flex;
    gap: 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .at-value-item {
    flex: 1;
    padding: 2rem 1.5rem;
    text-align: center;
    border-right: 1px solid var(--color-border);
  }

  .at-value-item:last-child { border-right: none; }

  .at-value-number {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .at-value-label {
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-top: 0.4rem;
  }

  /* ── Reviews horizontal scroll ── */
  .at-reviews-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.3rem, 3vw, 2.2rem);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.15;
    letter-spacing: -0.01em;
    max-width: 580px;
  }

  .at-reviews-strip {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    padding-bottom: 2rem;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .at-reviews-strip::-webkit-scrollbar { display: none; }

  .at-review-card {
    background: #f9f9f7;
    border-radius: 24px;
    padding: 2rem;
    width: 350px;
    flex-shrink: 0;
    scroll-snap-align: center;
    border: 1px solid var(--color-border);
  }

  .at-review-stars {
    color: var(--color-accent);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .at-review-text {
    font-family: var(--font-body);
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: 1.5rem;
    font-style: italic;
  }

  .at-review-author {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .at-review-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    background-color: var(--color-border);
    flex-shrink: 0;
  }

  .at-review-name {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .at-review-location {
    font-family: var(--font-body);
    font-size: 0.65rem;
    color: var(--color-muted);
    letter-spacing: 0.06em;
  }

  /* Drag cursor on reviews */
  .at-reviews-strip {
    cursor: grab;
  }
  .at-reviews-strip:active {
    cursor: grabbing;
  }

  /* Review scroll arrows */
  .at-scroll-arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    cursor: pointer;
    color: var(--color-text);
    transition: background-color 250ms ease, color 250ms ease, border-color 250ms ease;
    flex-shrink: 0;
  }

  .at-scroll-arrow:hover {
    background-color: var(--color-text);
    border-color: var(--color-text);
    color: var(--color-bg);
  }

  /* ─── Mobile Responsive ─── */
  @media (max-width: 767px) {
    #at-parallax-wrap {
      height: 60vh;
    }
    .at-hero-text {
      bottom: 2rem;
      left: 1.5rem;
      right: 1.5rem;
    }
    .at-hero-headline {
      font-size: clamp(1.5rem, 6vw, 2rem);
    }
    .at-values-strip {
      display: grid !important;
      grid-template-columns: 1fr 1fr;
    }
    .at-value-item {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }
    .at-value-item:nth-child(odd) {
      border-right: 1px solid var(--color-border);
    }
    .at-value-item:nth-child(n+3) {
      border-bottom: none;
    }
    .at-review-card {
      width: 280px;
      padding: 1.5rem;
    }
    .at-quote {
      font-size: clamp(1.3rem, 5vw, 2rem);
    }
  }
</style>

{%- comment -%}
  ─────────────────────────────────────────
  ABOUT TEMPLATE SECTION
  Used in: templates/page.about.json
  ─────────────────────────────────────────
{%- endcomment -%}

{%- comment -%} Review data declared within the review loop below using pipe delimiters {%- endcomment -%}

<div id="about-page">

  <!-- ══════════════════════════════════════
       1. EDITORIAL INTRO
  ══════════════════════════════════════ -->
  <section class="pt-40 pb-20 px-6 md:px-10" style="background-color: var(--color-bg);">
    <div class="max-w-screen-xl mx-auto">

      <span class="at-eyebrow">{{ section.settings.eyebrow }}</span>
      <p class="at-quote" id="at-quote">
        {{ section.settings.quote_text }}
      </p>

    </div>
  </section>

  <!-- ══════════════════════════════════════
       2. PARALLAX HERO + FLOATING CARDS
  ══════════════════════════════════════ -->
  <div id="at-parallax-wrap">

    <!-- Parallax Background Image -->
    {% if section.settings.parallax_image != blank %}
      <img
        id="at-parallax-img"
        src="{{ section.settings.parallax_image | image_url: width: 1920 }}"
        alt="{{ section.settings.parallax_image.alt | default: 'About us hero' }}"
        loading="lazy"
        width="1920"
        height="1280"
      />
    {% else %}
      <img
        id="at-parallax-img"
        src="https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=1920&q=85&auto=format&fit=crop"
        alt="Dropxlabel — where street style meets high fashion"
        loading="lazy"
        width="1920"
        height="1280"
      />
    {% endif %}

    <!-- Overlay -->
    <div id="at-parallax-overlay"></div>

    <!-- Hero Text (bottom-left) -->
    <div class="at-hero-text">
      <h2 class="at-hero-headline">
        {{ section.settings.hero_headline }}
      </h2>
    </div>

    <!-- Floating Cards (bottom-right) -->
    <div class="at-float-stack">

      <!-- Card 1 -->
      <div class="at-float-card" data-float-card>
        <p class="at-float-card-tag">Everyday Edit</p>
        <p class="at-float-card-title">Explore Edgy<br>Everyday Wear</p>
        <a href="{{ routes.collections_url }}" class="at-float-btn">
          Explore
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Card 2 -->
      <div class="at-float-card" data-float-card>
        <p class="at-float-card-tag">Signature Collection</p>
        <p class="at-float-card-title">The Tailored<br>Wardrobe Essentials</p>
        <a href="{{ routes.collections_url }}" class="at-float-btn">
          Shop Now
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

    </div>
    <!-- / Floating Cards -->

  </div>
  <!-- / Parallax Section -->

  <!-- ══════════════════════════════════════
       3. BRAND VALUES STRIP
  ══════════════════════════════════════ -->
  <div class="at-values-strip px-0" style="background-color: var(--color-bg);">
    {% for block in section.blocks %}
      {% if block.type == 'value_item' %}
        <div class="at-value-item" {{ block.shopify_attributes }}>
          <p class="at-value-number">{{ block.settings.number }}<span style="color: var(--color-accent);">{{ block.settings.suffix }}</span></p>
          <p class="at-value-label">{{ block.settings.label }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <!-- ══════════════════════════════════════
       4. CUSTOMER REVIEWS (Horizontal)
  ══════════════════════════════════════ -->
  <section class="py-24" style="background-color: var(--color-bg);">
    <div class="max-w-screen-xl mx-auto">

      <!-- Heading row -->
      <div class="flex justify-between items-end gap-8 px-6 md:px-10 mb-10">
        <h2 class="at-reviews-heading" id="at-reviews-head">
          Success Stories That Inspire —<br>
          <em style="font-weight: 400;">See What Real Customers Say</em>
        </h2>

        <!-- Scroll arrows -->
        <div class="hidden md:flex gap-3" style="flex-shrink: 0;">
          <button class="at-scroll-arrow" onclick="scrollReviews(-1)" aria-label="Previous reviews">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </button>
          <button class="at-scroll-arrow" onclick="scrollReviews(1)" aria-label="Next reviews">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>

      <!-- Horizontal review strip -->
      <div class="at-reviews-strip px-6 md:px-10" id="at-reviews-strip">

        {% for block in section.blocks %}
          {% if block.type == 'review_card' %}
            <article class="at-review-card" data-review-card {{ block.shopify_attributes }}>

              <!-- Stars -->
              <p class="at-review-stars" aria-label="{{ block.settings.stars }} stars">
                {% for i in (1..5) %}{% if i <= block.settings.stars %}★{% else %}☆{% endif %}{% endfor %}
              </p>

              <!-- Review text -->
              <blockquote class="at-review-text">"{{ block.settings.text }}"</blockquote>

              <!-- Author -->
              <div class="at-review-author">
                {% if block.settings.avatar != blank %}
                  <img
                    src="{{ block.settings.avatar | image_url: width: 80 }}"
                    alt="{{ block.settings.name }}"
                    class="at-review-avatar"
                    loading="lazy"
                    width="40"
                    height="40"
                  />
                {% else %}
                  <div class="at-review-avatar" style="background: var(--color-border); display: flex; align-items: center; justify-content: center; font-size: 1rem; color: var(--color-muted);">{{ block.settings.name | slice: 0 }}</div>
                {% endif %}
                <div>
                  <p class="at-review-name">{{ block.settings.name }}</p>
                  <p class="at-review-location">{{ block.settings.location }}</p>
                </div>
              </div>

            </article>
          {% endif %}
        {% endfor %}

      </div>
      <!-- / Review strip -->

    </div>
  </section>

</div>
<!-- / #about-page -->


{% schema %}
{
  "name": "About Page",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Editorial Intro"
    },
    {
      "type": "text",
      "id": "eyebrow",
