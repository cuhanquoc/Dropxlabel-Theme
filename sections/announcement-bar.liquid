{% comment %}
  ─────────────────────────────────────────
  ANNOUNCEMENT BAR — Top Banner
  Block-based: add "Message" blocks in Theme Editor
  Fallback: uses settings.text / settings.link when no blocks exist
  CSS → src/input.css
  ─────────────────────────────────────────
{% endcomment %}

{% if section.settings.show_bar and request.page_type != 'index' %}
  <div
    class="announcement-bar"
    data-animation="{{ section.settings.animation }}"
    style="
      background-color: {{ section.settings.bg_color }};
      color: {{ section.settings.text_color }};
      font-size: {{ section.settings.font_size | default: 11 }}px;
      padding-top: {{ section.settings.padding | default: 10 }}px;
      padding-bottom: {{ section.settings.padding | default: 10 }}px;
    "
    role="region"
    aria-label="Announcement"
  >

    {%- if section.blocks.size > 0 -%}
      {%- comment -%} Block-based: first block shown as static text {%- endcomment -%}
      {%- assign first_block = section.blocks | first -%}
      {%- if first_block.settings.link != blank -%}
        <a href="{{ first_block.settings.link }}" class="ab-static-text" {{ first_block.shopify_attributes }}>
          {%- if first_block.settings.badge != blank -%}<span class="ab-badge">{{ first_block.settings.badge }}</span>{%- endif -%}
          {{ first_block.settings.text }}
        </a>
      {%- else -%}
        <span class="ab-static-text" {{ first_block.shopify_attributes }}>
          {%- if first_block.settings.badge != blank -%}<span class="ab-badge">{{ first_block.settings.badge }}</span>{%- endif -%}
          {{ first_block.settings.text }}
        </span>
      {%- endif -%}

      {%- comment -%} Marquee: repeat all blocks to fill track {%- endcomment -%}
      <div class="ab-marquee-track">
        {%- for repeat in (1..4) -%}
          {%- for block in section.blocks -%}
            {%- if block.type == "message" -%}
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="ab-marquee-item" {{ block.shopify_attributes }}>
                  {%- if block.settings.badge != blank -%}<span class="ab-badge">{{ block.settings.badge }}</span>{%- endif -%}
                  {{ block.settings.text }}
                </a>
              {%- else -%}
                <span class="ab-marquee-item" {{ block.shopify_attributes }}>
                  {%- if block.settings.badge != blank -%}<span class="ab-badge">{{ block.settings.badge }}</span>{%- endif -%}
                  {{ block.settings.text }}
                </span>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      </div>

    {%- else -%}
      {%- comment -%} Legacy fallback — no blocks configured yet {%- endcomment -%}
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" class="ab-static-text">{{ section.settings.text }}</a>
      {%- else -%}
        <span class="ab-static-text">{{ section.settings.text }}</span>
      {%- endif -%}

      <div class="ab-marquee-track">
        {%- for i in (1..6) -%}
          {%- if section.settings.link != blank -%}
            <a href="{{ section.settings.link }}" class="ab-marquee-item">{{ section.settings.text }}</a>
          {%- else -%}
            <span class="ab-marquee-item">{{ section.settings.text }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_bar",
      "label": "Show Announcement Bar",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "Free Domestic Shipping over $150 and 30 Day Returns",
      "info": "This text is used as a fallback if no blocks are added."
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)",
      "info": "Makes the entire bar clickable. This link is used as a fallback if no blocks are added."
    },
    {
      "type": "header",
      "content": "Sizing"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 8,
      "max": 16,
      "step": 1,
      "default": 11,
      "unit": "px",
      "label": "Font Size"
    },
    {
      "type": "range",
      "id": "padding",
      "min": 4,
      "max": 20,
      "step": 2,
      "default": 10,
      "unit": "px",
      "label": "Vertical Padding",
      "info": "Controls the height of the bar"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#d4c8b0"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "select",
      "id": "animation",
      "label": "Animation Style",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "slide_down", "label": "Slide Down" },
        { "value": "fade_in", "label": "Fade In" },
        { "value": "marquee", "label": "Marquee (scrolling)" }
      ],
      "default": "fade_in",
      "info": "Choose how the bar appears on page load"
    }
  ],
  "max_blocks": 8,
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Message Text",
          "default": "New Announcement"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (optional)",
          "info": "e.g., NEW, SALE, LIMITED"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        { "type": "message", "settings": { "text": "Free shipping on orders over $150 🚚", "badge": "FREE SHIP" } },
        { "type": "message", "settings": { "text": "30-day hassle-free returns ↩" } },
        { "type": "message", "settings": { "text": "New arrivals every week — Shop now ✨", "badge": "NEW" } }
      ]
    }
  ]
}
{% endschema %}
