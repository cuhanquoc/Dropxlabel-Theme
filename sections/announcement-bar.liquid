{% comment %}
  ─────────────────────────────────────────
  ANNOUNCEMENT BAR — Top Banner
  Editable text, colors, and animation
  CSS → src/input.css
  ─────────────────────────────────────────
{% endcomment %}


{% if section.settings.show_bar %}
  <div
    class="announcement-bar"
    data-animation="{{ section.settings.animation }}"
    style="
      background-color: {{ section.settings.bg_color }};
      color: {{ section.settings.text_color }};
      font-size: {{ section.settings.font_size | default: 11 }}px;
      padding-top: {{ section.settings.padding | default: 10 }}px;
      padding-bottom: {{ section.settings.padding | default: 10 }}px;
    "
    role="region"
    aria-label="Announcement"
  >
    <!-- Static text (for slide_down & fade_in) -->
    {% if section.settings.link != blank %}
      <a href="{{ section.settings.link }}" class="ab-static-text">
        {{ section.settings.text }}
      </a>
    {% else %}
      <span class="ab-static-text">{{ section.settings.text }}</span>
    {% endif %}

    <!-- Marquee track (for marquee animation) -->
    <div class="ab-marquee-track">
      {% for i in (1..6) %}
        {% if section.settings.link != blank %}
          <a href="{{ section.settings.link }}" class="ab-marquee-item">{{ section.settings.text }}</a>
        {% else %}
          <span class="ab-marquee-item">{{ section.settings.text }}</span>
        {% endif %}
      {% endfor %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_bar",
      "label": "Show Announcement Bar",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "Free Domestic Shipping over $150 and 30 Day Returns"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)",
      "info": "Makes the entire bar clickable"
    },
    {
      "type": "header",
      "content": "Sizing"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 8,
      "max": 16,
      "step": 1,
      "default": 11,
      "unit": "px",
      "label": "Font Size"
    },
    {
      "type": "range",
      "id": "padding",
      "min": 4,
      "max": 20,
      "step": 2,
      "default": 10,
      "unit": "px",
      "label": "Vertical Padding",
      "info": "Controls the height of the bar"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#d4c8b0"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "select",
      "id": "animation",
      "label": "Animation Style",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "slide_down", "label": "Slide Down" },
        { "value": "fade_in", "label": "Fade In" },
        { "value": "marquee", "label": "Marquee (scrolling)" }
      ],
      "default": "fade_in",
      "info": "Choose how the bar appears on page load"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
