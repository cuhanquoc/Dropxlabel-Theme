  All modifications are logged.

  If you require assistance or have questions regarding this code, please contact support@versio.studio.
{%- endcomment -%}

{% style %}
  .vso-dt-section-{{ section.id }} {
    width: 100%;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }

  @media screen and (min-width: 750px) {
    .vso-dt-section-{{ section.id }} {
      margin-top: {{ section.settings.margin_top_desktop }}px;
      margin-bottom: {{ section.settings.margin_bottom_desktop }}px;
    }
  }

  .vso-dt-wrap-{{ section.id }} {
    border-radius: {{ section.settings.border_radius }}px;
    overflow: hidden;
    border: 1px solid {{ section.settings.border_color }};
  }

  .vso-dt-bar-{{ section.id }} {
    display: flex;
    background: {{ section.settings.tab_bar_bg }};
    padding: 5px;
    gap: 2px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .vso-dt-bar-{{ section.id }}::-webkit-scrollbar { display: none; }

  .vso-dt-btn-{{ section.id }} {
    flex: 0 0 auto;
    min-width: 0;
    padding: 9px 16px;
    border: none;
    background: transparent;
    color: {{ section.settings.tab_text_color }};
    font-size: {{ section.settings.tab_font_size_mobile }}px;
    cursor: pointer;
    border-radius: {{ section.settings.tab_radius }}px;
    transition: background 0.2s, color 0.2s;
    text-align: center;
    white-space: nowrap;
    font-family: inherit;
    line-height: 1.3;
  }

  @media screen and (min-width: 750px) {
    .vso-dt-btn-{{ section.id }} {
      font-size: {{ section.settings.tab_font_size }}px;
      padding: 10px 20px;
    }
  }

  .vso-dt-btn-{{ section.id }}.is-active {
    background: {{ section.settings.tab_active_bg }};
    color: {{ section.settings.tab_active_text }};
  }

  .vso-dt-panel-{{ section.id }} {
    display: none;
    padding: 16px 16px;
    background: {{ section.settings.content_bg }};
  }

  .vd-l { display: none !important; }

  @media screen and (min-width: 750px) {
    .vso-dt-panel-{{ section.id }} {
      padding: 16px 16px;
    }
  }

  .vso-dt-panel-{{ section.id }}.is-active { display: block; }

  /* Expert Review */
  .vso-dt-quote-{{ section.id }} {
    font-style: italic;
    line-height: 1.65;
    color: {{ section.settings.text_color }};
    margin: 0 0 24px;
    font-family: Georgia, 'Times New Roman', serif;
  }

  .vso-dt-author-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .vso-dt-avatar-{{ section.id }} {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .vso-dt-avatar-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .vso-dt-author-info-{{ section.id }} { display: flex; flex-direction: column; gap: 1px; }

  .vso-dt-author-name-{{ section.id }} {
    font-size: 14px;
    color: {{ section.settings.text_color }};
  }

  .vso-dt-author-cred-{{ section.id }} {
    color: {{ section.settings.accent_color }};
  }

  .vso-dt-author-meta-{{ section.id }} {
    font-size: 13px;
    color: {{ section.settings.secondary_text }};
  }

  /* Comparison */
  .vso-dt-comp-head-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-bottom: 12px;
  }

  .vso-dt-comp-label-{{ section.id }} {
    flex: 1;
    min-width: 0;
  }

  .vso-dt-comp-col-{{ section.id }} {
    width: 90px;
    text-align: center;
    font-size: 12px;
    padding: 7px 14px;
    border-radius: 20px;
  }

  @media screen and (min-width: 750px) {
    .vso-dt-comp-col-{{ section.id }} { width: 110px; }
  }

  .vso-dt-comp-col-{{ section.id }}.is-others {
    background: transparent;
    color: {{ section.settings.secondary_text }};
  }

  .vso-dt-comp-row-{{ section.id }} {
    display: flex;
    align-items: center;
    padding: 12px 0;
  }

  .vso-dt-comp-row-{{ section.id }}:last-child { border-bottom: none; }

  .vso-dt-comp-feat-{{ section.id }} {
    flex: 1;
    font-size: 13px;
    color: {{ section.settings.text_color }};
    min-width: 0;
  }

  @media screen and (min-width: 750px) {
    .vso-dt-comp-feat-{{ section.id }} { font-size: 14px; }
  }

  .vso-dt-comp-icon-{{ section.id }} {
    width: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media screen and (min-width: 750px) {
    .vso-dt-comp-icon-{{ section.id }} { width: 110px; }
  }

  .vso-dt-ci { border-radius: 50%; display: flex; align-items: center; justify-content: center; }
  .vso-dt-ci svg { width: 14px; height: 14px; }

  /* About */
  .vso-dt-about-sub-{{ section.id }} {
    color: {{ section.settings.accent_color }};
    margin-bottom: 8px;
  }

  .vso-dt-about-h-{{ section.id }} {
    line-height: 1.3;
    color: {{ section.settings.text_color }};
    margin: 0 0 16px;
  }

  .vso-dt-about-body-{{ section.id }} {
    font-size: 14px;
    line-height: 1.7;
    color: {{ section.settings.secondary_text }};
  }

  .vso-dt-about-body-{{ section.id }} p { margin: 0 0 14px; }
  .vso-dt-about-body-{{ section.id }} p:last-child { margin-bottom: 0; }

  .vso-dt-tags-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }

  .vso-dt-tag-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 13px;
  }

  .vso-dt-tag-icon-{{ section.id }} {
    flex-shrink: 0;
    width: {{ section.settings.tag_icon_size }}px;
    height: {{ section.settings.tag_icon_size }}px;
  }

  .vso-dt-tag-icon-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Results */
  .vso-dt-timeline-{{ section.id }} {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    position: relative;
    margin-bottom: 20px;
    padding: 0 6px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .vso-dt-timeline-{{ section.id }}::-webkit-scrollbar { display: none; }

  .vso-dt-timeline-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: 16px;
    left: 26px;
    right: 26px;
    height: 2px;
  }

  .vso-dt-ms-btn-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    cursor: pointer;
    position: relative;
    z-index: 1;
    padding: 0;
    min-width: 60px;
  }

  .vso-dt-ms-dot-{{ section.id }} {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: {{ section.settings.content_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s;
  }

  .vso-dt-ms-dot-{{ section.id }} .dot-inner {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    transition: all 0.25s;
  }

  .vso-dt-ms-btn-{{ section.id }}.is-active .vso-dt-ms-dot-{{ section.id }} .dot-inner {
    width: 14px;
    height: 14px;
  }

  .vso-dt-ms-label-{{ section.id }} {
    font-size: 10px;
    color: {{ section.settings.secondary_text }};
    white-space: nowrap;
    transition: color 0.2s;
  }

  .vso-dt-ms-btn-{{ section.id }}.is-active .vso-dt-ms-label-{{ section.id }} {
    color: {{ section.settings.text_color }};
  }

  .vso-dt-ms-check-{{ section.id }} { display: none; }

  .vso-dt-ms-btn-{{ section.id }}.has-check .dot-inner { display: none; }
  .vso-dt-ms-btn-{{ section.id }}.has-check .vso-dt-ms-check-{{ section.id }} {
    display: block;
    width: 14px;
    height: 14px;
  }

  .vso-dt-r-card-{{ section.id }} {
    display: none;
    border-radius: 10px;
    padding: 18px;
  }

  .vso-dt-r-card-{{ section.id }}.is-active { display: block; }

  .vso-dt-r-label-{{ section.id }} {
    font-size: 13px;
    color: {{ section.settings.accent_color }};
    margin-bottom: 4px;
  }

  .vso-dt-r-heading-{{ section.id }} {
    font-size: 17px;
    color: {{ section.settings.text_color }};
    margin-bottom: 6px;
  }

  .vso-dt-r-text-{{ section.id }} {
    font-size: 14px;
    line-height: 1.6;
    color: {{ section.settings.secondary_text }};
    margin: 0;
  }

  .vso-dt-r-bars-{{ section.id }} {
    display: flex;
    gap: 4px;
    margin-top: 16px;
  }

  .vso-dt-r-bar-{{ section.id }} {
    flex: 1;
    height: 4px;
    border-radius: 2px;
    transition: background 0.2s;
  }

  /* Block-specific styles (driven by tab block settings) */
  {%- for block in section.blocks -%}
    {%- if block.type == 'tab_expert' -%}
      .vso-dt-quote-{{ section.id }} { font-size: {{ block.settings.quote_size_mobile }}px; }
      @media screen and (min-width: 750px) {
        .vso-dt-quote-{{ section.id }} { font-size: {{ block.settings.quote_size }}px; }
      }
      .vso-dt-avatar-{{ section.id }} {
        background: {{ block.settings.avatar_bg }};
        color: {{ block.settings.avatar_text_color }};
      }
    {%- endif -%}

    {%- if block.type == 'tab_comparison' -%}
      .vso-dt-comp-label-{{ section.id }} {
        color: {{ block.settings.comp_label_color }};
      }
      .vso-dt-ci {
        width: {{ block.settings.icon_size }}px;
        height: {{ block.settings.icon_size }}px;
      }
      .vso-dt-ci svg {
        width: {{ block.settings.icon_size | times: 0.54 | round }}px;
        height: {{ block.settings.icon_size | times: 0.54 | round }}px;
      }
      .vso-dt-ci.is-yes {
        background: {{ block.settings.check_bg }};
        color: {{ block.settings.check_color }};
      }
      .vso-dt-ci.is-no {
        background: {{ block.settings.cross_bg }};
        color: {{ block.settings.cross_color }};
      }
      .vso-dt-comp-col-{{ section.id }}.is-product {
        background: {{ block.settings.comp_pill_bg }};
        color: {{ block.settings.comp_pill_text }};
      }
      .vso-dt-comp-head-{{ section.id }} {
        border-bottom: 1px solid {{ block.settings.row_border }};
      }
      .vso-dt-comp-row-{{ section.id }} {
        border-bottom: 1px solid {{ block.settings.row_border }};
      }
    {%- endif -%}

    {%- if block.type == 'tab_about' -%}
      .vso-dt-about-h-{{ section.id }} { font-size: {{ block.settings.about_heading_size_mobile }}px; }
      @media screen and (min-width: 750px) {
        .vso-dt-about-h-{{ section.id }} { font-size: {{ block.settings.about_heading_size }}px; }
      }
      .vso-dt-tag-{{ section.id }} {
        border: 1px solid {{ block.settings.tag_border }};
        color: {{ block.settings.tag_text }};
        background: {{ block.settings.tag_bg }};
      }
    {%- endif -%}

    {%- if block.type == 'tab_results' -%}
      .vso-dt-timeline-{{ section.id }}::before { background: {{ block.settings.timeline_line }}; }
      .vso-dt-ms-dot-{{ section.id }} { border: 2px solid {{ block.settings.timeline_line }}; }
      .vso-dt-ms-dot-{{ section.id }} .dot-inner { background: {{ block.settings.timeline_line }}; }
      .vso-dt-ms-btn-{{ section.id }}.is-active .vso-dt-ms-dot-{{ section.id }} { border-color: {{ block.settings.timeline_active }}; }
      .vso-dt-ms-btn-{{ section.id }}.is-active .vso-dt-ms-dot-{{ section.id }} .dot-inner { background: {{ block.settings.timeline_active }}; }
      .vso-dt-ms-check-{{ section.id }} { color: {{ block.settings.timeline_line }}; }
      .vso-dt-ms-btn-{{ section.id }}.is-active.has-check .vso-dt-ms-check-{{ section.id }} { color: {{ block.settings.timeline_active }}; }
      .vso-dt-r-card-{{ section.id }} {
        background: {{ block.settings.results_card_bg }};
        border: 1px solid {{ block.settings.results_card_border }};
      }
      .vso-dt-r-bar-{{ section.id }} { background: {{ block.settings.timeline_line }}; }
      .vso-dt-r-bar-{{ section.id }}.is-active { background: {{ block.settings.timeline_active }}; }
    {%- endif -%}
  {%- endfor -%}
{% endstyle %}

<script>
(function() {
  var SID = '{{ section.id }}';

  function position() {
    var tpl = document.querySelector('#vso-detail-tabs-' + SID);
    if (!tpl) return;
    var content = tpl.content.cloneNode(true);
    var el = content.firstElementChild;
    if (!el) return;

    var custom = document.querySelector('#vso-detail-tabs-placement');
    if (custom) {
      if (custom.parentNode) custom.parentNode.replaceChild(el, custom);
      else return;
    } else {
      var target = document.querySelector(
        '{% if section.settings.position == "below_title" or section.settings.position == "above_title" %}.product__title{% elsif section.settings.position == "below_description" %}.product__description{% else %}.button--add-to-cart, .product .product-form, .product-single__add-to-cart, .shopify-payment-button, .shopify-payment-button__button, .ProductForm__BuyButtons, .add-to-cart{% endif %}'
      );
      if (target) {
        var mode = '{% if section.settings.position == "below_buy" or section.settings.position == "below_title" or section.settings.position == "below_description" %}afterend{% else %}beforebegin{% endif %}';
        target.insertAdjacentElement(mode, el);
      } else {
        var form = document.querySelector('form[action$="/cart/add"], form.product-form, #product-form, [data-product-form], .product-form__buttons');
        if (form) {
          var pos = '{{ section.settings.position }}';
          form.insertAdjacentElement(pos.indexOf('above') > -1 ? 'beforebegin' : 'afterend', el);
        } else return;
      }
    }

    if (el.isConnected) {
      document.querySelectorAll('.vso-dt-section-' + SID).forEach(function(n) {
        if (n !== el) n.parentNode && n.parentNode.removeChild(n);
      });
      init(el);
    }
  }

  function init(root) {
    var btns = root.querySelectorAll('[data-dt-tab]');
    var panels = root.querySelectorAll('[data-dt-panel]');

    var bar = root.querySelector('[role="tablist"]');

    function checkBarFit() {
      if (!bar) return;
      var totalWidth = 0;
      btns.forEach(function(b) { totalWidth += b.offsetWidth; });
      var gap = 2 * Math.max(0, btns.length - 1);
      var fits = (totalWidth + gap + 10) <= bar.clientWidth;
      btns.forEach(function(b) { b.style.flex = fits ? '1 1 0%' : '0 0 auto'; });
    }

    checkBarFit();
    window.addEventListener('resize', checkBarFit);

    function scrollActiveIntoView(btn) {
      if (!bar || bar.scrollWidth <= bar.clientWidth) return;
      var idx = Array.prototype.indexOf.call(btns, btn);
      var scrollLeft;
      if (idx === 0) {
        scrollLeft = 0;
      } else if (idx === btns.length - 1) {
        scrollLeft = bar.scrollWidth - bar.clientWidth;
      } else {
        scrollLeft = btn.offsetLeft - (bar.clientWidth / 2) + (btn.offsetWidth / 2);
      }
      bar.scrollTo({ left: Math.max(0, scrollLeft), behavior: 'smooth' });
    }

    function switchTab(name, fromBtn) {
      btns.forEach(function(b) { b.classList.toggle('is-active', b.getAttribute('data-dt-tab') === name); });
      panels.forEach(function(p) { p.classList.toggle('is-active', p.getAttribute('data-dt-panel') === name); });
      if (fromBtn) scrollActiveIntoView(fromBtn);
    }

    btns.forEach(function(b) {
      b.addEventListener('click', function() { switchTab(b.getAttribute('data-dt-tab'), b); });
    });

    if (btns.length) switchTab(btns[0].getAttribute('data-dt-tab'));

    var msBtns = root.querySelectorAll('[data-dt-ms]');
    var msCards = root.querySelectorAll('[data-dt-ms-card]');
    var msBars = root.querySelectorAll('[data-dt-ms-bar]');

    function switchMs(idx) {
      msBtns.forEach(function(b, i) { b.classList.toggle('is-active', i == idx); });
      msCards.forEach(function(c, i) { c.classList.toggle('is-active', i == idx); });
      msBars.forEach(function(b, i) { b.classList.toggle('is-active', i == idx); });
    }

    msBtns.forEach(function(b, i) {
      b.addEventListener('click', function() { switchMs(i); });
    });

    if (msBtns.length) switchMs(0);
  }

  window.addEventListener('DOMContentLoaded', position);

  document.addEventListener('shopify:section:load', function(e) {
    if (e.detail.sectionId === SID) position();
  });
  document.addEventListener('shopify:section:reorder', function(e) {
    if (e.detail.sectionId === SID) position();
  });
  document.addEventListener('shopify:section:select', function(e) {
    if (e.detail.sectionId === SID) position();
  });
  document.addEventListener('shopify:block:select', function(e) {
    if (e.detail.sectionId !== SID) return;
    position();
    setTimeout(function() {
      var blockEl = document.querySelector('.vso-dt-section-' + SID + ' [data-block-id="' + e.detail.blockId + '"]');
      if (!blockEl) return;
      var root = blockEl.closest('.vso-dt-section-' + SID);
      if (!root) return;

      if (blockEl.hasAttribute('data-dt-tab')) {
        var name = blockEl.getAttribute('data-dt-tab');
        root.querySelectorAll('[data-dt-tab]').forEach(function(b) { b.classList.toggle('is-active', b.getAttribute('data-dt-tab') === name); });
        root.querySelectorAll('[data-dt-panel]').forEach(function(p) { p.classList.toggle('is-active', p.getAttribute('data-dt-panel') === name); });
        return;
      }

      var panel = blockEl.closest('[data-dt-panel]');
      if (panel) {
        var name = panel.getAttribute('data-dt-panel');
        root.querySelectorAll('[data-dt-tab]').forEach(function(b) { b.classList.toggle('is-active', b.getAttribute('data-dt-tab') === name); });
        root.querySelectorAll('[data-dt-panel]').forEach(function(p) { p.classList.toggle('is-active', p.getAttribute('data-dt-panel') === name); });
      }

      if (blockEl.hasAttribute('data-dt-ms')) {
        var msPanel = blockEl.closest('[data-dt-panel]');
        if (msPanel) {
          var allMs = msPanel.querySelectorAll('[data-dt-ms]');
          var allCards = msPanel.querySelectorAll('[data-dt-ms-card]');
          var allBars = msPanel.querySelectorAll('[data-dt-ms-bar]');
          var idx = Array.prototype.indexOf.call(allMs, blockEl);
          allMs.forEach(function(b, i) { b.classList.toggle('is-active', i === idx); });
          allCards.forEach(function(c, i) { c.classList.toggle('is-active', i === idx); });
          allBars.forEach(function(b, i) { b.classList.toggle('is-active', i === idx); });
        }
      }
    }, 100);
  });
})();
</script>

<template id="vso-detail-tabs-{{ section.id }}">
  <div class="vso-dt-section-{{ section.id }} vd-l">
    <div class="vso-dt-wrap-{{ section.id }}">
      <div class="vso-dt-bar-{{ section.id }}" role="tablist">
        {%- for block in section.blocks -%}
          {%- if block.type == 'tab_expert' or block.type == 'tab_comparison' or block.type == 'tab_about' or block.type == 'tab_results' -%}
            <button class="vso-dt-btn-{{ section.id }}" data-dt-tab="{{ block.type }}" data-block-id="{{ block.id }}" {{ block.shopify_attributes }} role="tab">{{ block.settings.title }}</button>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'tab_expert' -%}
        <div class="vso-dt-panel-{{ section.id }}" data-dt-panel="tab_expert" role="tabpanel">
          <div class="vso-dt-quote-{{ section.id }}">{{ block.settings.quote | escape }}</div>
          <div class="vso-dt-author-{{ section.id }}">
            {%- if block.settings.avatar_image != blank -%}
              <div class="vso-dt-avatar-{{ section.id }}">
                {{ block.settings.avatar_image | image_url: width: 84 | image_tag: loading: 'lazy', alt: block.settings.author_name }}
              </div>
            {%- else -%}
              <div class="vso-dt-avatar-{{ section.id }}">{{ block.settings.avatar_initials }}</div>
            {%- endif -%}
            <div class="vso-dt-author-info-{{ section.id }}">
              <div class="vso-dt-author-name-{{ section.id }}">{{ block.settings.author_name }}</div>
              {%- if block.settings.author_credential != blank -%}
                <div class="vso-dt-author-cred-{{ section.id }}">{{ block.settings.author_credential }}</div>
              {%- endif -%}
              {%- if block.settings.author_meta != blank -%}
                <div class="vso-dt-author-meta-{{ section.id }}">{{ block.settings.author_meta }}</div>
              {%- endif -%}
            </div>
          </div>
        </div>

        {%- elsif block.type == 'tab_comparison' -%}
        <div class="vso-dt-panel-{{ section.id }}" data-dt-panel="tab_comparison" role="tabpanel">
          <div class="vso-dt-comp-head-{{ section.id }}">
            {%- if block.settings.comp_label != blank -%}
              <span class="vso-dt-comp-label-{{ section.id }}">{{ block.settings.comp_label }}</span>
            {%- endif -%}
            <span class="vso-dt-comp-col-{{ section.id }} is-product">{{ block.settings.product_name }}</span>
            <span class="vso-dt-comp-col-{{ section.id }} is-others">{{ block.settings.others_name }}</span>
          </div>
          {%- for b in section.blocks -%}
            {%- if b.type == 'comparison_row' -%}
            <div class="vso-dt-comp-row-{{ section.id }}" data-block-id="{{ b.id }}" {{ b.shopify_attributes }}>
              <span class="vso-dt-comp-feat-{{ section.id }}">{{ b.settings.feature }}</span>
              <span class="vso-dt-comp-icon-{{ section.id }}">
                {%- if b.settings.product_has -%}
                  <span class="vso-dt-ci is-yes"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7.5L5.5 10.5L11.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                {%- else -%}
                  <span class="vso-dt-ci is-no"><svg viewBox="0 0 14 14" fill="none"><path d="M3.5 3.5L10.5 10.5M10.5 3.5L3.5 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
                {%- endif -%}
              </span>
              <span class="vso-dt-comp-icon-{{ section.id }}">
                {%- if b.settings.others_have -%}
                  <span class="vso-dt-ci is-yes"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7.5L5.5 10.5L11.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                {%- else -%}
                  <span class="vso-dt-ci is-no"><svg viewBox="0 0 14 14" fill="none"><path d="M3.5 3.5L10.5 10.5M10.5 3.5L3.5 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
                {%- endif -%}
              </span>
            </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- elsif block.type == 'tab_about' -%}
        <div class="vso-dt-panel-{{ section.id }}" data-dt-panel="tab_about" role="tabpanel">
          {%- if block.settings.subtitle != blank -%}
            <div class="vso-dt-about-sub-{{ section.id }}">{{ block.settings.subtitle }}</div>
          {%- endif -%}
          {%- if block.settings.heading != blank -%}
            <h3 class="vso-dt-about-h-{{ section.id }}">{{ block.settings.heading }}</h3>
          {%- endif -%}
          {%- if block.settings.content != blank -%}
            <div class="vso-dt-about-body-{{ section.id }} rte">{{ block.settings.content }}</div>
          {%- endif -%}
          {%- assign has_tags = false -%}
          {%- for b in section.blocks -%}
            {%- if b.type == 'about_tag' and b.settings.tag != blank -%}
              {%- assign has_tags = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if has_tags -%}
          <div class="vso-dt-tags-{{ section.id }}">
            {%- for b in section.blocks -%}
              {%- if b.type == 'about_tag' and b.settings.tag != blank -%}
                <span class="vso-dt-tag-{{ section.id }}" data-block-id="{{ b.id }}" {{ b.shopify_attributes }}>
                  {%- if b.settings.icon != blank -%}
                    <span class="vso-dt-tag-icon-{{ section.id }}">{{ b.settings.icon | image_url: width: 64 | image_tag: loading: 'lazy' }}</span>
                  {%- endif -%}
                  {{ b.settings.tag }}
                </span>
              {%- endif -%}
            {%- endfor -%}
          </div>
          {%- endif -%}
        </div>

        {%- elsif block.type == 'tab_results' -%}
        <div class="vso-dt-panel-{{ section.id }}" data-dt-panel="tab_results" role="tabpanel">
          <div class="vso-dt-timeline-{{ section.id }}">
            {%- for b in section.blocks -%}
              {%- if b.type == 'results_milestone' -%}
              <button class="vso-dt-ms-btn-{{ section.id }}{% if b.settings.show_checkmark %} has-check{% endif %}" data-dt-ms data-block-id="{{ b.id }}" {{ b.shopify_attributes }}>
                <span class="vso-dt-ms-dot-{{ section.id }}">
                  <span class="dot-inner"></span>
                  <svg class="vso-dt-ms-check-{{ section.id }}" viewBox="0 0 14 14" fill="none"><path d="M2.5 7.5L5.5 10.5L11.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <span class="vso-dt-ms-label-{{ section.id }}">{{ b.settings.label }}</span>
              </button>
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- for b in section.blocks -%}
            {%- if b.type == 'results_milestone' -%}
            <div class="vso-dt-r-card-{{ section.id }}" data-dt-ms-card>
              <div class="vso-dt-r-label-{{ section.id }}">{{ b.settings.label }}</div>
              <div class="vso-dt-r-heading-{{ section.id }}">{{ b.settings.heading }}</div>
              <p class="vso-dt-r-text-{{ section.id }}">{{ b.settings.content }}</p>
            </div>
            {%- endif -%}
          {%- endfor -%}

          <div class="vso-dt-r-bars-{{ section.id }}">
            {%- for b in section.blocks -%}
              {%- if b.type == 'results_milestone' -%}
                <div class="vso-dt-r-bar-{{ section.id }}" data-dt-ms-bar></div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</template>

