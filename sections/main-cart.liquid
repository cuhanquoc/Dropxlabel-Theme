<section class="main-cart-section" style="padding: 1.5rem 1rem 6rem;">
  <div style="max-width: 900px; margin: 0 auto;">
    <h1 style="font-family: var(--font-heading); font-size: 2rem; line-height: 1.15; margin: 0 0 1.25rem;">
      {{ section.settings.heading | default: 'Your cart' }}
    </h1>

    {% if cart.item_count == 0 %}
      <div style="border: 1px solid #e8e8e8; border-radius: 10px; padding: 1.25rem; background: #fff;">
        <p style="margin: 0 0 0.9rem; font-size: 1rem;">{{ section.settings.empty_text | default: 'Your cart is empty.' }}</p>
        <a
          href="{{ section.settings.continue_url | default: routes.collections_url }}"
          style="display: inline-flex; align-items: center; justify-content: center; min-height: 44px; padding: 0 1rem; border: 1px solid #111; border-radius: 999px; text-decoration: none; font-weight: 600;"
        >
          {{ section.settings.continue_label | default: 'Continue shopping' }}
        </a>
      </div>
    {% else %}
      <form action="{{ routes.cart_url }}" method="post" novalidate>
        <div style="display: grid; gap: 0.75rem;">
          {% for item in cart.items %}
            <div style="display: grid; grid-template-columns: 88px minmax(0,1fr); gap: 0.85rem; border: 1px solid #ececec; border-radius: 10px; padding: 0.75rem; background: #fff;">
              <a href="{{ item.url }}" style="display: block; border-radius: 8px; overflow: hidden; background: #f6f6f6;">
                {% if item.image %}
                  {{ item.image | image_url: width: 240 | image_tag: loading: 'lazy', alt: item.title, widths: '120,180,240', sizes: '88px', style: 'width:88px;height:110px;object-fit:cover;display:block;' }}
                {% endif %}
              </a>
              <div style="min-width: 0;">
                <a href="{{ item.url }}" style="text-decoration: none;">
                  <p style="margin: 0 0 0.35rem; color: #111; font-size: 1rem; font-weight: 600; line-height: 1.35;">
                    {{ item.product.title }}
                  </p>
                </a>
                <p style="margin: 0 0 0.55rem; color: #555; font-size: 0.92rem;">
                  {{ item.variant.title }}
                </p>

                <div style="display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;">
                  <div style="display: inline-flex; align-items: center; border: 1px solid #d9d9d9; border-radius: 7px; overflow: hidden; height: 40px;">
                    <button type="button" data-cart-qty-minus="{{ forloop.index0 }}" style="width: 40px; height: 40px; border: 0; background: #fff; font-size: 1.2rem;">−</button>
                    <input
                      type="number"
                      min="0"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      data-cart-qty-input="{{ forloop.index0 }}"
                      style="width: 44px; height: 40px; border: 0; text-align: center; font-size: 1rem; -moz-appearance: textfield;"
                    >
                    <button type="button" data-cart-qty-plus="{{ forloop.index0 }}" style="width: 40px; height: 40px; border: 0; background: #fff; font-size: 1.2rem;">+</button>
                  </div>

                  <p style="margin: 0; font-size: 1rem; font-weight: 700; color: #111;">
                    {{ item.final_line_price | money }}
                  </p>
                </div>

                <a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0" style="display: inline-block; margin-top: 0.55rem; font-size: 0.86rem; text-decoration: underline; color: #666;">
                  Remove
                </a>
              </div>
            </div>
          {% endfor %}
        </div>

        <div style="margin-top: 1rem; border: 1px solid #ececec; border-radius: 10px; padding: 1rem; background: #fff;">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
            <span style="font-size: 0.95rem; color: #444;">Subtotal</span>
            <strong style="font-size: 1.25rem;">{{ cart.total_price | money }}</strong>
          </div>
          <p style="margin: 0 0 0.9rem; color: #666; font-size: 0.88rem;">Taxes and shipping calculated at checkout.</p>

          <div style="display: grid; gap: 0.65rem;">
            <button type="submit" name="update" style="min-height: 44px; border: 1px solid #111; border-radius: 8px; background: #fff; font-weight: 600;">
              Update cart
            </button>
            <button type="submit" name="checkout" style="min-height: 48px; border: 0; border-radius: 8px; background: #111; color: #fff; font-weight: 700;">
              Checkout
            </button>
          </div>
        </div>
      </form>
    {% endif %}
  </div>
</section>

<script>
  (function () {
    const root = document.querySelector('.main-cart-section');
    if (!root) return;

    root.addEventListener('click', function (e) {
      const plusBtn = e.target.closest('[data-cart-qty-plus]');
      const minusBtn = e.target.closest('[data-cart-qty-minus]');
      if (!plusBtn && !minusBtn) return;

      const idx = plusBtn ? plusBtn.getAttribute('data-cart-qty-plus') : minusBtn.getAttribute('data-cart-qty-minus');
      const input = root.querySelector('[data-cart-qty-input="' + idx + '"]');
      if (!input) return;

      const current = Math.max(0, parseInt(input.value || '0', 10));
      input.value = plusBtn ? current + 1 : Math.max(0, current - 1);
    });
  })();
</script>

{% schema %}
{
  "name": "Main Cart",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your cart"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty cart text",
      "default": "Your cart is empty."
    },
    {
      "type": "text",
      "id": "continue_label",
      "label": "Continue button label",
      "default": "Continue shopping"
    },
    {
      "type": "url",
      "id": "continue_url",
      "label": "Continue button URL"
    }
  ],
  "presets": [
    {
      "name": "Main Cart"
    }
  ]
}
{% endschema %}
