{{ 'fam2.css' | asset_url | stylesheet_tag }}

<footer-accordion-mobile
  class="fam2 block md:hidden"
  style="
    --fam2-bg: {{ section.settings.bg_color }};
    --fam2-text: {{ section.settings.text_color }};
    --fam2-icon: {{ section.settings.icon_color }};
    --fam2-divider: {{ section.settings.divider_color }};
    --fam2-title-size: {{ section.settings.title_size }}px;
    --fam2-title-weight: {{ section.settings.title_weight }};
    --fam2-title-spacing: {{ section.settings.title_spacing | divided_by: 1000.0 }}em;
    --fam2-link-size: {{ section.settings.link_size }}px;
    --fam2-link-weight: {{ section.settings.link_weight }};
    --fam2-link-spacing: {{ section.settings.link_spacing | divided_by: 1000.0 }}em;
    --fam2-legal-size: {{ section.settings.legal_size }}px;
    --fam2-legal-weight: {{ section.settings.legal_weight }};
    --fam2-legal-spacing: {{ section.settings.legal_spacing | divided_by: 1000.0 }}em;
  "
>

  <style>
    .fam2-bar {
      position: relative;
      z-index: 1;
      background: transparent;
      padding: 20px 16px 28px;
      padding-bottom: calc(28px + env(safe-area-inset-bottom, 0px));
      border-top: 1px solid rgba(255,255,255,.08);
    }
    .fam2-bar__row {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 4px;
    }
    .fam2-bar__locale-row {
      margin-bottom: 10px;
    }
    .fam2-bar__locale {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-family: var(--font-body, sans-serif);
      font-size: .68rem;
      font-weight: 500;
      letter-spacing: .08em;
      color: var(--fam2-bar-text, #888);
      text-transform: uppercase;
    }
    .fam2-bar__globe,
    .fam2-bar__chevron {
      flex-shrink: 0;
      color: var(--fam2-bar-text, #888);
    }
    .fam2-bar__legal-row {
      margin-bottom: 14px;
    }
    .fam2-bar__copyright {
      font-family: var(--font-body, sans-serif);
      font-size: .62rem;
      font-weight: 400;
      letter-spacing: .04em;
      color: var(--fam2-bar-text, #888);
      text-align: center;
    }
    .fam2-bar__copyright a {
      color: var(--fam2-bar-text, #888);
      text-decoration: none;
      opacity: .8;
    }
    .fam2-bar__copyright a:hover { opacity: 1; }
    .fam2-bar__payments {
      justify-content: center;
    }
    .fam2-bar__pay-list {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: var(--fam2-bar-gap, 6px);
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .fam2-bar__pay-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255,255,255,.08);
      border-radius: var(--fam2-bar-icon-radius, 4px);
      padding: 4px 6px;
      line-height: 0;
    }
    .fam2-bar__pay-svg {
      width: auto;
      height: 20px;
      max-width: 38px;
      display: block;
    }
    @media (min-width: 768px) {
      .fam2-bar { padding: 24px 40px 32px; padding-bottom: calc(32px + env(safe-area-inset-bottom, 0px)); }
      .fam2-bar__pay-svg { height: 22px; max-width: 42px; }
    }

    /* ── Premium Newsletter ── */
    .fnl {
      position: relative;
      z-index: 1;
      background: var(--fnl-bg);
      color: var(--fnl-text);
      border: 1px solid var(--fnl-border);
      border-radius: 16px;
      margin: 20px 16px;
      padding: var(--fnl-pad-top) 0 var(--fnl-pad-bottom);
      overflow: hidden;
      box-shadow: 0 0 40px rgba(255,255,255,.03), inset 0 1px 0 rgba(255,255,255,.06);
    }

    .fnl__marquee {
      overflow: hidden;
      white-space: nowrap;
      display: flex;
      margin-bottom: 16px;
      mask-image: linear-gradient(to right, transparent 0%, #000 8%, #000 92%, transparent 100%);
      -webkit-mask-image: linear-gradient(to right, transparent 0%, #000 8%, #000 92%, transparent 100%);
    }
    .fnl__marquee-track {
      display: flex;
      flex-shrink: 0;
      animation: fnlScroll var(--fnl-mq-speed) linear infinite;
      will-change: transform;
    }
    .fnl__marquee-track[data-fnl-dir="right"] {
      animation-direction: reverse;
    }
    [data-fnl-pause]:hover .fnl__marquee-track {
      animation-play-state: paused;
    }
    @keyframes fnlScroll {
      from { transform: translateX(0); }
      to { transform: translateX(-100%); }
    }
    @media (prefers-reduced-motion: reduce) {
      .fnl__marquee-track { animation: none; }
    }
    .fnl__marquee-item {
      font-family: var(--font-heading, serif);
      font-size: var(--fnl-mq-size);
      font-weight: var(--fnl-mq-weight);
      letter-spacing: var(--fnl-mq-spacing);
      text-transform: uppercase;
      color: var(--fnl-text);
      flex-shrink: 0;
      padding: 0 4px;
    }
    @media (min-width: 768px) {
      .fnl__marquee-item { font-size: var(--fnl-mq-size-d); }
    }

    .fnl__subcopy {
      font-family: var(--font-body, sans-serif);
      font-size: var(--fnl-sub-size);
      font-weight: var(--fnl-sub-weight);
      line-height: 1.6;
      color: var(--fnl-text);
      opacity: .65;
      text-align: center;
      padding: 0 24px;
      margin: 0 0 20px;
    }

    .fnl__form { padding: 0 20px; }

    .fnl__capsule {
      display: flex;
      align-items: center;
      background: rgba(255,255,255,.06);
      border: 1px solid var(--fnl-border);
      border-radius: 999px;
      overflow: hidden;
      transition: border-color .2s ease, box-shadow .2s ease;
    }
    .fnl__capsule:focus-within {
      border-color: rgba(255,255,255,.25);
      box-shadow: 0 0 0 3px rgba(255,255,255,.06);
    }

    .fnl__input {
      flex: 1;
      min-width: 0;
      height: 50px;
      padding: 0 20px;
      border: none;
      background: transparent;
      font-family: var(--font-body, sans-serif);
      font-size: .82rem;
      color: var(--fnl-text);
      outline: none;
    }
    .fnl__input::placeholder { color: rgba(255,255,255,.35); }

    .fnl__btn {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      height: 42px;
      padding: 0 20px;
      margin: 4px;
      border: none;
      border-radius: 999px;
      background: var(--fnl-btn-bg);
      color: var(--fnl-btn-text);
      font-family: var(--font-body, sans-serif);
      font-size: .7rem;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      cursor: pointer;
      transition: transform .15s ease, opacity .2s ease;
      -webkit-tap-highlight-color: transparent;
    }
    .fnl__btn:hover { opacity: .88; }
    .fnl__btn:active { transform: scale(.95); }
    .fnl__btn-arrow { transition: transform .2s ease; }
    .fnl__btn:hover .fnl__btn-arrow { transform: translateX(3px); }

    .fnl__success {
      text-align: center;
      font-size: .85rem;
      color: #86EFAC;
      padding: 12px 20px;
    }
    .fnl__error {
      text-align: center;
      font-size: .78rem;
      color: #FCA5A5;
      padding: 0 20px 8px;
    }
  </style>

  {%- comment -%} Background image {%- endcomment -%}
  {%- if section.settings.bg_image != blank -%}
    <div
      class="fam2__bg"
      style="background-image: url('{{ section.settings.bg_image | image_url: width: 800 }}');"
      role="presentation"
      aria-hidden="true"
    ></div>
  {%- endif -%}

  {%- comment -%} Overlay {%- endcomment -%}
  {%- if section.settings.overlay_opacity > 0 -%}
    <div
      class="fam2__overlay"
      style="background-color: {{ section.settings.bg_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
      role="presentation"
      aria-hidden="true"
    ></div>
  {%- endif -%}

  <div class="fam2__inner">

    {%- comment -%}
      ── Single-pass block loop ──
      Renders ALL blocks in exact Theme Editor order.
      accordion_link blocks are skipped here — they render inside their
      matching accordion_group via an inner lookup loop.
      <ul> wrapper opens/closes automatically around consecutive groups.
    {%- endcomment -%}

    {%- assign fam2_in_list = false -%}
    {%- for block in section.blocks -%}

      {%- if block.type == 'accordion_group' -%}
        {%- comment -%} ── Accordion group (new system) ── {%- endcomment -%}
        {%- unless fam2_in_list -%}<ul class="fam2__list" role="list">{%- assign fam2_in_list = true -%}{%- endunless -%}

        {%- assign panel_id   = 'fam2-panel-'   | append: block.id -%}
        {%- assign trigger_id = 'fam2-trigger-' | append: block.id -%}
        {%- assign group_key  = block.settings.group_key | strip -%}

        {%- assign child_count = 0 -%}
        {%- for cb in section.blocks -%}
          {%- if cb.type == 'accordion_link' -%}
            {%- assign ck = cb.settings.parent_group_key | strip -%}
            {%- if ck == group_key and cb.settings.label != blank -%}
              {%- assign child_count = child_count | plus: 1 -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}

        <li class="fam2__item" {{ block.shopify_attributes }}>
          <button
            id="{{ trigger_id }}"
            class="fam2__trigger"
            type="button"
            aria-expanded="{% if block.settings.default_open %}true{% else %}false{% endif %}"
            aria-controls="{{ panel_id }}"
          >
            <span class="fam2__title">{{- block.settings.heading | escape -}}</span>
            <span class="fam2__icon" aria-hidden="true">
              <svg viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <line class="fam2__bar fam2__bar--h" x1="2" y1="9" x2="16" y2="9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                <line class="fam2__bar fam2__bar--v" x1="9" y1="2" x2="9" y2="16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              </svg>
            </span>
          </button>

          <div
            id="{{ panel_id }}"
            class="fam2__panel{% if block.settings.default_open %} fam2__panel--open{% endif %}"
            role="region"
            aria-labelledby="{{ trigger_id }}"
          >
            {%- if child_count > 0 -%}
              <ul class="fam2__links" role="list">
                {%- for cb in section.blocks -%}
                  {%- if cb.type == 'accordion_link' -%}
                    {%- assign ck  = cb.settings.parent_group_key | strip -%}
                    {%- assign lbl = cb.settings.label -%}
                    {%- if ck == group_key and lbl != blank -%}
                      <li class="fam2__link-item" {{ cb.shopify_attributes }}>
                        {%- if cb.settings.url != blank -%}
                          <a class="fam2__link" href="{{ cb.settings.url }}"
                            {%- if cb.settings.open_in_new_tab %} target="_blank" rel="noopener noreferrer"{%- endif -%}
                          >{{- lbl | escape -}}</a>
                        {%- else -%}
                          <span class="fam2__link fam2__link--placeholder" aria-disabled="true">{{- lbl | escape -}}</span>
                        {%- endif -%}
                      </li>
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- else -%}
              <p class="fam2__empty">
                {{- 'sections.footer_accordion_mobile.no_links' | t | default: 'Chưa có liên kết.' -}}
              </p>
            {%- endif -%}
          </div>
        </li>

      {%- elsif block.type == 'link_group' -%}
        {%- comment -%} ── Legacy link_group (deprecated, backward-compat) ── {%- endcomment -%}
        {%- unless fam2_in_list -%}<ul class="fam2__list" role="list">{%- assign fam2_in_list = true -%}{%- endunless -%}

        {%- assign panel_id   = 'fam2-panel-'   | append: block.id -%}
        {%- assign trigger_id = 'fam2-trigger-' | append: block.id -%}
        {%- assign has_links = false -%}
        {%- for i in (1..8) -%}
          {%- assign lbl_key = 'link_' | append: i | append: '_label' -%}
          {%- if block.settings[lbl_key] != blank -%}{%- assign has_links = true -%}{%- endif -%}
        {%- endfor -%}

        <li class="fam2__item" {{ block.shopify_attributes }}>
          <button id="{{ trigger_id }}" class="fam2__trigger" type="button" aria-expanded="false" aria-controls="{{ panel_id }}">
            <span class="fam2__title">{{- block.settings.group_title | escape -}}</span>
            <span class="fam2__icon" aria-hidden="true">
              <svg viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <line class="fam2__bar fam2__bar--h" x1="2" y1="9" x2="16" y2="9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                <line class="fam2__bar fam2__bar--v" x1="9" y1="2" x2="9" y2="16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              </svg>
            </span>
          </button>
          <div id="{{ panel_id }}" class="fam2__panel" role="region" aria-labelledby="{{ trigger_id }}">
            {%- if has_links -%}
              <ul class="fam2__links" role="list">
                {%- for i in (1..8) -%}
                  {%- assign lbl_key = 'link_' | append: i | append: '_label' -%}
                  {%- assign url_key = 'link_' | append: i | append: '_url' -%}
                  {%- assign lbl = block.settings[lbl_key] -%}
                  {%- assign url = block.settings[url_key] -%}
                  {%- if lbl != blank -%}
                    <li class="fam2__link-item">
                      {%- if url != blank -%}
                        <a class="fam2__link" href="{{ url }}">{{- lbl | escape -}}</a>
                      {%- else -%}
                        <span class="fam2__link fam2__link--placeholder" aria-disabled="true">{{- lbl | escape -}}</span>
                      {%- endif -%}
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- else -%}
              <p class="fam2__empty">{{- 'sections.footer_accordion_mobile.no_links' | t | default: 'Chưa có liên kết.' -}}</p>
            {%- endif -%}
          </div>
        </li>

      {%- elsif block.type == 'newsletter' -%}
        {%- comment -%} ── Premium Newsletter: Marquee + Capsule Form ── {%- endcomment -%}
        {%- if fam2_in_list -%}</ul>{%- assign fam2_in_list = false -%}{%- endif -%}

        {%- assign nl_id = 'fam2-nl-' | append: block.id -%}
        {%- assign mq_text = block.settings.nl_marquee_text | default: block.settings.nl_heading | default: 'JOIN THE DROP' -%}
        {%- assign mq_speed = block.settings.nl_marquee_speed | default: 30 -%}
        {%- assign mq_dir = block.settings.nl_marquee_direction | default: 'left' -%}
        {%- assign mq_pause = block.settings.nl_marquee_pause_hover -%}

        <div class="fnl" {{ block.shopify_attributes }} style="
          --fnl-bg: {{ block.settings.nl_bg_color | default: '#111111' }};
          --fnl-text: {{ block.settings.nl_text_color | default: '#ffffff' }};
          --fnl-border: {{ block.settings.nl_border_color | default: '#333333' }};
          --fnl-btn-bg: {{ block.settings.nl_btn_bg | default: '#ffffff' }};
          --fnl-btn-text: {{ block.settings.nl_btn_text | default: '#0a0a0a' }};
          --fnl-mq-size: {{ block.settings.nl_marquee_size_mobile | default: 28 }}px;
          --fnl-mq-size-d: {{ block.settings.nl_marquee_size_desktop | default: 42 }}px;
          --fnl-mq-weight: {{ block.settings.nl_marquee_weight | default: '800' }};
          --fnl-mq-spacing: {{ block.settings.nl_marquee_spacing | default: 4 }}px;
          --fnl-mq-speed: {{ mq_speed }}s;
          --fnl-sub-size: {{ block.settings.nl_subcopy_size | default: 13 }}px;
          --fnl-sub-weight: {{ block.settings.nl_subcopy_weight | default: '400' }};
          --fnl-pad-top: {{ block.settings.nl_padding_top | default: 32 }}px;
          --fnl-pad-bottom: {{ block.settings.nl_padding_bottom | default: 32 }}px;
        ">

          {%- if block.settings.nl_marquee_enabled -%}
          <div class="fnl__marquee" aria-hidden="true"{% if mq_pause %} data-fnl-pause{% endif %}>
            <div class="fnl__marquee-track" data-fnl-dir="{{ mq_dir }}">
              {%- for i in (1..6) -%}
                <span class="fnl__marquee-item">{{ mq_text }}&nbsp;&nbsp;&nbsp;✦&nbsp;&nbsp;&nbsp;</span>
              {%- endfor -%}
            </div>
            <div class="fnl__marquee-track" data-fnl-dir="{{ mq_dir }}" aria-hidden="true">
              {%- for i in (1..6) -%}
                <span class="fnl__marquee-item">{{ mq_text }}&nbsp;&nbsp;&nbsp;✦&nbsp;&nbsp;&nbsp;</span>
              {%- endfor -%}
            </div>
          </div>
          {%- endif -%}

          {%- if block.settings.nl_subcopy_enabled and block.settings.nl_subtext != blank -%}
            <p class="fnl__subcopy">{{ block.settings.nl_subtext | escape }}</p>
          {%- endif -%}

          {%- if block.settings.nl_form_enabled -%}
          {% form 'customer', class: 'fnl__form', id: nl_id %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            {%- if form.posted_successfully? -%}
              <p class="fnl__success" role="status">
                {{ block.settings.nl_success | default: 'Thank you for subscribing!' | escape }}
              </p>
            {%- else -%}
              {%- if form.errors -%}
                <p class="fnl__error" role="alert">{{ form.errors | default_errors }}</p>
              {%- endif -%}
              <div class="fnl__capsule">
                <label for="{{ nl_id }}-email" class="sr-only">
                  {{ block.settings.nl_placeholder | default: 'Your email' | escape }}
                </label>
                <input
                  id="{{ nl_id }}-email"
                  class="fnl__input"
                  type="email"
                  name="contact[email]"
                  autocomplete="email"
                  required
                  placeholder="{{ block.settings.nl_placeholder | default: 'Your email' | escape }}"
                  aria-label="{{ block.settings.nl_placeholder | default: 'Your email' | escape }}"
                >
                <button class="fnl__btn" type="submit">
                  {{ block.settings.nl_btn_label | default: 'Subscribe' | escape }}
                  <svg class="fnl__btn-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </div>
            {%- endif -%}
          {% endform %}
          {%- endif -%}

        </div>

      {%- comment -%} accordion_link blocks are rendered inside their parent group — skip here {%- endcomment -%}
      {%- endif -%}

    {%- endfor -%}
    {%- if fam2_in_list -%}</ul>{%- endif -%}

    {%- comment -%} ── Social Icons ── {%- endcomment -%}
    {%- assign has_social = false -%}
    {%- if section.settings.social_instagram != blank
      or section.settings.social_tiktok != blank
      or section.settings.social_facebook != blank
      or section.settings.social_pinterest != blank
      or section.settings.social_youtube != blank -%}
      {%- assign has_social = true -%}
    {%- endif -%}

    {%- if has_social -%}
      <div class="fam2__social" role="list">

        {%- if section.settings.social_instagram != blank -%}
          <a
            class="fam2__social-link"
            href="{{ section.settings.social_instagram }}"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="{{ 'general.social.instagram' | t | default: 'Instagram' }}"
            role="listitem"
          >
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.social_tiktok != blank -%}
          <a
            class="fam2__social-link"
            href="{{ section.settings.social_tiktok }}"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="{{ 'general.social.tiktok' | t | default: 'TikTok' }}"
            role="listitem"
          >
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.16 8.16 0 004.77 1.52V6.75a4.84 4.84 0 01-1-.06z"/>
            </svg>
          </a>
