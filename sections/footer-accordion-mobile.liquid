    {%- endif -%}

    {%- comment -%} ── Legal / Copyright ── {%- endcomment -%}
    {%- if section.settings.legal_text != blank -%}
      <p class="fam2__legal">
        {{- section.settings.legal_text -}}
      </p>
    {%- endif -%}

  {%- comment -%} ── Bottom Bar: Locale · Copyright · Payment Icons ── {%- endcomment -%}
  <div class="fam2-bar" style="
    --fam2-bar-text: {{ section.settings.bar_text_color | default: '#888888' }};
    --fam2-bar-icon-radius: {{ section.settings.bar_icon_radius | default: 4 }}px;
    --fam2-bar-gap: {{ section.settings.bar_spacing | default: 6 }}px;
  ">

    {%- if section.settings.bar_show_locale -%}
    <div class="fam2-bar__row fam2-bar__locale-row">
      <span class="fam2-bar__locale">
        <svg class="fam2-bar__globe" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
        {{ cart.currency.symbol }} {{ cart.currency.iso_code }} / {{ localization.language.iso_code | upcase }}
        <svg class="fam2-bar__chevron" xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
      </span>
    </div>
    {%- endif -%}

    <div class="fam2-bar__row fam2-bar__legal-row">
      <span class="fam2-bar__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
        {%- if section.settings.bar_show_powered %}
          {{ powered_by_link }}
        {%- endif -%}
      </span>
    </div>

    {%- if section.settings.bar_show_payments -%}
      {%- if shop.enabled_payment_types.size > 0 -%}
      <div class="fam2-bar__row fam2-bar__payments">
        <ul class="fam2-bar__pay-list" role="list" aria-label="Accepted payment methods">
          {%- for type in shop.enabled_payment_types -%}
            <li class="fam2-bar__pay-icon">
              {{ type | payment_type_svg_tag: class: 'fam2-bar__pay-svg' }}
            </li>
          {%- endfor -%}
        </ul>
      </div>
      {%- endif -%}
    {%- endif -%}

  </div>

  </div>{%- comment -%} /.fam2__inner {%- endcomment -%}

  {%- comment -%} ── Floating Chat Button ── {%- endcomment -%}
  {%- if section.settings.chat_url != blank -%}
    <a
      class="fam2__chat"
      href="{{ section.settings.chat_url }}"
      aria-label="{{ section.settings.chat_label | default: 'Liên hệ hỗ trợ' | escape }}"
    >
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/>
      </svg>
    </a>
  {%- endif -%}

</footer-accordion-mobile>

<script src="{{ 'fam2.js' | asset_url }}" defer></script>

