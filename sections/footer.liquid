<footer-section id="site-footer" class="dx-footer text-white">

  <div class="dx-footer__shell">
    <div class="dx-footer__headline-band" aria-hidden="true">
      {%- assign footer_marquee = section.settings.marquee_text | default: section.settings.newsletter_heading | default: shop.name -%}
      <div class="dx-footer__headline-rail">
        <span class="dx-footer__headline-outline">{{ footer_marquee }}</span>
        <span class="dx-footer__headline-solid">{{ footer_marquee }}</span>
        <span class="dx-footer__headline-outline">{{ footer_marquee }}</span>
      </div>
      <span class="dx-footer__headline-blur dx-footer__headline-blur--left"></span>
      <span class="dx-footer__headline-blur dx-footer__headline-blur--right"></span>
    </div>

    <div class="dx-footer__main{% if section.blocks.size == 0 %} dx-footer__main--single{% endif %}">
      <div class="dx-footer__brand ft-brand-section" data-footer-col>
        <div class="dx-footer__brand-stack">
          {%- if section.settings.brand_description != blank -%}
            <p class="dx-footer__brand-desc font-body">{{ section.settings.brand_description }}</p>
          {%- endif -%}
          {%- if section.settings.show_newsletter -%}
            <div class="dx-footer__newsletter-form">
              {% form 'customer', id: 'footer-newsletter-form' %}
                {%- if form.posted_successfully? -%}
                  <p class="dx-footer__newsletter-state dx-footer__newsletter-state--success">{{ 'footer.newsletter.success' | t }}</p>
                {%- elsif form.errors -%}
                  <p class="dx-footer__newsletter-state dx-footer__newsletter-state--error">
                    {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
                  </p>
                {%- else -%}
                  <div class="dx-footer__newsletter-row">
                    <label for="footer-email" class="sr-only">{{ section.settings.newsletter_placeholder | default: 'Enter your email' }}</label>
                    <input
                      type="email"
                      name="contact[email]"
                      id="footer-email"
                      placeholder="{{ section.settings.newsletter_placeholder | default: 'Enter your email' }}"
                      required
                      autocomplete="email"
                      class="dx-footer__newsletter-input font-body"
                    >
                    <button
                      type="submit"
                      class="dx-footer__newsletter-btn font-body cursor-pointer"
                    >
                      {{ section.settings.newsletter_button | default: 'Subscribe' }}
                    </button>
                  </div>
                {%- endif -%}
              {% endform %}
            </div>
          {%- endif -%}
        </div>
      </div>

      <div class="dx-footer__link-grid" id="dx-footer-link-grid">
        <div class="dx-footer__menu-col" data-footer-col data-footer-group="quick-links">
          <h3 class="dx-footer__menu-title font-body">Quick links</h3>
          <ul class="dx-footer__menu-list" role="list" data-footer-list="quick-links"></ul>
        </div>
        <div class="dx-footer__menu-col" data-footer-col data-footer-group="support">
          <h3 class="dx-footer__menu-title font-body">Support</h3>
          <ul class="dx-footer__menu-list" role="list" data-footer-list="support"></ul>
        </div>
        <div class="dx-footer__menu-col" data-footer-col data-footer-group="follow-us">
          <h3 class="dx-footer__menu-title font-body">Follow us on</h3>
          <ul class="dx-footer__menu-list" role="list" data-footer-list="follow-us"></ul>
        </div>
      </div>
    </div>

    <div class="dx-footer__bar" aria-hidden="true">
      <div class="dx-footer__bar-inner" data-footer-col>
        <div class="dx-footer__locale font-body" aria-label="Store locale">
          <span class="dx-footer__locale-globe" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.55" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a15 15 0 0 1 0 18"/><path d="M12 3a15 15 0 0 0 0 18"/></svg>
          </span>
          <span>{{ cart.currency.iso_code }} / {{ request.locale.iso_code | upcase }}</span>
        </div>
        <p class="dx-footer__copyright font-body">
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
          {%- if section.settings.copyright_text != blank -%}
            {{ section.settings.copyright_text }}
          {%- else -%}
            All rights reserved.
          {%- endif -%}
        </p>
        {%- if section.settings.show_payment_icons -%}
          <div class="dx-footer__payments" aria-label="Accepted payment methods">
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'dx-footer__payment-icon' }}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

</footer-section>

<script>
  (() => {
    const renderDesktopFooterFromMobile = () => {
      const dataNode = document.getElementById('fam2-footer-data');
      const host = document.getElementById('dx-footer-link-grid');
      if (!dataNode || !host) return;

      let payload;
      try {
        payload = JSON.parse(dataNode.textContent);
      } catch (_error) {
        return;
      }

      const renderList = (key, items) => {
        const list = host.querySelector(`[data-footer-list="${key}"]`);
        if (!list) return;
        list.innerHTML = '';
        items.forEach((item) => {
          if (!item || !item.title) return;
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.className = 'dx-footer__menu-link font-body';
          a.textContent = item.title;
          a.href = item.url || '#';
          if (item.external) {
            a.target = '_blank';
            a.rel = 'noopener noreferrer';
          }
          if (key === 'follow-us' && item.external) {
            const icon = document.createElement('span');
            icon.className = 'dx-footer__menu-link-external';
            icon.textContent = '↗';
            icon.setAttribute('aria-hidden', 'true');
            a.appendChild(icon);
          }
          li.appendChild(a);
          list.appendChild(li);
        });
      };

      renderList('quick-links', payload.quickLinks || []);
      renderList('support', payload.support || []);
      renderList('follow-us', payload.social || []);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', renderDesktopFooterFromMobile, { once: true });
    } else {
      renderDesktopFooterFromMobile();
    }

    document.addEventListener('shopify:section:load', renderDesktopFooterFromMobile);
    document.addEventListener('shopify:section:reorder', renderDesktopFooterFromMobile);
  })();
</script>

<style>
  .dx-footer {
    display: block;
  }

  @media (max-width: 767px) {
    .dx-footer {
      display: none;
    }
  }

  @media (min-width: 768px) {
    .dx-footer {
      position: relative;
      background: #222225;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      overflow: clip;
    }

    .dx-footer__shell {
      width: min(100%, 2048px);
      margin: 0 auto;
      padding-inline: 0;
    }

    .dx-footer__headline-band {
      position: relative;
      overflow: hidden;
      padding-top: 0;
      padding-bottom: clamp(1.25rem, 2vw, 1.9rem);
    }

    .dx-footer__headline-rail {
      display: flex;
      align-items: baseline;
      gap: clamp(1.8rem, 2.4vw, 2.8rem);
      width: max-content;
      min-width: 100%;
      white-space: nowrap;
      transform: translateX(-24%);
    }

    .dx-footer__headline-solid,
    .dx-footer__headline-outline {
      font-family: var(--font-heading, sans-serif);
      font-size: clamp(4.8rem, 8vw, 8rem);
      font-weight: 500;
      line-height: 0.88;
      letter-spacing: -0.055em;
      text-transform: none;
    }

    .dx-footer__headline-solid {
      color: rgba(255, 255, 255, 0.97);
    }

    .dx-footer__headline-outline {
      color: transparent;
      -webkit-text-stroke: 1px rgba(255, 255, 255, 0.2);
    }

    .dx-footer__headline-blur {
      position: absolute;
      top: 0;
      bottom: 0;
      width: clamp(4rem, 11vw, 14rem);
      pointer-events: none;
      z-index: 1;
    }

    .dx-footer__headline-blur--left {
      left: 0;
      background: linear-gradient(90deg, #222225 0%, rgba(34, 34, 37, 0.86) 40%, rgba(34, 34, 37, 0) 100%);
    }

    .dx-footer__headline-blur--right {
      right: 0;
      background: linear-gradient(270deg, #222225 0%, rgba(34, 34, 37, 0.86) 40%, rgba(34, 34, 37, 0) 100%);
    }

    .dx-footer__main {
      display: grid;
      grid-template-columns: minmax(0, 1.08fr) minmax(0, 1.52fr);
      gap: clamp(3rem, 4vw, 5rem);
      align-items: start;
      padding-top: 0;
      padding-inline: clamp(1.5rem, 3vw, 2rem);
      padding-bottom: clamp(4.4rem, 5vw, 5.4rem);
    }

    .dx-footer__newsletter-row {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.35rem;
      border: 1px solid rgba(112, 118, 171, 0.18);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.06);
      width: min(100%, 45rem);
    }

    .dx-footer__newsletter-state {
      margin: 0;
      font-size: 0.92rem;
      line-height: 1.45;
      color: rgba(255, 255, 255, 0.8);
    }

    .dx-footer__newsletter-state--success {
      color: rgba(255, 255, 255, 0.88);
    }

    .dx-footer__newsletter-state--error {
      color: #f1c7bf;
    }

    .dx-footer__newsletter-input {
      flex: 1 1 0;
      max-width: none;
      border: 0;
      border-radius: 999px;
      background: transparent;
      min-height: 0;
      padding: 1rem 1.35rem;
      font-size: 1rem;
      font-weight: 400;
      letter-spacing: -0.01em;
      text-transform: none;
      color: rgba(255, 255, 255, 0.92);
      box-shadow: none;
    }

    .dx-footer__newsletter-input::placeholder {
      color: rgba(255, 255, 255, 0.34);
      letter-spacing: -0.01em;
    }

    .dx-footer__newsletter-input:focus {
      outline: none;
    }

    .dx-footer__newsletter-btn {
      border: 0;
      border-radius: 999px;
      background: #f4f1ec;
      color: #111111;
      min-height: 0;
      padding: 1rem 3.45rem;
      font-size: 1rem;
      font-weight: 400;
      letter-spacing: -0.01em;
      text-transform: none;
      white-space: nowrap;
    }

    .dx-footer__newsletter-btn:hover {
      background: #ffffff;
      color: #111111;
      opacity: 1;
    }

    .dx-footer__main--single {
      grid-template-columns: minmax(0, 1fr);
    }

    .dx-footer__brand-stack {
      display: flex;
      flex-direction: column;
      gap: 2.4rem;
      padding-right: clamp(2rem, 3.5vw, 4rem);
    }

    .dx-footer__brand-desc {
      max-width: 44rem;
      margin: 0;
      padding-right: 0;
      font-size: clamp(1rem, 1.12vw, 1.12rem);
      line-height: 1.5;
      color: rgba(255, 255, 255, 0.84);
    }

    .dx-footer__link-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: clamp(2rem, 2vw, 3rem);
      padding-left: clamp(2.25rem, 3vw, 3.25rem);
      border-left: 1px solid rgba(255, 255, 255, 0.08);
    }

    .dx-footer__menu-title {
      margin: 0 0 1.35rem;
      font-family: var(--font-body, sans-serif);
      font-size: 1.08rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      text-transform: none;
      color: rgba(255, 255, 255, 0.96);
    }

    .dx-footer__menu-list {
      display: flex;
      flex-direction: column;
      gap: 0.88rem;
      margin: 0;
      padding: 0;
    }

    .dx-footer__menu-link {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      position: relative;
      width: fit-content;
      padding-bottom: 0.1rem;
      font-size: 0.98rem;
      line-height: 1.42;
      letter-spacing: -0.01em;
      color: rgba(255, 255, 255, 0.76);
      transition: color 0.24s ease;
      text-transform: uppercase;
    }

    .dx-footer__menu-link::after {
      content: '';
      position: absolute;
      left: 0;
      bottom: -0.18rem;
      width: 100%;
      height: 1px;
      background: currentColor;
      transform: scaleX(0);
      transform-origin: right center;
      transition: transform 0.28s ease;
    }

    .dx-footer__menu-link:hover::after {
      transform: scaleX(1);
      transform-origin: left center;
    }

    .dx-footer__menu-link:hover {
      color: #ffffff;
    }

    .dx-footer__menu-link-external {
      font-size: 0.9em;
      line-height: 1;
      transform: translateY(-0.02em);
    }

    .dx-footer__bar {
      display: none;
    }

    .dx-footer__bar-inner {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      align-items: center;
      gap: 1.5rem;
    }

    .dx-footer__locale {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      font-size: 0.9rem;
      color: rgba(255, 255, 255, 0.58);
    }

    .dx-footer__locale-globe {
      display: inline-flex;
      align-items: center;
    }

    .dx-footer__copyright {
      justify-self: center;
      font-size: 0.92rem;
      letter-spacing: -0.01em;
      text-transform: none;
      color: rgba(255, 255, 255, 0.52);
      text-align: center;
    }

    .dx-footer__payments {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 0.45rem;
    }

    .dx-footer__payment-icon {
      height: 1.45rem;
      width: auto;
      opacity: 0.88;
      transition: opacity 0.2s ease;
    }

    .dx-footer__payment-icon:hover {
      opacity: 1;
    }
  }

  @media (min-width: 768px) and (max-width: 1120px) {
    .dx-footer__main,
    .dx-footer__bar-inner {
      grid-template-columns: 1fr;
    }

    .dx-footer__link-grid {
      padding-left: 0;
      border-left: 0;
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      padding-top: 2rem;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .dx-footer__brand-stack {
      padding-right: 0;
    }

    .dx-footer__payments,
    .dx-footer__copyright {
      justify-self: start;
      text-align: left;
    }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "site-footer",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand description",
      "default": "Premium fashion for the modern lifestyle."
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "marquee_text",
      "label": "Marquee text",
      "default": "Your Favorite Styles at Unmissable Prices!"
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "label": "Newsletter subtext",
      "default": "Get early access to new drops, exclusive offers, and style inspiration."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "newsletter_button",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "title": "Shop",
          "menu": "main-menu"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "title": "Support",
          "menu": "footer"
        }
