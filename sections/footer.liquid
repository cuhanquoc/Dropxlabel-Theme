    { "type": "text", "id": "col3_title", "label": "Column Title", "default": "Customer Care" },
    { "type": "text", "id": "c3_link1_label", "label": "Link 1 Label", "default": "Size Guide" },
    { "type": "url",  "id": "c3_link1_url",   "label": "Link 1 URL" },
    { "type": "text", "id": "c3_link2_label", "label": "Link 2 Label", "default": "Help & FAQs" },
    { "type": "url",  "id": "c3_link2_url",   "label": "Link 2 URL" },
    { "type": "text", "id": "c3_link3_label", "label": "Link 3 Label", "default": "Return My Order" },
    { "type": "url",  "id": "c3_link3_url",   "label": "Link 3 URL" },
    { "type": "text", "id": "c3_link4_label", "label": "Link 4 Label", "default": "Refer a Friend" },
    { "type": "url",  "id": "c3_link4_url",   "label": "Link 4 URL" },

    { "type": "header", "content": "── Terms & Policies Column ──" },
    { "type": "text", "id": "col4_title", "label": "Column Title", "default": "Terms & Policies" },
    { "type": "text", "id": "c4_link1_label", "label": "Link 1 Label", "default": "Duties & Taxes" },
    { "type": "url",  "id": "c4_link1_url",   "label": "Link 1 URL" },
    { "type": "text", "id": "c4_link2_label", "label": "Link 2 Label", "default": "Shipping Info" },
    { "type": "url",  "id": "c4_link2_url",   "label": "Link 2 URL" },
    { "type": "text", "id": "c4_link3_label", "label": "Link 3 Label", "default": "Privacy Policy" },
    { "type": "url",  "id": "c4_link3_url",   "label": "Link 3 URL" },
    { "type": "text", "id": "c4_link4_label", "label": "Link 4 Label", "default": "Terms Conditions" },
    { "type": "url",  "id": "c4_link4_url",   "label": "Link 4 URL" },

    { "type": "header", "content": "── Follow Us Column ──" },
