    { "type": "text", "id": "c4_link1_label", "label": "Link 1 Label", "default": "Duties & Taxes" },
    { "type": "url",  "id": "c4_link1_url",   "label": "Link 1 URL" },
    { "type": "text", "id": "c4_link2_label", "label": "Link 2 Label", "default": "Shipping Info" },
    { "type": "url",  "id": "c4_link2_url",   "label": "Link 2 URL" },
    { "type": "text", "id": "c4_link3_label", "label": "Link 3 Label", "default": "Privacy Policy" },
