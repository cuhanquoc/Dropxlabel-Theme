<!-- ══════════════════════════════════════════════
     FOOTER — Quiet Luxury | Mobile-first from Stitch
══════════════════════════════════════════════ -->

<style>

  /* ── Footer Accordion (mobile) ── */
  .ft-accordion-icon {
    position: relative;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  .ft-accordion-icon::before,
  .ft-accordion-icon::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    background: rgba(255,255,255,0.5);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  /* Horizontal bar */
  .ft-accordion-icon::before {
    width: 12px;
    height: 1.5px;
    transform: translate(-50%, -50%);
  }
  /* Vertical bar → becomes 0 when open */
  .ft-accordion-icon::after {
    width: 1.5px;
    height: 12px;
    transform: translate(-50%, -50%);
  }
  /* Open state: rotate to minus */
  [aria-expanded="true"] .ft-accordion-icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
    opacity: 0;
  }
</style>

<footer id="site-footer" class="block bg-[#0a0a0a] text-white font-body" role="contentinfo">

  <!-- ── NEWSLETTER SECTION (full-width on mobile) ── -->
  <div class="px-6 md:px-10 lg:px-14 pt-12 pb-8 md:pt-20 md:pb-14">
    <div class="max-w-screen-xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr] gap-10 lg:gap-14">

      <!-- COL 1: Heading + Description + Newsletter -->
      <div class="max-w-[400px]">
        <!-- Large stylized heading (mobile-prominent) -->
        <h2 class="font-heading text-[clamp(2rem,8vw,3.5rem)] leading-[1.05] font-semibold tracking-[-0.02em] text-white mb-4 md:mb-6">
          {{ section.settings.newsletter_heading | default: 'Your Favorite Store' }}
        </h2>

        <p class="font-body text-[0.88rem] leading-[1.7] text-white/50 mb-8">
          {{ section.settings.newsletter_text | default: 'Whether you\'re looking for chic essentials, statement outfits, or casual staples, we\'ve got something to suit every style. Browse our fresh arrivals and update your wardrobe with the season\'s hottest looks today!' }}
        </p>

        <!-- Newsletter Form -->
        {%- form 'customer', id: 'footer-newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter" />
          <div class="flex items-center rounded-full border border-white/20 overflow-hidden max-w-[400px] transition-colors duration-300 focus-within:border-white/50">
            <label for="footer-email" class="sr-only">Email address</label>
            <input
              id="footer-email"
              name="contact[email]"
              type="email"
              class="flex-1 bg-transparent border-none text-white font-body text-[0.82rem] tracking-[0.03em] py-4 px-6 outline-none min-w-0 placeholder:text-white/30"
              placeholder="Email"
              required
              autocomplete="email"
            />
            <button type="submit" class="shrink-0 font-body text-[0.72rem] font-semibold uppercase tracking-[0.15em] text-[#0a0a0a] bg-white border-none rounded-full py-3 px-8 mr-1 cursor-pointer whitespace-nowrap transition-all duration-300 hover:bg-white/90">
              Subscribe
            </button>
          </div>
        {%- endform -%}
      </div>

      <!-- COL 2: Quick Links -->
      <div class="md:pt-0" data-ft-accordion>
        <!-- Desktop title -->
        <p class="hidden md:block font-body text-[0.72rem] font-medium uppercase tracking-[0.2em] text-white/40 mb-5">
          {{ section.settings.col2_title | default: 'Quick links' }}
        </p>
        <!-- Mobile accordion toggle -->
        <button
          class="flex md:hidden items-center justify-between w-full py-5 bg-transparent border-none border-b border-white/[0.08] cursor-pointer text-white"
          aria-expanded="false"
          data-ft-toggle
        >
          <span class="font-body text-base font-semibold">{{ section.settings.col2_title | default: 'Quick links' }}</span>
          <span class="ft-accordion-icon" aria-hidden="true"></span>
        </button>
        <nav
          class="hidden md:flex flex-col gap-0"
          data-ft-panel
          aria-label="{{ section.settings.col2_title | default: 'Quick links' }}"
        >
        
          <div class="py-3 md:py-0 flex flex-col gap-0">
            {% if section.settings.c2_link1_label != blank %}<a href="{{ section.settings.c2_link1_url | default: '#' }}" class="block font-body text-[0.82rem] text-white/50 no-underline py-[0.45rem] transition-colors duration-300 hover:text-white uppercase tracking-[0.08em]">{{ section.settings.c2_link1_label }}</a>{% endif %}
            {% if section.settings.c2_link2_label != blank %}<a href="{{ section.settings.c2_link2_url | default: '#' }}" class="block font-body text-[0.82rem] text-white/50 no-underline py-[0.45rem] transition-colors duration-300 hover:text-white uppercase tracking-[0.08em]">{{ section.settings.c2_link2_label }}</a>{% endif %}
            {% if section.settings.c2_link3_label != blank %}<a href="{{ section.settings.c2_link3_url | default: '#' }}" class="block font-body text-[0.82rem] text-white/50 no-underline py-[0.45rem] transition-colors duration-300 hover:text-white uppercase tracking-[0.08em]">{{ section.settings.c2_link3_label }}</a>{% endif %}
            {% if section.settings.c2_link4_label != blank %}<a href="{{ section.settings.c2_link4_url | default: '#' }}" class="block font-body text-[0.82rem] text-white/50 no-underline py-[0.45rem] transition-colors duration-300 hover:text-white uppercase tracking-[0.08em]">{{ section.settings.c2_link4_label }}</a>{% endif %}
            {% if section.settings.c2_link5_label != blank %}<a href="{{ section.settings.c2_link5_url | default: '#' }}" class="block font-body text-[0.82rem] text-white/50 no-underline py-[0.45rem] transition-colors duration-300 hover:text-white uppercase tracking-[0.08em]">{{ section.settings.c2_link5_label }}</a>{% endif %}
            {% if section.settings.c2_link6_label != blank %}<a href="{{ section.settings.c2_link6_url | default: '#' }}" class="block font-body text-[0.82rem] text-white/50 no-underline py-[0.45rem] transition-colors duration-300 hover:text-white uppercase tracking-[0.08em]">{{ section.settings.c2_link6_label }}</a>{% endif %}
          </div>
        </nav>
      </div>

      <!-- COL 3: Support -->
      <div class="md:pt-0" data-ft-accordion>
        <p class="hidden md:block font-body text-[0.72rem] font-medium uppercase tracking-[0.2em] text-white/40 mb-5">
          {{ section.settings.col3_title | default: 'Support' }}
        </p>
        <button
          class="flex md:hidden items-center justify-between w-full py-5 bg-transparent border-none border-b border-white/[0.08] cursor-pointer text-white"
          aria-expanded="false"
          data-ft-toggle
        >
          <span class="font-body text-base font-semibold">{{ section.settings.col3_title | default: 'Support' }}</span>
          <span class="ft-accordion-icon" aria-hidden="true"></span>
        </button>
        <nav
          class="hidden md:flex flex-col gap-0"
          data-ft-panel
          aria-label="{{ section.settings.col3_title | default: 'Support' }}"
        >
          <div class="py-3 md:py-0 flex flex-col gap-0">
            {% if section.settings.c3_link1_label != blank %}<a href="{{ section.settings.c3_link1_url | default: '#' }}" class="block font-body text-[0.82rem] text-white/50 no-underline py-[0.45rem] transition-colors duration-300 hover:text-white uppercase tracking-[0.08em]">{{ section.settings.c3_link1_label }}</a>{% endif %}
            {% if section.settings.c3_link2_label != blank %}<a href="{{ section.settings.c3_link2_url | default: '#' }}" class="block font-body text-[0.82rem] text-white/50 no-underline py-[0.45rem] transition-colors duration-300 hover:text-white uppercase tracking-[0.08em]">{{ section.settings.c3_link2_label }}</a>{% endif %}
            {% if section.settings.c3_link3_label != blank %}<a href="{{ section.settings.c3_link3_url | default: '#' }}" class="block font-body text-[0.82rem] text-white/50 no-underline py-[0.45rem] transition-colors duration-300 hover:text-white uppercase tracking-[0.08em]">{{ section.settings.c3_link3_label }}</a>{% endif %}
            {% if section.settings.c3_link4_label != blank %}<a href="{{ section.settings.c3_link4_url | default: '#' }}" class="block font-body text-[0.82rem] text-white/50 no-underline py-[0.45rem] transition-colors duration-300 hover:text-white uppercase tracking-[0.08em]">{{ section.settings.c3_link4_label }}</a>{% endif %}
            {% if section.settings.c3_link5_label != blank %}<a href="{{ section.settings.c3_link5_url | default: '#' }}" class="block font-body text-[0.82rem] text-white/50 no-underline py-[0.45rem] transition-colors duration-300 hover:text-white uppercase tracking-[0.08em]">{{ section.settings.c3_link5_label }}</a>{% endif %}
            {% if section.settings.c3_link6_label != blank %}<a href="{{ section.settings.c3_link6_url | default: '#' }}" class="block font-body text-[0.82rem] text-white/50 no-underline py-[0.45rem] transition-colors duration-300 hover:text-white uppercase tracking-[0.08em]">{{ section.settings.c3_link6_label }}</a>{% endif %}
          </div>
        </nav>
      </div>

      <!-- COL 4: Follow Us (text links with arrow icons) -->
      <div class="md:pt-0" data-ft-accordion>
        <p class="hidden md:block font-body text-[0.72rem] font-medium uppercase tracking-[0.2em] text-white/40 mb-5">
          Follow us on
        </p>
        <button
          class="flex md:hidden items-center justify-between w-full py-5 bg-transparent border-none border-b border-white/[0.08] cursor-pointer text-white"
          aria-expanded="false"
          data-ft-toggle
        >
          <span class="font-body text-base font-semibold">Follow us on</span>
          <span class="ft-accordion-icon" aria-hidden="true"></span>
        </button>
        <nav
          class="hidden md:flex flex-col gap-0"
          data-ft-panel
          aria-label="Social media links"
        >
          <div class="py-3 md:py-0 flex flex-col gap-0">
            {% if section.settings.social_facebook != blank %}
            <a href="{{ section.settings.social_facebook }}" class="group flex items-center gap-1.5 font-body text-[0.82rem] text-white/50 no-underline py-[0.45rem] transition-colors duration-300 hover:text-white" target="_blank" rel="noopener">
              Facebook
              <svg class="w-3 h-3 opacity-50 group-hover:opacity-100 transition-opacity duration-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M7 7h10v10"/></svg>
            </a>
            {% endif %}
            {% if section.settings.social_twitter != blank %}
            <a href="{{ section.settings.social_twitter }}" class="group flex items-center gap-1.5 font-body text-[0.82rem] text-white/50 no-underline py-[0.45rem] transition-colors duration-300 hover:text-white" target="_blank" rel="noopener">
              X
              <svg class="w-3 h-3 opacity-50 group-hover:opacity-100 transition-opacity duration-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M7 7h10v10"/></svg>
            </a>
            {% endif %}
            {% if section.settings.social_instagram != blank %}
            <a href="{{ section.settings.social_instagram }}" class="group flex items-center gap-1.5 font-body text-[0.82rem] text-white/50 no-underline py-[0.45rem] transition-colors duration-300 hover:text-white" target="_blank" rel="noopener">
              Instagram
              <svg class="w-3 h-3 opacity-50 group-hover:opacity-100 transition-opacity duration-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M7 7h10v10"/></svg>
            </a>
            {% endif %}
            {% if section.settings.social_youtube != blank %}
            <a href="{{ section.settings.social_youtube }}" class="group flex items-center gap-1.5 font-body text-[0.82rem] text-white/50 no-underline py-[0.45rem] transition-colors duration-300 hover:text-white" target="_blank" rel="noopener">
              YouTube
              <svg class="w-3 h-3 opacity-50 group-hover:opacity-100 transition-opacity duration-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M7 7h10v10"/></svg>
            </a>
            {% endif %}
            {% if section.settings.social_tiktok != blank %}
            <a href="{{ section.settings.social_tiktok }}" class="group flex items-center gap-1.5 font-body text-[0.82rem] text-white/50 no-underline py-[0.45rem] transition-colors duration-300 hover:text-white" target="_blank" rel="noopener">
              Pinterest
              <svg class="w-3 h-3 opacity-50 group-hover:opacity-100 transition-opacity duration-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M7 7h10v10"/></svg>
            </a>
            {% endif %}
          </div>
        </nav>
      </div>

    </div>
  </div>

  <!-- ── BOTTOM BAR ── -->
  <div class="flex flex-col md:flex-row items-center md:items-center justify-between gap-4 px-6 md:px-10 lg:px-14 py-5 border-t border-white/[0.06]">

    <!-- Left: Localization -->
    <div class="flex items-center gap-3 text-white/40 text-[0.75rem]">
      {%- form 'localization', id: 'FooterLanguageCurrencyForm', class: 'flex items-center gap-2' -%}
        {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
          <div class="flex items-center gap-1 cursor-pointer hover:text-white/60 transition-colors duration-200">
            <span class="text-base">🇺🇸</span>
            <span class="font-body text-[0.75rem] tracking-wide">
              {{ localization.country.currency.iso_code }} / {{ localization.language.iso_code | upcase }}
            </span>
            <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>

    <!-- Center: Copyright -->
    <p class="font-body text-[0.72rem] text-white/30 text-center">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
      <a href="https://www.shopify.com" class="text-white/30 no-underline hover:text-white/50 transition-colors duration-200" target="_blank" rel="noopener">Powered by Shopify</a>
    </p>

    <!-- Right: Payment Icons + Scroll to Top -->
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-1 flex-wrap" aria-label="Accepted payment methods">
        {%- for type in shop.enabled_payment_types -%}
          <span class="inline-flex items-center justify-center h-6 opacity-50 hover:opacity-80 transition-opacity duration-300">{{ type | payment_type_svg_tag }}</span>
        {%- endfor -%}
      </div>
      <!-- Scroll to Top -->
      <button class="flex items-center justify-center w-9 h-9 rounded-full border border-white/15 bg-transparent text-white cursor-pointer transition-all duration-300 hover:bg-white/10 hover:border-white/30 shrink-0" onclick="window.scrollTo({top: 0, behavior: 'smooth'})" aria-label="Scroll to top">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m18 15-6-6-6 6"/>
        </svg>
      </button>
    </div>

  </div>

</footer>

<script>
  (function () {
    var footer = document.getElementById('site-footer');
    if (!footer) return;
    var toggles = footer.querySelectorAll('[data-ft-toggle]');

    toggles.forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (window.innerWidth >= 768) return;
        var parent = btn.closest('[data-ft-accordion]');
        var panel = parent ? parent.querySelector('[data-ft-panel]') : null;
        if (!panel) return;
        var isExpanded = btn.getAttribute('aria-expanded') === 'true';

        btn.setAttribute('aria-expanded', !isExpanded);

        if (isExpanded) {
          panel.classList.remove('flex');
          panel.classList.add('hidden');
        } else {
          panel.classList.remove('hidden');
          panel.classList.add('flex');
        }
      });
    });
  }());
</script>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "── Newsletter ──" },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "Your Favorite Store"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter Description",
      "default": "Whether you're looking for chic essentials, statement outfits, or casual staples, we've got something to suit every style. Browse our fresh arrivals and update your wardrobe with the season's hottest looks today!"
    },

    { "type": "header", "content": "── Quick Links ──" },
    { "type": "text", "id": "col2_title", "label": "Column Title", "default": "Quick links" },
    { "type": "text", "id": "c2_link1_label", "label": "Link 1 Label", "default": "HOME" },
    { "type": "url",  "id": "c2_link1_url",   "label": "Link 1 URL" },
    { "type": "text", "id": "c2_link2_label", "label": "Link 2 Label", "default": "SEARCH" },
