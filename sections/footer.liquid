<footer-section id="site-footer" class="dx-footer text-white">

  <div class="dx-footer__shell">
    <div class="dx-footer__headline-band" aria-hidden="true">
      {%- assign footer_marquee = section.settings.marquee_text | default: section.settings.newsletter_heading | default: shop.name -%}
      <div class="dx-footer__headline-rail">
        <span class="dx-footer__headline-outline">{{ footer_marquee }}</span>
        <span class="dx-footer__headline-solid">{{ footer_marquee }}</span>
        <span class="dx-footer__headline-outline">{{ footer_marquee }}</span>
      </div>
    </div>

    {%- if section.settings.show_newsletter -%}
      <div class="dx-footer__newsletter" data-footer-col>
        <div class="dx-footer__newsletter-copy">
          {%- if section.settings.newsletter_heading != blank -%}
            <h2 class="dx-footer__newsletter-title font-heading">
              {{ section.settings.newsletter_heading }}
            </h2>
          {%- endif -%}
          {%- if section.settings.newsletter_subtext != blank -%}
            <p class="dx-footer__newsletter-subtext font-body">{{ section.settings.newsletter_subtext }}</p>
          {%- endif -%}
        </div>
        <div class="dx-footer__newsletter-form">
          {% form 'customer', id: 'footer-newsletter-form' %}
            {%- if form.posted_successfully? -%}
              <p class="dx-footer__newsletter-state dx-footer__newsletter-state--success">{{ 'footer.newsletter.success' | t }}</p>
            {%- elsif form.errors -%}
              <p class="dx-footer__newsletter-state dx-footer__newsletter-state--error">
                {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
              </p>
            {%- else -%}
              <div class="dx-footer__newsletter-row">
                <label for="footer-email" class="sr-only">{{ section.settings.newsletter_placeholder | default: 'Enter your email' }}</label>
                <input
                  type="email"
                  name="contact[email]"
                  id="footer-email"
                  placeholder="{{ section.settings.newsletter_placeholder | default: 'Enter your email' }}"
                  required
                  autocomplete="email"
                  class="dx-footer__newsletter-input font-body"
                >
                <button
                  type="submit"
                  class="dx-footer__newsletter-btn font-body cursor-pointer"
                >
                  {{ section.settings.newsletter_button | default: 'Subscribe' }}
                </button>
              </div>
            {%- endif -%}
          {% endform %}
        </div>
      </div>
    {%- endif -%}

    <div class="dx-footer__main{% if section.blocks.size == 0 %} dx-footer__main--single{% endif %}">
      <div class="dx-footer__brand ft-brand-section" data-footer-col>
        {%- if section.settings.brand_description != blank -%}
          <p class="dx-footer__brand-desc font-body">{{ section.settings.brand_description }}</p>
        {%- endif -%}
      </div>

      <div class="dx-footer__link-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'link_list' -%}
            <div class="dx-footer__menu-col" data-footer-col {{ block.shopify_attributes }}>
              {%- if block.settings.title != blank -%}
                <h3 class="dx-footer__menu-title font-body">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="dx-footer__menu-list" role="list">
                  {%- for link in block.settings.menu.links -%}
                    <li>
                      <a href="{{ link.url }}" class="dx-footer__menu-link font-body">{{ link.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="dx-footer__bar">
      <div class="dx-footer__bar-inner" data-footer-col>
        <div class="dx-footer__locale font-body" aria-label="Store locale">
          <span class="dx-footer__locale-globe" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.55" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a15 15 0 0 1 0 18"/><path d="M12 3a15 15 0 0 0 0 18"/></svg>
          </span>
          <span>{{ cart.currency.iso_code }} / {{ request.locale.iso_code | upcase }}</span>
        </div>
        <p class="dx-footer__copyright font-body">
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
          {%- if section.settings.copyright_text != blank -%}
            {{ section.settings.copyright_text }}
          {%- else -%}
            All rights reserved.
          {%- endif -%}
        </p>
        {%- if section.settings.show_payment_icons -%}
          <div class="dx-footer__payments" aria-label="Accepted payment methods">
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'dx-footer__payment-icon' }}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

</footer-section>

<style>
  .dx-footer {
    display: block;
  }

  @media (max-width: 767px) {
    .dx-footer {
      display: none;
    }
  }

  @media (min-width: 768px) {
    .dx-footer {
      position: relative;
      background: #222225;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      overflow: clip;
    }

    .dx-footer__shell {
      width: min(100%, 1600px);
      margin: 0 auto;
      padding-inline: clamp(1.5rem, 3vw, 3.5rem);
    }

    .dx-footer__headline-band {
      overflow: hidden;
      padding-top: 1rem;
      padding-bottom: clamp(2.5rem, 4vw, 3.75rem);
    }

    .dx-footer__headline-rail {
      display: flex;
      align-items: baseline;
      gap: clamp(1.25rem, 2vw, 2rem);
      width: max-content;
      min-width: 100%;
      white-space: nowrap;
    }

    .dx-footer__headline-solid,
    .dx-footer__headline-outline {
      font-family: var(--font-body, sans-serif);
      font-size: clamp(4rem, 7vw, 7rem);
      font-weight: 800;
      line-height: 0.9;
      letter-spacing: -0.045em;
      text-transform: none;
    }

    .dx-footer__headline-solid {
      color: rgba(255, 255, 255, 0.96);
    }

    .dx-footer__headline-outline {
      color: transparent;
      -webkit-text-stroke: 1px rgba(255, 255, 255, 0.18);
    }

    .dx-footer__newsletter {
      display: grid;
      grid-template-columns: minmax(0, 1.14fr) minmax(0, 1.56fr);
      gap: clamp(2.25rem, 4vw, 5rem);
      align-items: start;
      padding-top: 0;
      padding-bottom: clamp(3rem, 4.5vw, 4rem);
    }

    .dx-footer__newsletter-title {
      margin: 0;
      max-width: 32rem;
      font-family: var(--font-heading, serif);
      font-size: clamp(1.15rem, 1.7vw, 1.5rem);
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: -0.015em;
    }

    .dx-footer__newsletter-subtext {
      max-width: 43rem;
      margin: 0 0 1.8rem;
      font-size: clamp(1rem, 1.08vw, 1.08rem);
      line-height: 1.58;
      color: rgba(255, 255, 255, 0.78);
    }

    .dx-footer__newsletter-copy {
      padding-right: clamp(1rem, 2vw, 2rem);
    }

    .dx-footer__newsletter-form {
      align-self: end;
    }

    .dx-footer__newsletter-row {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.5rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.01);
    }

    .dx-footer__newsletter-state {
      margin: 0;
      font-size: 0.76rem;
      line-height: 1.6;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .dx-footer__newsletter-state--success {
      color: rgba(255, 255, 255, 0.8);
    }

    .dx-footer__newsletter-state--error {
      color: #f1c7bf;
    }

    .dx-footer__newsletter-input {
      flex: 1 1 0;
      max-width: none;
      border: 0;
      border-radius: 999px;
      background: transparent;
      min-height: 0;
      padding: 0.95rem 1rem;
      font-size: 1rem;
      letter-spacing: -0.01em;
      text-transform: none;
      color: rgba(255, 255, 255, 0.92);
      box-shadow: none;
    }

    .dx-footer__newsletter-input::placeholder {
      color: rgba(255, 255, 255, 0.34);
      letter-spacing: -0.01em;
    }

    .dx-footer__newsletter-input:focus {
      outline: none;
    }

    .dx-footer__newsletter-btn {
      border: 0;
      border-radius: 999px;
      background: #f4f1ec;
      color: #111111;
      min-height: 0;
      padding: 0.95rem 2.2rem;
      font-size: 0.92rem;
      font-weight: 500;
      letter-spacing: -0.01em;
      text-transform: none;
      white-space: nowrap;
    }

    .dx-footer__newsletter-btn:hover {
      background: #ffffff;
      color: #111111;
      opacity: 1;
    }

    .dx-footer__main {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.42fr);
      gap: clamp(2rem, 4vw, 5.5rem);
      align-items: start;
      padding-top: 0;
      padding-bottom: clamp(3rem, 4.5vw, 4rem);
      border-top: 1px solid rgba(255, 255, 255, 0.07);
    }

    .dx-footer__main--single {
      grid-template-columns: minmax(0, 1fr);
    }

    .dx-footer__brand-desc {
      max-width: 42rem;
      margin: 0;
      padding-right: clamp(1rem, 3vw, 3.5rem);
      font-size: clamp(1rem, 1.08vw, 1.08rem);
      line-height: 1.58;
      color: rgba(255, 255, 255, 0.78);
    }

    .dx-footer__link-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: clamp(1.5rem, 2vw, 2.5rem);
      padding-left: clamp(2rem, 3vw, 3rem);
      border-left: 1px solid rgba(255, 255, 255, 0.08);
    }

    .dx-footer__menu-title {
      margin: 0 0 1rem;
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      text-transform: none;
      color: rgba(255, 255, 255, 0.92);
    }

    .dx-footer__menu-list {
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      margin: 0;
      padding: 0;
    }

    .dx-footer__menu-link {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      position: relative;
      font-size: 0.98rem;
      line-height: 1.55;
      letter-spacing: -0.01em;
      color: rgba(255, 255, 255, 0.72);
      transition: color 0.24s ease;
    }

    .dx-footer__menu-col:last-child .dx-footer__menu-link::after {
      content: '↗';
      position: static;
      width: auto;
      height: auto;
      background: none;
      opacity: 1;
      transform: none;
      font-size: 0.9em;
    }

    .dx-footer__menu-link:hover {
      color: #ffffff;
    }

    .dx-footer__bar {
      border-top: 1px solid rgba(255, 255, 255, 0.07);
      padding-top: 1rem;
      padding-bottom: 1rem;
    }

    .dx-footer__bar-inner {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      align-items: center;
      gap: 1.5rem;
    }

    .dx-footer__locale {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      font-size: 0.9rem;
      color: rgba(255, 255, 255, 0.58);
    }

    .dx-footer__locale-globe {
      display: inline-flex;
      align-items: center;
    }

    .dx-footer__copyright {
      justify-self: center;
      font-size: 0.92rem;
      letter-spacing: -0.01em;
      text-transform: none;
      color: rgba(255, 255, 255, 0.52);
      text-align: center;
    }

    .dx-footer__payments {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 0.45rem;
    }

    .dx-footer__payment-icon {
      height: 1.45rem;
      width: auto;
      opacity: 0.88;
      transition: opacity 0.2s ease;
    }

    .dx-footer__payment-icon:hover {
      opacity: 1;
    }
  }

  @media (min-width: 768px) and (max-width: 1120px) {
    .dx-footer__newsletter,
    .dx-footer__main,
    .dx-footer__bar-inner {
      grid-template-columns: 1fr;
    }

    .dx-footer__link-grid {
      padding-left: 0;
      border-left: 0;
      border-top: 1px solid rgba(255, 255, 255, 0.07);
      padding-top: 2rem;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .dx-footer__payments,
    .dx-footer__copyright {
      justify-self: start;
      text-align: left;
    }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "site-footer",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand description",
      "default": "Premium fashion for the modern lifestyle."
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "marquee_text",
      "label": "Marquee text",
      "default": "Your Favorite Styles at Unmissable Prices!"
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "label": "Newsletter subtext",
      "default": "Get early access to new drops, exclusive offers, and style inspiration."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "newsletter_button",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "title": "Shop",
          "menu": "main-menu"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "title": "Support",
          "menu": "footer"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "title": "Company",
          "menu": "footer"
        }
      }
    ]
  }
}
{% endschema %}
