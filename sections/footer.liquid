<style>
  /* ─────────────────────────────────────────
     FOOTER — Quiet Luxury / Dark Edition
  ───────────────────────────────────────── */

  /* Giant headline stroke text */
  .footer-giant-text {
    font-family: var(--font-heading);
    font-size: 7vw;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    color: #ffffff;
    -webkit-text-stroke: none;
    white-space: nowrap;
    display: inline-block;
    transition: -webkit-text-stroke 500ms ease, color 500ms ease;
    cursor: default;
    user-select: none;
    padding-right: 2vw;
  }

  /* Marquee track */
  .footer-marquee {
    display: flex;
    width: max-content;
    animation: footer-scroll var(--ft-speed, 20s) linear infinite;
  }

  #footer-giant:hover .footer-marquee {
    animation-play-state: paused;
  }

  @keyframes footer-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }



  /* Column headings */
  .footer-col-title {
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #ffffff;
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  /* Footer nav links */
  .footer-link {
    display: block;
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: #9ca3af; /* gray-400 */
    text-decoration: none;
    margin-bottom: 0.75rem;
    transition: color 250ms ease;
    line-height: 1;
  }

  .footer-link:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  /* Newsletter input */
  .footer-input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid #4b5563; /* gray-600 */
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 0.82rem;
    padding: 0.6rem 0;
    outline: none;
    transition: border-color 300ms ease;
    letter-spacing: 0.04em;
  }

  .footer-input::placeholder {
    color: #6b7280; /* gray-500 */
    letter-spacing: 0.04em;
  }

  .footer-input:focus {
    border-bottom-color: var(--color-accent);
  }

  /* Subscribe button */
  .footer-subscribe-btn {
    margin-top: 1.25rem;
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: transparent;
    border: 1px solid rgba(197, 168, 128, 0.45);
    border-radius: 9999px;
    padding: 0.55rem 1.5rem;
    cursor: pointer;
    transition: background-color 300ms ease, color 300ms ease, border-color 300ms ease;
  }

  .footer-subscribe-btn:hover {
    background-color: var(--color-accent);
    color: #181818;
    border-color: var(--color-accent);
  }

  /* Social icon buttons */
  .footer-social {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: #9ca3af;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.8rem;
    margin-bottom: 0.85rem;
    transition: color 250ms ease;
  }

  .footer-social:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  .footer-social svg {
    flex-shrink: 0;
  }

  /* Payment icons */
  .payment-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 22px;
    padding: 0 8px;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    color: #9ca3af;
    text-transform: uppercase;
  }

  /* ─── Mobile Responsive ─── */
  @media (max-width: 767px) {
    .footer-giant-text {
      font-size: 10vw;
    }
  }
</style>

<footer
  id="site-footer"
  class="pt-16 md:pt-32 pb-10 overflow-hidden"
  style="background-color: #181818;"
  role="contentinfo"
>

  <!-- ── Giant Typography ── -->
  <div
    id="footer-giant"
    class="w-full overflow-hidden mb-4"
  >
    <div class="footer-marquee" style="--ft-speed: {{ section.settings.giant_speed | default: 20 }}s;">
      <span class="footer-giant-text">{{ section.settings.giant_text }}</span>
      <span class="footer-giant-text">{{ section.settings.giant_text }}</span>
      <span class="footer-giant-text">{{ section.settings.giant_text }}</span>
      <span class="footer-giant-text">{{ section.settings.giant_text }}</span>
    </div>
  </div>

  <!-- Thin accent divider -->
  <div
    class="mx-6 md:mx-10 mb-10 md:mb-20"
    style="height: 1px; background: linear-gradient(to right, var(--color-accent), transparent);"
  ></div>

  <!-- ── Footer 4-Column Grid ── -->
  <div
    id="footer-grid"
    class="grid grid-cols-1 md:grid-cols-4 gap-12 px-6 md:px-10"
  >

    <!-- COL 1: Newsletter -->
    <div data-footer-col>
      <p class="footer-col-title">{{ section.settings.newsletter_heading }}</p>
      <p style="font-family: var(--font-body); font-size: 0.82rem; line-height: 1.75; color: #6b7280; margin-bottom: 1.75rem;">
        {{ section.settings.newsletter_text }}
      </p>

      <form
        action="/contact#contact_form"
        method="post"
        onsubmit="event.preventDefault();"
        novalidate
      >
        <input type="hidden" name="form_type" value="customer" />
        <input type="hidden" name="utf8"      value="✓" />
        <input type="hidden" name="contact[tags]" value="newsletter" />

        <label for="footer-email" class="sr-only">Email address</label>
        <input
          id="footer-email"
          name="contact[email]"
          type="email"
          class="footer-input"
          placeholder="your@email.com"
          required
          autocomplete="email"
        />
        <button type="submit" class="footer-subscribe-btn">Subscribe</button>
      </form>
    </div>

    <!-- COL 2: Quick Links -->
    <div data-footer-col>
      <p class="footer-col-title">Explore</p>
      <nav aria-label="Footer quick links">
        <a href="{{ routes.root_url }}"        class="footer-link">Home</a>
        <a href="{{ routes.collections_url }}" class="footer-link">Catalog</a>
        <a href="{{ pages['about-us'].url | default: '/pages/about' }}" class="footer-link">About Us</a>
        <a href="{{ blogs.news.url | default: '/blogs/journal' }}"      class="footer-link">Journal</a>
      </nav>
    </div>

    <!-- COL 3: Support -->
    <div data-footer-col>
      <p class="footer-col-title">Support</p>
      <nav aria-label="Footer support links">
        <a href="{{ pages['privacy-policy'].url | default: '/policies/privacy-policy' }}" class="footer-link">Privacy Policy</a>
        <a href="{{ pages['refund-policy'].url  | default: '/policies/refund-policy' }}"  class="footer-link">Refund Policy</a>
        <a href="{{ pages['shipping-policy'].url | default: '/policies/shipping-policy' }}" class="footer-link">Shipping Policy</a>
        <a href="{{ pages['faq'].url | default: '/pages/faq' }}" class="footer-link">FAQ</a>
      </nav>
    </div>

    <!-- COL 4: Social -->
    <div data-footer-col>
      <p class="footer-col-title">Follow Us</p>

      <!-- Instagram -->
      {% if section.settings.instagram_url != blank %}
      <a href="{{ section.settings.instagram_url }}" class="footer-social" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        Instagram
      </a>
      {% endif %}

      <!-- TikTok -->
      {% if section.settings.tiktok_url != blank %}
      <a href="{{ section.settings.tiktok_url }}" class="footer-social" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/>
        </svg>
        TikTok
      </a>
      {% endif %}

      <!-- Facebook -->
      {% if section.settings.facebook_url != blank %}
      <a href="{{ section.settings.facebook_url }}" class="footer-social" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
        </svg>
        Facebook
      </a>
      {% endif %}
    </div>

  </div>
  <!-- / Footer Grid -->

  <!-- ── Bottom Bar ── -->
  <div
    class="border-t mt-10 md:mt-20 pt-8 px-6 md:px-10 flex flex-col md:flex-row justify-between items-center gap-4"
    style="border-color: #1f2937;"
  >
    <!-- Copyright -->
    <p style="font-family: var(--font-body); font-size: 0.72rem; letter-spacing: 0.08em; color: #4b5563;">
      &copy; {{ 'now' | date: '%Y' }} Dropxlabel. All rights reserved.
    </p>

    <!-- Payment Icons -->
    <div class="flex items-center gap-2" aria-label="Accepted payment methods">
      <span class="payment-icon">Visa</span>
      <span class="payment-icon">MC</span>
      <span class="payment-icon">PayPal</span>
      <span class="payment-icon">Momo</span>
      <span class="payment-icon">VNPay</span>
    </div>
  </div>
  <!-- / Bottom Bar -->

</footer>


<script>
  /* ─────────────────────────────────────────────────────
     GSAP ScrollTrigger — Footer entrance animations
     Requires: gsap.min.js + ScrollTrigger.min.js
     (already loaded via defer in layout/theme.liquid)
  ───────────────────────────────────────────────────── */

  gsap.registerPlugin(ScrollTrigger);

  let mmFooter = gsap.matchMedia();

  mmFooter.add("(min-width: 768px)", () => {
    gsap.from('#footer-giant .footer-giant-text', {
      scrollTrigger: { trigger: '#site-footer', start: 'top 85%', once: true },
      y: 80, opacity: 0, duration: 1.4, ease: 'power4.out', immediateRender: false,
    });
    gsap.from('#footer-grid [data-footer-col]', {
      scrollTrigger: { trigger: '#footer-grid', start: 'top 88%', once: true },
      y: 48, opacity: 0, duration: 1.2, ease: 'power3.out', stagger: 0.18, immediateRender: false,
    });
  });

  mmFooter.add("(max-width: 767px)", () => {
    gsap.from('#footer-giant .footer-giant-text', {
      scrollTrigger: { trigger: '#site-footer', start: 'top 90%', once: true },
      y: 30, opacity: 0, duration: 0.8, ease: 'power3.out', immediateRender: false,
    });
    gsap.from('#footer-grid [data-footer-col]', {
      scrollTrigger: { trigger: '#footer-grid', start: 'top 90%', once: true },
      y: 20, opacity: 0, duration: 0.8, ease: 'power3.out', stagger: 0.05, immediateRender: false,
    });
  });

</script>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "giant_text",
      "label": "Giant Text",
      "default": "Elevate Your Wardrobe at\u00a0Dropxlabel"
    },
    {
      "type": "range",
      "id": "giant_speed",
      "min": 5,
      "max": 60,
      "step": 5,
      "default": 20,
      "label": "Scroll Speed (seconds)",
      "info": "Lower = faster"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "Join the Club"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter Description",
      "default": "Đăng ký để nhận những bộ sưu tập mới nhất và đặc quyền dành riêng cho hội viên nội bộ."
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    }
  ]
}
{% endschema %}
