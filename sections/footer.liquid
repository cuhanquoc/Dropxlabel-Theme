<style>
  /* ─────────────────────────────────────────
     FOOTER — Quiet Luxury / Dark Edition
  ───────────────────────────────────────── */

  /* Giant headline stroke text */
  .footer-giant-text {
    font-family: var(--font-heading);
    font-size: 7vw;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    color: #ffffff;
    -webkit-text-stroke: none;
    white-space: nowrap;
    display: inline-block;
    transition: -webkit-text-stroke 500ms ease, color 500ms ease;
    cursor: default;
    user-select: none;
    padding-right: 2vw;
  }

  /* Marquee track */
  .footer-marquee {
    display: flex;
    width: max-content;
    animation: footer-scroll var(--ft-speed, 20s) linear infinite;
  }

  #footer-giant:hover .footer-marquee {
    animation-play-state: paused;
  }

  @keyframes footer-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }



  /* Column headings */
  .footer-col-title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    color: #ffffff;
    font-weight: 500;
    margin-bottom: 1.25rem;
    letter-spacing: 0.01em;
  }

  /* Footer nav links */
  .footer-link {
    display: block;
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: #9ca3af;
    text-decoration: none;
    margin-bottom: 0.75rem;
    transition: color 250ms ease;
    line-height: 1;
  }

  .footer-link:hover {
    color: #ffffff;
  }

  /* Newsletter promo text */
  .footer-promo {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 1.8vw, 1.35rem);
    font-weight: 500;
    color: #ffffff;
    line-height: 1.45;
    margin-bottom: 1.5rem;
  }

  .footer-promo-highlight {
    color: #e53e3e;
    font-weight: 700;
  }

  /* Newsletter inline input */
  .footer-newsletter-row {
    display: flex;
    align-items: stretch;
    border-bottom: 1px solid #4b5563;
    max-width: 280px;
  }

  .footer-input {
    flex: 1;
    background: transparent;
    border: none;
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 0.82rem;
    padding: 0.6rem 0;
    outline: none;
    letter-spacing: 0.04em;
    min-width: 0;
  }

  .footer-input::placeholder {
    color: #6b7280;
    letter-spacing: 0.04em;
  }

  /* Subscribe button — inline */
  .footer-subscribe-btn {
    background: transparent;
    border: none;
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: #9ca3af;
    cursor: pointer;
    padding: 0.6rem 0 0.6rem 1rem;
    transition: color 300ms ease;
    white-space: nowrap;
  }

  .footer-subscribe-btn:hover {
    color: #ffffff;
  }

  /* Social icon buttons */
  /* .footer-social {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: #9ca3af;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.8rem;
    margin-bottom: 0.85rem;
    transition: color 250ms ease;
  }

  .footer-social:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  .footer-social svg {
    flex-shrink: 0;
  } */

  /* Payment icons */
  .payment-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 22px;
    padding: 0 8px;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    color: #9ca3af;
    text-transform: uppercase;
  }

  /* ─── Mobile Responsive ─── */
  @media (max-width: 767px) {
    .footer-giant-text {
      font-size: 10vw;
    }
    .footer-newsletter-row { max-width: 100%; }
  }
</style>

<footer
  id="site-footer"
  class="pt-16 md:pt-32 pb-10 overflow-hidden"
  style="background-color: #181818;"
  role="contentinfo"
>

  <!-- ── Giant Typography ── -->
  <div
    id="footer-giant"
    class="w-full overflow-hidden mb-4"
  >
    <div class="footer-marquee" style="--ft-speed: {{ section.settings.giant_speed | default: 20 }}s;">
      <span class="footer-giant-text">{{ section.settings.giant_text }}</span>
      <span class="footer-giant-text">{{ section.settings.giant_text }}</span>
      <span class="footer-giant-text">{{ section.settings.giant_text }}</span>
      <span class="footer-giant-text">{{ section.settings.giant_text }}</span>
    </div>
  </div>

  <!-- Thin accent divider -->
  <div
    class="mx-6 md:mx-10 mb-10 md:mb-16"
    style="height: 1px; background: linear-gradient(to right, rgba(255,255,255,0.15), transparent);"
  ></div>

  <!-- ── Footer 5-Column Grid ── -->
  <div
    id="footer-grid"
    class="grid grid-cols-1 md:grid-cols-5 gap-8 md:gap-10 px-6 md:px-10"
  >

    <!-- COL 1: Newsletter Promo -->
    <div data-footer-col>
      <p class="footer-promo">
        {{ section.settings.newsletter_text }}
      </p>

      <form
        action="/contact#contact_form"
        method="post"
        onsubmit="event.preventDefault();"
        novalidate
      >
        <input type="hidden" name="form_type" value="customer" />
        <input type="hidden" name="utf8"      value="✓" />
        <input type="hidden" name="contact[tags]" value="newsletter" />

        <div class="footer-newsletter-row">
          <label for="footer-email" class="sr-only">Email address</label>
          <input
            id="footer-email"
            name="contact[email]"
            type="email"
            class="footer-input"
            placeholder="Enter your email"
            required
            autocomplete="email"
          />
          <button type="submit" class="footer-subscribe-btn">Subscribe</button>
        </div>
      </form>
    </div>

    <!-- COL 2: Company -->
    <div data-footer-col>
      <p class="footer-col-title">{{ section.settings.col2_title | default: 'Company' }}</p>
      <nav aria-label="Company links">
        <a href="{{ pages['about-us'].url | default: '/pages/about' }}" class="footer-link">About Us</a>
        <a href="{{ blogs.news.url | default: '/blogs/journal' }}" class="footer-link">Blog</a>
        <a href="{{ pages['careers'].url | default: '/pages/careers' }}" class="footer-link">Careers</a>
        <a href="{{ pages['locations'].url | default: '/pages/locations' }}" class="footer-link">Locations</a>
      </nav>
    </div>

    <!-- COL 3: Customer Care -->
    <div data-footer-col>
      <p class="footer-col-title">{{ section.settings.col3_title | default: 'Customer Care' }}</p>
      <nav aria-label="Customer care links">
        <a href="{{ pages['size-guide'].url | default: '/pages/size-guide' }}" class="footer-link">Size Guide</a>
        <a href="{{ pages['faq'].url | default: '/pages/faq' }}" class="footer-link">Help & FAQs</a>
        <a href="{{ pages['return-my-order'].url | default: '/pages/returns' }}" class="footer-link">Return My Order</a>
        <a href="{{ pages['refer-a-friend'].url | default: '/pages/refer' }}" class="footer-link">Refer a Friend</a>
      </nav>
    </div>

    <!-- COL 4: Terms & Policies -->
    <div data-footer-col>
      <p class="footer-col-title">{{ section.settings.col4_title | default: 'Terms & Policies' }}</p>
      <nav aria-label="Terms and policies links">
        <a href="{{ pages['duties-and-taxes'].url | default: '/pages/duties-taxes' }}" class="footer-link">Duties & Taxes</a>
        <a href="{{ pages['shipping-policy'].url | default: '/policies/shipping-policy' }}" class="footer-link">Shipping Info</a>
        <a href="{{ pages['privacy-policy'].url | default: '/policies/privacy-policy' }}" class="footer-link">Privacy Policy</a>
        <a href="{{ pages['terms-of-service'].url | default: '/policies/terms-of-service' }}" class="footer-link">Terms Conditions</a>
      </nav>
    </div>

    <!-- COL 5: Follow Us -->
    <div data-footer-col>
      <p class="footer-col-title">{{ section.settings.col5_title | default: 'Follow us' }}</p>
      <nav aria-label="Social links">
        {% if section.settings.instagram_url != blank %}
          <a href="{{ section.settings.instagram_url }}" class="footer-link" target="_blank" rel="noopener">Instagram</a>
        {% endif %}
        {% if section.settings.facebook_url != blank %}
          <a href="{{ section.settings.facebook_url }}" class="footer-link" target="_blank" rel="noopener">Facebook</a>
        {% endif %}
        {% if section.settings.pinterest_url != blank %}
          <a href="{{ section.settings.pinterest_url }}" class="footer-link" target="_blank" rel="noopener">Pinterest</a>
        {% endif %}
        {% if section.settings.tiktok_url != blank %}
          <a href="{{ section.settings.tiktok_url }}" class="footer-link" target="_blank" rel="noopener">Tiktok</a>
        {% endif %}
      </nav>
    </div>

  </div>
  <!-- / Footer Grid -->

  <!-- ── Bottom Bar ── -->
  <div
    class="border-t mt-10 md:mt-20 pt-8 px-6 md:px-10 flex flex-col md:flex-row justify-between items-center gap-4"
    style="border-color: #1f2937;"
  >
    <!-- Copyright -->
    <p style="font-family: var(--font-body); font-size: 0.72rem; letter-spacing: 0.08em; color: #4b5563;">
      &copy; {{ 'now' | date: '%Y' }} Dropxlabel. All rights reserved.
    </p>

    <!-- Payment Icons -->
    <div class="flex items-center gap-2" aria-label="Accepted payment methods">
      <span class="payment-icon">Visa</span>
      <span class="payment-icon">MC</span>
      <span class="payment-icon">PayPal</span>
      <span class="payment-icon">Momo</span>
      <span class="payment-icon">VNPay</span>
    </div>
  </div>
  <!-- / Bottom Bar -->

</footer>


<script>
  /* ─────────────────────────────────────────────────────
     GSAP ScrollTrigger — Footer entrance animations
     Requires: gsap.min.js + ScrollTrigger.min.js
     (already loaded via defer in layout/theme.liquid)
  ───────────────────────────────────────────────────── */

  gsap.registerPlugin(ScrollTrigger);

  let mmFooter = gsap.matchMedia();

  mmFooter.add("(min-width: 768px)", () => {
    gsap.from('#footer-giant .footer-giant-text', {
      scrollTrigger: { trigger: '#site-footer', start: 'top 85%', once: true },
      y: 80, opacity: 0, duration: 1.4, ease: 'power4.out', immediateRender: false,
    });
    gsap.from('#footer-grid [data-footer-col]', {
      scrollTrigger: { trigger: '#footer-grid', start: 'top 88%', once: true },
      y: 48, opacity: 0, duration: 1.2, ease: 'power3.out', stagger: 0.18, immediateRender: false,
    });
  });

  mmFooter.add("(max-width: 767px)", () => {
    gsap.from('#footer-giant .footer-giant-text', {
      scrollTrigger: { trigger: '#site-footer', start: 'top 90%', once: true },
      y: 30, opacity: 0, duration: 0.8, ease: 'power3.out', immediateRender: false,
    });
    gsap.from('#footer-grid [data-footer-col]', {
      scrollTrigger: { trigger: '#footer-grid', start: 'top 90%', once: true },
      y: 20, opacity: 0, duration: 0.8, ease: 'power3.out', stagger: 0.05, immediateRender: false,
    });
  });

</script>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "giant_text",
      "label": "Giant Text",
      "default": "Elevate Your Wardrobe at\u00a0Dropxlabel"
    },
    {
      "type": "range",
      "id": "giant_speed",
      "min": 5,
      "max": 60,
      "step": 5,
      "default": 20,
      "label": "Scroll Speed (seconds)",
      "info": "Lower = faster"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter Promo Text",
      "default": "Receive an exclusive <span class='footer-promo-highlight'>20%</span> discount code when you signup."
    },
    {
      "type": "header",
      "content": "Column Titles"
    },
    {
      "type": "text",
      "id": "col2_title",
      "label": "Column 2 Title",
      "default": "Company"
    },
    {
      "type": "text",
      "id": "col3_title",
      "label": "Column 3 Title",
      "default": "Customer Care"
    },
    {
      "type": "text",
      "id": "col4_title",
      "label": "Column 4 Title",
      "default": "Terms & Policies"
    },
    {
      "type": "text",
      "id": "col5_title",
      "label": "Column 5 Title",
      "default": "Follow us"
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "pinterest_url",
      "label": "Pinterest URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    }
  ]
}
{% endschema %}

