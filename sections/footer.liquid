<style>
  /* ─────────────────────────────────────────────────
     FOOTER — Quiet Luxury / Art Director Edition
     Principles: Editorial Whitespace · Serif Hierarchy
     Muted Palette · Sharp Geometry
  ───────────────────────────────────────────────── */

  /* ── Marquee Giant Text ── */
  .ft-giant {
    font-family: var(--font-heading);
    font-size: clamp(4rem, 8vw, 9rem);
    font-weight: 300;
    font-style: italic;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 0.9;
    color: rgba(255,255,255,0.92);
    white-space: nowrap;
    display: inline-block;
    cursor: default;
    user-select: none;
    padding-right: 3vw;
  }

  .ft-marquee-track {
    display: flex;
    width: max-content;
    animation: ft-drift var(--ft-speed, 20s) linear infinite;
  }

  .ft-marquee-wrap:hover .ft-marquee-track {
    animation-play-state: paused;
  }

  @keyframes ft-drift {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── Eyebrow Labels (Column Titles) ── */
  .ft-eyebrow {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: rgba(255,255,255,0.4);
    margin-bottom: 2rem;
    line-height: 1;
  }

  /* ── Nav Stacking ── */
  .ft-nav {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Layout Containers ── */
  .ft-desktop-layout {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    align-items: flex-start;
  }

  .ft-newsletter-col {
    width: 100%;
  }

  .ft-links-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem;
    width: 100%;
  }

  /* ── Link Style ── */
  .ft-link {
    display: block;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    padding: 0.5rem 0;
    transition: color 350ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
    line-height: 1;
    border: none;
    background: none;
  }

  .ft-link:hover {
    color: rgba(255,255,255,0.95);
  }

  /* ── Newsletter Promo ── */
  .ft-promo-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: rgba(255,255,255,0.9);
    margin-bottom: 2.5rem;
  }

  .ft-promo-heading em {
    font-style: italic;
    color: #c9a96e;
    font-weight: 400;
  }

  /* ── Email Input ── */
  .ft-email-row {
    display: flex;
    align-items: center;
    gap: 0;
    border-bottom: 1px solid rgba(255,255,255,0.15);
    max-width: 320px;
    padding-bottom: 2px;
  }

  .ft-email-input {
    flex: 1;
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.85);
    font-family: var(--font-body);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    padding: 0.75rem 0;
    outline: none;
    min-width: 0;
  }

  .ft-email-input::placeholder {
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.06em;
  }

  /* Subscribe — Pill Button */
  .ft-subscribe {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: rgba(255,255,255,0.6);
    background: transparent;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 9999px;
    padding: 0.55rem 1.6rem;
    cursor: pointer;
    transition: color 350ms ease, border-color 350ms ease, background 350ms ease;
    white-space: nowrap;
    margin-left: 1.5rem;
    flex-shrink: 0;
  }

  .ft-subscribe:hover {
    color: #181818;
    background: rgba(255,255,255,0.9);
    border-color: rgba(255,255,255,0.9);
  }

  /* ── Vertical Divider ── */
  .ft-vdivider {
    width: 1px;
    background: rgba(255,255,255,0.08);
    flex-shrink: 0;
    align-self: stretch;
  }

  /* ── Payment Badge ── */
  .ft-pay {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 24px;
    padding: 0 10px;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.1);
    font-family: var(--font-body);
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  /* ── Copyright ── */
  .ft-copyright {
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.2);
  }

  /* ── Responsive ── */

  /* ── Desktop & Tablet (≥ 768px) ── */
  @media (min-width: 768px) {
    .ft-desktop-layout {
      flex-direction: row !important;
      gap: 0 !important;
      align-items: flex-start !important;
    }
    .ft-newsletter-col {
      flex: 0 0 30% !important;
      max-width: 380px !important;
      padding-right: 3rem !important;
    }
    .ft-vdivider {
      display: block !important;
    }
    .ft-links-grid {
      flex: 1 !important;
      display: grid !important;
      grid-template-columns: repeat(4, 1fr) !important;
      gap: 2rem !important;
      padding-left: 3rem !important;
    }
    .ft-bottom-bar {
      flex-direction: row !important;
      justify-content: space-between !important;
      align-items: center !important;
    }
  }

  /* ── Large Desktop (≥ 1024px) ── */
  @media (min-width: 1024px) {
    .ft-newsletter-col {
      padding-right: 4rem !important;
    }
    .ft-links-grid {
      gap: 2.5rem !important;
      padding-left: 4rem !important;
    }
  }

  /* ── Mobile (< 768px) ── */
  @media (max-width: 767px) {
    .ft-giant { font-size: 12vw; }
    .ft-desktop-layout {
      flex-direction: column !important;
      gap: 3rem !important;
    }
    .ft-newsletter-col {
      flex: unset !important;
      max-width: 100% !important;
      padding-right: 0 !important;
      padding-bottom: 3rem !important;
      border-bottom: 1px solid rgba(255,255,255,0.06) !important;
    }
    .ft-vdivider { display: none !important; }
    .ft-links-grid {
      grid-template-columns: repeat(2, 1fr) !important;
      padding-left: 0 !important;
      gap: 2.5rem !important;
    }
    .ft-email-row { max-width: 100%; }
    .ft-promo-heading { font-size: 1.4rem; }
    .ft-bottom-bar {
      flex-direction: column !important;
      gap: 1.5rem !important;
    }
  }
</style>

<!-- ══════════════════════════════════════════════
     FOOTER — Quiet Luxury
     ══════════════════════════════════════════════ -->
<footer
  id="site-footer"
  role="contentinfo"
  style="background: #141414;"
  class="pt-24 md:pt-40 pb-12 md:pb-16 overflow-hidden"
>

  <!-- ── Giant Marquee ── -->
  <div id="footer-giant" class="ft-marquee-wrap w-full overflow-hidden mb-16 md:mb-24">
    <div class="ft-marquee-track" style="--ft-speed: {{ section.settings.giant_speed | default: 20 }}s;">
      <span class="ft-giant">{{ section.settings.giant_text }}</span>
      <span class="ft-giant">{{ section.settings.giant_text }}</span>
      <span class="ft-giant">{{ section.settings.giant_text }}</span>
      <span class="ft-giant">{{ section.settings.giant_text }}</span>
    </div>
  </div>

  <!-- ── Hairline Divider ── -->
  <div class="mx-8 md:mx-16 lg:mx-24 mb-16 md:mb-28" style="height: 1px; background: rgba(255,255,255,0.06);"></div>

  <!-- ── Main Content: Newsletter + 4 Columns ── -->
  <div id="footer-grid" class="px-8 md:px-16 lg:px-24">
    <div class="ft-desktop-layout" style="display: flex;">

      <!-- LEFT: Newsletter -->
      <div data-footer-col class="ft-newsletter-col">
        <p class="ft-eyebrow">Newsletter</p>

        <p class="ft-promo-heading">
          {{ section.settings.newsletter_text }}
        </p>

        <form action="/contact#contact_form" method="post" onsubmit="event.preventDefault();" novalidate>
          <input type="hidden" name="form_type" value="customer" />
          <input type="hidden" name="utf8" value="✓" />
          <input type="hidden" name="contact[tags]" value="newsletter" />

          <div class="ft-email-row">
            <label for="footer-email" class="sr-only">Email address</label>
            <input
              id="footer-email"
              name="contact[email]"
              type="email"
              class="ft-email-input"
              placeholder="Your email address"
              required
              autocomplete="email"
            />
          </div>
          <div style="margin-top: 1.5rem;">
            <button type="submit" class="ft-subscribe">Subscribe</button>
          </div>
        </form>
      </div>

      <!-- DIVIDER -->
      <div class="ft-vdivider hidden md:block"></div>

      <!-- RIGHT: 4 Link Columns -->
      <div class="ft-links-grid">

        <!-- Company -->
        <div data-footer-col>
          <p class="ft-eyebrow">{{ section.settings.col2_title | default: 'Company' }}</p>
          <nav class="ft-nav" aria-label="Company">
            {% if section.settings.c2_link1_label != blank %}<a href="{{ section.settings.c2_link1_url | default: '#' }}" class="ft-link">{{ section.settings.c2_link1_label }}</a>{% endif %}
            {% if section.settings.c2_link2_label != blank %}<a href="{{ section.settings.c2_link2_url | default: '#' }}" class="ft-link">{{ section.settings.c2_link2_label }}</a>{% endif %}
            {% if section.settings.c2_link3_label != blank %}<a href="{{ section.settings.c2_link3_url | default: '#' }}" class="ft-link">{{ section.settings.c2_link3_label }}</a>{% endif %}
            {% if section.settings.c2_link4_label != blank %}<a href="{{ section.settings.c2_link4_url | default: '#' }}" class="ft-link">{{ section.settings.c2_link4_label }}</a>{% endif %}
          </nav>
        </div>

        <!-- Customer Care -->
        <div data-footer-col>
          <p class="ft-eyebrow">{{ section.settings.col3_title | default: 'Customer Care' }}</p>
          <nav class="ft-nav" aria-label="Customer Care">
            {% if section.settings.c3_link1_label != blank %}<a href="{{ section.settings.c3_link1_url | default: '#' }}" class="ft-link">{{ section.settings.c3_link1_label }}</a>{% endif %}
            {% if section.settings.c3_link2_label != blank %}<a href="{{ section.settings.c3_link2_url | default: '#' }}" class="ft-link">{{ section.settings.c3_link2_label }}</a>{% endif %}
            {% if section.settings.c3_link3_label != blank %}<a href="{{ section.settings.c3_link3_url | default: '#' }}" class="ft-link">{{ section.settings.c3_link3_label }}</a>{% endif %}
            {% if section.settings.c3_link4_label != blank %}<a href="{{ section.settings.c3_link4_url | default: '#' }}" class="ft-link">{{ section.settings.c3_link4_label }}</a>{% endif %}
          </nav>
        </div>

        <!-- Terms & Policies -->
        <div data-footer-col>
          <p class="ft-eyebrow">{{ section.settings.col4_title | default: 'Terms & Policies' }}</p>
          <nav class="ft-nav" aria-label="Terms and Policies">
            {% if section.settings.c4_link1_label != blank %}<a href="{{ section.settings.c4_link1_url | default: '#' }}" class="ft-link">{{ section.settings.c4_link1_label }}</a>{% endif %}
            {% if section.settings.c4_link2_label != blank %}<a href="{{ section.settings.c4_link2_url | default: '#' }}" class="ft-link">{{ section.settings.c4_link2_label }}</a>{% endif %}
            {% if section.settings.c4_link3_label != blank %}<a href="{{ section.settings.c4_link3_url | default: '#' }}" class="ft-link">{{ section.settings.c4_link3_label }}</a>{% endif %}
            {% if section.settings.c4_link4_label != blank %}<a href="{{ section.settings.c4_link4_url | default: '#' }}" class="ft-link">{{ section.settings.c4_link4_label }}</a>{% endif %}
          </nav>
        </div>

        <!-- Follow Us -->
        <div data-footer-col>
          <p class="ft-eyebrow">{{ section.settings.col5_title | default: 'Follow Us' }}</p>
          <nav class="ft-nav" aria-label="Social">
            {% if section.settings.c5_link1_label != blank %}<a href="{{ section.settings.c5_link1_url | default: '#' }}" class="ft-link" target="_blank" rel="noopener">{{ section.settings.c5_link1_label }}</a>{% endif %}
            {% if section.settings.c5_link2_label != blank %}<a href="{{ section.settings.c5_link2_url | default: '#' }}" class="ft-link" target="_blank" rel="noopener">{{ section.settings.c5_link2_label }}</a>{% endif %}
            {% if section.settings.c5_link3_label != blank %}<a href="{{ section.settings.c5_link3_url | default: '#' }}" class="ft-link" target="_blank" rel="noopener">{{ section.settings.c5_link3_label }}</a>{% endif %}
            {% if section.settings.c5_link4_label != blank %}<a href="{{ section.settings.c5_link4_url | default: '#' }}" class="ft-link" target="_blank" rel="noopener">{{ section.settings.c5_link4_label }}</a>{% endif %}
          </nav>
        </div>

      </div>
    </div>
  </div>

  <!-- ── Bottom Bar ── -->
  <div
    class="ft-bottom-bar mt-24 md:mt-36 pt-10 mx-8 md:mx-16 lg:mx-24 flex flex-row justify-between items-center"
    style="border-top: 1px solid rgba(255,255,255,0.06);"
  >
    <p class="ft-copyright">
      &copy; {{ 'now' | date: '%Y' }} Dropxlabel. All Rights Reserved.
    </p>

    <div class="flex items-center gap-3" aria-label="Accepted payment methods">
      <span class="ft-pay">Visa</span>
      <span class="ft-pay">MC</span>
      <span class="ft-pay">PayPal</span>
      <span class="ft-pay">Momo</span>
      <span class="ft-pay">VNPay</span>
    </div>
  </div>

</footer>


<script>
  gsap.registerPlugin(ScrollTrigger);

  let mmFooter = gsap.matchMedia();

  mmFooter.add("(min-width: 768px)", () => {
    gsap.from('.ft-giant', {
      scrollTrigger: { trigger: '#site-footer', start: 'top 85%', once: true },
      y: 100, opacity: 0, duration: 1.6, ease: 'power4.out', immediateRender: false,
    });
    gsap.from('#footer-grid [data-footer-col]', {
      scrollTrigger: { trigger: '#footer-grid', start: 'top 88%', once: true },
      y: 60, opacity: 0, duration: 1.4, ease: 'power3.out', stagger: 0.12, immediateRender: false,
    });
  });

  mmFooter.add("(max-width: 767px)", () => {
    gsap.from('.ft-giant', {
      scrollTrigger: { trigger: '#site-footer', start: 'top 92%', once: true },
      y: 30, opacity: 0, duration: 0.8, ease: 'power3.out', immediateRender: false,
    });
    gsap.from('#footer-grid [data-footer-col]', {
      scrollTrigger: { trigger: '#footer-grid', start: 'top 92%', once: true },
      y: 20, opacity: 0, duration: 0.8, ease: 'power3.out', stagger: 0.05, immediateRender: false,
    });
  });
</script>

{% schema %}
