<style>
  .footer-shell {
    background: #0f0d0b;
    color: #f7f1e8;
  }

  .footer-shell__newsletter {
    padding: 3.75rem 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-shell__newsletter-inner {
    max-width: 54rem;
    margin: 0 auto;
    padding: 2rem 1.25rem;
  }

  .footer-shell__headline {
    font-family: var(--font-heading, serif);
    letter-spacing: -0.02em;
  }

  .footer-shell__subcopy {
    color: rgba(247, 241, 232, 0.62);
  }

  .footer-shell__newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: stretch;
  }

  .footer-shell__newsletter-row {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    justify-content: center;
  }

  .footer-shell__newsletter-input {
    flex: 1 1 16rem;
    max-width: 26rem;
    min-height: 48px;
    color: #f7f1e8;
    padding: 0 1.1rem;
    font-family: var(--font-body, sans-serif);
  }

  .footer-shell__newsletter-input::placeholder {
    color: rgba(247, 241, 232, 0.38);
  }

  .footer-shell__newsletter-input:focus {
    outline: 2px solid rgba(247, 241, 232, 0.36);
    outline-offset: 2px;
  }

  .footer-shell__newsletter-button {
    min-height: 48px;
    padding: 0 1.35rem;
    color: #11100f;
    font-family: var(--font-body, sans-serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .footer-shell__newsletter-button:hover {
    transform: translateY(-1px);
  }

  .footer-shell__content {
    max-width: 80rem;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .footer-shell__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) repeat(3, minmax(0, 1fr));
    gap: clamp(2rem, 4vw, 4rem);
  }

  .footer-shell__brand {
    min-width: 0;
  }

  .footer-shell__logo {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    margin-bottom: 1.25rem;
  }

  .footer-shell__description {
    color: rgba(247, 241, 232, 0.56);
    line-height: 1.7;
    max-width: 24rem;
  }

  .footer-shell__social {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  .footer-shell__social-link {
    width: 42px;
    height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(247, 241, 232, 0.62);
    transition: transform 0.18s ease, color 0.18s ease, border-color 0.18s ease, background-color 0.18s ease;
  }

  .footer-shell__social-link:hover {
    color: #f7f1e8;
    border-color: rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.06);
    transform: translateY(-1px);
  }

  .footer-shell__heading {
    margin-bottom: 1.15rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(247, 241, 232, 0.42);
  }

  .footer-shell__links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-shell__link {
    color: rgba(247, 241, 232, 0.62);
    font-size: 0.9rem;
    line-height: 1.5;
    transition: color 0.18s ease, transform 0.18s ease;
  }

  .footer-shell__link:hover {
    color: #f7f1e8;
  }

  .footer-shell__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1.5rem 1.5rem calc(1.5rem + env(safe-area-inset-bottom, 0px));
  }

  .footer-shell__bottom-inner {
    max-width: 80rem;
    margin: 0 auto;
  }

  .footer-shell__copyright {
    color: rgba(247, 241, 232, 0.34);
    line-height: 1.6;
  }

  .footer-shell__payments {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-shell__payment-icon svg {
    height: 24px;
    width: auto;
    opacity: 0.36;
  }

  @media (min-width: 768px) {
    .footer-shell__newsletter {
      padding-inline: 2.5rem;
    }

    .footer-shell__newsletter-inner {
      padding: 2.5rem 2rem;
    }

    .footer-shell__newsletter-form {
      align-items: center;
    }

    .footer-shell__newsletter-row {
      flex-direction: row;
      align-items: center;
    }

    .footer-shell__content {
      padding: 4.5rem 2.5rem;
    }

    .footer-shell__bottom {
      padding-inline: 2.5rem;
    }

    .footer-shell__bottom-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
  }

  @media (max-width: 767px) {
    .footer-shell__grid {
      grid-template-columns: 1fr;
      gap: 2.25rem;
    }

    .footer-shell__newsletter-input {
      max-width: none;
      width: 100%;
    }
  }
</style>

<footer-section class="footer-shell block">

  {%- if section.settings.show_newsletter -%}
  <div class="footer-shell__newsletter">
    <div class="footer-shell__newsletter-inner ui-surface ui-surface--dark text-center">
      {%- if section.settings.newsletter_heading != blank -%}
        <h2 class="footer-shell__headline text-2xl md:text-3xl font-semibold mb-3 text-white">
          {{ section.settings.newsletter_heading }}
        </h2>
      {%- endif -%}
      {%- if section.settings.newsletter_subtext != blank -%}
        <p class="footer-shell__subcopy font-body text-sm mb-6">{{ section.settings.newsletter_subtext }}</p>
      {%- endif -%}
      {% form 'customer', id: 'footer-newsletter-form', class: 'footer-shell__newsletter-form' %}
        {%- if form.posted_successfully? -%}
          <p class="text-green-400 text-sm">{{ 'footer.newsletter.success' | t }}</p>
        {%- else -%}
          <div class="footer-shell__newsletter-row">
            <label for="footer-email" class="sr-only">{{ section.settings.newsletter_placeholder | default: 'Enter your email' }}</label>
            <input
              type="email"
              name="contact[email]"
              id="footer-email"
              placeholder="{{ section.settings.newsletter_placeholder | default: 'Enter your email' }}"
              required
              autocomplete="email"
              class="footer-shell__newsletter-input ui-surface ui-surface--dark text-sm"
              style="--ui-bg: rgba(255, 255, 255, 0.04); --ui-border: rgba(255, 255, 255, 0.14); --ui-shadow: none; --ui-blur: 0px;"
            >
            <button
              type="submit"
              class="footer-shell__newsletter-button ui-pill cursor-pointer"
              style="--ui-bg: #f7f1e8; --ui-fg: #11100f; --ui-border: rgba(255, 255, 255, 0.9); --ui-shadow: none; --ui-blur: 0px; padding-inline: 1.35rem; letter-spacing: 0.12em; min-height: 48px;"
            >
              {{ section.settings.newsletter_button | default: 'Subscribe' }}
            </button>
          </div>
        {%- endif -%}
      {% endform %}
    </div>
  </div>
  {%- endif -%}

  <div class="footer-shell__content">
    <div class="footer-shell__grid">

      <!-- Col 1: Brand -->
      <div class="footer-shell__brand">
        {%- if section.settings.logo != blank -%}
          <a href="{{ routes.root_url }}" class="footer-shell__logo inline-block mb-5">
            {{- section.settings.logo | image_url: width: 160 | image_tag:
                alt: shop.name,
                loading: 'lazy',
                class: 'h-8 w-auto object-contain brightness-0 invert'
            -}}
          </a>
        {%- else -%}
          <a href="{{ routes.root_url }}" class="footer-shell__logo inline-block mb-5">
            <span class="font-heading text-xl font-bold tracking-wide text-white">{{ shop.name }}</span>
          </a>
        {%- endif -%}

        {%- if section.settings.brand_description != blank -%}
          <p class="footer-shell__description text-sm font-body leading-relaxed mb-6">{{ section.settings.brand_description }}</p>
        {%- endif -%}

        <!-- Social icons -->
        <div class="footer-shell__social">
          {%- if settings.social_instagram_url != blank -%}
            <a href="{{ settings.social_instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram" class="footer-shell__social-link ui-icon-disc ui-icon-disc--dark" style="--ui-size: 42px; --ui-bg: rgba(255, 255, 255, 0.03); --ui-border: rgba(255, 255, 255, 0.08); --ui-shadow: none;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4.5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok_url != blank -%}
            <a href="{{ settings.social_tiktok_url }}" target="_blank" rel="noopener" aria-label="TikTok" class="footer-shell__social-link ui-icon-disc ui-icon-disc--dark" style="--ui-size: 42px; --ui-bg: rgba(255, 255, 255, 0.03); --ui-border: rgba(255, 255, 255, 0.08); --ui-shadow: none;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.37 6.37 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.15 8.15 0 004.78 1.52V6.77a4.85 4.85 0 01-1.01-.08z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_facebook_url != blank -%}
            <a href="{{ settings.social_facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook" class="footer-shell__social-link ui-icon-disc ui-icon-disc--dark" style="--ui-size: 42px; --ui-bg: rgba(255, 255, 255, 0.03); --ui-border: rgba(255, 255, 255, 0.08); --ui-shadow: none;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073C24 5.404 18.627 0 12 0 5.383 0 0 5.404 0 12.073 0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_pinterest_url != blank -%}
            <a href="{{ settings.social_pinterest_url }}" target="_blank" rel="noopener" aria-label="Pinterest" class="footer-shell__social-link ui-icon-disc ui-icon-disc--dark" style="--ui-size: 42px; --ui-bg: rgba(255, 255, 255, 0.03); --ui-border: rgba(255, 255, 255, 0.08); --ui-shadow: none;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_youtube_url != blank -%}
            <a href="{{ settings.social_youtube_url }}" target="_blank" rel="noopener" aria-label="YouTube" class="footer-shell__social-link ui-icon-disc ui-icon-disc--dark" style="--ui-size: 42px; --ui-bg: rgba(255, 255, 255, 0.03); --ui-border: rgba(255, 255, 255, 0.08); --ui-shadow: none;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Col 2 & 3 & 4: Link blocks (from blocks) -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div class="footer-shell__links" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="footer-shell__heading font-body text-xs font-semibold uppercase tracking-widest text-white/40 mb-5">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.menu != blank -%}
              <ul class="flex flex-col gap-3" role="list">
                {%- for link in block.settings.menu.links -%}
                  <li>
                    <a href="{{ link.url }}" class="footer-shell__link text-sm font-body transition-colors">{{ link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-shell__bottom">
    <div class="footer-shell__bottom-inner flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="footer-shell__copyright text-xs font-body">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
        {%- if section.settings.copyright_text != blank -%}
          {{ section.settings.copyright_text }}
        {%- else -%}
          All rights reserved.
        {%- endif -%}
      </p>
      <!-- Payment icons -->
      {%- if section.settings.show_payment_icons -%}
        <div class="footer-shell__payments flex items-center gap-2 flex-wrap justify-center md:justify-end">
          {%- for type in shop.enabled_payment_types -%}
            <span class="footer-shell__payment-icon">
              {{ type | payment_type_svg_tag: class: 'h-6 w-auto opacity-40' }}
            </span>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>

</footer-section>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "site-footer",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand description",
      "default": "Premium fashion for the modern lifestyle."
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "label": "Newsletter subtext",
      "default": "Get early access to new drops, exclusive offers, and style inspiration."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "newsletter_button",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "title": "Shop",
          "menu": "main-menu"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "title": "Support",
          "menu": "footer"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "title": "Company",
          "menu": "footer"
        }
      }
    ]
  }
}
{% endschema %}
