<footer-section class="block bg-[#1a1a1a] text-white overflow-hidden">
  <!-- ═══ Marquee Headline ═══ -->
  <div class="overflow-hidden pt-10 pb-6 md:pt-16 md:pb-10">
    <div class="ft-marquee-track flex w-max select-none"
         style="animation: ft-drift {{ section.settings.marquee_speed | default: 20 }}s linear infinite;">
      {% for i in (1..6) %}
        <span class="ft-marquee-word whitespace-nowrap pr-4 font-heading font-bold uppercase text-[clamp(2.8rem,8vw,5.5rem)] leading-none tracking-[-0.02em]">
          {{ section.settings.marquee_heading | default: 'Your Favorite Styles at Unmissable Prices' }}
        </span>
      {% endfor %}
    </div>
  </div>

  <!-- ═══ Main Content ═══ -->
  <div class="max-w-[1280px] mx-auto px-5 md:px-10 pb-10 md:pb-16">
    <div class="flex flex-col md:flex-row md:gap-12 lg:gap-16">

      <!-- ── Col 1: Description + Email ── -->
      <div class="md:w-[38%] lg:w-[35%] mb-10 md:mb-0">
        <p class="font-body text-[0.85rem] md:text-[0.82rem] leading-[1.7] text-white/60 mb-6 max-w-[400px]">
          {{ section.settings.newsletter_text }}
        </p>

        <!-- Email Subscribe -->
        <form class="ft-subscribe-form flex items-center rounded-full border border-white/[0.12] bg-white/[0.05] overflow-hidden max-w-[400px]"
              action="/contact#contact_form" method="post">
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="utf8" value="✓">
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="email"
                 name="contact[email]"
                 placeholder="Email"
                 required
                 class="flex-1 bg-transparent px-5 py-3 text-[0.85rem] text-white placeholder-white/30 outline-none font-body">
          <button type="submit"
                  class="bg-white text-[#1a1a1a] font-body font-semibold text-[0.82rem] tracking-[0.02em] px-5 py-2.5 rounded-full mr-1.5 transition-all duration-300 hover:bg-white/90 active:scale-95 shrink-0">
            Subscribe
          </button>
        </form>
      </div>

      <!-- ── Col 2-4: Navigation Columns ── -->
      <div class="flex-1 flex flex-col md:flex-row md:justify-between md:gap-8 lg:gap-12">

        {%- if section.blocks.size > 0 -%}
          {%- comment -%} Block-based rendering — each link_column block is one accordion column {%- endcomment -%}
          {%- assign current_column = nil -%}
          {%- for block in section.blocks -%}

            {%- if block.type == "link_column" -%}
              {%- unless current_column == nil -%}
                    </ul>
                  </div>
                </div>
              {%- endunless -%}
              {%- assign current_column = block -%}
              <div class="ft-accordion-group border-t border-white/[0.08] md:border-t-0" {{ block.shopify_attributes }}>
                <button class="ft-accordion-btn w-full flex items-center justify-between py-4 md:py-0 md:pointer-events-none md:cursor-default"
                        aria-expanded="false">
                  <span class="font-heading font-bold text-[1.1rem] md:text-[0.95rem] text-white leading-tight">
                    {{ block.settings.title | default: 'Links' }}
                  </span>
                  <span class="ft-accordion-icon md:hidden w-5 h-5 relative flex items-center justify-center">
                    <span class="block w-[18px] h-[2px] bg-white/60 rounded-full transition-transform duration-300"></span>
                    <span class="ft-icon-vertical block w-[18px] h-[2px] bg-white/60 rounded-full absolute transition-transform duration-300 rotate-90"></span>
                  </span>
                </button>
                <div class="ft-accordion-panel overflow-hidden md:!max-h-none md:!opacity-100 md:!mt-4"
                     style="max-height: 0; opacity: 0; transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease, margin 0.3s ease;">
                  <ul class="pb-5 md:pb-0 flex flex-col gap-3">

            {%- elsif block.type == "link_item" and current_column != nil -%}
              {%- if block.settings.label != blank and block.settings.url != blank -%}
                    <li {{ block.shopify_attributes }}>
                      <a href="{{ block.settings.url }}"
                         class="font-body text-[0.72rem] tracking-[0.14em] uppercase text-white/50 hover:text-white transition-colors duration-300">
                        {{ block.settings.label }}
                      </a>
                    </li>
              {%- endif -%}

            {%- elsif block.type == "social_links" -%}
              {%- unless current_column == nil -%}
                    </ul>
                  </div>
                </div>
              {%- endunless -%}
              {%- assign current_column = block -%}
              <div class="ft-accordion-group border-t border-white/[0.08] md:border-t-0" {{ block.shopify_attributes }}>
                <button class="ft-accordion-btn w-full flex items-center justify-between py-4 md:py-0 md:pointer-events-none md:cursor-default"
                        aria-expanded="false">
                  <span class="font-heading font-bold text-[1.1rem] md:text-[0.95rem] text-white leading-tight">
                    {{ block.settings.title | default: 'Follow us on' }}
                  </span>
                  <span class="ft-accordion-icon md:hidden w-5 h-5 relative flex items-center justify-center">
                    <span class="block w-[18px] h-[2px] bg-white/60 rounded-full transition-transform duration-300"></span>
                    <span class="ft-icon-vertical block w-[18px] h-[2px] bg-white/60 rounded-full absolute transition-transform duration-300 rotate-90"></span>
                  </span>
                </button>
                <div class="ft-accordion-panel overflow-hidden md:!max-h-none md:!opacity-100 md:!mt-4"
                     style="max-height: 0; opacity: 0; transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease, margin 0.3s ease;">
                  <ul class="pb-5 md:pb-0 flex flex-col gap-3">
                    {%- if block.settings.instagram != blank -%}
                      <li>
                        <a href="{{ block.settings.instagram }}" target="_blank" rel="noopener"
                           class="inline-flex items-center gap-2 font-body text-[0.8rem] tracking-[0.04em] text-white/50 hover:text-white transition-colors duration-300">
                          Instagram
                          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10"/></svg>
                        </a>
                      </li>
                    {%- endif -%}
                    {%- if block.settings.twitter != blank -%}
                      <li>
                        <a href="{{ block.settings.twitter }}" target="_blank" rel="noopener"
                           class="inline-flex items-center gap-2 font-body text-[0.8rem] tracking-[0.04em] text-white/50 hover:text-white transition-colors duration-300">
                          X (Twitter)
                          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10"/></svg>
                        </a>
                      </li>
                    {%- endif -%}
                    {%- if block.settings.youtube != blank -%}
                      <li>
                        <a href="{{ block.settings.youtube }}" target="_blank" rel="noopener"
                           class="inline-flex items-center gap-2 font-body text-[0.8rem] tracking-[0.04em] text-white/50 hover:text-white transition-colors duration-300">
                          YouTube
                          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10"/></svg>
                        </a>
                      </li>
                    {%- endif -%}
                    {%- if block.settings.tiktok != blank -%}
                      <li>
                        <a href="{{ block.settings.tiktok }}" target="_blank" rel="noopener"
                           class="inline-flex items-center gap-2 font-body text-[0.8rem] tracking-[0.04em] text-white/50 hover:text-white transition-colors duration-300">
                          TikTok / Pinterest
                          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10"/></svg>
                        </a>
                      </li>
                    {%- endif -%}
                    {%- if block.settings.facebook != blank -%}
                      <li>
                        <a href="{{ block.settings.facebook }}" target="_blank" rel="noopener"
                           class="inline-flex items-center gap-2 font-body text-[0.8rem] tracking-[0.04em] text-white/50 hover:text-white transition-colors duration-300">
                          Facebook
                          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10"/></svg>
                        </a>
                      </li>
                    {%- endif -%}
                  </ul>
                </div>
              </div>
              {%- assign current_column = nil -%}
            {%- endif -%}

          {%- endfor -%}

          {%- comment -%} Close last link_column if open {%- endcomment -%}
          {%- unless current_column == nil or current_column.type == "social_links" -%}
                  </ul>
                </div>
              </div>
          {%- endunless -%}

        {%- else -%}
          {%- comment -%} Legacy fallback — settings c2/c3 columns + social settings {%- endcomment -%}

          <!-- ── Quick Links (Col 2) ── -->
          <div class="ft-accordion-group border-t border-white/[0.08] md:border-t-0">
            <button class="ft-accordion-btn w-full flex items-center justify-between py-4 md:py-0 md:pointer-events-none md:cursor-default"
                    aria-expanded="false">
              <span class="font-heading font-bold text-[1.1rem] md:text-[0.95rem] text-white leading-tight">
                {{ section.settings.col2_title | default: 'Quick links' }}
              </span>
              <span class="ft-accordion-icon md:hidden w-5 h-5 relative flex items-center justify-center">
                <span class="block w-[18px] h-[2px] bg-white/60 rounded-full transition-transform duration-300"></span>
                <span class="ft-icon-vertical block w-[18px] h-[2px] bg-white/60 rounded-full absolute transition-transform duration-300 rotate-90"></span>
              </span>
            </button>
            <div class="ft-accordion-panel overflow-hidden md:!max-h-none md:!opacity-100 md:!mt-4"
                 style="max-height: 0; opacity: 0; transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease, margin 0.3s ease;">
              <ul class="pb-5 md:pb-0 flex flex-col gap-3">
                {%- for i in (1..6) -%}
                  {%- assign label_key = 'c2_link' | append: i | append: '_label' -%}
                  {%- assign url_key = 'c2_link' | append: i | append: '_url' -%}
                  {%- assign label = section.settings[label_key] -%}
                  {%- assign url = section.settings[url_key] -%}
                  {%- if label != blank and url != blank -%}
                    <li>
                      <a href="{{ url }}"
                         class="font-body text-[0.72rem] tracking-[0.14em] uppercase text-white/50 hover:text-white transition-colors duration-300">
                        {{ label }}
                      </a>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </div>
          </div>

          <!-- ── Support (Col 3) ── -->
          <div class="ft-accordion-group border-t border-white/[0.08] md:border-t-0">
            <button class="ft-accordion-btn w-full flex items-center justify-between py-4 md:py-0 md:pointer-events-none md:cursor-default"
                    aria-expanded="false">
              <span class="font-heading font-bold text-[1.1rem] md:text-[0.95rem] text-white leading-tight">
                {{ section.settings.col3_title | default: 'Support' }}
              </span>
              <span class="ft-accordion-icon md:hidden w-5 h-5 relative flex items-center justify-center">
                <span class="block w-[18px] h-[2px] bg-white/60 rounded-full transition-transform duration-300"></span>
                <span class="ft-icon-vertical block w-[18px] h-[2px] bg-white/60 rounded-full absolute transition-transform duration-300 rotate-90"></span>
              </span>
            </button>
            <div class="ft-accordion-panel overflow-hidden md:!max-h-none md:!opacity-100 md:!mt-4"
                 style="max-height: 0; opacity: 0; transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease, margin 0.3s ease;">
              <ul class="pb-5 md:pb-0 flex flex-col gap-3">
                {%- for i in (1..6) -%}
                  {%- assign label_key = 'c3_link' | append: i | append: '_label' -%}
                  {%- assign url_key = 'c3_link' | append: i | append: '_url' -%}
                  {%- assign label = section.settings[label_key] -%}
                  {%- assign url = section.settings[url_key] -%}
                  {%- if label != blank and url != blank -%}
                    <li>
                      <a href="{{ url }}"
                         class="font-body text-[0.72rem] tracking-[0.14em] uppercase text-white/50 hover:text-white transition-colors duration-300">
                        {{ label }}
                      </a>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </div>
          </div>

          <!-- ── Follow us on (Col 4 / Social) ── -->
          <div class="ft-accordion-group border-t border-white/[0.08] md:border-t-0">
            <button class="ft-accordion-btn w-full flex items-center justify-between py-4 md:py-0 md:pointer-events-none md:cursor-default"
                    aria-expanded="false">
              <span class="font-heading font-bold text-[1.1rem] md:text-[0.95rem] text-white leading-tight">
                {{ section.settings.col4_title | default: 'Follow us on' }}
              </span>
              <span class="ft-accordion-icon md:hidden w-5 h-5 relative flex items-center justify-center">
                <span class="block w-[18px] h-[2px] bg-white/60 rounded-full transition-transform duration-300"></span>
                <span class="ft-icon-vertical block w-[18px] h-[2px] bg-white/60 rounded-full absolute transition-transform duration-300 rotate-90"></span>
              </span>
            </button>
            <div class="ft-accordion-panel overflow-hidden md:!max-h-none md:!opacity-100 md:!mt-4"
                 style="max-height: 0; opacity: 0; transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease, margin 0.3s ease;">
              <ul class="pb-5 md:pb-0 flex flex-col gap-3">
                {%- if section.settings.social_instagram != blank -%}
                  <li>
                    <a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener"
                       class="inline-flex items-center gap-2 font-body text-[0.8rem] tracking-[0.04em] text-white/50 hover:text-white transition-colors duration-300">
                      Instagram
                      <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10"/></svg>
                    </a>
                  </li>
                {%- endif -%}
                {%- if section.settings.social_twitter != blank -%}
                  <li>
                    <a href="{{ section.settings.social_twitter }}" target="_blank" rel="noopener"
                       class="inline-flex items-center gap-2 font-body text-[0.8rem] tracking-[0.04em] text-white/50 hover:text-white transition-colors duration-300">
                      X (Twitter)
                      <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10"/></svg>
                    </a>
                  </li>
                {%- endif -%}
                {%- if section.settings.social_youtube != blank -%}
                  <li>
                    <a href="{{ section.settings.social_youtube }}" target="_blank" rel="noopener"
                       class="inline-flex items-center gap-2 font-body text-[0.8rem] tracking-[0.04em] text-white/50 hover:text-white transition-colors duration-300">
                      YouTube
                      <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10"/></svg>
                    </a>
                  </li>
                {%- endif -%}
                {%- if section.settings.social_tiktok != blank -%}
                  <li>
                    <a href="{{ section.settings.social_tiktok }}" target="_blank" rel="noopener"
                       class="inline-flex items-center gap-2 font-body text-[0.8rem] tracking-[0.04em] text-white/50 hover:text-white transition-colors duration-300">
                      Pinterest
                      <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10"/></svg>
                    </a>
                  </li>
                {%- endif -%}
                {%- if section.settings.social_facebook != blank -%}
                  <li>
                    <a href="{{ section.settings.social_facebook }}" target="_blank" rel="noopener"
                       class="inline-flex items-center gap-2 font-body text-[0.8rem] tracking-[0.04em] text-white/50 hover:text-white transition-colors duration-300">
                      Facebook
                      <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.5 11.5L11.5 4.5M11.5 4.5H6M11.5 4.5V10"/></svg>
                    </a>
                  </li>
                {%- endif -%}
              </ul>
            </div>
          </div>

        {%- endif -%}

      </div>
    </div>

    <!-- ── Bottom bar ── -->
    <div class="mt-10 pt-6 border-t border-white/[0.06] flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex flex-col items-center md:items-start gap-1">
        <p class="font-body text-[0.65rem] tracking-[0.1em] uppercase text-white/30">
          {%- if section.settings.copyright_text != blank -%}
            {{ section.settings.copyright_text }}
          {%- else -%}
            &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
          {%- endif -%}
        </p>
        {%- if section.settings.hotline != blank -%}
          <p class="font-body text-[0.65rem] tracking-[0.1em] uppercase text-white/30">{{ section.settings.hotline }}</p>
        {%- endif -%}
        {%- assign has_legal = false -%}
        {%- for i in (1..4) -%}
          {%- liquid
            assign legal_label_key = 'legal_' | append: i | append: '_label'
            assign legal_url_key   = 'legal_' | append: i | append: '_url'
            assign legal_label     = section.settings[legal_label_key]
            assign legal_url       = section.settings[legal_url_key]
          -%}
          {%- if legal_label != blank -%}
            {%- assign has_legal = true -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if has_legal -%}
          <nav class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-1" aria-label="Legal links">
            {%- for i in (1..4) -%}
              {%- liquid
                assign legal_label_key = 'legal_' | append: i | append: '_label'
                assign legal_url_key   = 'legal_' | append: i | append: '_url'
                assign legal_label     = section.settings[legal_label_key]
                assign legal_url       = section.settings[legal_url_key]
              -%}
              {%- if legal_label != blank -%}
                <a href="{{ legal_url | default: '#' }}" class="font-body text-[0.6rem] tracking-[0.08em] uppercase text-white/20 hover:text-white/50 transition-colors">{{ legal_label }}</a>
              {%- endif -%}
            {%- endfor -%}
          </nav>
        {%- endif -%}
      </div>
      <div class="flex items-center gap-3 opacity-40">
        {%- for type in shop.enabled_payment_types -%}
          <span class="h-6">{{ type | payment_type_svg_tag }}</span>
        {%- endfor -%}
      </div>
    </div>
  </div>
</footer-section>

<script>
  /* ═══ Footer Accordion — Web Component ═══ */
  if (!customElements.get('footer-section')) {
    class FooterSection extends HTMLElement {
      constructor() {
        super();
        this._buttons = [];
      }

      connectedCallback() {
        this.initAccordion();
      }

      disconnectedCallback() {
        this._buttons.forEach(btn => {
          btn.removeEventListener('click', btn._handler);
        });
        this._buttons = [];
      }

      initAccordion() {
        this._buttons = [...this.querySelectorAll('.ft-accordion-btn')];

        this._buttons.forEach(btn => {
          btn._handler = () => this.toggle(btn);
          btn.addEventListener('click', btn._handler);
        });
      }

      toggle(btn) {
        if (window.innerWidth >= 768) return;

        const group = btn.closest('.ft-accordion-group');
        const panel = group.querySelector('.ft-accordion-panel');
        const iconVertical = btn.querySelector('.ft-icon-vertical');
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        if (isOpen) {
          panel.style.maxHeight = '0';
          panel.style.opacity = '0';
          panel.style.marginTop = '0';
          btn.setAttribute('aria-expanded', 'false');
          if (iconVertical) iconVertical.style.transform = 'rotate(90deg)';
        } else {
          /* Close all others first */
          this._buttons.forEach(otherBtn => {
            if (otherBtn !== btn && otherBtn.getAttribute('aria-expanded') === 'true') {
              const otherGroup = otherBtn.closest('.ft-accordion-group');
              const otherPanel = otherGroup.querySelector('.ft-accordion-panel');
              const otherIcon = otherBtn.querySelector('.ft-icon-vertical');
              otherPanel.style.maxHeight = '0';
              otherPanel.style.opacity = '0';
              otherPanel.style.marginTop = '0';
              otherBtn.setAttribute('aria-expanded', 'false');
              if (otherIcon) otherIcon.style.transform = 'rotate(90deg)';
            }
          });

          panel.style.maxHeight = panel.scrollHeight + 'px';
          panel.style.opacity = '1';
          panel.style.marginTop = '0.5rem';
          btn.setAttribute('aria-expanded', 'true');
          if (iconVertical) iconVertical.style.transform = 'rotate(0deg)';
        }
      }
    }

    customElements.define('footer-section', FooterSection);
  }
</script>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "footer-section",
  "settings": [
    {
      "type": "header",
      "content": "Marquee"
    },
    {
      "type": "text",
      "id": "marquee_heading",
      "label": "Marquee Heading",
      "default": "Your Favorite Styles at Unmissable Prices"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "Marquee Speed (seconds)",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 20
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter Description",
      "default": "Whether you're looking for chic essentials, statement outfits, or casual staples, we've got something to suit every style. Browse our fresh arrivals and update your wardrobe with the season's hottest looks today!"
    },
    {
      "type": "header",
      "content": "Legacy: Column 2 — Quick Links (used when no blocks exist)"
    },
    {
      "type": "text",
      "id": "col2_title",
      "label": "Column 2 Title",
      "default": "Quick links"
    },
    {
      "type": "text",
      "id": "c2_link1_label",
      "label": "Link 1 Label"
    },
    {
      "type": "url",
      "id": "c2_link1_url",
      "label": "Link 1 URL"
    },
    {
      "type": "text",
      "id": "c2_link2_label",
      "label": "Link 2 Label"
    },
    {
      "type": "url",
      "id": "c2_link2_url",
      "label": "Link 2 URL"
    },
    {
      "type": "text",
      "id": "c2_link3_label",
      "label": "Link 3 Label"
    },
    {
      "type": "url",
      "id": "c2_link3_url",
      "label": "Link 3 URL"
    },
    {
      "type": "text",
      "id": "c2_link4_label",
      "label": "Link 4 Label"
    },
