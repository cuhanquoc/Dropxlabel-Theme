<hero-banner class="block relative w-full h-[100dvh] overflow-hidden bg-black">

  <!-- Nền: Video hoặc Ảnh (video ưu tiên nếu có) -->
  <div class="absolute inset-0 overflow-hidden">
    {% if section.settings.background_video != blank %}
      <!-- Video nền -->
      <video
        class="hero-video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        poster="{% if section.settings.background_image != blank %}{{ section.settings.background_image | image_url: width: 1920 }}{% endif %}"
      >
        {% for source in section.settings.background_video.sources %}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {% endfor %}
      </video>
    {% elsif section.settings.background_image != blank %}
      <!-- Ảnh nền -->
      <img
        src="{{ section.settings.background_image | image_url: width: 1920 }}"
        alt="{{ section.settings.background_image.alt | default: 'Hero background' }}"
        class="hero-image"
        loading="eager"
        fetchpriority="high"
      />
    {% else %}
      <!-- Fallback -->
      <img
        src="https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=1920&q=80&auto=format&fit=crop"
        alt="High fashion editorial — warm tones"
        class="hero-image"
        loading="eager"
        fetchpriority="high"
      />
    {% endif %}
  </div>

  <!-- Gradient Overlay -->
  <div class="absolute inset-0 bg-black/30"></div>
  <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(0,0,0,0.6)_0%,rgba(0,0,0,0.1)_60%,transparent_100%)]"></div>
  <div class="absolute inset-0 bg-[linear-gradient(to_top,rgba(0,0,0,0.55)_0%,transparent_45%)]"></div>

  <!-- Nội dung Hero -->
  <div class="hero-content-wrap absolute inset-0 flex flex-col justify-center items-start px-6 md:px-10 lg:px-14 pb-[8vh] md:pb-[14vh]">

    <!-- Eyebrow label -->
    <p class="hero-eyebrow font-body text-[9px] tracking-[0.3em] uppercase text-accent mb-8">
      {{ section.settings.eyebrow_text }}
    </p>

    <!-- Headline (GSAP Staggered Text Reveal) -->
    <h1 class="hero-headline font-heading text-[clamp(2.2rem,10vw,9rem)] font-semibold leading-[0.9] text-white max-w-[780px] tracking-[0.02em] mb-7">
      {{ section.settings.headline }}
    </h1>

    <!-- Sub-copy -->
    <p class="hero-copy font-body text-[0.9rem] leading-[1.8] text-white/[0.72] max-w-[380px] tracking-[0.02em] mb-10">
      {{ section.settings.subheadline }}
    </p>

    <!-- CTA Button (circle LEFT, text RIGHT — merged inline) -->
    <a href="{{ section.settings.cta_url }}" class="maya-merge-btn hero-cta">
      <span class="maya-merge-circle">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 17 17 7M7 7h10v10"/>
        </svg>
      </span>
      <span class="maya-merge-text ml-[-26px] pl-[44px]">{{ section.settings.cta_text }}</span>
    </a>

  </div>

  <!-- Marquee -->
  {%- assign marquee_speed_val = section.settings.marquee_speed | default: 22 -%}
  {%- assign marquee_dir = section.settings.marquee_direction | default: 'left' -%}
  <div class="absolute w-full overflow-hidden bottom-10 pointer-events-none">
    <div class="marquee-track" style="
      --marquee-speed: {{ marquee_speed_val }}s;
      --marquee-animation: {% if marquee_dir == 'right' %}marquee-reverse{% else %}marquee{% endif %};
    ">
      {% for i in (1..4) %}
        <span class="marquee-text" style="color: {{ section.settings.marquee_color | default: 'rgba(255,255,255,0.6)' }};">{{ section.settings.marquee_text }}&nbsp;</span>
      {% endfor %}
    </div>
  </div>

</hero-banner>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Background Media"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Recommended: 1920×1080px. Used as fallback if no video is set."
    },
    {
      "type": "video",
      "id": "background_video",
      "label": "Background Video",
      "info": "Short loop video (<10s). If set, this takes priority over the image."
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow Text",
      "default": "New Collection 2025"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline",
      "default": "Timeless<br>Fashion Essence",
      "info": "Use <br> for line breaks"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Sub-headline",
      "default": "Curated pieces that transcend seasons — wear what endures beyond trends."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Explore Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button Link",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Marquee Settings"
    },
    {
      "type": "text",
      "id": "marquee_text",
      "label": "Marquee Text",
      "default": "Elegance • Style • Luxury • Forever •",
      "info": "Scrolling text at the bottom"
    },
    {
      "type": "color",
      "id": "marquee_color",
      "label": "Marquee Text Color",
      "default": "#ffffff99",
      "info": "Supports opacity (e.g. rgba)"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 22,
      "unit": "s",
      "label": "Marquee Speed",
      "info": "Lower = faster. Default: 22s"
    },
    {
      "type": "select",
      "id": "marquee_direction",
      "label": "Marquee Direction",
      "options": [
        { "value": "left", "label": "Left to Right" },
        { "value": "right", "label": "Right to Left" }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
