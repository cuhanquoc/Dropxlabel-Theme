<style>
  /* ─── Ken Burns Effect ─── */
  @keyframes kenBurns {
    0%   { transform: scale(1)    translateX(0)     translateY(0);      filter: blur(10px); }
    15%  { filter: blur(0px); }
    33%  { transform: scale(1.05) translateX(-1%)   translateY(-0.5%);  filter: blur(0px); }
    66%  { transform: scale(1.10) translateX(1%)    translateY(-1%);    filter: blur(0px); }
    100% { transform: scale(1.15) translateX(-0.5%) translateY(-1.5%);  filter: blur(0px); }
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    animation: kenBurns 30s ease-in-out infinite alternate;
    transform-origin: center center;
    will-change: transform;
  }

  /* ─── Hero Text Entrance ─── */
  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-eyebrow {
    animation: fadeSlideUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  .hero-headline {
    animation: fadeSlideUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.55s both;
  }

  .hero-copy {
    animation: fadeSlideUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.75s both;
  }

  .hero-cta {
    animation: fadeSlideUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.95s both;
  }

  /* ─── CTA Button: Magnetic Merge Arrow ─── */
  .maya-magnetic-wrap {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    text-decoration: none;
    cursor: pointer;
  }

  .mm-pill {
    background-color: #ffffff;
    color: #0a0a0a;
    padding: 1.1rem 3.5rem;
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    transition: all 0.6s cubic-bezier(0.87, 0, 0.13, 1);
  }

  .mm-circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 58px;
    height: 58px;
    background-color: #ffffff;
    color: #0a0a0a;
    border-radius: 50%;
    transition: all 0.6s cubic-bezier(0.87, 0, 0.13, 1);
    flex-shrink: 0;
  }

  /* Hover: hút vào nhau */
  .maya-magnetic-wrap:hover { gap: 0px; }

  .maya-magnetic-wrap:hover .mm-pill {
    padding-right: 4.5rem;
    background-color: #e5e5e5;
  }

  .maya-magnetic-wrap:hover .mm-circle {
    transform: translateX(-52px) rotate(-45deg);
    background-color: #0a0a0a;
    color: #ffffff;
  }

  /* ─── Marquee ─── */
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee 22s linear infinite;
    will-change: transform;
  }

  .marquee-track:hover {
    animation-play-state: paused;
  }

  .marquee-text {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    white-space: nowrap;
    padding-right: 4rem;
    line-height: 1;
    user-select: none;
  }
</style>

<section class="relative w-full h-screen overflow-hidden bg-black">

  <!-- Ảnh nền với Ken Burns Animation -->
  <div class="absolute inset-0 overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=1920&q=80&auto=format&fit=crop"
      alt="High fashion editorial — warm tones"
      class="hero-image"
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <!-- Gradient Overlay: dark từ bên trái + tối phần dưới -->
  <div class="absolute inset-0 bg-black/30"></div>
  <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.1) 60%, transparent 100%);"></div>
  <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 45%);"></div>

  <!-- Nội dung Hero giữa ảnh -->
  <div class="absolute inset-0 flex flex-col justify-center items-start px-20" style="padding-bottom: 14vh;">

    <!-- Eyebrow label -->
    <p class="hero-eyebrow" style="font-family: var(--font-body); font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--color-accent); margin-bottom: 1.25rem;">
      New Collection 2025
    </p>

    <!-- Headline -->
    <h1 class="hero-headline" style="font-family: var(--font-heading); font-size: clamp(3.5rem, 12vw, 9rem); font-weight: 600; line-height: 0.9; color: #ffffff; max-width: 780px; letter-spacing: -0.03em; margin-bottom: 1.5rem;">
      Timeless<br>Fashion Essence
    </h1>

    <!-- Sub-copy -->
    <p class="hero-copy" style="font-family: var(--font-body); font-size: 0.9rem; line-height: 1.8; color: rgba(255,255,255,0.72); max-width: 380px; letter-spacing: 0.02em; margin-bottom: 2.5rem;">
      Curated pieces that transcend seasons — wear what endures beyond trends.
    </p>

    <!-- CTA Button -->
    <a href="{{ routes.collections_url }}" class="maya-magnetic-wrap hero-cta">
      <span class="mm-pill">Explore Now</span>
      <span class="mm-circle">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </span>
    </a>



  </div>

  <!-- Marquee dải chữ viền trong suốt -->
  <div class="absolute w-full overflow-hidden" style="bottom: 2.5rem; pointer-events: none;">
    <div class="marquee-track">
      <!-- Lặp 2 lần để tạo loop vô tận liền mạch -->
      <span class="marquee-text">Elegance &bull; Style &bull; Luxury &bull; Forever &bull;&nbsp;</span>
      <span class="marquee-text">Elegance &bull; Style &bull; Luxury &bull; Forever &bull;&nbsp;</span>
      <span class="marquee-text">Elegance &bull; Style &bull; Luxury &bull; Forever &bull;&nbsp;</span>
      <span class="marquee-text">Elegance &bull; Style &bull; Luxury &bull; Forever &bull;&nbsp;</span>
    </div>
  </div>

</section>
