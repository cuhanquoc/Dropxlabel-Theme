<style>
  /* ─── Ken Burns Effect ─── */
  @keyframes kenBurns {
    0%   { transform: scale(1)    translateX(0)     translateY(0);      filter: blur(10px); }
    15%  { filter: blur(0px); }
    33%  { transform: scale(1.05) translateX(-1%)   translateY(-0.5%);  filter: blur(0px); }
    66%  { transform: scale(1.10) translateX(1%)    translateY(-1%);    filter: blur(0px); }
    100% { transform: scale(1.15) translateX(-0.5%) translateY(-1.5%);  filter: blur(0px); }
  }

  .hero-image,
  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    animation: kenBurns 30s ease-in-out infinite alternate;
    transform-origin: center center;
    will-change: transform;
  }

  .hero-video {
    animation: none; /* video tự có motion, không cần Ken Burns */
  }

  /* ─── Hero Text Entrance ─── */
  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-eyebrow {
    animation: fadeSlideUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  .hero-headline {
    /* Animation handled by GSAP stagger — no CSS animation */
  }

  /* Staggered Text Reveal masks */
  .hero-line-mask {
    display: block;
    overflow: hidden;
  }

  .hero-line {
    display: block;
    transform: translateY(100%);
    will-change: transform;
  }

  .hero-copy {
    animation: fadeSlideUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.75s both;
  }

  .hero-cta {
    animation: fadeSlideUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.95s both;
  }

  /* ─── Marquee ─── */
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @keyframes marquee-reverse {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: var(--marquee-animation, marquee) var(--marquee-speed, 22s) linear infinite;
    will-change: transform;
  }

  .marquee-track:hover {
    animation-play-state: paused;
  }

  .marquee-text {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    white-space: nowrap;
    padding-right: 4rem;
    line-height: 1;
    user-select: none;
  }

  /* ─── Desktop (≥ 768px) ─── */
  @media (min-width: 768px) {
    .hero-content-wrap {
      padding-left: 2.5rem;
      padding-right: 2.5rem;
    }
    .maya-merge-text {
      padding: 1.35rem 3rem;
      font-size: 0.78rem;
      letter-spacing: 0.2em;
    }
    .maya-merge-circle {
      width: 52px;
      height: 52px;
    }
  }

  /* ─── Large Desktop (≥ 1024px) ─── */
  @media (min-width: 1024px) {
    .hero-content-wrap {
      padding-left: 3.5rem;
      padding-right: 3.5rem;
    }
  }

  /* ─── Mobile (< 768px) ─── */
  @media (max-width: 767px) {
    .marquee-text {
      font-size: clamp(1.8rem, 8vw, 3rem);
      padding-right: 2rem;
    }
    .maya-merge-btn {
      align-self: flex-start;
      margin-left: 4px;
    }
    .maya-merge-text {
      padding: 0.8rem 1.5rem 0.8rem 2.2rem;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
    }
    .maya-merge-circle {
      width: 40px;
      height: 40px;
    }
  }
  /* ─── CTA: Magnetic Merge Button ─── */
  .maya-merge-btn {
    display: inline-flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    align-self: flex-start;
    gap: 0;
    text-decoration: none;
    cursor: pointer;
    max-width: fit-content;
  }

  .maya-merge-text {
    position: relative;
    z-index: 2;
    background-color: #ffffff;
    color: #0a0a0a;
    padding: 1.35rem 3rem;
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    white-space: nowrap;
    transition: padding 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .maya-merge-circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    background-color: #0a0a0a;
    color: #ffffff;
    border-radius: 50%;
    flex-shrink: 0;
    position: relative;
    z-index: 3;
    transition:
      background-color 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      color            0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* ─── HOVER: circle bg becomes lighter, text pill merges ─── */
  @media (hover: hover) {
    .maya-merge-btn:hover .maya-merge-text {
      padding-left: 4rem;
      margin-left: -26px;
    }
    .maya-merge-btn:hover .maya-merge-circle {
      background-color: #333333;
      color: #ffffff;
    }
  }
</style>

<section class="relative w-full h-[100dvh] overflow-hidden bg-black">

  <!-- Nền: Video hoặc Ảnh (video ưu tiên nếu có) -->
  <div class="absolute inset-0 overflow-hidden">
    {% if section.settings.background_video != blank %}
      <!-- Video nền -->
      <video
        class="hero-video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        poster="{% if section.settings.background_image != blank %}{{ section.settings.background_image | image_url: width: 1920 }}{% endif %}"
      >
        {% for source in section.settings.background_video.sources %}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {% endfor %}
      </video>
    {% elsif section.settings.background_image != blank %}
      <!-- Ảnh nền -->
      <img
        src="{{ section.settings.background_image | image_url: width: 1920 }}"
        alt="{{ section.settings.background_image.alt | default: 'Hero background' }}"
        class="hero-image"
        loading="eager"
        fetchpriority="high"
      />
    {% else %}
      <!-- Fallback -->
      <img
        src="https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=1920&q=80&auto=format&fit=crop"
        alt="High fashion editorial — warm tones"
        class="hero-image"
        loading="eager"
        fetchpriority="high"
      />
    {% endif %}
  </div>

  <!-- Gradient Overlay -->
  <div class="absolute inset-0 bg-black/30"></div>
  <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.1) 60%, transparent 100%);"></div>
  <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 45%);"></div>

  <!-- Nội dung Hero -->
  <div class="absolute inset-0 flex flex-col justify-center items-start px-10" style="padding-bottom: 14vh;">
    <style>
      @media (max-width: 767px) {
        .hero-content-wrap { padding-bottom: 8vh !important; }
      }
    </style>

    <!-- Eyebrow label -->
    <p class="hero-eyebrow" style="font-family: var(--font-body); font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--color-accent); margin-bottom: 32px;">
      {{ section.settings.eyebrow_text }}
    </p>

    <!-- Headline (GSAP Staggered Text Reveal) -->
    <h1 id="hero-heading" class="hero-headline" style="font-family: var(--font-heading); font-size: clamp(2.2rem, 10vw, 9rem); font-weight: 600; line-height: 0.9; color: #ffffff; max-width: 780px; letter-spacing: 0.02em; margin-bottom: 28px;">
      {{ section.settings.headline }}
    </h1>

    <!-- Sub-copy -->
    <p class="hero-copy" style="font-family: var(--font-body); font-size: 0.9rem; line-height: 1.8; color: rgba(255,255,255,0.72); max-width: 380px; letter-spacing: 0.02em; margin-bottom: 40px;">
      {{ section.settings.subheadline }}
    </p>

    <!-- CTA Button (circle LEFT, text RIGHT — merged inline) -->
    <a href="{{ section.settings.cta_url }}" class="maya-merge-btn hero-cta">
      <span class="maya-merge-circle">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 17 17 7M7 7h10v10"/>
        </svg>
      </span>
      <span class="maya-merge-text" style="margin-left: -26px; padding-left: 44px;">{{ section.settings.cta_text }}</span>
    </a>

  </div>

  <!-- Marquee -->
  {%- assign marquee_speed_val = section.settings.marquee_speed | default: 22 -%}
  {%- assign marquee_dir = section.settings.marquee_direction | default: 'left' -%}
  <div class="absolute w-full overflow-hidden" style="bottom: 2.5rem; pointer-events: none;">
    <div class="marquee-track" style="
      --marquee-speed: {{ marquee_speed_val }}s;
      --marquee-animation: {% if marquee_dir == 'right' %}marquee-reverse{% else %}marquee{% endif %};
    ">
      {% for i in (1..4) %}
        <span class="marquee-text" style="color: {{ section.settings.marquee_color | default: 'rgba(255,255,255,0.6)' }};">{{ section.settings.marquee_text }}&nbsp;</span>
      {% endfor %}
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Background Media"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Recommended: 1920×1080px. Used as fallback if no video is set."
    },
    {
      "type": "video",
      "id": "background_video",
      "label": "Background Video",
      "info": "Short loop video (<10s). If set, this takes priority over the image."
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow Text",
      "default": "New Collection 2025"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline",
      "default": "Timeless<br>Fashion Essence",
      "info": "Use <br> for line breaks"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Sub-headline",
      "default": "Curated pieces that transcend seasons — wear what endures beyond trends."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Explore Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button Link",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Marquee Settings"
    },
    {
      "type": "text",
      "id": "marquee_text",
      "label": "Marquee Text",
      "default": "Elegance • Style • Luxury • Forever •",
      "info": "Scrolling text at the bottom"
    },
    {
      "type": "color",
      "id": "marquee_color",
      "label": "Marquee Text Color",
      "default": "#ffffff99",
      "info": "Supports opacity (e.g. rgba)"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 22,
      "unit": "s",
      "label": "Marquee Speed",
      "info": "Lower = faster. Default: 22s"
    },
    {
      "type": "select",
      "id": "marquee_direction",
      "label": "Marquee Direction",
      "options": [
        { "value": "left", "label": "Left to Right" },
        { "value": "right", "label": "Right to Left" }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
