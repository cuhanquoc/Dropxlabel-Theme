<hero-banner class="relative block min-h-[100dvh] overflow-hidden bg-[#f8f6f1] text-[#0c0c0b]">
  <div class="absolute inset-0 overflow-hidden">
    {% if section.settings.background_video != blank %}
      <video
        class="hero-video h-full w-full object-cover object-center opacity-70"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="{% if section.settings.background_image != blank %}{{ section.settings.background_image | image_url: width: 1920 }}{% endif %}"
      >
        {% for source in section.settings.background_video.sources %}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {% endfor %}
      </video>
    {% elsif section.settings.background_image != blank %}
      <img
        src="{{ section.settings.background_image | image_url: width: 1920 }}"
        alt="{{ section.settings.background_image.alt | default: 'Hero background' }}"
        class="hero-image h-full w-full object-cover object-center opacity-75"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="1080"
      />
    {% else %}
      <div
        class="hero-image h-full w-full bg-[radial-gradient(circle_at_top_left,rgba(196,168,130,0.18),transparent_34%),linear-gradient(180deg,#fbf8f3_0%,#f4efe6_100%)]"
        role="img"
        aria-label="Hero background"
      ></div>
    {% endif %}
  </div>

  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(248,246,241,0.86)_0%,rgba(248,246,241,0.54)_45%,rgba(248,246,241,0.08)_100%)]"></div>
  <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(248,246,241,0.04)_0%,rgba(248,246,241,0.18)_64%,rgba(248,246,241,0.78)_100%)]"></div>

  <div class="relative z-10 mx-auto flex min-h-[100dvh] w-full max-w-7xl items-end px-5 pb-16 pt-24 md:px-8 lg:items-center lg:px-12 lg:py-20">
    <div class="max-w-[42rem]">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'eyebrow' %}
              <p {{ block.shopify_attributes }} class="mb-6 inline-flex rounded-full border border-black/10 bg-white/70 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.32em] text-[#6f6558] backdrop-blur-sm">
                {{ block.settings.text }}
              </p>
            {% when 'heading' %}
              <h1 {{ block.shopify_attributes }} class="hero-headline font-heading text-[clamp(3rem,11vw,8.5rem)] leading-[0.88] tracking-[-0.05em] text-[#0c0c0b]">
                {{ block.settings.text }}
              </h1>
            {% when 'subheadline' %}
              <p {{ block.shopify_attributes }} class="mt-6 max-w-[34rem] font-body text-[0.98rem] leading-[1.8] text-[#5f5a52] md:text-[1.05rem]">
                {{ block.settings.text }}
              </p>
            {% when 'button' %}
              <a
                {{ block.shopify_attributes }}
                href="{{ block.settings.url | default: '#' }}"
                class="group mt-8 inline-flex items-center gap-3 rounded-full border border-black/10 bg-[#0c0c0b] px-4 py-3 text-[#f8f6f1] shadow-[0_18px_40px_-24px_rgba(12,12,11,0.55)] transition-transform duration-300 ease-out hover:-translate-y-0.5 active:translate-y-px"
              >
                <span class="font-body text-[0.72rem] font-semibold uppercase tracking-[0.24em] md:text-[0.78rem]">
                  {{ block.settings.label }}
                </span>
                <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-white/10 ring-1 ring-inset ring-white/15 transition-transform duration-300 ease-out group-hover:translate-x-0.5 group-hover:scale-105">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7 17 17 7M7 7h10v10"/>
                  </svg>
                </span>
              </a>
          {% endcase %}
        {% endfor %}
      {% else %}
        <p class="mb-6 inline-flex rounded-full border border-black/10 bg-white/70 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.32em] text-[#6f6558] backdrop-blur-sm">
          {{ section.settings.eyebrow_text }}
        </p>

        <h1 class="hero-headline font-heading text-[clamp(3rem,11vw,8.5rem)] leading-[0.88] tracking-[-0.05em] text-[#0c0c0b]">
          {{ section.settings.headline }}
        </h1>

        <p class="mt-6 max-w-[34rem] font-body text-[0.98rem] leading-[1.8] text-[#5f5a52] md:text-[1.05rem]">
          {{ section.settings.subheadline }}
        </p>

        <a
          href="{{ section.settings.cta_url }}"
          class="group mt-8 inline-flex items-center gap-3 rounded-full border border-black/10 bg-[#0c0c0b] px-4 py-3 text-[#f8f6f1] shadow-[0_18px_40px_-24px_rgba(12,12,11,0.55)] transition-transform duration-300 ease-out hover:-translate-y-0.5 active:translate-y-px"
        >
          <span class="font-body text-[0.72rem] font-semibold uppercase tracking-[0.24em] md:text-[0.78rem]">
            {{ section.settings.cta_text }}
          </span>
          <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-white/10 ring-1 ring-inset ring-white/15 transition-transform duration-300 ease-out group-hover:translate-x-0.5 group-hover:scale-105">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 17 17 7M7 7h10v10"/>
            </svg>
          </span>
        </a>
      {% endif %}

      <div class="mt-8 flex flex-wrap gap-2">
        <span class="rounded-full border border-black/10 bg-white/70 px-3 py-2 text-[10px] font-semibold uppercase tracking-[0.24em] text-[#6f6558] backdrop-blur-sm">Curated silhouettes</span>
        <span class="rounded-full border border-black/10 bg-white/70 px-3 py-2 text-[10px] font-semibold uppercase tracking-[0.24em] text-[#6f6558] backdrop-blur-sm">Seasonal texture</span>
        <span class="rounded-full border border-black/10 bg-white/70 px-3 py-2 text-[10px] font-semibold uppercase tracking-[0.24em] text-[#6f6558] backdrop-blur-sm">Quiet confidence</span>
      </div>
    </div>
  </div>

  {%- assign marquee_speed_val = section.settings.marquee_speed | default: 22 -%}
  {%- assign marquee_dir = section.settings.marquee_direction | default: 'left' -%}
  <div class="absolute inset-x-0 bottom-6 z-10 px-5 md:px-8 lg:px-12">
    <div class="overflow-hidden border-y border-black/10 bg-white/60 backdrop-blur-md">
      <div
        class="marquee-track"
        style="
          --marquee-speed: {{ marquee_speed_val }}s;
          --marquee-animation: {% if marquee_dir == 'right' %}marquee-reverse{% else %}marquee{% endif %};
        "
        aria-hidden="true"
      >
        {% for i in (1..4) %}
          <span class="marquee-text text-[10px] tracking-[0.34em] text-[#6f6558]" style="color: {{ section.settings.marquee_color | default: 'rgba(111, 101, 88, 0.7)' }};">
            {{ section.settings.marquee_text }}&nbsp;
          </span>
        {% endfor %}
      </div>
    </div>
  </div>
</hero-banner>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Background Media"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Recommended: 1920×1080px. Used as fallback if no video is set."
    },
    {
      "type": "video",
      "id": "background_video",
      "label": "Background Video",
      "info": "Short loop video (<10s). If set, this takes priority over the image."
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow Text",
      "default": "New Collection 2025"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline",
      "default": "Timeless<br>Fashion Essence",
      "info": "Use <br> for line breaks"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Sub-headline",
      "default": "Curated pieces that transcend seasons — wear what endures beyond trends."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Explore Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button Link",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Marquee Settings"
    },
    {
      "type": "text",
      "id": "marquee_text",
      "label": "Marquee Text",
      "default": "Elegance • Style • Luxury • Forever •",
      "info": "Scrolling text at the bottom"
    },
    {
      "type": "color",
      "id": "marquee_color",
      "label": "Marquee Text Color",
      "default": "#ffffff99",
      "info": "Supports opacity (e.g. rgba)"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 22,
      "unit": "s",
      "label": "Marquee Speed",
      "info": "Lower = faster. Default: 22s"
    },
    {
      "type": "select",
      "id": "marquee_direction",
      "label": "Marquee Direction",
      "options": [
        { "value": "left", "label": "Left to Right" },
        { "value": "right", "label": "Right to Left" }
      ],
      "default": "left"
    }
  ],
  "max_blocks": 12,
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "New Collection 2025"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Timeless<br>Fashion Essence",
          "info": "Use <br> for line breaks"
        }
      ]
    },
    {
      "type": "subheadline",
      "name": "Subheadline",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Curated pieces that transcend seasons — wear what endures beyond trends."
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Explore Now"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "eyebrow" },
        { "type": "heading" },
        { "type": "subheadline" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
