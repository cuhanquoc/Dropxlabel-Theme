<hero-banner class="hero-banner block relative w-full h-[100dvh] overflow-hidden bg-black" data-section-id="{{ section.id }}">

  <!-- Nền: Video hoặc Ảnh (video ưu tiên nếu có) -->
  <div class="absolute inset-0 overflow-hidden">
    {% if section.settings.background_video != blank %}
      <!-- Video nền -->
      <video
        class="hero-video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        fetchpriority="high"
        poster="{% if section.settings.background_image != blank %}{{ section.settings.background_image | image_url: width: 1920 }}{% endif %}"
      >
        {% for source in section.settings.background_video.sources %}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {% endfor %}
      </video>
    {% elsif section.settings.background_image != blank %}
      <!-- Ảnh nền -->
      <img
        src="{{ section.settings.background_image | image_url: width: 1920 }}"
        alt="{{ section.settings.background_image.alt | default: 'Hero background' }}"
        class="hero-image"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="1080"
      />
    {% else %}
      <!-- Fallback: Shopify blank placeholder (no external CDN) -->
      <div
        class="hero-image"
        style="background:{{ settings.colors_background_1 | default: '#111' }};width:100%;height:100%;display:block;"
        role="img"
        aria-label="Hero background"
      ></div>
    {% endif %}
  </div>

  <!-- Gradient Overlay -->
  <div class="absolute inset-0 bg-black/30"></div>
  <div class="absolute inset-0 hidden md:block bg-[linear-gradient(to_bottom,rgba(0,0,0,0.26)_0%,rgba(0,0,0,0.18)_16%,rgba(0,0,0,0.06)_30%,transparent_44%)]"></div>
  <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(0,0,0,0.6)_0%,rgba(0,0,0,0.1)_60%,transparent_100%)]"></div>
  <div class="absolute inset-0 bg-[linear-gradient(to_top,rgba(0,0,0,0.55)_0%,transparent_45%)]"></div>

  <!-- Nội dung Hero -->
  <div class="hero-content-wrap absolute inset-0 flex flex-col justify-center items-start px-6 md:px-10 lg:px-14 pb-[8vh] md:pb-[14vh]">

    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'eyebrow' %}
            <p {{ block.shopify_attributes }} class="hero-eyebrow font-body text-[9px] tracking-[0.3em] uppercase text-accent mb-8">
              {{ block.settings.text }}
            </p>
          {% when 'heading' %}
            <h1 {{ block.shopify_attributes }} class="hero-headline font-heading text-[clamp(2.2rem,10vw,9rem)] font-semibold leading-[0.9] text-white max-w-[780px] tracking-[0.02em] mb-7">
              {{ block.settings.text }}
            </h1>
          {% when 'subheadline' %}
            <p {{ block.shopify_attributes }} class="hero-copy font-body text-[0.9rem] leading-[1.8] text-white/[0.72] max-w-[380px] tracking-[0.02em] mb-10">
              {{ block.settings.text }}
            </p>
          {% when 'button' %}
            <a {{ block.shopify_attributes }} href="{{ block.settings.url | default: '#' }}" class="maya-merge-btn hero-cta group relative inline-flex h-[52px] w-max cursor-pointer items-center no-underline max-md:h-10">
              <span class="relative z-10 flex h-[52px] w-[52px] shrink-0 items-center justify-center rounded-full bg-[#0a0a0a] text-white transition-colors duration-500 group-hover:bg-[#333333] max-md:h-10 max-md:w-10">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 17 17 7M7 7h10v10"/>
                </svg>
              </span>
              <span class="relative z-0 flex h-full -ml-[26px] items-center rounded-full bg-white pl-[44px] pr-8 font-body text-[0.78rem] font-semibold uppercase tracking-[0.2em] text-[#0a0a0a] transition-all duration-500 group-hover:pl-[56px] max-md:pl-[36px] max-md:pr-6 max-md:text-[0.65rem] max-md:tracking-[0.15em]">
                {{ block.settings.label }}
              </span>
            </a>
        {% endcase %}
      {% endfor %}
    {% else %}
      <!-- Backward-compatible fallback -->
      <p class="hero-eyebrow font-body text-[9px] tracking-[0.3em] uppercase text-accent mb-8">
        {{ section.settings.eyebrow_text }}
      </p>

      <h1 class="hero-headline font-heading text-[clamp(2.2rem,10vw,9rem)] font-semibold leading-[0.9] text-white max-w-[780px] tracking-[0.02em] mb-7">
        {{ section.settings.headline }}
      </h1>

      <p class="hero-copy font-body text-[0.9rem] leading-[1.8] text-white/[0.72] max-w-[380px] tracking-[0.02em] mb-10">
        {{ section.settings.subheadline }}
      </p>

      <a href="{{ section.settings.cta_url }}" class="maya-merge-btn hero-cta group relative inline-flex h-[52px] w-max cursor-pointer items-center no-underline max-md:h-10">
        <span class="relative z-10 flex h-[52px] w-[52px] shrink-0 items-center justify-center rounded-full bg-[#0a0a0a] text-white transition-colors duration-500 group-hover:bg-[#333333] max-md:h-10 max-md:w-10">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 17 17 7M7 7h10v10"/>
          </svg>
        </span>
        <span class="relative z-0 flex h-full -ml-[26px] items-center rounded-full bg-white pl-[44px] pr-8 font-body text-[0.78rem] font-semibold uppercase tracking-[0.2em] text-[#0a0a0a] transition-all duration-500 group-hover:pl-[56px] max-md:pl-[36px] max-md:pr-6 max-md:text-[0.65rem] max-md:tracking-[0.15em]">
          {{ section.settings.cta_text }}
        </span>
      </a>
    {% endif %}

  </div>

  <!-- Marquee -->
  {%- assign marquee_speed_val = section.settings.marquee_speed | default: 22 -%}
  {%- assign marquee_dir = section.settings.marquee_direction | default: 'left' -%}
  <div class="absolute w-full overflow-hidden bottom-10 pointer-events-none">
    <div class="marquee-track" style="
      --marquee-speed: {{ marquee_speed_val }}s;
      --marquee-animation: {% if marquee_dir == 'right' %}marquee-reverse{% else %}marquee{% endif %};
    ">
      {% for i in (1..4) %}
        <span class="marquee-text" style="color: {{ section.settings.marquee_color | default: 'rgba(255,255,255,0.6)' }};">{{ section.settings.marquee_text }}&nbsp;</span>
      {% endfor %}
    </div>
  </div>

</hero-banner>

<style>
  hero-banner[data-section-id="{{ section.id }}"] .hero-video,
  hero-banner[data-section-id="{{ section.id }}"] .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @keyframes heroSlideRight-{{ section.id }} {
    from {
      opacity: 0;
      transform: translate3d(-24px, 0, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @media (max-width: 767px) {
    hero-banner[data-section-id="{{ section.id }}"] {
      height: calc(100svh - 148px);
      min-height: 500px;
      max-height: 640px;
    }

    hero-banner[data-section-id="{{ section.id }}"] .hero-content-wrap {
      justify-content: center;
      align-items: flex-start;
      padding: 1.25rem 1.5rem 2.8rem;
    }

    hero-banner[data-section-id="{{ section.id }}"] .hero-eyebrow {
      margin-bottom: 1.15rem;
      font-size: 0.82rem;
      letter-spacing: 0.28em;
      line-height: 1.2;
      opacity: 0;
      animation: heroSlideRight-{{ section.id }} 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.08s forwards;
    }

    hero-banner[data-section-id="{{ section.id }}"] .hero-headline {
      max-width: 8.4ch;
      margin-bottom: 1.15rem;
      font-size: clamp(3rem, 12vw, 4.7rem);
      line-height: 0.92;
      opacity: 0;
      animation: heroSlideRight-{{ section.id }} 0.82s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
    }

    hero-banner[data-section-id="{{ section.id }}"] .hero-copy {
      max-width: 24ch;
      margin-bottom: 1.85rem;
      font-size: 1rem;
      line-height: 1.5;
      color: rgba(255, 255, 255, 0.8);
      opacity: 0;
      animation: heroSlideRight-{{ section.id }} 0.78s cubic-bezier(0.22, 1, 0.36, 1) 0.34s forwards;
    }

    hero-banner[data-section-id="{{ section.id }}"] .hero-cta {
      margin-bottom: 0;
      align-self: flex-start;
      opacity: 0;
      animation: heroSlideRight-{{ section.id }} 0.82s cubic-bezier(0.22, 1, 0.36, 1) 0.48s forwards;
    }

    hero-banner[data-section-id="{{ section.id }}"] .marquee-track {
      opacity: 0.82;
    }

    hero-banner[data-section-id="{{ section.id }}"] .absolute.w-full.overflow-hidden.bottom-10 {
      bottom: 0.35rem;
    }
  }

  @media (min-width: 768px) {
    hero-banner[data-section-id="{{ section.id }}"] .hero-content-wrap {
      justify-content: flex-end;
      padding-top: calc(var(--dx-live-header-stack-height, 72px) + clamp(2.75rem, 4vw, 4.5rem));
      padding-bottom: 6.25rem;
    }

    hero-banner[data-section-id="{{ section.id }}"] .hero-eyebrow {
      margin-bottom: 1.25rem;
    }

    hero-banner[data-section-id="{{ section.id }}"] .hero-headline {
      max-width: 7.4ch;
      margin-bottom: 1.35rem;
    }

    hero-banner[data-section-id="{{ section.id }}"] .hero-copy {
      margin-bottom: 2.1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    hero-banner[data-section-id="{{ section.id }}"] .hero-eyebrow,
    hero-banner[data-section-id="{{ section.id }}"] .hero-headline,
    hero-banner[data-section-id="{{ section.id }}"] .hero-copy,
    hero-banner[data-section-id="{{ section.id }}"] .hero-cta {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script>
  (function () {
    var root = document.querySelector('hero-banner[data-section-id="{{ section.id }}"]');
    if (!root || root.dataset.mobileMediaInit === 'true') return;
    root.dataset.mobileMediaInit = 'true';

    var heroVideo = root.querySelector('.hero-video');
    if (!heroVideo) return;

    function syncHeroMedia() {
      var isMobile = window.matchMedia('(max-width: 767px)').matches;

      if (isMobile) {
        heroVideo.removeAttribute('autoplay');
        heroVideo.pause();
        try {
          heroVideo.currentTime = 0;
        } catch (e) {}
      } else if (!heroVideo.hasAttribute('autoplay')) {
        heroVideo.setAttribute('autoplay', '');
        var playPromise = heroVideo.play();
        if (playPromise && typeof playPromise.catch === 'function') {
          playPromise.catch(function () {});
        }
      }
    }

    syncHeroMedia();
    window.addEventListener('resize', syncHeroMedia, { passive: true });
  })();
</script>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Background Media"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Recommended: 1920×1080px. Used as fallback if no video is set."
    },
    {
      "type": "video",
      "id": "background_video",
      "label": "Background Video",
      "info": "Short loop video (<10s). If set, this takes priority over the image."
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow Text",
      "default": "New Collection 2025"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline",
      "default": "Timeless<br>Fashion Essence",
      "info": "Use <br> for line breaks"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Sub-headline",
      "default": "Curated pieces that transcend seasons — wear what endures beyond trends."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Explore Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button Link",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Marquee Settings"
    },
    {
      "type": "text",
      "id": "marquee_text",
      "label": "Marquee Text",
      "default": "Elegance • Style • Luxury • Forever •",
      "info": "Scrolling text at the bottom"
    },
    {
      "type": "color",
      "id": "marquee_color",
      "label": "Marquee Text Color",
      "default": "#ffffff99",
      "info": "Supports opacity (e.g. rgba)"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 22,
      "unit": "s",
      "label": "Marquee Speed",
      "info": "Lower = faster. Default: 22s"
    },
    {
      "type": "select",
      "id": "marquee_direction",
      "label": "Marquee Direction",
      "options": [
        { "value": "left", "label": "Left to Right" },
        { "value": "right", "label": "Right to Left" }
      ],
      "default": "left"
    }
  ],
  "max_blocks": 12,
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "New Collection 2025"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Timeless<br>Fashion Essence",
          "info": "Use <br> for line breaks"
        }
      ]
    },
    {
      "type": "subheadline",
      "name": "Subheadline",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Curated pieces that transcend seasons — wear what endures beyond trends."
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Explore Now"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "eyebrow" },
        { "type": "heading" },
        { "type": "subheadline" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
