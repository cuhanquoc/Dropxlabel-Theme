{% comment %} HEADER — CSS → src/input.css {% endcomment %}

{%- liquid
  assign is_home = false
  if request.page_type == 'index'
    assign is_home = true
  endif
-%}

<style>
  .site-header { position: sticky; top: 0; background-color: #ffffff; border-bottom: 1px solid #eaeaea; z-index: 40; }
  .site-header, .nav-link, .icon-btn, .mega-trigger { color: #0a0a0a !important; }
  .hamburger-line { background-color: #0a0a0a !important; }
  .site-header svg { stroke: #0a0a0a !important; }
  .header-logo-img { filter: invert(1); }
</style>

<header class="site-header w-full transition-colors duration-300">
  <div class="hdr-inner">

    <!-- ── LEFT: Hamburger (mobile) / Nav Links (desktop) ── -->
    <div class="hdr-left">
      <!-- Hamburger — mobile only -->
      <button type="button" class="hamburger-btn" id="hamburger-btn"
              aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="{{ routes.root_url }}" class="nav-link">Home</a>

        <!-- Catalog + Mega Menu -->
        <div class="mega-trigger">
          <a href="{{ routes.collections_url }}" class="nav-link">
            Catalog
            <svg class="chevron-down" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </a>

          <div class="mega-menu">
            <div class="mega-images">
              <a href="{{ section.settings.mega_image_link | default: routes.collections_url }}" class="mega-img-panel">
                {% if section.settings.mega_image != blank %}
                  <img src="{{ section.settings.mega_image | image_url: width: 800 }}" alt="{{ section.settings.mega_image_label | default: 'Fashion' }}" loading="lazy" />
                {% else %}
                  <div class="mega-img-placeholder" style="width:800px;height:600px;max-width:100%;background:#1a1a1a;display:block;" role="img" aria-label="{{ section.settings.mega_image_label | default: "Women's Fashion" }}"></div>
                {% endif %}
                <div class="mega-img-label">
                  <span class="mega-img-label-text">{{ section.settings.mega_image_label | default: "Women's Fashion" }}</span>
                  <span class="mega-img-label-arrow"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M7 7h10v10"/></svg></span>
                </div>
              </a>

              <a href="{{ section.settings.mega_video_link | default: routes.collections_url }}" class="mega-video-panel">
                {% if section.settings.mega_video != blank %}
                  <video autoplay muted loop playsinline preload="metadata">
                    {% for source in section.settings.mega_video.sources %}
                      <source src="{{ source.url }}" type="{{ source.mime_type }}">
                    {% endfor %}
                  </video>
                {% else %}
                  <div style="width:100%;height:100%;background:linear-gradient(160deg,#1a1a1a 0%,#2e2e2e 50%,#111 100%);display:flex;align-items:center;justify-content:center;" role="img" aria-label="{{ section.settings.mega_video_label | default: "Men's Fashion" }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  </div>
                {% endif %}
                <div class="mega-img-label">
                  <span class="mega-img-label-text">{{ section.settings.mega_video_label | default: "Men's Fashion" }}</span>
                  <span class="mega-img-label-arrow"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M7 7h10v10"/></svg></span>
                </div>
              </a>
            </div>

            <div class="mega-cols">
              {% for block in section.blocks %}
                {% if block.type == 'mega_column' %}
                  <div class="mega-col" {{ block.shopify_attributes }}>
                    <p class="mega-col-title" style="font-size: {{ block.settings.title_font_size | default: 14 }}px; font-weight: {{ block.settings.title_font_weight | default: '700' }}; color: {{ block.settings.title_color | default: '#1a1a1a' }};">{{ block.settings.title | default: 'Collection' }}</p>
                    <ul>
                      {% if block.settings.link_1_label != blank %}<li><a href="{{ block.settings.link_1_url | default: routes.collections_url }}">{{ block.settings.link_1_label }}</a></li>{% endif %}
                      {% if block.settings.link_2_label != blank %}<li><a href="{{ block.settings.link_2_url | default: routes.collections_url }}">{{ block.settings.link_2_label }}</a></li>{% endif %}
                      {% if block.settings.link_3_label != blank %}<li><a href="{{ block.settings.link_3_url | default: routes.collections_url }}">{{ block.settings.link_3_label }}</a></li>{% endif %}
                      {% if block.settings.link_4_label != blank %}<li><a href="{{ block.settings.link_4_url | default: routes.collections_url }}">{{ block.settings.link_4_label }}</a></li>{% endif %}
                      {% if block.settings.link_5_label != blank %}<li><a href="{{ block.settings.link_5_url | default: routes.collections_url }}">{{ block.settings.link_5_label }}</a></li>{% endif %}
                      {% if block.settings.link_6_label != blank %}<li><a href="{{ block.settings.link_6_url | default: routes.collections_url }}">{{ block.settings.link_6_label }}</a></li>{% endif %}
                      {% if block.settings.link_7_label != blank %}<li><a href="{{ block.settings.link_7_url | default: routes.collections_url }}">{{ block.settings.link_7_label }}</a></li>{% endif %}
                      {% if block.settings.link_8_label != blank %}<li><a href="{{ block.settings.link_8_url | default: routes.collections_url }}">{{ block.settings.link_8_label }}</a></li>{% endif %}
                    </ul>
                  </div>
                {% endif %}
              {% endfor %}
            </div>

            <button class="mega-close" data-action="mega-close" aria-label="Close menu">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
            </button>
          </div>
        </div>

        {%- assign nav_link_blocks = section.blocks | where: 'type', 'nav_link' -%}
        {%- if nav_link_blocks.size > 0 -%}
          {%- for block in nav_link_blocks -%}
            {%- if block.settings.label != blank -%}
              <a href="{{ block.settings.url | default: '#' }}" class="nav-link" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          <a href="{{ pages['about-us'].url | default: '/pages/about' }}" class="nav-link">About</a>
          <a href="{{ routes.blogs_url }}" class="nav-link">Blogs</a>
        {%- endif -%}
      </nav>
    </div>
    <!-- /hdr-left -->

    <!-- ── CENTER: Logo ── -->
    <a href="{{ routes.root_url }}" class="hdr-logo header-logo-wrap">
      {% if section.settings.logo_image != blank %}
        <img
          src="{{ section.settings.logo_image | image_url: width: 400 }}"
          alt="{{ shop.name }}"
          class="header-logo-img"
          style="max-width: {{ section.settings.logo_width | default: 120 }}px; height: auto;"
          loading="eager"
          fetchpriority="high"
        />
      {% else %}
        <span class="hdr-logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
      {% endif %}
    </a>

    <!-- ── RIGHT: Icon Actions ── -->
    <div class="hdr-right header-right-icons">

      <!-- Search -->
      <button class="icon-btn hdr-icon-btn" aria-label="Search" data-action="open-search">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.3-4.3"/>
        </svg>
      </button>

      <!-- Account — desktop only on mobile (already in mobile menu) -->
      <a href="{{ routes.account_url }}" class="icon-btn hdr-icon-btn hdr-account-icon" aria-label="My Account">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
        </svg>
      </a>

      <!-- Cart -->
      <button class="icon-btn hdr-icon-btn relative" aria-label="Shopping Cart" data-action="open-cart">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
          <path d="M3 6h18"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {% if cart.item_count > 0 %}
          <span class="cart-count">{{ cart.item_count }}</span>
        {% else %}
          <span class="cart-count" style="display:none;">0</span>
        {% endif %}
      </button>

    </div>
    <!-- /hdr-right -->

  </div>
</header>

<style>
  /* ── Header Inner: 3-column layout ── */
  .hdr-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 1rem 1.5rem;
    gap: 0;
  }

  .hdr-left  { display: flex; align-items: center; justify-content: flex-start; }
  .hdr-logo  { display: flex; align-items: center; justify-content: center; text-decoration: none; }
  .hdr-right { display: flex; align-items: center; justify-content: flex-end; gap: 0.5rem; }

  .hdr-logo-text {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
    color: #0a0a0a;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* Icon buttons — equal 44×44 touch target */
  .hdr-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: none;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background-color 0.2s ease;
    position: relative;
    flex-shrink: 0;
  }

  .hdr-icon-btn:hover {
    background-color: rgba(10, 10, 10, 0.06);
  }

  .hdr-icon-btn:active {
    background-color: rgba(10, 10, 10, 0.1);
  }

  /* Desktop: full padding */
  @media (min-width: 768px) {
    .hdr-inner {
      padding: 1.25rem 2.5rem;
    }
    .hdr-right {
      gap: 0;
    }
  }

  @media (min-width: 1024px) {
    .hdr-inner {
      padding: 1.25rem 3.5rem;
    }
  }

  /* Mobile: tighter, balanced */
  @media (max-width: 767px) {
    .hdr-inner {
      padding: 0.75rem 0.75rem;
    }

    /* Hide account on mobile header — accessible via mobile menu */
    .hdr-account-icon {
      display: none;
    }

    .hdr-right {
      gap: 0;
    }
  }
</style>

<!-- ═══ MOBILE MENU OVERLAY ═══ -->
<div class="mobile-menu-overlay" id="mobile-menu" role="dialog" aria-modal="true" aria-label="Navigation menu">
  <a href="{{ routes.root_url }}" class="mobile-nav-link" data-action="close-mobile-menu">Home</a>
  <a href="{{ routes.collections_url }}" class="mobile-nav-link" data-action="close-mobile-menu">Catalog</a>
  <a href="{{ pages['about-us'].url | default: '/pages/about' }}" class="mobile-nav-link" data-action="close-mobile-menu">About</a>
  <a href="{{ routes.blogs_url }}" class="mobile-nav-link" data-action="close-mobile-menu">Blogs</a>

  <div class="mobile-menu-divider"></div>

  <div class="mobile-menu-icons">
    <button class="mobile-menu-icon-link" data-action="close-mobile-menu open-search" style="background:none;border:none;cursor:pointer;">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      Search
    </button>
    <a href="{{ routes.account_url }}" class="mobile-menu-icon-link" data-action="close-mobile-menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
      Account
    </a>
    <button class="mobile-menu-icon-link" data-action="close-mobile-menu open-cart" style="background:none;border:none;cursor:pointer;">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      Cart
    </button>
  </div>
</div>

<script>
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-action]');
    if (!btn) return;
    var actions = btn.dataset.action.split(' ');
    actions.forEach(function(action) {
      if (action === 'mega-close') {
        var panel = btn.closest('.mega-menu');
        if (panel) {
          panel.style.pointerEvents = 'none';
          panel.style.clipPath = 'inset(0 0 100% 0)';
          panel.style.opacity = '0';
        }
      } else if (action === 'close-mobile-menu') {
        if (typeof MobileMenu !== 'undefined') MobileMenu.close();
      } else if (action === 'open-search') {
        if (typeof PredictiveSearch !== 'undefined') PredictiveSearch.open();
      } else if (action === 'open-cart') {
        if (typeof CartDrawer !== 'undefined') CartDrawer.open();
      }
    });
  });
</script>

{% schema %}
{
  "name": "Header",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image",
      "info": "Recommended: PNG with transparent background, max 400×100px."
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 300,
      "step": 10,
      "default": 120,
      "unit": "px",
      "label": "Logo Max Width"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text (fallback)",
      "default": "Dropxlabel"
    },
    {
      "type": "header",
      "content": "Mega Menu — Panel 1 (Image)"
    },
    {
      "type": "image_picker",
      "id": "mega_image",
      "label": "Panel 1 Image",
      "info": "Recommended: 600 × 800px (3:4 portrait)."
    },
    {
      "type": "text",
      "id": "mega_image_label",
      "label": "Panel 1 Label",
      "default": "Women's Fashion"
    },
    {
      "type": "url",
      "id": "mega_image_link",
      "label": "Panel 1 Link"
    },
    {
      "type": "header",
      "content": "Mega Menu — Panel 2 (Video)"
    },
    {
      "type": "video",
      "id": "mega_video",
      "label": "Panel 2 Video",
      "info": "Recommended: 600 × 800px (3:4 portrait), MP4."
    },
    {
      "type": "text",
      "id": "mega_video_label",
      "label": "Panel 2 Label",
      "default": "Men's Fashion"
    },
    {
      "type": "url",
      "id": "mega_video_link",
      "label": "Panel 2 Link"
    }
  ],
  "max_blocks": 8,
  "blocks": [
    {
      "type": "nav_link",
      "name": "Nav Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Link Label",
          "default": "Page"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        }
      ]
    },
    {
      "type": "mega_column",
      "name": "Collection Column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column Title",
          "default": "Summer Essentials"
        },
        {
          "type": "range",
          "id": "title_font_size",
          "min": 10,
          "max": 24,
          "step": 1,
          "default": 14,
          "unit": "px",
          "label": "Title Font Size"
        },
        {
          "type": "select",
          "id": "title_font_weight",
          "label": "Title Font Weight",
          "options": [
            { "value": "400", "label": "Regular" },
            { "value": "500", "label": "Medium" },
            { "value": "600", "label": "Semi-Bold" },
            { "value": "700", "label": "Bold" },
            { "value": "800", "label": "Extra Bold" }
          ],
          "default": "700"
        },
        {
          "type": "color",
          "id": "title_color",
          "label": "Title Color",
          "default": "#1a1a1a"
        },
        {
          "type": "header",
          "content": "Links (leave label blank to hide)"
        },
        { "type": "text", "id": "link_1_label", "label": "Link 1 Label", "default": "Product 1" },
        { "type": "url",  "id": "link_1_url",   "label": "Link 1 URL" },
        { "type": "text", "id": "link_2_label", "label": "Link 2 Label", "default": "Product 2" },
        { "type": "url",  "id": "link_2_url",   "label": "Link 2 URL" },
        { "type": "text", "id": "link_3_label", "label": "Link 3 Label", "default": "Product 3" },
        { "type": "url",  "id": "link_3_url",   "label": "Link 3 URL" },
        { "type": "text", "id": "link_4_label", "label": "Link 4 Label" },
        { "type": "url",  "id": "link_4_url",   "label": "Link 4 URL" },
        { "type": "text", "id": "link_5_label", "label": "Link 5 Label" },
        { "type": "url",  "id": "link_5_url",   "label": "Link 5 URL" },
        { "type": "text", "id": "link_6_label", "label": "Link 6 Label" },
        { "type": "url",  "id": "link_6_url",   "label": "Link 6 URL" },
        { "type": "text", "id": "link_7_label", "label": "Link 7 Label" },
        { "type": "url",  "id": "link_7_url",   "label": "Link 7 URL" },
        { "type": "text", "id": "link_8_label", "label": "Link 8 Label" },
        { "type": "url",  "id": "link_8_url",   "label": "Link 8 URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header",
      "blocks": [
        { "type": "nav_link", "settings": { "label": "About", "url": "/pages/about" } },
        { "type": "nav_link", "settings": { "label": "Blogs", "url": "/blogs/news" } },
        { "type": "mega_column", "settings": { "title": "Summer Essentials", "link_1_label": "Chic Soft Teddy Coat", "link_2_label": "Fitted Sleeveless Shirt", "link_3_label": "Classic Zip Front Shirt" } },
        { "type": "mega_column", "settings": { "title": "Sportswear", "link_1_label": "Long-Sleeve Sports Tee", "link_2_label": "Polyester Gym Suit", "link_3_label": "Racerback Sports Bra" } },
        { "type": "mega_column", "settings": { "title": "Winter Wardrobe", "link_1_label": "Oversized Hoodie", "link_2_label": "Warm and Soft Hoodie", "link_3_label": "Winter Hoodie" } }
      ]
    }
  ]
}
{% endschema %}
