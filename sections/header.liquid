<style>
  /* ─── Header Styles ─── */
  .nav-link {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
    transition: opacity 250ms ease;
    position: relative;
    text-decoration: none;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-accent);
    transition: width 350ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-link:hover {
    opacity: 0.7;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .header-logo {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #ffffff;
    text-decoration: none;
    transition: opacity 250ms ease;
    white-space: nowrap;
  }

  .header-logo:hover {
    opacity: 0.85;
  }

  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: rgba(255, 255, 255, 0.9);
    transition: opacity 250ms ease, transform 250ms ease;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }

  .icon-btn:hover {
    opacity: 0.7;
    transform: scale(1.1);
  }

  .cart-count {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 14px;
    height: 14px;
    background-color: var(--color-accent);
    border-radius: 50%;
    font-size: 0.55rem;
    font-family: var(--font-body);
    color: #222222;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    line-height: 1;
  }

  /* ═══════════════════════════════════════
     MOBILE HEADER RESPONSIVE
     ═══════════════════════════════════════ */
  @media (max-width: 767px) {
    header.site-header {
      padding: 1rem 1.25rem !important;
    }
  }

  /* ─── Hamburger Button ─── */
  .hamburger-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    gap: 5px;
    z-index: 310;
  }

  .hamburger-line {
    display: block;
    width: 20px;
    height: 1.5px;
    background-color: #ffffff;
    border-radius: 2px;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.3s ease,
                width 0.3s ease;
    transform-origin: center;
  }

  .hamburger-btn[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .hamburger-btn[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
    width: 0;
  }
  .hamburger-btn[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  @media (max-width: 767px) {
    .hamburger-btn { display: flex; }
  }

  /* ─── Mobile Menu Overlay ─── */
  .mobile-menu-overlay {
    position: fixed;
    inset: 0;
    background-color: rgba(10, 10, 10, 0.97);
    z-index: 300;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 5rem 2rem 3rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
    overflow-y: auto;
  }

  .mobile-menu-overlay.open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-nav-link {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 7vw, 2.8rem);
    font-weight: 600;
    color: #ffffff;
    text-decoration: none;
    text-align: center;
    padding: 0.75rem 0;
    letter-spacing: 0.02em;
    opacity: 0;
    transform: translateY(20px);
    transition: color 250ms ease;
  }

  .mobile-menu-overlay.open .mobile-nav-link {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-nav-link:hover,
  .mobile-nav-link:active {
    color: var(--color-accent);
    opacity: 1;
  }

  /* Stagger animation delays */
  .mobile-nav-link:nth-child(1) { transition-delay: 0.08s; }
  .mobile-nav-link:nth-child(2) { transition-delay: 0.14s; }
  .mobile-nav-link:nth-child(3) { transition-delay: 0.20s; }
  .mobile-nav-link:nth-child(4) { transition-delay: 0.26s; }
  .mobile-nav-link:nth-child(5) { transition-delay: 0.32s; }

  .mobile-menu-overlay:not(.open) .mobile-nav-link {
    transition-delay: 0s !important;
  }

  .mobile-menu-divider {
    width: 40px;
    height: 1px;
    background-color: var(--color-accent);
    margin: 1.5rem auto;
    opacity: 0;
    transition: opacity 0.4s ease 0.35s;
  }

  .mobile-menu-overlay.open .mobile-menu-divider {
    opacity: 1;
  }

  .mobile-menu-overlay:not(.open) .mobile-menu-divider {
    transition-delay: 0s !important;
  }

  .mobile-menu-icons {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 1rem;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease 0.4s, transform 0.4s ease 0.4s;
  }

  .mobile-menu-overlay.open .mobile-menu-icons {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-menu-overlay:not(.open) .mobile-menu-icons {
    transition-delay: 0s !important;
  }

  .mobile-menu-icon-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.55rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: color 250ms ease;
  }

  .mobile-menu-icon-link:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  /* ═══════════════════════════════════════
     MEGA MENU — Full-width Catalog Dropdown
     ═══════════════════════════════════════ */
  .mega-trigger {
    position: relative;
  }

  .mega-trigger .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .mega-trigger .nav-link .chevron-down {
    transition: transform 0.3s ease;
    width: 10px;
    height: 10px;
  }

  .mega-trigger:hover .nav-link .chevron-down {
    transform: rotate(180deg);
  }

  .mega-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: #ffffff;
    z-index: 100;
    display: flex;
    /* Animation: clip from top */
    clip-path: inset(0 0 100% 0);
    opacity: 0;
    pointer-events: none;
    transition:
      clip-path   0.5s cubic-bezier(0.22, 1, 0.36, 1),
      opacity     0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mega-trigger:hover .mega-menu {
    clip-path: inset(0 0 0 0);
    opacity: 1;
    pointer-events: auto;
  }

  /* Left half: 2 image panels */
  .mega-images {
    display: flex;
    width: 50%;
    height: 100%;
  }

  .mega-img-panel {
    position: relative;
    flex: 1;
    overflow: hidden;
    text-decoration: none;
    color: #ffffff;
  }

  .mega-img-panel img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mega-img-panel:hover img {
    transform: scale(1.05);
  }

  .mega-img-panel::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 50%);
    pointer-events: none;
  }

  .mega-img-label {
    position: absolute;
    bottom: 1.8rem;
    left: 1.5rem;
    right: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 2;
  }

  .mega-img-label-text {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 600;
    color: #ffffff;
    letter-spacing: 0.01em;
  }

  .mega-img-label-arrow {
    width: 40px;
    height: 40px;
    border: 1px solid rgba(255,255,255,0.5);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .mega-img-panel:hover .mega-img-label-arrow {
    background-color: #ffffff;
    border-color: #ffffff;
  }

  .mega-img-label-arrow svg {
    color: #ffffff;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .mega-img-panel:hover .mega-img-label-arrow svg {
    color: #0a0a0a;
    transform: rotate(-45deg);
  }

  /* Right half: collection columns */
  .mega-cols {
    width: 50%;
    height: 100%;
    display: flex;
    gap: 0;
    padding: 7rem 4rem 3rem 3rem;
    overflow-y: auto;
  }

  .mega-col {
    flex: 1;
    padding: 0 1.5rem;
  }

  .mega-col-title {
    font-family: var(--font-heading);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #0a0a0a;
    margin-bottom: 1.5rem;
  }

  .mega-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mega-col li {
    margin-bottom: 0.7rem;
  }

  .mega-col a {
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: #555555;
    text-decoration: none;
    transition: color 0.25s ease;
    line-height: 1.5;
  }

  .mega-col a:hover {
    color: #0a0a0a;
  }

  /* Close button inside mega menu */
  .mega-close {
    position: absolute;
    top: 1.8rem;
    right: 2rem;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    background: none;
    border: none;
    color: #333333;
    transition: transform 0.3s ease;
    z-index: 110;
  }

  .mega-close:hover {
    transform: rotate(90deg);
  }
</style>

