{%- liquid
  assign nav_link_blocks = section.blocks | where: 'type', 'nav_link'
-%}

<header class="dx-header" data-section-id="{{ section.id }}">
  <div class="dx-header__inner">
    <div class="dx-header__left">
      <button
        id="hamburger-btn"
        type="button"
        class="dx-menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-collection-menu"
        data-action="open-collection-menu"
      >
        <span class="dx-menu-btn__line"></span>
        <span class="dx-menu-btn__line"></span>
        <span class="dx-menu-btn__line"></span>
      </button>

      <nav class="dx-nav-desktop" aria-label="Primary">
        <a href="{{ routes.root_url }}" class="dx-nav-link nav-link">Home</a>

        <div class="dx-catalog">
          <a href="{{ routes.collections_url }}" class="dx-nav-link nav-link" aria-haspopup="true">
            Catalog
            <svg class="dx-nav-link__chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </a>

          <div class="dx-mega" role="menu" aria-label="Catalog menu">
            <div class="dx-mega__media-col">
              <a href="{{ section.settings.mega_image_link | default: routes.collections_url }}" class="dx-mega__card" role="menuitem">
                {% if section.settings.mega_image != blank %}
                  {{ section.settings.mega_image | image_url: width: 900 | image_tag: class: 'dx-mega__image', loading: 'lazy', alt: section.settings.mega_image_label | default: "Women's Fashion" }}
                {% else %}
                  <div class="dx-mega__image dx-mega__image--placeholder" role="img" aria-label="{{ section.settings.mega_image_label | default: "Women's Fashion" }}"></div>
                {% endif %}
                <div class="dx-mega__label-wrap">
                  <span class="dx-mega__label">{{ section.settings.mega_image_label | default: "Women's Fashion" }}</span>
                  <span class="dx-mega__label-icon" aria-hidden="true">↗</span>
                </div>
              </a>

              <a href="{{ section.settings.mega_video_link | default: routes.collections_url }}" class="dx-mega__card" role="menuitem">
                {% if section.settings.mega_video != blank %}
                  <video class="dx-mega__image" autoplay muted loop playsinline preload="metadata">
                    {% for source in section.settings.mega_video.sources %}
                      <source src="{{ source.url }}" type="{{ source.mime_type }}">
                    {% endfor %}
                  </video>
                {% else %}
                  <div class="dx-mega__image dx-mega__image--placeholder" role="img" aria-label="{{ section.settings.mega_video_label | default: "Men's Fashion" }}"></div>
                {% endif %}
                <div class="dx-mega__label-wrap">
                  <span class="dx-mega__label">{{ section.settings.mega_video_label | default: "Men's Fashion" }}</span>
                  <span class="dx-mega__label-icon" aria-hidden="true">↗</span>
                </div>
              </a>
            </div>

            <div class="dx-mega__links-col">
              {% for block in section.blocks %}
                {% if block.type == 'mega_column' %}
                  <div class="dx-mega__column" {{ block.shopify_attributes }}>
                    <p class="dx-mega__title" style="font-size: {{ block.settings.title_font_size | default: 14 }}px; font-weight: {{ block.settings.title_font_weight | default: '700' }}; color: {{ block.settings.title_color | default: '#1a1a1a' }};">
                      {{ block.settings.title | default: 'Collection' }}
                    </p>
                    <ul class="dx-mega__list" role="none">
                      {% if block.settings.link_1_label != blank %}<li><a href="{{ block.settings.link_1_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_1_label }}</a></li>{% endif %}
                      {% if block.settings.link_2_label != blank %}<li><a href="{{ block.settings.link_2_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_2_label }}</a></li>{% endif %}
                      {% if block.settings.link_3_label != blank %}<li><a href="{{ block.settings.link_3_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_3_label }}</a></li>{% endif %}
                      {% if block.settings.link_4_label != blank %}<li><a href="{{ block.settings.link_4_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_4_label }}</a></li>{% endif %}
                      {% if block.settings.link_5_label != blank %}<li><a href="{{ block.settings.link_5_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_5_label }}</a></li>{% endif %}
                      {% if block.settings.link_6_label != blank %}<li><a href="{{ block.settings.link_6_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_6_label }}</a></li>{% endif %}
                      {% if block.settings.link_7_label != blank %}<li><a href="{{ block.settings.link_7_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_7_label }}</a></li>{% endif %}
                      {% if block.settings.link_8_label != blank %}<li><a href="{{ block.settings.link_8_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_8_label }}</a></li>{% endif %}
                    </ul>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>

        {%- if nav_link_blocks.size > 0 -%}
          {%- for block in nav_link_blocks -%}
            {%- if block.settings.label != blank -%}
              <a href="{{ block.settings.url | default: '#' }}" class="dx-nav-link nav-link" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          <a href="{{ pages['about-us'].url | default: '/pages/about' }}" class="dx-nav-link nav-link">About</a>
          <a href="{{ routes.blogs_url }}" class="dx-nav-link nav-link">Blogs</a>
        {%- endif -%}
      </nav>
    </div>

    <a href="{{ routes.root_url }}" class="dx-logo" style="--dx-logo-width: {{ section.settings.logo_width | default: 180 }}px;">
      {% if section.settings.logo_image != blank %}
        {{ section.settings.logo_image | image_url: width: 1200 | image_tag: class: 'dx-logo__image', loading: 'eager', alt: shop.name }}
      {% else %}
        <span class="dx-logo__text">{{ section.settings.logo_text | default: shop.name }}</span>
      {% endif %}
    </a>

    <div class="dx-header__right" aria-label="Header actions">
      <button class="dx-icon-btn icon-btn" aria-label="Search" data-action="open-search" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.3-4.3"/>
        </svg>
      </button>

      <a href="{{ routes.account_url }}" class="dx-icon-btn icon-btn" aria-label="My Account">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
        </svg>
      </a>

      <button class="dx-icon-btn dx-icon-btn--cart icon-btn" aria-label="Shopping Cart" data-action="open-cart" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
          <path d="M3 6h18"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span class="cart-count"{% if cart.item_count == 0 %} style="display:none"{% endif %}>{{ cart.item_count }}</span>
      </button>
    </div>
  </div>
</header>

<div id="mobile-menu" class="dx-mobile-menu" aria-hidden="true" role="dialog" aria-label="Site menu" aria-modal="true">
  <a href="{{ routes.root_url }}" class="dx-mobile-menu__link" data-action="close-mobile-menu">Home</a>
  <a href="{{ routes.collections_url }}" class="dx-mobile-menu__link" data-action="close-mobile-menu">Catalog</a>
  <a href="{{ pages['about-us'].url | default: '/pages/about' }}" class="dx-mobile-menu__link" data-action="close-mobile-menu">About</a>
  <a href="{{ routes.blogs_url }}" class="dx-mobile-menu__link" data-action="close-mobile-menu">Blogs</a>

  <div class="dx-mobile-menu__icons">
    <button class="dx-mobile-menu__icon-link" data-action="close-mobile-menu open-search" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.3-4.3"/>
      </svg>
      Search
    </button>

    <a href="{{ routes.account_url }}" class="dx-mobile-menu__icon-link" data-action="close-mobile-menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="8" r="4"/>
        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
      </svg>
      Account
    </a>

    <button class="dx-mobile-menu__icon-link" data-action="close-mobile-menu open-cart" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
        <path d="M3 6h18"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      Cart
    </button>
  </div>
</div>

<style>
  .dx-header__inner {
    position: relative;
  }

  @media (max-width: 767px) {
    .dx-header__inner {
      display: grid;
      grid-template-columns: 44px minmax(0, 1fr) auto;
      align-items: center;
      min-height: 56px;
      padding: 0 1rem;
      gap: 0.35rem;
    }

    .dx-header__left {
      width: 44px;
      min-width: 44px;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      z-index: 2;
    }

    .dx-logo {
      position: static;
      left: auto;
      transform: none;
      justify-self: center;
      max-width: min(calc(100% - 0.5rem), var(--dx-logo-width, 180px));
      width: min(calc(100% - 0.5rem), var(--dx-logo-width, 180px));
      height: 28px;
      padding-inline: 0;
      z-index: 1;
    }

    .dx-logo__image {
      width: 100%;
      max-width: 100%;
      height: 100%;
      max-height: none;
      object-fit: cover;
      object-position: center;
    }

    .dx-header__right {
      margin-left: 0;
      justify-self: end;
      gap: 0.25rem;
      z-index: 2;
    }
  }
</style>

<script>
(function () {
  var KEY = '__dx_header_v2_init';
  if (window[KEY]) return;
  window[KEY] = true;

  function setHamburgerExpanded(expanded) {
    var btn = document.getElementById('hamburger-btn');
    if (btn) btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
  }

  function closeAllMenus() {
    if (typeof window.MobileMenu !== 'undefined') window.MobileMenu.close();
    if (typeof window.MobileCollectionMenu !== 'undefined') window.MobileCollectionMenu.close();
    setHamburgerExpanded(false);
  }

  document.addEventListener('click', function (event) {
    var trigger = event.target.closest('[data-action]');
    if (!trigger) return;

    var actions = trigger.dataset.action.split(' ');
    actions.forEach(function (action) {
      if (action === 'close-mobile-menu') {
        closeAllMenus();
        return;
      }

      if (action === 'open-collection-menu') {
        if (typeof window.MobileCollectionMenu !== 'undefined') {
          window.MobileCollectionMenu.open();
        } else if (typeof window.MobileMenu !== 'undefined') {
          window.MobileMenu.open();
        }
        setHamburgerExpanded(true);
        return;
      }

      if (action === 'toggle-mobile-menu') {
        if (typeof window.MobileMenu !== 'undefined') {
          window.MobileMenu.toggle();
        }
        return;
      }

      if (action === 'open-search' && typeof window.PredictiveSearch !== 'undefined') {
        window.PredictiveSearch.open();
        return;
      }

      if (action === 'open-cart' && typeof window.CartDrawer !== 'undefined') {
        window.CartDrawer.open();
      }
    });
  });

  document.addEventListener('keydown', function (event) {
    if (event.key === 'Escape') closeAllMenus();
  });

  var header = document.querySelector('.dx-header');
  if (!header) return;

  function updateHeaderState() {
    header.classList.toggle('is-scrolled', window.scrollY > 12);
  }

  updateHeaderState();
  window.addEventListener('scroll', updateHeaderState, { passive: true });
})();
</script>
{% schema %}
{
  "name": "Header",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image",
      "info": "Recommended: PNG with transparent background, max 400×100px. If set, replaces text logo."
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 500,
      "step": 10,
      "default": 180,
      "unit": "px",
      "label": "Logo Max Width",
      "info": "Controls the maximum width of the logo image. Use a tightly cropped transparent PNG for best results."
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text (fallback)",
      "default": "Dropxlabel",
      "info": "Shown when no logo image is uploaded"
    },
    {
      "type": "header",
      "content": "Mega Menu — Panel 1 (Image)"
    },
    {
      "type": "image_picker",
      "id": "mega_image",
      "label": "Panel 1 Image",
      "info": "Recommended: 600 × 800px (3:4 portrait). Left image in the Catalog dropdown."
    },
    {
      "type": "text",
      "id": "mega_image_label",
      "label": "Panel 1 Label",
      "default": "Women's Fashion"
    },
    {
      "type": "url",
      "id": "mega_image_link",
      "label": "Panel 1 Link"
    },
    {
      "type": "header",
      "content": "Mega Menu — Panel 2 (Video)"
    },
    {
      "type": "video",
      "id": "mega_video",
      "label": "Panel 2 Video",
      "info": "Recommended: 600 × 800px (3:4 portrait), MP4, max 10s. Upload via Files > Videos."
    },
    {
      "type": "text",
      "id": "mega_video_label",
      "label": "Panel 2 Label",
      "default": "Men's Fashion"
    },
    {
      "type": "url",
      "id": "mega_video_link",
      "label": "Panel 2 Link"
    }
  ],
  "max_blocks": 8,
  "blocks": [
    {
      "type": "nav_link",
      "name": "Nav Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Link Label",
          "default": "Page",
          "info": "Text shown in the desktop navigation bar"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        }
      ]
    },
    {
      "type": "mega_column",
      "name": "Collection Column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column Title",
          "default": "Summer Essentials"
        },
        {
          "type": "range",
          "id": "title_font_size",
          "min": 10,
          "max": 24,
          "step": 1,
          "default": 14,
          "unit": "px",
          "label": "Title Font Size"
        },
        {
          "type": "select",
          "id": "title_font_weight",
          "label": "Title Font Weight",
          "options": [
            { "value": "400", "label": "Regular" },
            { "value": "500", "label": "Medium" },
            { "value": "600", "label": "Semi-Bold" },
            { "value": "700", "label": "Bold" },
            { "value": "800", "label": "Extra Bold" }
          ],
          "default": "700"
        },
        {
          "type": "color",
          "id": "title_color",
          "label": "Title Color",
          "default": "#1a1a1a"
        },
        {
          "type": "header",
          "content": "Links (leave label blank to hide)"
        },
        { "type": "text", "id": "link_1_label", "label": "Link 1 Label", "default": "Product 1" },
        { "type": "url",  "id": "link_1_url",   "label": "Link 1 URL" },
        { "type": "text", "id": "link_2_label", "label": "Link 2 Label", "default": "Product 2" },
        { "type": "url",  "id": "link_2_url",   "label": "Link 2 URL" },
        { "type": "text", "id": "link_3_label", "label": "Link 3 Label", "default": "Product 3" },
        { "type": "url",  "id": "link_3_url",   "label": "Link 3 URL" },
        { "type": "text", "id": "link_4_label", "label": "Link 4 Label" },
        { "type": "url",  "id": "link_4_url",   "label": "Link 4 URL" },
        { "type": "text", "id": "link_5_label", "label": "Link 5 Label" },
        { "type": "url",  "id": "link_5_url",   "label": "Link 5 URL" },
        { "type": "text", "id": "link_6_label", "label": "Link 6 Label" },
        { "type": "url",  "id": "link_6_url",   "label": "Link 6 URL" },
        { "type": "text", "id": "link_7_label", "label": "Link 7 Label" },
        { "type": "url",  "id": "link_7_url",   "label": "Link 7 URL" },
        { "type": "text", "id": "link_8_label", "label": "Link 8 Label" },
        { "type": "url",  "id": "link_8_url",   "label": "Link 8 URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header",
      "blocks": [
        {
          "type": "nav_link",
          "settings": {
            "label": "About",
            "url": "/pages/about"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "label": "Blogs",
            "url": "/blogs/news"
          }
        },
        {
          "type": "mega_column",
          "settings": {
            "title": "Summer Essentials",
            "link_1_label": "Chic Soft Teddy Coat",
            "link_2_label": "Fitted Sleeveless Shirt",
            "link_3_label": "Classic Zip Front Shirt"
          }
        },
        {
          "type": "mega_column",
          "settings": {
            "title": "Sportswear",
            "link_1_label": "Long-Sleeve Sports Tee",
            "link_2_label": "Polyester Gym Suit",
            "link_3_label": "Racerback Sports Bra"
          }
        },
        {
          "type": "mega_column",
          "settings": {
            "title": "Winter Wardrobe",
            "link_1_label": "Oversized Hoodie",
            "link_2_label": "Warm and Soft Hoodie",
            "link_3_label": "Winter Hoodie"
          }
        }
      ]
    }
  ]
}
{% endschema %}
