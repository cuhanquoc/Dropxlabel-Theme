<style>
  /* ─── Header Styles ─── */
  .nav-link {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
    transition: opacity 250ms ease;
    position: relative;
    text-decoration: none;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-accent);
    transition: width 350ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-link:hover {
    opacity: 0.7;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .header-logo {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #ffffff;
    text-decoration: none;
    transition: opacity 250ms ease;
    white-space: nowrap;
  }

  .header-logo:hover {
    opacity: 0.85;
  }

  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: rgba(255, 255, 255, 0.9);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), filter 0.35s ease, opacity 0.25s ease;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    will-change: transform;
  }

  .icon-btn:hover {
    transform: scale(1.2);
    filter: drop-shadow(0 0 6px rgba(255,255,255,0.4));
    opacity: 1;
  }

  .cart-count {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 14px;
    height: 14px;
    background-color: var(--color-accent);
    border-radius: 50%;
    font-size: 0.55rem;
    font-family: var(--font-body);
    color: #222222;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    line-height: 1;
  }

  /* ═══════════════════════════════════════
     DESKTOP HEADER (≥ 768px)
     ═══════════════════════════════════════ */
  @media (min-width: 768px) {
    header.site-header {
      display: flex;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      padding: 1.5rem 2.5rem;
    }
    .hamburger-btn {
      display: none;
    }
    .mobile-menu-overlay {
      display: none !important;
    }
  }

  @media (min-width: 1024px) {
    header.site-header {
      padding: 1.5rem 3.5rem;
    }
  }

  /* ═══════════════════════════════════════
     MOBILE HEADER RESPONSIVE
     ═══════════════════════════════════════ */
  @media (max-width: 767px) {
    header.site-header {
      padding: 1rem 1.25rem !important;
      display: grid !important;
      grid-template-columns: auto 1fr auto;
      align-items: center;
    }
    header.site-header .header-logo-wrap {
      justify-self: center;
    }
    header.site-header .header-right-icons {
      justify-self: end;
    }
  }

  /* ─── Hamburger Button ─── */
  .hamburger-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    gap: 5px;
    z-index: 310;
  }

  .hamburger-line {
    display: block;
    width: 20px;
    height: 1.5px;
    background-color: #ffffff;
    border-radius: 2px;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.3s ease,
                width 0.3s ease;
    transform-origin: center;
  }

  .hamburger-btn[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .hamburger-btn[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
    width: 0;
  }
  .hamburger-btn[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  @media (max-width: 767px) {
    .hamburger-btn { display: flex; }
  }

  /* ─── Mobile Menu Overlay ─── */
  .mobile-menu-overlay {
    position: fixed;
    inset: 0;
    background-color: rgba(10, 10, 10, 0.97);
    z-index: 300;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 5rem 2rem 3rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
    overflow-y: auto;
  }

  .mobile-menu-overlay.open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-nav-link {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 7vw, 2.8rem);
    font-weight: 600;
    color: #ffffff;
    text-decoration: none;
    text-align: center;
    padding: 0.75rem 0;
    letter-spacing: 0.02em;
    opacity: 0;
    transform: translateY(20px);
    transition: color 250ms ease;
  }

  .mobile-menu-overlay.open .mobile-nav-link {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-nav-link:hover,
  .mobile-nav-link:active {
    color: var(--color-accent);
    opacity: 1;
  }

  /* Stagger animation delays */
  .mobile-nav-link:nth-child(1) { transition-delay: 0.08s; }
  .mobile-nav-link:nth-child(2) { transition-delay: 0.14s; }
  .mobile-nav-link:nth-child(3) { transition-delay: 0.20s; }
  .mobile-nav-link:nth-child(4) { transition-delay: 0.26s; }
  .mobile-nav-link:nth-child(5) { transition-delay: 0.32s; }

  .mobile-menu-overlay:not(.open) .mobile-nav-link {
    transition-delay: 0s !important;
  }

  .mobile-menu-divider {
    width: 40px;
    height: 1px;
    background-color: var(--color-accent);
    margin: 1.5rem auto;
    opacity: 0;
    transition: opacity 0.4s ease 0.35s;
  }

  .mobile-menu-overlay.open .mobile-menu-divider {
    opacity: 1;
  }

  .mobile-menu-overlay:not(.open) .mobile-menu-divider {
    transition-delay: 0s !important;
  }

  .mobile-menu-icons {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 1rem;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease 0.4s, transform 0.4s ease 0.4s;
  }

  .mobile-menu-overlay.open .mobile-menu-icons {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-menu-overlay:not(.open) .mobile-menu-icons {
    transition-delay: 0s !important;
  }

  .mobile-menu-icon-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.55rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: color 250ms ease;
  }

  .mobile-menu-icon-link:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  /* ═══════════════════════════════════════
     MEGA MENU — Full-width Catalog Dropdown
     ═══════════════════════════════════════ */
  .mega-trigger {
    position: relative;
  }

  .mega-trigger .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .mega-trigger .nav-link .chevron-down {
    transition: transform 0.3s ease;
    width: 10px;
    height: 10px;
  }

  .mega-trigger:hover .nav-link .chevron-down {
    transform: rotate(180deg);
  }

  .mega-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 60vh;
    min-height: 480px;
    max-height: 680px;
    background-color: #ffffff;
    z-index: 100;
    display: flex;
    /* Animation: clip from top */
    clip-path: inset(0 0 100% 0);
    opacity: 0;
    pointer-events: none;
    transition:
      clip-path   0.5s cubic-bezier(0.22, 1, 0.36, 1),
      opacity     0.4s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 12px 60px rgba(0, 0, 0, 0.15);
  }

  .mega-trigger:hover .mega-menu {
    clip-path: inset(0 0 0 0);
    opacity: 1;
    pointer-events: auto;
  }

  /* Video panel styling */
  .mega-video-panel {
    position: relative;
    flex: 1;
    overflow: hidden;
    text-decoration: none;
    color: #ffffff;
  }

  .mega-video-panel video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mega-video-panel:hover video {
    transform: scale(1.05);
  }

  .mega-video-panel::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 50%);
    pointer-events: none;
  }

  /* Left half: 2 image panels */
  .mega-images {
    display: flex;
    width: 50%;
    height: 100%;
  }

  .mega-img-panel {
    position: relative;
    flex: 1;
    overflow: hidden;
    text-decoration: none;
    color: #ffffff;
  }

  .mega-img-panel img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mega-img-panel:hover img {
    transform: scale(1.05);
  }

  .mega-img-panel::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 50%);
    pointer-events: none;
  }

  .mega-img-label {
    position: absolute;
    bottom: 1.8rem;
    left: 1.5rem;
    right: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 2;
  }

  .mega-img-label-text {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 600;
    color: #ffffff;
    letter-spacing: 0.01em;
  }

  .mega-img-label-arrow {
    width: 40px;
    height: 40px;
    border: 1px solid rgba(255,255,255,0.5);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .mega-img-panel:hover .mega-img-label-arrow {
    background-color: #ffffff;
    border-color: #ffffff;
  }

  .mega-img-label-arrow svg {
    color: #ffffff;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .mega-img-panel:hover .mega-img-label-arrow svg {
    color: #0a0a0a;
    transform: rotate(-45deg);
  }

  /* Right half: collection columns */
  .mega-cols {
    width: 50%;
    height: 100%;
    display: flex;
    gap: 0;
    padding: 4rem 4rem 2rem 3rem;
    overflow-y: auto;
  }

  .mega-col {
    flex: 1;
    padding: 0 1.5rem;
  }

  .mega-col-title {
    font-family: var(--font-heading);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #0a0a0a;
    margin-bottom: 1.5rem;
  }

  .mega-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mega-col li {
    margin-bottom: 0.7rem;
  }

  .mega-col a {
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: #555555;
    text-decoration: none;
    transition: color 0.25s ease;
    line-height: 1.5;
  }

  .mega-col a:hover {
    color: #0a0a0a;
  }

  /* Close button inside mega menu */
  .mega-close {
    position: absolute;
    top: 1.8rem;
    right: 2rem;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    background: none;
    border: none;
    color: #333333;
    transition: transform 0.3s ease;
    z-index: 110;
  }

  .mega-close:hover {
    transform: rotate(90deg);
  }
</style>

<header class="site-header absolute left-0 w-full z-50 flex justify-between items-center px-10 py-6 text-white bg-transparent" style="top: var(--ab-height, 0px);">

  <!-- LEFT: Navigation Links -->
  <!-- Hamburger Button (mobile only) -->
  <button class="hamburger-btn" id="hamburger-btn" aria-label="Open menu" aria-expanded="false" onclick="MobileMenu.toggle()">
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
  </button>

  <nav class="hidden md:flex items-center gap-8">
    <a href="{{ routes.root_url }}" class="nav-link">Home</a>

    <!-- Catalog with Mega Menu -->
    <div class="mega-trigger">
      <a href="{{ routes.collections_url }}" class="nav-link">
        Catalog
        <svg class="chevron-down" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m6 9 6 6 6-6"/>
        </svg>
      </a>

      <!-- ═══ MEGA MENU PANEL ═══ -->
      <div class="mega-menu">

        <!-- Left: 2 Image Panels -->
        <div class="mega-images">

          <!-- Panel 1 -->
          <a href="{{ section.settings.mega_image_link | default: routes.collections_url }}" class="mega-img-panel">
            {% if section.settings.mega_image != blank %}
              <img
                src="{{ section.settings.mega_image | image_url: width: 800 }}"
                alt="{{ section.settings.mega_image_label | default: 'Fashion' }}"
                loading="lazy"
              />
            {% else %}
              <img
                src="https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=800&q=75&auto=format&fit=crop"
                alt="Women's Fashion"
                loading="lazy"
              />
            {% endif %}
            <div class="mega-img-label">
              <span class="mega-img-label-text">{{ section.settings.mega_image_label | default: "Women's Fashion" }}</span>
              <span class="mega-img-label-arrow">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 17 17 7M7 7h10v10"/>
                </svg>
              </span>
            </div>
          </a>

          <!-- Panel 2 — Video -->
          <a href="{{ section.settings.mega_video_link | default: routes.collections_url }}" class="mega-video-panel">
            {% if section.settings.mega_video != blank %}
              <video
                src="{{ section.settings.mega_video.sources[1].url }}"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
              ></video>
            {% else %}
              <video
                src="https://cdn.shopify.com/videos/c/o/v/bf5b2a3f95c84e6fbb94b32d06a85f42.mp4"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                poster="https://images.unsplash.com/photo-1617137968427-85924c800a22?w=800&q=75&auto=format&fit=crop"
              ></video>
            {% endif %}
            <div class="mega-img-label">
              <span class="mega-img-label-text">{{ section.settings.mega_video_label | default: "Men's Fashion" }}</span>
              <span class="mega-img-label-arrow">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 17 17 7M7 7h10v10"/>
                </svg>
              </span>
            </div>
          </a>

        </div>

        <!-- Right: Collection Columns (dynamic blocks) -->
        <div class="mega-cols">
          {% for block in section.blocks %}
            {% if block.type == 'mega_column' %}
              <div class="mega-col" {{ block.shopify_attributes }}>
                <p class="mega-col-title" style="
                  font-size: {{ block.settings.title_font_size | default: 14 }}px;
                  font-weight: {{ block.settings.title_font_weight | default: '700' }};
                  color: {{ block.settings.title_color | default: '#1a1a1a' }};
                ">
                  {{ block.settings.title | default: 'Collection' }}
                </p>
                <ul>
                  {% if block.settings.link_1_label != blank %}
                    <li><a href="{{ block.settings.link_1_url | default: routes.collections_url }}">{{ block.settings.link_1_label }}</a></li>
                  {% endif %}
                  {% if block.settings.link_2_label != blank %}
                    <li><a href="{{ block.settings.link_2_url | default: routes.collections_url }}">{{ block.settings.link_2_label }}</a></li>
                  {% endif %}
                  {% if block.settings.link_3_label != blank %}
                    <li><a href="{{ block.settings.link_3_url | default: routes.collections_url }}">{{ block.settings.link_3_label }}</a></li>
                  {% endif %}
                  {% if block.settings.link_4_label != blank %}
                    <li><a href="{{ block.settings.link_4_url | default: routes.collections_url }}">{{ block.settings.link_4_label }}</a></li>
                  {% endif %}
                  {% if block.settings.link_5_label != blank %}
                    <li><a href="{{ block.settings.link_5_url | default: routes.collections_url }}">{{ block.settings.link_5_label }}</a></li>
                  {% endif %}
                  {% if block.settings.link_6_label != blank %}
                    <li><a href="{{ block.settings.link_6_url | default: routes.collections_url }}">{{ block.settings.link_6_label }}</a></li>
                  {% endif %}
                  {% if block.settings.link_7_label != blank %}
                    <li><a href="{{ block.settings.link_7_url | default: routes.collections_url }}">{{ block.settings.link_7_label }}</a></li>
                  {% endif %}
                  {% if block.settings.link_8_label != blank %}
                    <li><a href="{{ block.settings.link_8_url | default: routes.collections_url }}">{{ block.settings.link_8_label }}</a></li>
                  {% endif %}
                </ul>
              </div>
            {% endif %}
          {% endfor %}
        </div>

        <!-- Close button -->
        <button class="mega-close" onclick="this.closest('.mega-menu').style.pointerEvents='none'; this.closest('.mega-menu').style.clipPath='inset(0 0 100% 0)'; this.closest('.mega-menu').style.opacity='0';">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>

      </div>
      <!-- / MEGA MENU PANEL -->

    </div>
    <!-- / Catalog with Mega Menu -->

    <a href="{{ pages['about-us'].url | default: '/pages/about' }}" class="nav-link">About</a>
    <a href="{{ routes.blogs_url }}" class="nav-link">Blogs</a>
  </nav>

  <!-- CENTER: Brand Logo -->
  <a href="{{ routes.root_url }}" class="header-logo header-logo-wrap">
    {% if section.settings.logo_image != blank %}
      <img
        src="{{ section.settings.logo_image | image_url: width: 400 }}"
        alt="{{ shop.name }}"
        class="header-logo-img"
        style="max-width: {{ section.settings.logo_width | default: 120 }}px; height: auto;"
        loading="eager"
      />
    {% else %}
      {{ section.settings.logo_text | default: shop.name }}
    {% endif %}
  </a>

  <!-- RIGHT: Icon Actions -->
  <div class="flex items-center gap-6 header-right-icons">

    <!-- Search Icon -->
    <button class="icon-btn" aria-label="Search" onclick="PredictiveSearch.open()">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.3-4.3"/>
      </svg>
    </button>

    <!-- Account Icon -->
    <a href="{{ routes.account_url }}" class="icon-btn" aria-label="My Account">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="-1 0 26 26" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="8" r="4"/>
        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
      </svg>
    </a>

    <!-- Cart Icon -->
    <button class="icon-btn relative" aria-label="Shopping Cart" onclick="CartDrawer.open()">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
        <path d="M3 6h18"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      {% if cart.item_count > 0 %}
        <span class="cart-count">{{ cart.item_count }}</span>
      {% endif %}
    </button>

  </div>
</header>

<!-- ═══ MOBILE MENU OVERLAY ═══ -->
<div class="mobile-menu-overlay" id="mobile-menu">
  <a href="{{ routes.root_url }}" class="mobile-nav-link" onclick="MobileMenu.close()">Home</a>
  <a href="{{ routes.collections_url }}" class="mobile-nav-link" onclick="MobileMenu.close()">Catalog</a>
  <a href="{{ pages['about-us'].url | default: '/pages/about' }}" class="mobile-nav-link" onclick="MobileMenu.close()">About</a>
  <a href="{{ routes.blogs_url }}" class="mobile-nav-link" onclick="MobileMenu.close()">Blogs</a>

  <div class="mobile-menu-divider"></div>

  <div class="mobile-menu-icons">
    <button class="mobile-menu-icon-link" onclick="MobileMenu.close(); PredictiveSearch.open();" style="background:none;border:none;cursor:pointer;">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.3-4.3"/>
      </svg>
      Search
    </button>
    <a href="{{ routes.account_url }}" class="mobile-menu-icon-link" onclick="MobileMenu.close()">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="8" r="4"/>
        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
      </svg>
      Account
    </a>
    <button class="mobile-menu-icon-link" onclick="MobileMenu.close(); CartDrawer.open();" style="background:none;border:none;cursor:pointer;">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
        <path d="M3 6h18"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      Cart
    </button>
  </div>
</div>

<script>
  /* ─── Mobile Menu Toggle ─── */
  window.MobileMenu = (function () {
    const menu = document.getElementById('mobile-menu');
    const btn  = document.getElementById('hamburger-btn');
    let isOpen = false;

    function open() {
      if (isOpen) return;
      isOpen = true;
      menu.classList.add('open');
      btn.setAttribute('aria-expanded', 'true');
      btn.setAttribute('aria-label', 'Close menu');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      if (!isOpen) return;
      isOpen = false;
      menu.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', 'Open menu');
      document.body.style.overflow = '';
    }

    function toggle() {
      isOpen ? close() : open();
    }

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && isOpen) close();
    });

    return { open, close, toggle };
  }());
</script>

