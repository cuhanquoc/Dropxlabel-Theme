{%- liquid
  assign nav_link_blocks = section.blocks | where: 'type', 'nav_link'
-%}

<header class="dx-header" data-section-id="{{ section.id }}">
  <div class="dx-header__inner">
    <div class="dx-header__left">
      <button
        id="hamburger-btn"
        type="button"
        class="dx-menu-btn"
        aria-label="Open categories"
        aria-haspopup="dialog"
        aria-expanded="false"
        aria-controls="mobile-collection-menu"
        data-action="toggle-collection-menu"
        data-mobile-collection-menu-trigger
      >
        <span class="dx-menu-btn__line"></span>
        <span class="dx-menu-btn__line"></span>
      </button>

      <nav class="dx-nav-desktop" aria-label="Primary">
        <a href="{{ routes.root_url }}" class="dx-nav-link nav-link">Home</a>

        <div class="dx-catalog">
          <a href="{{ routes.collections_url }}" class="dx-nav-link nav-link" aria-haspopup="true">
            Catalog
            <svg class="dx-nav-link__chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </a>

          <div class="dx-mega" role="menu" aria-label="Catalog menu">
            <div class="dx-mega__media-col">
              <a href="{{ section.settings.mega_image_link | default: routes.collections_url }}" class="dx-mega__card" role="menuitem">
                {% if section.settings.mega_image != blank %}
                  {{ section.settings.mega_image | image_url: width: 900 | image_tag: class: 'dx-mega__image', loading: 'lazy', alt: section.settings.mega_image_label | default: "Women's Fashion" }}
                {% else %}
                  <div class="dx-mega__image dx-mega__image--placeholder" role="img" aria-label="{{ section.settings.mega_image_label | default: "Women's Fashion" }}"></div>
                {% endif %}
                <div class="dx-mega__label-wrap">
                  <span class="dx-mega__label">{{ section.settings.mega_image_label | default: "Women's Fashion" }}</span>
                  <span class="dx-mega__label-icon" aria-hidden="true">↗</span>
                </div>
              </a>

              <a href="{{ section.settings.mega_video_link | default: routes.collections_url }}" class="dx-mega__card" role="menuitem">
                {% if section.settings.mega_video != blank %}
                  {{ section.settings.mega_video | video_tag: class: 'dx-mega__image', autoplay: true, muted: true, loop: true, playsinline: true, preload: 'metadata' }}
                {% else %}
                  <div class="dx-mega__image dx-mega__image--placeholder" role="img" aria-label="{{ section.settings.mega_video_label | default: "Men's Fashion" }}"></div>
                {% endif %}
                <div class="dx-mega__label-wrap">
                  <span class="dx-mega__label">{{ section.settings.mega_video_label | default: "Men's Fashion" }}</span>
                  <span class="dx-mega__label-icon" aria-hidden="true">↗</span>
                </div>
              </a>
            </div>

            <div class="dx-mega__links-col">
              {% for block in section.blocks %}
                {% if block.type == 'mega_column' %}
                  <div class="dx-mega__column" {{ block.shopify_attributes }}>
                    <p class="dx-mega__title" style="font-size: {{ block.settings.title_font_size | default: 14 }}px; font-weight: {{ block.settings.title_font_weight | default: '700' }}; color: {{ block.settings.title_color | default: '#1a1a1a' }};">
                      {{ block.settings.title | default: 'Collection' }}
                    </p>
                    <ul class="dx-mega__list" role="none">
                      {% if block.settings.link_1_label != blank %}<li><a href="{{ block.settings.link_1_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_1_label }}</a></li>{% endif %}
                      {% if block.settings.link_2_label != blank %}<li><a href="{{ block.settings.link_2_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_2_label }}</a></li>{% endif %}
                      {% if block.settings.link_3_label != blank %}<li><a href="{{ block.settings.link_3_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_3_label }}</a></li>{% endif %}
                      {% if block.settings.link_4_label != blank %}<li><a href="{{ block.settings.link_4_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_4_label }}</a></li>{% endif %}
                      {% if block.settings.link_5_label != blank %}<li><a href="{{ block.settings.link_5_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_5_label }}</a></li>{% endif %}
                      {% if block.settings.link_6_label != blank %}<li><a href="{{ block.settings.link_6_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_6_label }}</a></li>{% endif %}
                      {% if block.settings.link_7_label != blank %}<li><a href="{{ block.settings.link_7_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_7_label }}</a></li>{% endif %}
                      {% if block.settings.link_8_label != blank %}<li><a href="{{ block.settings.link_8_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_8_label }}</a></li>{% endif %}
                    </ul>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>

        {%- if nav_link_blocks.size > 0 -%}
          {%- for block in nav_link_blocks -%}
            {%- if block.settings.label != blank -%}
              <a href="{{ block.settings.url | default: '#' }}" class="dx-nav-link nav-link" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          <a href="{{ pages['about-us'].url | default: '/pages/about' }}" class="dx-nav-link nav-link">About</a>
          <a href="{{ routes.blogs_url }}" class="dx-nav-link nav-link">Blogs</a>
        {%- endif -%}
      </nav>
    </div>

    <a href="{{ routes.root_url }}" class="dx-logo" style="--dx-logo-width: {{ section.settings.logo_width | default: 180 }}px;">
      {% if section.settings.logo_image != blank %}
        {{ section.settings.logo_image | image_url: width: 1200 | image_tag: class: 'dx-logo__image', loading: 'eager', alt: shop.name }}
      {% else %}
        <span class="dx-logo__text">{{ section.settings.logo_text | default: shop.name }}</span>
      {% endif %}
    </a>

    <div class="dx-header__right" aria-label="Header actions">
      <button class="dx-icon-btn icon-btn" aria-label="Search" data-action="open-search" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.3-4.3"/>
        </svg>
      </button>

      <a href="{{ routes.account_url }}" class="dx-icon-btn dx-icon-btn--account icon-btn" aria-label="My Account">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
        </svg>
      </a>

      <button class="dx-icon-btn dx-icon-btn--cart icon-btn" aria-label="Shopping Cart" data-action="open-cart" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
          <path d="M3 6h18"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span class="cart-count"{% if cart.item_count == 0 %} style="display:none"{% endif %}>{{ cart.item_count }}</span>
      </button>
    </div>
  </div>
</header>

<div id="mobile-menu" class="dx-mobile-menu" aria-hidden="true" role="dialog" aria-label="Site menu" aria-modal="true">
  <a href="{{ routes.root_url }}" class="dx-mobile-menu__link" data-action="close-mobile-menu">Home</a>
  <a href="{{ routes.collections_url }}" class="dx-mobile-menu__link" data-action="close-mobile-menu">Catalog</a>
  <a href="{{ pages['about-us'].url | default: '/pages/about' }}" class="dx-mobile-menu__link" data-action="close-mobile-menu">About</a>
  <a href="{{ routes.blogs_url }}" class="dx-mobile-menu__link" data-action="close-mobile-menu">Blogs</a>

  <div class="dx-mobile-menu__icons">
    <button class="dx-mobile-menu__icon-link" data-action="close-mobile-menu open-search" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.3-4.3"/>
      </svg>
      Search
    </button>

    <a href="{{ routes.account_url }}" class="dx-mobile-menu__icon-link" data-action="close-mobile-menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="8" r="4"/>
        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
      </svg>
      Account
    </a>

    <button class="dx-mobile-menu__icon-link" data-action="close-mobile-menu open-cart" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
        <path d="M3 6h18"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      Cart
    </button>
  </div>
</div>

<style>
  .dx-header {
    --dx-shell-bg: rgba(246, 241, 234, 0.92);
    --dx-shell-bg-strong: rgba(246, 241, 234, 0.985);
    --dx-shell-text: #171412;
    --dx-shell-muted: rgba(23, 20, 18, 0.62);
    --dx-shell-line: rgba(23, 20, 18, 0.1);
    --dx-shell-line-strong: rgba(23, 20, 18, 0.16);
    --dx-shell-surface: rgba(255, 255, 255, 0.62);
    --dx-shell-shadow: 0 12px 34px rgba(23, 20, 18, 0.08);
    position: sticky;
    top: 0;
    z-index: 40;
    background: var(--dx-shell-bg);
    color: var(--dx-shell-text);
    backdrop-filter: blur(16px) saturate(145%);
    -webkit-backdrop-filter: blur(16px) saturate(145%);
    border-bottom: 1px solid var(--dx-shell-line);
    transition: box-shadow 0.22s ease, border-color 0.22s ease, background-color 0.22s ease;
  }

  .dx-header.is-scrolled {
    box-shadow: var(--dx-shell-shadow);
    border-bottom-color: var(--dx-shell-line-strong);
  }

  .dx-header__inner {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
  }

  .dx-nav-desktop {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2vw, 1.75rem);
  }

  .dx-nav-link {
    position: relative;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    color: var(--dx-shell-text);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .dx-nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 10px;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.22s ease;
    opacity: 0.45;
  }

  .dx-nav-link:hover,
  .dx-nav-link:focus-visible {
    opacity: 0.72;
  }

  .dx-nav-link:hover::after,
  .dx-nav-link:focus-visible::after {
    transform: scaleX(1);
  }

  .dx-nav-link__chevron {
    width: 12px;
    height: 12px;
  }

  .dx-catalog {
    position: relative;
  }

  .dx-catalog:focus-within .dx-nav-link__chevron,
  .dx-catalog:hover .dx-nav-link__chevron {
    transform: rotate(180deg);
  }

  .dx-mega {
    position: absolute;
    top: calc(100% + 12px);
    left: 0;
    width: min(1120px, 92vw);
    min-height: 420px;
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 1px;
    background: var(--dx-shell-line);
    border: 1px solid var(--dx-shell-line-strong);
    border-radius: 28px;
    box-shadow: 0 26px 60px rgba(23, 20, 18, 0.14);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(10px);
    transition: opacity 0.22s ease, transform 0.22s ease, visibility 0.22s ease;
    z-index: 70;
    overflow: hidden;
    background-color: rgba(251, 247, 240, 0.98);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .dx-catalog:focus-within .dx-mega,
  .dx-catalog:hover .dx-mega {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .dx-mega__media-col {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    min-height: 100%;
    gap: 1px;
    background: var(--dx-shell-line);
  }

  .dx-mega__card {
    position: relative;
    display: block;
    color: #fff;
    text-decoration: none;
    overflow: hidden;
    background: #0f0d0b;
  }

  .dx-mega__card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 44%, rgba(0, 0, 0, 0.58) 100%);
    opacity: 0.95;
    transition: opacity 0.22s ease;
  }

  .dx-mega__card:hover::after,
  .dx-mega__card:focus-visible::after {
    opacity: 1;
  }

  .dx-mega__image {
    width: 100%;
    height: 100%;
    min-height: 420px;
    object-fit: cover;
    display: block;
    transform: scale(1);
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .dx-mega__card:hover .dx-mega__image,
  .dx-mega__card:focus-visible .dx-mega__image {
    transform: scale(1.04);
  }

  .dx-mega__image--placeholder {
    background: linear-gradient(160deg, #1a1613, #2c241e 52%, #11100f);
  }

  .dx-mega__label-wrap {
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .dx-mega__label {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .dx-mega__label-icon {
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.48);
    border-radius: 999px;
    font-size: 0.9rem;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .dx-mega__links-col {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 0;
    padding: 2.3rem 2rem;
    align-content: start;
    background: rgba(251, 247, 240, 0.98);
  }

  .dx-mega__column {
    padding: 0 1rem;
  }

  .dx-mega__title {
    margin: 0 0 0.95rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .dx-mega__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.5rem;
  }

  .dx-mega__list a {
    color: rgba(23, 20, 18, 0.72);
    text-decoration: none;
    font-size: 0.85rem;
    line-height: 1.5;
    transition: color 0.14s ease, transform 0.14s ease;
  }

  .dx-mega__list a:hover,
  .dx-mega__list a:focus-visible {
    color: var(--dx-shell-text);
  }

  .dx-logo {
    justify-self: center;
    color: var(--dx-shell-text);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    max-width: min(46vw, var(--dx-logo-width, 120px));
  }

  .dx-logo__image {
    display: block;
    width: 100%;
    max-width: var(--dx-logo-width, 120px);
    height: auto;
    filter: none;
  }

  .dx-logo__text {
    font-size: 1.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dx-header__right {
    justify-self: end;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.4rem;
  }

  .dx-icon-btn {
    width: 44px;
    height: 44px;
    border: 1px solid transparent;
    background: transparent;
    color: var(--dx-shell-text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
    border-radius: 999px;
    -webkit-tap-highlight-color: transparent;
    transition: background-color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  .dx-icon-btn:hover {
    background: rgba(23, 20, 18, 0.05);
    border-color: rgba(23, 20, 18, 0.08);
  }

  .dx-icon-btn:focus-visible {
    outline: 2px solid rgba(23, 20, 18, 0.3);
    outline-offset: 2px;
  }

  .dx-icon-btn--account {
    display: inline-flex;
  }

  .dx-icon-btn--cart {
    position: relative;
  }

  .dx-icon-btn--cart .cart-count {
    position: absolute;
    top: 3px;
    right: 1px;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    border-radius: 999px;
    background: #171412;
    color: #fff;
    font-size: 0.68rem;
    font-weight: 700;
    line-height: 18px;
    text-align: center;
    box-shadow: 0 6px 14px rgba(23, 20, 18, 0.18);
  }

  .dx-mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    padding: 6rem 1.5rem 2.5rem;
    background:
      radial-gradient(circle at 50% 0%, rgba(23, 20, 18, 0.04), transparent 48%),
      linear-gradient(180deg, rgba(246, 241, 234, 0.985), rgba(244, 238, 229, 0.96));
    color: var(--dx-shell-text);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.22s ease, visibility 0.22s ease;
  }

  .dx-mobile-menu::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.45), transparent 24%, transparent 76%, rgba(23, 20, 18, 0.02));
  }

  .dx-mobile-menu.open {
    opacity: 1;
    visibility: visible;
  }

  .dx-mobile-menu__link {
    color: var(--dx-shell-text);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 1rem;
    font-weight: 600;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }

  .dx-mobile-menu__icons {
    margin-top: 1.25rem;
    gap: 0.75rem;
    color: var(--dx-shell-text);
    flex-wrap: wrap;
  }

  .dx-mobile-menu__icon-link,
  .dx-mobile-menu__icons {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dx-mobile-menu__icon-link {
    border: 1px solid var(--dx-shell-line);
    background: rgba(255, 255, 255, 0.58);
    color: inherit;
    text-decoration: none;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 94px;
    min-height: 44px;
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    transition: background-color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  .dx-mobile-menu__icon-link:hover,
  .dx-mobile-menu__icon-link:focus-visible {
    background: rgba(255, 255, 255, 0.82);
    border-color: var(--dx-shell-line-strong);
  }

  @media (max-width: 767px) {
    .dx-header {
      background: rgba(246, 241, 234, 0.94);
      border-bottom-color: rgba(23, 20, 18, 0.08);
    }

    .dx-header__inner {
      display: flex;
      align-items: center;
      min-height: 64px;
      padding: 0 0.9rem;
      gap: 0;
    }

    .dx-header__left {
      width: 44px;
      min-width: 44px;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      z-index: 2;
    }

    .dx-nav-desktop {
      display: none;
    }

    .dx-menu-btn {
      display: inline-flex;
      width: 44px;
      height: 44px;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 5px;
      padding: 0;
      border: 0;
      background: transparent;
      color: var(--dx-shell-text);
      cursor: pointer;
      border-radius: 999px;
      z-index: 2;
      -webkit-tap-highlight-color: transparent;
    }

    .dx-menu-btn:hover {
      background: rgba(23, 20, 18, 0.04);
    }

    .dx-menu-btn__line {
      display: block;
      height: 1.6px;
      border-radius: 999px;
      background: currentColor;
    }

    .dx-menu-btn__line:first-child {
      width: 100%;
    }

    .dx-menu-btn__line:last-child {
      width: 18px;
    }

    .dx-logo {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      justify-self: center;
      max-width: min(46vw, var(--dx-logo-width, 180px));
      width: min(46vw, var(--dx-logo-width, 180px));
      height: 32px;
      padding-inline: 0.25rem;
      overflow: hidden;
      z-index: 1;
    }

    .dx-logo__image {
      width: 100%;
      max-width: 100%;
      height: 100%;
      max-height: none;
      object-fit: contain;
      object-position: center;
    }

    .dx-logo__text {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100%;
      color: var(--dx-shell-text);
      font-size: 18px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .dx-header__right {
      width: 112px;
      min-width: 112px;
      display: flex;
      align-items: center;
      justify-self: end;
      justify-content: flex-end;
      gap: 0.25rem;
      z-index: 2;
    }

    .dx-icon-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      padding: 0;
      border: 1px solid transparent;
      background: transparent;
      color: var(--dx-shell-text);
    }

    .dx-icon-btn--account {
      display: none;
    }

    .dx-icon-btn--cart {
      position: relative;
    }

    .dx-icon-btn--cart .cart-count {
      top: 2px;
      right: 1px;
      min-width: 16px;
      height: 16px;
      padding: 0 4px;
      font-size: 9px;
      line-height: 16px;
    }

    .dx-mobile-menu {
      display: flex;
    }

    body.mcm-open .dx-mobile-menu {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }

    .dx-mega {
      display: none;
    }
  }

  @media (min-width: 768px) {
    .dx-header__inner {
      min-height: 72px;
      padding: 0 1.5rem;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      align-items: center;
      column-gap: 1rem;
    }

    .dx-menu-btn {
      display: none;
    }

    .dx-mobile-menu {
      display: none !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dx-header,
    .dx-nav-link,
    .dx-nav-link::after,
    .dx-mega,
    .dx-mega__image,
    .dx-icon-btn,
    .dx-mobile-menu,
    .dx-mobile-menu__icon-link,
    .dx-mobile-menu__link {
      transition: none;
    }
  }
</style>

<script>
(function () {
  var KEY = '__dx_header_v2_init';
  if (window[KEY]) return;
  window[KEY] = true;

  function setHamburgerExpanded(expanded) {
    var buttons = document.querySelectorAll('[data-mobile-collection-menu-trigger]');
    buttons.forEach(function (btn) {
      btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
    });
  }

  function syncMobileMenuState(open) {
    document.body.classList.toggle('mcm-open', open);
    setHamburgerExpanded(open);
  }

  function closeAllMenus() {
    if (typeof window.MobileMenu !== 'undefined') window.MobileMenu.close();
    if (typeof window.MobileCollectionMenu !== 'undefined') window.MobileCollectionMenu.close();
    syncMobileMenuState(false);
  }

  window.addEventListener('mobile-collection-menu:change', function (event) {
    if (!event || !event.detail) return;
    syncMobileMenuState(!!event.detail.open);
  });

  document.addEventListener('click', function (event) {
    var trigger = event.target.closest('[data-action]');
    if (!trigger) return;

    var actions = trigger.dataset.action.split(' ');
    actions.forEach(function (action) {
      if (action === 'close-mobile-menu') {
        closeAllMenus();
        return;
      }

      if (action === 'open-collection-menu' || action === 'toggle-collection-menu') {
        var isOpen = document.body.classList.contains('mcm-open');
        if (typeof window.MobileCollectionMenu !== 'undefined') {
          if (action === 'toggle-collection-menu' && isOpen) {
            window.MobileCollectionMenu.close();
          } else if (action === 'toggle-collection-menu') {
            window.MobileCollectionMenu.open();
          } else {
            window.MobileCollectionMenu.open();
          }
        } else if (typeof window.MobileMenu !== 'undefined') {
          if (action === 'toggle-collection-menu' && isOpen) {
            window.MobileMenu.close();
          } else {
            window.MobileMenu.open();
          }
        }
        return;
      }

      if (action === 'toggle-mobile-menu') {
        if (typeof window.MobileMenu !== 'undefined') {
          window.MobileMenu.toggle();
        }
        return;
      }

      if (action === 'open-search' && typeof window.PredictiveSearch !== 'undefined') {
        window.PredictiveSearch.open();
        return;
      }

      if (action === 'open-cart' && typeof window.CartDrawer !== 'undefined') {
        window.CartDrawer.open();
      }
    });
  });

  document.addEventListener('keydown', function (event) {
    if (event.key === 'Escape') closeAllMenus();
  });

  var header = document.querySelector('.dx-header');
  if (!header) return;

  function updateHeaderState() {
    header.classList.toggle('is-scrolled', window.scrollY > 12);
  }

  updateHeaderState();
  window.addEventListener('scroll', updateHeaderState, { passive: true });
})();
</script>
