{%- liquid
  assign logo_width = section.settings.logo_width | default: 180
  assign logo_width_desktop = section.settings.desktop_logo_width | default: 64
  assign mobile_side_width = section.settings.mobile_side_width | default: 88
  assign desktop_background_opacity = section.settings.desktop_background_opacity | default: 0 | divided_by: 100.0
  assign mobile_background_opacity = section.settings.mobile_background_opacity | default: 100 | divided_by: 100.0
  assign desktop_logo_image = section.settings.desktop_logo_image
  assign mobile_logo_image = section.settings.mobile_logo_image | default: section.settings.logo_image
  assign privacy_url = shop.privacy_policy.url | default: '/policies/privacy-policy'
-%}

<header class="dx-header" data-section-id="{{ section.id }}">
  <div class="dx-header__inner">
    <div class="dx-header__left">
      <button
        id="hamburger-btn"
        type="button"
        class="dx-menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-collection-menu"
        data-action="open-collection-menu"
      >
        <span class="dx-menu-btn__line"></span>
        <span class="dx-menu-btn__line"></span>
      </button>

      <nav class="dx-nav-desktop" aria-label="Primary">
        <a href="{{ routes.root_url }}" class="dx-nav-link nav-link">Home</a>

        <div class="dx-catalog">
          <a href="{{ routes.collections_url }}" class="dx-nav-link nav-link" aria-haspopup="true">
            Catalog
            <svg class="dx-nav-link__chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </a>

          <div class="dx-mega" role="menu" aria-label="Catalog menu">
            <div class="dx-mega__media-col">
              <a href="{{ section.settings.mega_image_link | default: routes.collections_url }}" class="dx-mega__card" role="menuitem">
                {% if section.settings.mega_image != blank %}
                  {{ section.settings.mega_image | image_url: width: 900 | image_tag: class: 'dx-mega__image', loading: 'lazy', alt: section.settings.mega_image_label | default: "Women's Fashion" }}
                {% else %}
                  <div class="dx-mega__image dx-mega__image--placeholder" role="img" aria-label="{{ section.settings.mega_image_label | default: "Women's Fashion" }}"></div>
                {% endif %}
                <div class="dx-mega__label-wrap">
                  <span class="dx-mega__label">{{ section.settings.mega_image_label | default: "Women's Fashion" }}</span>
                  <span class="dx-mega__label-icon" aria-hidden="true">↗</span>
                </div>
              </a>

              <a href="{{ section.settings.mega_video_link | default: routes.collections_url }}" class="dx-mega__card" role="menuitem">
                {% if section.settings.mega_video != blank %}
                  <video class="dx-mega__image" autoplay muted loop playsinline preload="metadata">
                    {% for source in section.settings.mega_video.sources %}
                      <source src="{{ source.url }}" type="{{ source.mime_type }}">
                    {% endfor %}
                  </video>
                {% else %}
                  <div class="dx-mega__image dx-mega__image--placeholder" role="img" aria-label="{{ section.settings.mega_video_label | default: "Men's Fashion" }}"></div>
                {% endif %}
                <div class="dx-mega__label-wrap">
                  <span class="dx-mega__label">{{ section.settings.mega_video_label | default: "Men's Fashion" }}</span>
                  <span class="dx-mega__label-icon" aria-hidden="true">↗</span>
                </div>
              </a>
            </div>

            <div class="dx-mega__links-col">
              {% for block in section.blocks %}
                {% if block.type == 'mega_column' %}
                  <div class="dx-mega__column" {{ block.shopify_attributes }}>
                    <p class="dx-mega__title" style="font-size: {{ block.settings.title_font_size | default: 14 }}px; font-weight: {{ block.settings.title_font_weight | default: '700' }}; color: {{ block.settings.title_color | default: '#1a1a1a' }};">
                      {{ block.settings.title | default: 'Collection' }}
                    </p>
                    <ul class="dx-mega__list" role="none">
                      {% if block.settings.link_1_label != blank %}<li><a href="{{ block.settings.link_1_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_1_label }}</a></li>{% endif %}
                      {% if block.settings.link_2_label != blank %}<li><a href="{{ block.settings.link_2_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_2_label }}</a></li>{% endif %}
                      {% if block.settings.link_3_label != blank %}<li><a href="{{ block.settings.link_3_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_3_label }}</a></li>{% endif %}
                      {% if block.settings.link_4_label != blank %}<li><a href="{{ block.settings.link_4_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_4_label }}</a></li>{% endif %}
                      {% if block.settings.link_5_label != blank %}<li><a href="{{ block.settings.link_5_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_5_label }}</a></li>{% endif %}
                      {% if block.settings.link_6_label != blank %}<li><a href="{{ block.settings.link_6_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_6_label }}</a></li>{% endif %}
                      {% if block.settings.link_7_label != blank %}<li><a href="{{ block.settings.link_7_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_7_label }}</a></li>{% endif %}
                      {% if block.settings.link_8_label != blank %}<li><a href="{{ block.settings.link_8_url | default: routes.collections_url }}" role="menuitem">{{ block.settings.link_8_label }}</a></li>{% endif %}
                    </ul>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>

        <a href="{{ pages['about-us'].url | default: '/pages/about' }}" class="dx-nav-link nav-link">About</a>
        <a href="{{ routes.blogs_url }}" class="dx-nav-link nav-link">Blogs</a>
        <a href="{{ privacy_url }}" class="dx-nav-link nav-link">Privacy</a>
      </nav>
    </div>

    <a
      href="{{ routes.root_url }}"
      class="dx-logo{% if section.settings.invert_desktop_logo %} dx-logo--invert-desktop{% endif %}{% if section.settings.invert_mobile_logo %} dx-logo--invert-mobile{% endif %}"
      style="--dx-logo-mobile-width: {{ logo_width }}px; --dx-logo-desktop-width: {{ logo_width_desktop }}px;"
    >
      {% if desktop_logo_image != blank %}
        {{ desktop_logo_image | image_url: width: 1200 | image_tag: class: 'dx-logo__image dx-logo__image--desktop', loading: 'eager', fetchpriority: 'high', alt: shop.name }}
      {% else %}
        <span class="dx-logo__text dx-logo__text--desktop">{{ section.settings.logo_text | default: shop.name }}</span>
      {% endif %}

      {% if mobile_logo_image != blank %}
        {{ mobile_logo_image | image_url: width: 1200 | image_tag: class: 'dx-logo__image dx-logo__image--mobile', loading: 'eager', fetchpriority: 'high', alt: shop.name }}
      {% else %}
        <span class="dx-logo__text dx-logo__text--mobile">{{ section.settings.logo_text | default: shop.name }}</span>
      {% endif %}
    </a>

    <div class="dx-header__right" aria-label="Header actions">
      <button class="dx-icon-btn icon-btn" aria-label="Search" data-action="open-search" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.3-4.3"/>
        </svg>
      </button>

      <a href="{{ routes.account_url }}" class="dx-icon-btn dx-icon-btn--account icon-btn" aria-label="My Account">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
        </svg>
      </a>

      <button class="dx-icon-btn dx-icon-btn--cart icon-btn" aria-label="Shopping Cart" data-action="open-cart" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
          <path d="M3 6h18"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span class="cart-count"{% if cart.item_count == 0 %} style="display:none"{% endif %}>{{ cart.item_count }}</span>
      </button>
    </div>
  </div>
</header>

<div id="mobile-menu" class="dx-mobile-menu" aria-hidden="true" role="dialog" aria-label="Site menu" aria-modal="true">
  <a href="{{ routes.root_url }}" class="dx-mobile-menu__link" data-action="close-mobile-menu">Home</a>
  <a href="{{ routes.collections_url }}" class="dx-mobile-menu__link" data-action="close-mobile-menu">Catalog</a>
  <a href="{{ pages['about-us'].url | default: '/pages/about' }}" class="dx-mobile-menu__link" data-action="close-mobile-menu">About</a>
  <a href="{{ routes.blogs_url }}" class="dx-mobile-menu__link" data-action="close-mobile-menu">Blogs</a>
  <a href="{{ privacy_url }}" class="dx-mobile-menu__link" data-action="close-mobile-menu">Privacy</a>

  <div class="dx-mobile-menu__icons">
    <button class="dx-mobile-menu__icon-link" data-action="close-mobile-menu open-search" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.3-4.3"/>
      </svg>
      Search
    </button>

    <a href="{{ routes.account_url }}" class="dx-mobile-menu__icon-link" data-action="close-mobile-menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="8" r="4"/>
        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
      </svg>
      Account
    </a>

    <button class="dx-mobile-menu__icon-link" data-action="close-mobile-menu open-cart" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
        <path d="M3 6h18"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      Cart
    </button>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} {
    --dx-desktop-overlap: 0px;
    position: relative;
    z-index: 40;
    margin-bottom: 0;
    background: transparent !important;
    background-color: transparent !important;
  }

  #shopify-section-{{ section.id }}.dx-header-section--overlay-hero {
    margin-bottom: calc(var(--dx-desktop-overlap) * -1);
  }

  .dx-header[data-section-id="{{ section.id }}"] {
    --dx-desktop-header-height: 72px;
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
    color: {{ section.settings.desktop_text_color | default: '#ffffff' }};
    border-bottom: 1px solid {{ section.settings.border_color | default: '#ffffff' | color_modify: 'alpha', 0.24 }};
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    box-shadow: none !important;
  }

  .dx-header[data-section-id="{{ section.id }}"].is-scrolled {
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
    border-bottom-color: {{ section.settings.border_color | default: '#ffffff' | color_modify: 'alpha', 0.24 }};
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    box-shadow: none !important;
  }

  .dx-header[data-section-id="{{ section.id }}"] .dx-header__inner {
    position: relative;
    max-width: none;
    min-height: var(--dx-desktop-header-height);
    padding: 0 clamp(1.5rem, 2.2vw, 2rem);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    column-gap: clamp(1.25rem, 1.8vw, 2.1rem);
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
  }

  .dx-header[data-section-id="{{ section.id }}"] .dx-logo,
  .dx-header[data-section-id="{{ section.id }}"] .dx-logo__text {
    color: {{ section.settings.desktop_text_color | default: '#ffffff' }};
  }

  .dx-header[data-section-id="{{ section.id }}"] .dx-logo {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    justify-self: center;
    width: min(100%, var(--dx-logo-desktop-width, 92px));
    max-width: var(--dx-logo-desktop-width, 92px);
    min-height: auto;
    padding: 0;
    overflow: visible;
    z-index: 4;
    pointer-events: auto;
  }

  .dx-header[data-section-id="{{ section.id }}"] .dx-logo__image {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    max-height: none;
    object-fit: contain;
    object-position: center;
    filter: none;
    mix-blend-mode: normal;
  }

  .dx-header[data-section-id="{{ section.id }}"] .dx-logo__image--mobile,
  .dx-header[data-section-id="{{ section.id }}"] .dx-logo__text--mobile {
    display: none;
  }

  .dx-header[data-section-id="{{ section.id }}"] .dx-logo--invert-desktop .dx-logo__image {
    filter: invert(1) brightness(2);
  }

  .dx-header[data-section-id="{{ section.id }}"] .dx-header__left {
    order: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    z-index: 2;
  }

  .dx-header[data-section-id="{{ section.id }}"] .dx-nav-desktop {
    display: flex;
    align-items: center;
    gap: clamp(1.35rem, 1.7vw, 1.75rem);
  }

  .dx-header[data-section-id="{{ section.id }}"] .dx-nav-link,
  .dx-header[data-section-id="{{ section.id }}"] .dx-icon-btn,
  .dx-header[data-section-id="{{ section.id }}"] .dx-menu-btn {
    color: {{ section.settings.desktop_text_color | default: '#ffffff' }};
  }

  .dx-header[data-section-id="{{ section.id }}"] .dx-nav-link {
    font-size: clamp(0.97rem, 0.98vw, 1.03rem);
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
  }

  .dx-header[data-section-id="{{ section.id }}"] .dx-nav-link__chevron {
    width: 14px;
    height: 14px;
  }

  .dx-header[data-section-id="{{ section.id }}"] .dx-header__right {
    order: 2;
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    z-index: 2;
  }

  .dx-header[data-section-id="{{ section.id }}"] .dx-icon-btn {
    width: 36px;
    height: 36px;
  }

  .dx-header[data-section-id="{{ section.id }}"] .dx-icon-btn:hover {
    background: transparent;
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      --dx-desktop-overlap: 0px;
      margin-bottom: 0;
    }

    .dx-header[data-section-id="{{ section.id }}"] {
      --dx-mobile-side-width: {{ mobile_side_width }}px;
      background: {{ section.settings.mobile_background | default: '#000000' | color_modify: 'alpha', mobile_background_opacity }};
      color: {{ section.settings.mobile_text_color | default: '#ffffff' }};
      border-bottom-color: {{ section.settings.border_color | default: '#ffffff' | color_modify: 'alpha', 0.18 }};
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-header__inner {
      display: grid;
      grid-template-columns: var(--dx-mobile-side-width) minmax(0, 1fr) var(--dx-mobile-side-width);
      align-items: center;
      min-height: 56px;
      padding: 0 1rem;
      gap: 0.5rem;
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-header__left {
      order: initial;
      width: var(--dx-mobile-side-width);
      min-width: var(--dx-mobile-side-width);
      display: flex;
      align-items: center;
      justify-content: flex-start;
      z-index: 2;
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-nav-desktop {
      display: none;
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-menu-btn {
      display: inline-flex;
      width: 26px;
      flex-direction: column;
      gap: 5px;
      padding: 0;
      border: 0;
      background: transparent;
      color: {{ section.settings.mobile_text_color | default: '#ffffff' }};
      cursor: pointer;
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-menu-btn__line {
      display: block;
      height: 1.5px;
      border-radius: 999px;
      background: currentColor;
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-menu-btn__line:first-child {
      width: 100%;
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-menu-btn__line:last-child {
      width: 18px;
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-logo {
      order: initial;
      position: static;
      left: auto;
      transform: none;
      justify-self: center;
      max-width: min(100%, var(--dx-logo-mobile-width, 180px));
      width: min(100%, var(--dx-logo-mobile-width, 180px));
      height: 32px;
      padding-inline: 0.25rem;
      overflow: hidden;
      z-index: 1;
      color: {{ section.settings.mobile_text_color | default: '#ffffff' }};
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-logo__image {
      width: 100%;
      max-width: 100%;
      height: 100%;
      max-height: none;
      object-fit: contain;
      object-position: center;
      filter: none;
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-logo__image--desktop,
    .dx-header[data-section-id="{{ section.id }}"] .dx-logo__text--desktop {
      display: none;
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-logo__image--mobile {
      display: block;
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-logo__text--mobile {
      display: flex;
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-logo--invert-mobile .dx-logo__image {
      filter: invert(1) brightness(2);
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-logo__text {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100%;
      color: {{ section.settings.mobile_text_color | default: '#ffffff' }};
      font-size: 20px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-header__right {
      order: initial;
      width: var(--dx-mobile-side-width);
      min-width: var(--dx-mobile-side-width);
      display: flex;
      align-items: center;
      justify-self: end;
      justify-content: flex-end;
      gap: 0.5rem;
      z-index: 2;
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-icon-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      padding: 0;
      border: 0;
      background: transparent;
      color: {{ section.settings.mobile_text_color | default: '#ffffff' }};
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-icon-btn--account {
      display: none;
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-icon-btn--cart {
      position: relative;
    }

    .dx-header[data-section-id="{{ section.id }}"] .dx-icon-btn--cart .cart-count {
      position: absolute;
      top: -4px;
      right: -4px;
      min-width: 14px;
      height: 14px;
      padding: 0 3px;
      border-radius: 999px;
      background: #fff;
      color: #000;
      font-size: 9px;
      font-weight: 700;
      line-height: 14px;
      text-align: center;
    }
  }
</style>

<script>
(function () {
  var KEY = '__dx_header_v2_init';
  if (window[KEY]) return;
  window[KEY] = true;

  function setHamburgerExpanded(expanded) {
    var btn = document.getElementById('hamburger-btn');
    if (btn) btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
  }

  function closeAllMenus() {
    if (typeof window.MobileMenu !== 'undefined') window.MobileMenu.close();
    if (typeof window.MobileCollectionMenu !== 'undefined') window.MobileCollectionMenu.close();
    setHamburgerExpanded(false);
  }

  document.addEventListener('click', function (event) {
    var trigger = event.target.closest('[data-action]');
    if (!trigger) return;

    var actions = trigger.dataset.action.split(' ');
    actions.forEach(function (action) {
      if (action === 'close-mobile-menu') {
        closeAllMenus();
        return;
      }

      if (action === 'open-collection-menu') {
        if (typeof window.MobileCollectionMenu !== 'undefined') {
          window.MobileCollectionMenu.open();
        } else if (typeof window.MobileMenu !== 'undefined') {
          window.MobileMenu.open();
        }
        setHamburgerExpanded(true);
        return;
      }

      if (action === 'toggle-mobile-menu') {
        if (typeof window.MobileMenu !== 'undefined') {
          window.MobileMenu.toggle();
        }
        return;
      }

      if (action === 'open-search' && typeof window.PredictiveSearch !== 'undefined') {
        window.PredictiveSearch.open();
        return;
      }

      if (action === 'open-cart' && typeof window.CartDrawer !== 'undefined') {
        window.CartDrawer.open();
      }
    });
  });

  document.addEventListener('keydown', function (event) {
    if (event.key === 'Escape') closeAllMenus();
  });

  var header = document.querySelector('.dx-header');
  if (!header) return;

  function updateHeaderState() {
    header.classList.toggle('is-scrolled', window.scrollY > 12);
  }

  updateHeaderState();
  window.addEventListener('scroll', updateHeaderState, { passive: true });
})();
</script>

<script>
  (function () {
    var sectionRoot = document.getElementById('shopify-section-{{ section.id }}');
    var header = sectionRoot ? sectionRoot.querySelector('.dx-header[data-section-id="{{ section.id }}"]') : null;
    if (!sectionRoot || !header) return;

    function shouldOverlayHero() {
      var isDesktop = window.matchMedia('(min-width: 768px)').matches;
      if (!isDesktop) return false;

      var main = document.getElementById('main-content');
      if (!main) return false;

      var firstSection = main.querySelector(':scope > .shopify-section, :scope > [id^="shopify-section-"]');
      if (!firstSection) return false;

      return firstSection.querySelector('hero-banner') !== null;
    }

    function syncDesktopHeaderMetrics() {
      var overlayHero = shouldOverlayHero();

      if (!overlayHero) {
        sectionRoot.classList.remove('dx-header-section--overlay-hero');
        sectionRoot.style.setProperty('--dx-desktop-overlap', '0px');
        document.documentElement.style.setProperty('--dx-live-header-stack-height', '0px');
        return;
      }

      sectionRoot.classList.add('dx-header-section--overlay-hero');

      window.requestAnimationFrame(function () {
        var stackHeight = Math.ceil(sectionRoot.getBoundingClientRect().height || header.getBoundingClientRect().height || 72);
        if (stackHeight < 72) stackHeight = 72;

      sectionRoot.style.setProperty('--dx-desktop-overlap', stackHeight + 'px');
      document.documentElement.style.setProperty('--dx-live-header-stack-height', stackHeight + 'px');
    });
  }

  syncDesktopHeaderMetrics();
  window.addEventListener('resize', syncDesktopHeaderMetrics, { passive: true });
  document.addEventListener('shopify:section:load', syncDesktopHeaderMetrics);
  document.addEventListener('shopify:section:select', syncDesktopHeaderMetrics);
  document.addEventListener('shopify:block:select', syncDesktopHeaderMetrics);
})();
</script>
