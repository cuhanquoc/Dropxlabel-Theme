{% comment %}
  ─────────────────────────────────────────────────────
  MAGNETIC HOVER — Awwwards-grade Spring Physics
  Apply data-magnetic to any element for the effect.
  Strengths: "soft" (links), "medium" (buttons), "strong" (CTAs)
  ─────────────────────────────────────────────────────
{% endcomment %}

<style>
  /* ─── Magnetic Hover: GPU-accelerated ─── */
  [data-magnetic] {
    will-change: transform;
  }

  /* Mega menu links — subtle magnetic + underline reveal */
  .mega-col a {
    will-change: transform;
    display: inline-block;
    position: relative;
  }

  .mega-col a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-accent);
    transition: width 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mega-col a:hover::after {
    width: 100%;
  }

  /* Nav-link magnetic enhancement */
  .nav-link {
    will-change: transform;
  }

  /* Footer links */
  .footer-link {
    will-change: transform;
    display: inline-block;
  }

  /* CTA buttons */
  .maya-merge-btn,
  .ta-cta-btn,
  .btn-add-to-cart {
    will-change: transform;
  }
</style>

