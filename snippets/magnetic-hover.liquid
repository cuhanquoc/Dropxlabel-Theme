{% comment %}
  ─────────────────────────────────────────────────────
  MAGNETIC HOVER — Awwwards-grade Spring Physics
  Apply data-magnetic to any element for the effect.
  Strengths: "soft" (links), "medium" (buttons), "strong" (CTAs)
  ─────────────────────────────────────────────────────
{% endcomment %}

<style>
  /* ─── Magnetic Hover: GPU-accelerated ─── */
  [data-magnetic] {
    will-change: transform;
    display: inline-block;
  }

  /* Mega menu links — subtle magnetic + underline reveal */
  .mega-col a {
    will-change: transform;
    display: inline-block;
    position: relative;
  }

  .mega-col a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-accent);
    transition: width 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mega-col a:hover::after {
    width: 100%;
  }

  /* Nav-link magnetic enhancement */
  .nav-link {
    will-change: transform;
  }

  /* Footer links */
  .footer-link {
    will-change: transform;
    display: inline-block;
  }

  /* CTA buttons */
  .maya-merge-btn,
  .ta-cta-btn,
  .btn-add-to-cart {
    will-change: transform;
  }
</style>

<script>
  /* ─────────────────────────────────────────────────────
     MAGNETIC HOVER — Spring Physics Engine
     Awwwards-grade interaction design

     How it works:
     1. On mousemove: element follows cursor with damped offset
     2. GSAP Expo.out easing = fast launch, smooth deceleration
     3. On mouseleave: slower return creates physical "drag" feel
     4. Only transforms (GPU-composited) for 60fps guarantee
  ───────────────────────────────────────────────────── */

  (function () {
    'use strict';

    if (typeof gsap === 'undefined') return;

    /* Skip on touch-only devices — no hover means no magnetic */
    if (!window.matchMedia('(hover: hover)').matches) return;

    /* ── Strength presets ── */
    const PRESETS = {
      soft:   { move: 0.15, enter: 0.35, leave: 0.65 },
      medium: { move: 0.25, enter: 0.30, leave: 0.55 },
      strong: { move: 0.40, enter: 0.25, leave: 0.50 },
    };

    /* ── Core: Turn any element into a magnetic target ── */
    function initMagnetic(el) {
      const strength = el.dataset.magnetic || 'soft';
      const preset   = PRESETS[strength] || PRESETS.soft;
      let rect;

      function onEnter() {
        rect = el.getBoundingClientRect();
      }

      function onMove(e) {
        if (!rect) return;
        const cx = rect.left + rect.width  / 2;
        const cy = rect.top  + rect.height / 2;
        const dx = (e.clientX - cx) * preset.move;
        const dy = (e.clientY - cy) * preset.move;

        gsap.to(el, {
          x: dx,
          y: dy,
          duration: preset.enter,
          ease: 'expo.out',
          overwrite: 'auto',
        });
      }

      function onLeave() {
        gsap.to(el, {
          x: 0,
          y: 0,
          duration: preset.leave,
          ease: 'expo.out',
          overwrite: 'auto',
        });
        rect = null;
      }

      el.addEventListener('mouseenter', onEnter, { passive: true });
      el.addEventListener('mousemove',  onMove,  { passive: true });
      el.addEventListener('mouseleave', onLeave, { passive: true });
    }

    /* ── Auto-bind: elements with data-magnetic ── */
    function bindAll() {
      document.querySelectorAll('[data-magnetic]').forEach(initMagnetic);

      /* Auto-apply "soft" to mega menu links */
      document.querySelectorAll('.mega-col a').forEach(el => {
        if (!el.dataset.magnetic) {
          el.dataset.magnetic = 'soft';
          initMagnetic(el);
        }
      });

      /* Auto-apply "soft" to header nav links */
      document.querySelectorAll('.nav-link').forEach(el => {
        if (!el.dataset.magnetic) {
          el.dataset.magnetic = 'soft';
          initMagnetic(el);
        }
      });

      /* Auto-apply "soft" to footer links */
      document.querySelectorAll('.footer-link, .footer-social').forEach(el => {
        if (!el.dataset.magnetic) {
          el.dataset.magnetic = 'soft';
          initMagnetic(el);
        }
      });

      /* Auto-apply "medium" to CTA buttons */
      document.querySelectorAll('.maya-merge-btn, .ta-cta-btn').forEach(el => {
        if (!el.dataset.magnetic) {
          el.dataset.magnetic = 'medium';
          initMagnetic(el);
        }
      });

      /* Auto-apply "medium" to icon buttons */
      document.querySelectorAll('.icon-btn').forEach(el => {
        if (!el.dataset.magnetic) {
          el.dataset.magnetic = 'medium';
          initMagnetic(el);
        }
      });
    }

    /* ── Wait for DOM then bind ── */
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bindAll);
    } else {
      bindAll();
    }

  }());
</script>
