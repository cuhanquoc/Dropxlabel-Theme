<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ page_description | default: shop.description | escape }}" />
  <meta name="theme-color" content="#F8F6F1" />
  <meta name="color-scheme" content="light" />
  <title>{{ page_title | default: shop.name }}</title>

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180, height: 180 }}">
  {%- endif -%}

  <!-- Shopify Required -->
  {{ content_for_header }}

  <!-- Google Fonts: Cormorant Garamond (Serif) + DM Sans (Sans-serif) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
    rel="stylesheet"
  />

  <!-- Tailwind CSS (compiled + minified) -->
  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}" />

  <!-- Alpine.js v3 — UI state management (defer) -->
  <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>

  <!-- GSAP (GreenSock Animation Platform) v3.12.5 -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>

  <!-- Global CSS: Quiet Luxury Design System -->
  <style>
    :root {
      --color-bg: #f8f6f1;
      --color-background: var(--color-bg);
      --color-text: #0c0c0b;
      --color-base-text: var(--color-text);
      --color-foreground: var(--color-text);
      --color-accent: #c4a882;
      --color-muted: #8c8880;
      --color-surface: #ffffff;
      --color-border: #e5e2d9;
      --color-border-subtle: rgba(12, 12, 11, 0.08);
      --color-elevated: #fcfbf8;

      --font-heading: "Cormorant Garamond", serif;
      --font-heading-family: var(--font-heading);
      --font-body: "DM Sans", sans-serif;
      --font-body-family: var(--font-body);

      --space-xs: 4px;
      --space-sm: 8px;
      --space-md: 16px;
      --space-lg: 32px;
      --space-xl: 64px;
      --space-2xl: 112px;
      --space-3xl: 160px;

      --radius-sm: 8px;
      --radius-md: 14px;
      --radius-lg: 24px;
      --radius-xl: 32px;

      --shadow-soft: 0 18px 44px rgba(12, 12, 11, 0.06);
      --shadow-inset: inset 0 1px 0 rgba(255, 255, 255, 0.55);

      --transition-base: 240ms cubic-bezier(0.16, 1, 0.3, 1);
      --transition-smooth: 600ms cubic-bezier(0.16, 1, 0.3, 1);
      --z-skip-link: 80;
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
    }

    html {
      color-scheme: light;
      scroll-behavior: smooth;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      margin: 0;
      min-height: 100dvh;
      background: var(--color-bg);
      color: var(--color-text);
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.75;
      text-rendering: optimizeLegibility;
    }

    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
      line-height: 1.08;
      font-weight: 600;
      letter-spacing: -0.02em;
      text-wrap: balance;
      color: var(--color-text);
    }

    p, li {
      text-wrap: pretty;
    }

    a {
      color: inherit;
      text-decoration-thickness: 0.08em;
      text-underline-offset: 0.16em;
      transition: color var(--transition-base), opacity var(--transition-base), transform var(--transition-base);
    }

    a:hover {
      color: var(--color-accent);
    }

    button,
    input,
    select,
    textarea {
      font: inherit;
      color: inherit;
    }

    button {
      cursor: pointer;
    }

    img,
    video,
    svg,
    canvas {
      display: block;
      max-width: 100%;
    }

    ::selection {
      background: rgba(196, 168, 130, 0.24);
      color: var(--color-text);
    }

    :focus:not(:focus-visible) {
      outline: none;
    }

    :focus-visible {
      outline: 2px solid var(--color-accent);
      outline-offset: 4px;
      border-radius: 4px;
    }

    .font-heading {
      font-family: var(--font-heading) !important;
    }

    .font-body {
      font-family: var(--font-body) !important;
    }

    .text-accent {
      color: var(--color-accent) !important;
    }

    .bg-accent {
      background-color: var(--color-accent) !important;
    }

    .border-accent {
      border-color: var(--color-accent) !important;
    }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .skip-link {
      position: fixed;
      top: 1rem;
      left: 1rem;
      z-index: var(--z-skip-link);
      display: inline-flex;
      align-items: center;
      min-height: 44px;
      padding: 0.875rem 1rem;
      border: 1px solid var(--color-border);
      border-radius: 9999px;
      background: var(--color-surface);
      color: var(--color-text);
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-decoration: none;
      box-shadow: var(--shadow-soft);
      transform: translateY(-180%);
      transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
    }

    .skip-link:focus,
    .skip-link:focus-visible {
      transform: translateY(0);
    }

    .section-padding {
      padding-top: var(--space-2xl);
      padding-bottom: var(--space-2xl);
    }

    .container {
      width: 100%;
      max-width: 1400px;
      margin-left: auto;
      margin-right: auto;
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }

    .responsive-grid {
      display: grid;
      gap: 1.5rem;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
    }

    .surface-panel {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-soft);
    }

    .quiet-divider {
      border-color: var(--color-border-subtle);
    }

    @media (min-width: 768px) {
      .section-padding {
        padding-top: calc(var(--space-2xl) * 1.1);
        padding-bottom: calc(var(--space-2xl) * 1.1);
      }
      .container {
        padding-left: 2rem;
        padding-right: 2rem;
      }
      .responsive-grid {
        gap: 2rem;
      }
    }

    @media (min-width: 1024px) {
      .section-padding {
        padding-top: var(--space-3xl);
        padding-bottom: var(--space-3xl);
      }
      .container {
        padding-left: 4rem;
        padding-right: 4rem;
      }
      .responsive-grid {
        gap: 2.5rem;
      }
    }
  </style>


</head>

<body>
<!-- Skip to main content link — visible on keyboard focus only -->
<a href="#main-content" class="skip-link">
  Skip to content
</a>

{% section 'announcement-bar' %}
{% section 'header' %}
  <!-- Shopify Required: renders section/template content -->
  <main id="main-content" tabindex="-1">
    {{ content_for_layout }}
  </main>

{% section 'footer-accordion-mobile' %}
{% section 'mobile-bottom-nav' %}
{% section 'mobile-collection-menu' %}
{% section 'cart-drawer' %}
{% render 'predictive-search' %}
{% render 'magnetic-hover' %}
{% render 'custom-cursor' %}

<!-- Modular JS (extracted from inline scripts) -->
<script src="{{ 'global.js' | asset_url }}" defer></script>
<script src="{{ 'animations.js' | asset_url }}" defer></script>
<script src="{{ 'cart.js' | asset_url }}" defer></script>

</body>
</html>
