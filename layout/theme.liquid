<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ page_description | default: shop.description | escape }}" />
  <title>{{ page_title | default: shop.name }}</title>

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180, height: 180 }}">
  {%- endif -%}

  <!-- Shopify Required -->
  {{ content_for_header }}

  <!-- Google Fonts: Playfair Display (Serif) + Inter (Sans-serif) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />

  <!-- Tailwind CSS (compiled + minified) -->
  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}" />

  <!-- Alpine.js v3 — UI state management (defer) -->
  <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>

  <!-- GSAP (GreenSock Animation Platform) v3.12.5 -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>

  <!-- Global CSS: Quiet Luxury Design System -->
  <style>
    /* ─── CSS Custom Properties ─── */
    :root {
      /* Colour Palette */
      --color-bg:        #F9F8F6; /* Trắng ngà      */
      --color-text:      #222222; /* Xám than        */
      --color-accent:    #C5A880; /* Vàng đồng       */
      --color-muted:     #8A8A8A; /* Xám nhạt phụ    */
      --color-surface:   #FFFFFF; /* Bề mặt card     */
      --color-border:    #E8E5DF; /* Viền tinh tế    */

      /* Typography */
      --font-heading:    'Playfair Display', serif;
      --font-body:       'Inter', sans-serif;

      /* Spacing Scale */
      --space-xs:  4px;
      --space-sm:  8px;
      --space-md:  16px;
      --space-lg:  32px;
      --space-xl:  64px;
      --space-2xl: 128px;

      /* Transitions */
      --transition-base:   250ms ease;
      --transition-smooth: 600ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* ─── Base Reset & Body ─── */
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      background-color: var(--color-bg);
      color:            var(--color-text);
      font-family:      var(--font-body);
      font-size:        16px;
      line-height:      1.7;
      min-height:       100dvh;
    }

    /* ─── Heading Typography ─── */
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
      line-height: 1.2;
      font-weight: 600;
      color:       var(--color-text);
    }

    /* ─── Link Base ─── */
    a {
      color:           var(--color-accent);
      text-decoration: none;
      transition:      opacity var(--transition-base);
    }
    a:hover {
      opacity: 0.75;
    }

    /* ─── Accent Utilities ─── */
    .text-accent  { color:            var(--color-accent); }
    .bg-accent    { background-color: var(--color-accent); }
    .border-accent{ border-color:     var(--color-accent); }

    /* ─── Global Layout Utilities ─── */

    /* Section Padding — consistent vertical rhythm */
    .section-padding {
      padding-top: var(--space-xl);
      padding-bottom: var(--space-xl);
    }

    /* Container — constrained width + responsive horizontal padding */
    .container {
      width: 100%;
      max-width: 1280px;
      margin-left: auto;
      margin-right: auto;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }

    /* Responsive Grid — auto-fit columns */
    .responsive-grid {
      display: grid;
      gap: 1.5rem;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    }

    /* ─── Focus Visible — global keyboard nav ring ─── */
    /* Remove default outline for mouse/touch users */
    :focus:not(:focus-visible) { outline: none; }

    /* Visible ring only for keyboard navigation */
    :focus-visible {
      outline: 2px solid var(--color-accent);
      outline-offset: 2px;
      border-radius: 2px;
    }

    /* Special: inputs that use border-bottom as focus indicator */
    input:focus-visible,
    textarea:focus-visible,
    select:focus-visible {
      outline: none;
      box-shadow: 0 2px 0 0 var(--color-accent);
    }

    /* Screen-reader only */
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    /* ─── Tablet + Desktop overrides (≥ 768px) ─── */
    @media (min-width: 768px) {
      .section-padding {
        padding-top: calc(var(--space-xl) * 1.5);
        padding-bottom: calc(var(--space-xl) * 1.5);
      }
      .container {
        padding-left: 2.5rem;
        padding-right: 2.5rem;
      }
      .responsive-grid {
        gap: 2rem;
      }
    }

    /* ─── Large Desktop overrides (≥ 1024px) ─── */
    @media (min-width: 1024px) {
      .section-padding {
        padding-top: calc(var(--space-xl) * 2);
        padding-bottom: calc(var(--space-xl) * 2);
      }
      .container {
        padding-left: 4rem;
        padding-right: 4rem;
      }
      .responsive-grid {
        gap: 2.5rem;
      }
    }
  </style>


</head>

<body>
<!-- Skip to main content link — visible on keyboard focus only -->
<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:px-4 focus:py-2 focus:bg-[--color-accent] focus:text-white focus:rounded focus:font-body focus:text-sm focus:no-underline">
  Skip to content
</a>

{% section 'announcement-bar' %}
{% section 'header' %}
  <!-- Shopify Required: renders section/template content -->
  <main id="main-content" tabindex="-1">
    {{ content_for_layout }}
  </main>

{% section 'footer' %}
{% section 'footer-accordion-mobile' %}
{% section 'mobile-bottom-nav' %}
{% section 'mobile-collection-menu' %}
{% section 'cart-drawer' %}
{% render 'predictive-search' %}
{% render 'magnetic-hover' %}
{% render 'custom-cursor' %}

<!-- Modular JS (extracted from inline scripts) -->
<script src="{{ 'global.js' | asset_url }}" defer></script>
<script src="{{ 'animations.js' | asset_url }}" defer></script>
<script src="{{ 'cart.js' | asset_url }}" defer></script>

</body>
</html>
