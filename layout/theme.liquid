<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ page_description | default: shop.description | escape }}" />
  <title>{{ page_title | default: shop.name }}</title>

  <!-- Shopify Required -->
  {{ content_for_header }}

  <!-- Google Fonts: Playfair Display (Serif) + Inter (Sans-serif) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- GSAP (GreenSock Animation Platform) v3.12.5 -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

  <!-- Global CSS: Quiet Luxury Design System -->
  <style>
    /* ─── CSS Custom Properties ─── */
    :root {
      /* Colour Palette */
      --color-bg:        #F9F8F6; /* Trắng ngà      */
      --color-text:      #222222; /* Xám than        */
      --color-accent:    #C5A880; /* Vàng đồng       */
      --color-muted:     #8A8A8A; /* Xám nhạt phụ    */
      --color-surface:   #FFFFFF; /* Bề mặt card     */
      --color-border:    #E8E5DF; /* Viền tinh tế    */

      /* Typography */
      --font-heading:    'Playfair Display', serif;
      --font-body:       'Inter', sans-serif;

      /* Spacing Scale */
      --space-xs:  4px;
      --space-sm:  8px;
      --space-md:  16px;
      --space-lg:  32px;
      --space-xl:  64px;
      --space-2xl: 128px;

      /* Transitions */
      --transition-base:   250ms ease;
      --transition-smooth: 600ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* ─── Base Reset & Body ─── */
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      background-color: var(--color-bg);
      color:            var(--color-text);
      font-family:      var(--font-body);
      font-size:        16px;
      line-height:      1.7;
      min-height:       100vh;
    }

    /* ─── Heading Typography ─── */
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
      line-height: 1.2;
      font-weight: 600;
      color:       var(--color-text);
    }

    /* ─── Link Base ─── */
    a {
      color:           var(--color-accent);
      text-decoration: none;
      transition:      opacity var(--transition-base);
    }
    a:hover {
      opacity: 0.75;
    }

    /* ─── Accent Utilities ─── */
    .text-accent  { color:            var(--color-accent); }
    .bg-accent    { background-color: var(--color-accent); }
    .border-accent{ border-color:     var(--color-accent); }
  </style>

  <!-- Tailwind Config override to match design tokens -->
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            bg:      '#F9F8F6',
            text:    '#222222',
            accent:  '#C5A880',
            muted:   '#8A8A8A',
            surface: '#FFFFFF',
            border:  '#E8E5DF',
          },
          fontFamily: {
            heading: ['"Playfair Display"', 'serif'],
            body:    ['Inter', 'sans-serif'],
          },
        }
      }
    }
  </script>
</head>

<body>
{% section 'announcement-bar' %}
{% section 'header' %}
  <!-- Shopify Required: renders section/template content -->
  {{ content_for_layout }}

{% section 'footer' %}
{% render 'cart-drawer' %}
{% render 'predictive-search' %}
{% render 'magnetic-hover' %}
{% render 'custom-cursor' %}

</body>
</html>
